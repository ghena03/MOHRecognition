@model DTOs.ForgetPasswordDto
@{
    Layout = null;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <title>Forgot Password</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/ForgetPassword.css" asp-append-version="true" />
</head>

<body>
    <div class="page">

        <!-- HEADER -->
        <div class="admin-header">
            <h2>Forgot Password</h2>
            <p>Reset using Email or Phone, then enter the verification code</p>
        </div>

        <!-- CARD -->
        <div class="card">

            <!-- LEFT IMAGE -->
            <div class="sign">
                <img src="https://rnji.mohe.gov.jo/AppLogin/images/SIGN.jpg" alt="MOHE">
            </div>

            <!-- RIGHT PANEL -->
            <div class="panel">
                <h1>Verification</h1>
                <p class="subtext">
                    Choose a method, then enter the 6-digit code we send you.
                </p>

                <!-- ✅ show server-side validation errors -->
                <div asp-validation-summary="All" class="error"></div>

                <form asp-controller="Home" asp-action="ForgetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="role" value="@(ViewBag.Role ?? "admin")" />


                    <!-- METHOD -->
                    <div class="method">
                        <input type="radio" id="mEmail" name="Method" value="email" checked>
                        <label for="mEmail" class="pill">Email</label>

                        <input type="radio" id="mPhone" name="Method" value="phone">
                        <label for="mPhone" class="pill">Phone</label>
                    </div>

                    <!-- EMAIL -->
                    <div class="row method-email">
                        <span class="icon">📧</span>
                        <input asp-for="Email" type="email" placeholder="Email address">
                    </div>
                    <span class="field-error" asp-validation-for="Email"></span>

                    <!-- PHONE -->
                    <div class="row method-phone">
                        <span class="icon">📱</span>
                        <input asp-for="Phone" type="tel" placeholder="Phone number (e.g. 079xxxxxxx)">
                    </div>
                    <span class="field-error" asp-validation-for="Phone"></span>

                    <!-- You will implement sending code in backend later -->
                    <button class="secondary" type="button">Send Code</button>

                    <!-- ✅ CODE (6 boxes) -->
                    <div class="code-block">
                        <div class="code-title">Verification Code</div>

                        <!-- real value -->
                        <input asp-for="Code" type="hidden" id="Code" />

                        <div class="code-inputs" aria-label="6 digit code">
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 1" required>
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 2" required>
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 3" required>
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 4" required>
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 5" required>
                            <input class="code-box" type="text" inputmode="numeric" maxlength="1" aria-label="Digit 6" required>
                        </div>

                        <span class="field-error" asp-validation-for="Code"></span>

                        <div class="code-hint">
                            Didn’t get it? <a href="#">Resend</a>
                        </div>
                    </div>

                    <!-- submit will validate then redirect to ResetPassword -->
                    <button class="primary" type="submit">Verify & Continue</button>

                    <div class="actions">
                        <a class="link" asp-controller="Home" asp-action="AdminLogIn">← Back to Login</a>
                    </div>

                </form>
            </div>

        </div>
    </div>

    <script>
        // UI only: switch email/phone fields
        function updateMethodUI() {
            const useEmail = document.getElementById("mEmail").checked;

            document.querySelector(".method-email").style.display = useEmail ? "flex" : "none";
            document.querySelector(".method-phone").style.display = useEmail ? "none" : "flex";

            document.querySelector('input[name="Email"]').required = useEmail;
            document.querySelector('input[name="Phone"]').required = !useEmail;
        }

        document.getElementById("mEmail").addEventListener("change", updateMethodUI);
        document.getElementById("mPhone").addEventListener("change", updateMethodUI);
        window.addEventListener("load", updateMethodUI);

        // Code boxes: auto move + paste + build hidden Code
        const inputs = Array.from(document.querySelectorAll(".code-box"));
        const hidden = document.getElementById("Code");

        function syncHidden() {
            hidden.value = inputs.map(i => i.value).join("");
        }

        inputs.forEach((input, idx) => {
            input.addEventListener("input", () => {
                input.value = input.value.replace(/\D/g, "");
                if (input.value && idx < inputs.length - 1) inputs[idx + 1].focus();
                syncHidden();
            });

            input.addEventListener("keydown", (e) => {
                if (e.key === "Backspace" && !input.value && idx > 0) inputs[idx - 1].focus();
            });

            input.addEventListener("paste", (e) => {
                const text = (e.clipboardData || window.clipboardData).getData("text");
                const digits = (text || "").replace(/\D/g, "").slice(0, inputs.length);
                if (!digits) return;

                e.preventDefault();
                digits.split("").forEach((d, i) => inputs[i].value = d);
                inputs[Math.min(digits.length, inputs.length) - 1].focus();
                syncHidden();
            });
        });

        window.addEventListener("load", () => inputs[0].focus());
    </script>
</body>
</html>
