@model DTOs.StaffLogInDto
@if (TempData["Error"] != null)
{
    <div class="error">
        @TempData["Error"]
    </div>
}
@{
    Layout = null;

    var role = (ViewBag.Role as string ?? "admin").ToLower();
    var culture = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isRtl = culture == "ar";
    var dir = isRtl ? "rtl" : "ltr";

    var title = role == "recognition" ? S["Login_MemberTitle"].Value : S["Login_AdminTitle"].Value;
    var desc = role == "recognition" ? S["Login_MemberDesc"].Value : S["Login_AdminDesc"].Value;
    var emailPlaceholder = role == "recognition" ? S["Login_MemberEmail"].Value : S["Login_AdminEmail"].Value;
}

<!doctype html>
<html lang="@culture" dir="@dir">
<head>
    <meta charset="utf-8" />
    <title>@title</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/css/StaffLogIn.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    @if (isRtl)
    {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
    <style>
        /* ── RTL fixes specific to this page ── */

        /* Card: image is on left in LTR, flip to right in RTL */
        [dir="rtl"] .card {
            flex-direction: row-reverse;
        }

        /* Sign image keeps its natural size — no flip needed */
        [dir="rtl"] .sign {
            border-left: none;
            border-right: 1px solid rgba(0,0,0,0.08);
        }

        /* Panel text aligns right */
        [dir="rtl"] .panel {
            text-align: right;
        }

        /* Input rows: icon on right, input fills left */
        [dir="rtl"] .row {
            flex-direction: row-reverse;
        }

        /* Password toggle button stays on the correct side */
        [dir="rtl"] .pass-toggle {
            right: unset;
            left: 10px;
        }

        /* Admin header */
        [dir="rtl"] .admin-header {
            text-align: right;
        }

        /* Remember me row */
        [dir="rtl"] .remember-row {
            flex-direction: row-reverse;
        }

        /* Links */
        [dir="rtl"] .links {
            text-align: right;
        }

        /* Language switcher position */
        .lang-switcher-wrap {
            position: absolute;
            top: 12px;
            right: 16px;
        }

        [dir="rtl"] .lang-switcher-wrap {
            right: unset;
            left: 16px;
        }

        .lang-switcher {
            background: rgba(255,255,255,0.15);
            border-color: rgba(255,255,255,0.3);
        }

        .lang-btn {
            color: #fff;
        }
    </style>
</head>

<body class="@(isRtl ? "rtl-body" : "ltr-body")">
    <div class="page" style="position:relative;">

        @* Language switcher — top corner *@
        <div class="lang-switcher-wrap">
            @await Html.PartialAsync("~/Views/Shared/_LanguageSwitcher.cshtml")
        </div>

        <div class="admin-header">
            <h2>@title</h2>
            <p>@desc</p>
        </div>

        <div class="card">
            <div class="sign">
                <img src="@Url.Content("~/images/SIGN.jpg")" />
            </div>

            <div class="panel">
                <h1>@S["Login_SignIn"]</h1>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="error"></div>
                }

                <form asp-controller="Home" asp-action="StaffLogIn" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="role" value="@role" />
                    <input type="hidden" name="GeneratedCaptcha" id="generatedCaptcha" />

                    <!-- EMAIL -->
                    <div class="row">
                        <span class="icon"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" type="email" placeholder="@emailPlaceholder" />
                    </div>
                    <span class="field-error" asp-validation-for="Email"></span>

                    <!-- PASSWORD -->
                    <div class="row pass-row">
                        <span class="icon"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" type="password" id="loginPassword" placeholder="@S["Login_Password"]" />
                        <button type="button" class="pass-toggle" id="toggleLoginPassword">
                            <i class="fa-regular fa-eye"></i>
                        </button>
                    </div>
                    <span class="field-error" asp-validation-for="Password"></span>

                

                    <!-- CAPTCHA -->
                    <div class="captcha">
                        <canvas id="captchaCanvas" width="200" height="50"></canvas>
                        <button type="button" class="refresh" id="refreshCaptcha">
                            <i class="fa-solid fa-rotate"></i>
                        </button>
                    </div>

                    <div class="hint">@S["Login_CaptchaHint"]</div>

                    <div class="row">
                        <input asp-for="Captcha" id="captchaInput" type="text" placeholder="@S["Login_CaptchaPlaceholder"]" />
                    </div>
                    <span class="field-error" asp-validation-for="Captcha"></span>

                    <!-- REMEMBER -->
                    <div class="remember-row">
                        <label class="remember">
                            <input asp-for="RememberMe" type="checkbox" />
                            <span>@S["Login_RememberMe"]</span>
                        </label>
                    </div>

                    <button class="login" type="submit">@S["Login_Submit"]</button>

                    <div class="links">
                        <a asp-controller="Home" asp-action="ForgetPassword" asp-route-role="@role">
                            @S["Login_ForgotPassword"]
                        </a>
                    </div>

                    <div class="links">
                        <a href="#">@S["Login_CreateAccount"]</a>
                    </div>
                </form>
            </div>
        </div>

    </div>

    <!-- PASSWORD TOGGLE -->
    <script>
        const passwordInput = document.getElementById("loginPassword");
        const toggleButton = document.getElementById("toggleLoginPassword");

        toggleButton.addEventListener("click", function () {
            const isHidden = passwordInput.type === "password";
            passwordInput.type = isHidden ? "text" : "password";
            toggleButton.innerHTML = isHidden
                ? '<i class="fa-regular fa-eye-slash"></i>'
                : '<i class="fa-regular fa-eye"></i>';
        });
    </script>

    <!-- CAPTCHA SCRIPT -->
    <script>
        let generatedCaptcha = "";

        function randomText(length) {
            const chars = "ABCDEFGHJKLMNPQRSTUVWXYZ23456789";
            let result = "";
            for (let i = 0; i < length; i++) {
                result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return result;
        }

        function drawCaptcha() {
            const canvas = document.getElementById("captchaCanvas");
            const ctx = canvas.getContext("2d");

            generatedCaptcha = randomText(6);
            document.getElementById("generatedCaptcha").value = generatedCaptcha;

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.font = "28px Arial";
            ctx.fillStyle = "#7a2d2a";

            for (let i = 0; i < generatedCaptcha.length; i++) {
                const x = 20 + i * 25;
                const y = 30 + Math.random() * 5;
                const angle = (Math.random() - 0.5) * 0.5;
                ctx.save();
                ctx.translate(x, y);
                ctx.rotate(angle);
                ctx.fillText(generatedCaptcha[i], 0, 0);
                ctx.restore();
            }

            for (let i = 0; i < 5; i++) {
                ctx.strokeStyle = "rgba(0,0,0,0.2)";
                ctx.beginPath();
                ctx.moveTo(Math.random() * 200, Math.random() * 50);
                ctx.lineTo(Math.random() * 200, Math.random() * 50);
                ctx.stroke();
            }

            for (let i = 0; i < 30; i++) {
                ctx.fillStyle = "rgba(0,0,0,0.2)";
                ctx.beginPath();
                ctx.arc(Math.random() * 200, Math.random() * 50, 1, 0, 2 * Math.PI);
                ctx.fill();
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            drawCaptcha();
            document.getElementById("refreshCaptcha").addEventListener("click", drawCaptcha);
        });
    </script>

</body>
</html>
