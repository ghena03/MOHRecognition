@model DTOs.ResetPasswordDto
@{
    Layout = null;
    var role = (ViewBag.Role as string ?? "admin").ToLower();
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <title>Reset Password</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/ResetPassword.css" asp-append-version="true" />
</head>

<body>
    <main class="page">
        <section class="shell">

            <header class="heroBar">
                <h2>Reset Password</h2>
                <p>Create a new password for your account</p>
            </header>

            <div class="card">
                <aside class="brand">
                    <img src="https://rnji.mohe.gov.jo/AppLogin/images/SIGN.jpg" alt="MOHE" />
                </aside>

                <section class="content">
                    <div class="title">
                        <h1>New Password</h1>
                        <p>Enter your new password and confirm it.</p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div asp-validation-summary="All" class="alert alert--error" role="alert"></div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert--success" role="alert">
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <div class="hint">
                        <span class="hint__badge">Tip</span>
                        Password must be 8+ chars, include 1 uppercase, and 1 special character.
                    </div>

                    <form id="resetForm" asp-controller="Home" asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="role" value="@role" />

                        <div class="field">
                            <label asp-for="NewPassword">New Password</label>

                            <div class="input">
                                <span class="input__icon" aria-hidden="true">🔒</span>

                                <input asp-for="NewPassword"
                                       type="password"
                                       id="newPass"
                                       placeholder="Enter new password"
                                       minlength="8"
                                       autocomplete="new-password" />

                                <button type="button" class="input__action" id="eyeNew" aria-label="Show password">
                                    Show
                                </button>
                            </div>

                            <span class="field-error" asp-validation-for="NewPassword"></span>
                            <small class="field__help">
                                8+ chars • 1 uppercase • 1 special (!&#64;#$%^&*)
                            </small>
                        </div>

                        <div class="field">
                            <label asp-for="ConfirmPassword">Confirm Password</label>

                            <div class="input">
                                <span class="input__icon" aria-hidden="true">✅</span>

                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       id="confirmPass"
                                       placeholder="Re-enter new password"
                                       minlength="8"
                                       autocomplete="new-password" />

                                <button type="button" class="input__action" id="eyeConfirm" aria-label="Show password">
                                    Show
                                </button>
                            </div>

                            <span class="field-error" asp-validation-for="ConfirmPassword"></span>
                            <small class="field__help">Must match exactly.</small>
                        </div>

                        <div class="alert alert--error" id="errorBox" style="display:none;" aria-live="polite"></div>

                        <button class="btn" type="submit">Update Password</button>

                        <div class="footer">
                            <a class="link"
                                   asp-controller="Home"
                                   asp-action="StaffLogIn"
                                   asp-route-role="@role">
                                Back to Login
                            </a>
                        </div>
                    </form>
                </section>
            </div>

        </section>
    </main>

    <script>
            const newPass = document.getElementById("newPass");
            const confirmPass = document.getElementById("confirmPass");
            const errorBox = document.getElementById("errorBox");

            function toggle(btn, input) {
                const hidden = input.type === "password";
                input.type = hidden ? "text" : "password";
                btn.textContent = hidden ? "Hide" : "Show";
                btn.setAttribute("aria-label", hidden ? "Hide password" : "Show password");
                input.focus();
            }

            document.getElementById("eyeNew").addEventListener("click", function () {
                toggle(this, newPass);
            });

            document.getElementById("eyeConfirm").addEventListener("click", function () {
                toggle(this, confirmPass);
            });

            function isStrongPassword(p) {
                const hasUpper = /[A-Z]/.test(p);
                const hasSpecial = /[^A-Za-z0-9]/.test(p);
                const longEnough = p.length >= 8;
                return longEnough && hasUpper && hasSpecial;
            }

            document.getElementById("resetForm").addEventListener("submit", function (e) {
                const p1 = (newPass.value || "").trim();
                const p2 = (confirmPass.value || "").trim();

                if (!p1 || !p2) {
                    e.preventDefault();
                    errorBox.textContent = "Please fill both password fields.";
                    errorBox.style.display = "block";
                    return;
                }

                if (!isStrongPassword(p1)) {
                    e.preventDefault();
                    errorBox.textContent = "Password must be 8+ characters and include 1 uppercase letter and 1 special character.";
                    errorBox.style.display = "block";
                    return;
                }

                if (p1 !== p2) {
                    e.preventDefault();
                    errorBox.textContent = "Passwords do not match.";
                    errorBox.style.display = "block";
                    return;
                }

                errorBox.style.display = "none";
            });
    </script>
</body>
</html>