@model DTOs.AdmissionRequirementsDto

<div class="card-bd">

    <!-- Diploma -->
    <div class="row" style="margin-bottom:14px;">
        <div class="field" style="flex:1;">
            <label>Diploma Requirement <span class="req">*</span></label>
            <input id="req_Diploma" type="text" placeholder="Write requirement..." />
        </div>
        <div class="field" style="width:180px; align-self:end;">
            <button type="button" class="btn-primary" data-adm-add="Diploma">Add</button>
        </div>
    </div>

    @if (Model?.Diploma != null && Model.Diploma.Any())
    {
        <table class="tbl" style="margin-bottom:18px;">
            <thead>
                <tr>
                    <th style="width:80px;">#</th>
                    <th>Requirement</th>
                    <th style="width:120px;">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Diploma)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>@r.Requirement</td>
                        <td>
                            <button type="button" class="btn-danger"
                                    data-adm-del="Diploma" data-id="@r.Id">
                                Delete
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

