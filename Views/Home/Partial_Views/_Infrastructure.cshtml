@model DTOs.InfrastructureDto

<div class="duration-wrap" style="margin-top:0;">
    <div class="lab-section-card">
        <div class="lab-section-title">Core University Infrastructure Overview</div>
        <div class="lab-section-sub">Provide the primary campus university infrastructure counts required for evaluation.</div>

        <!-- UI Banner -->
        <div id="infraBanner" class="banner warn" style="display:none; margin-top:12px;" role="status" aria-live="polite">
            <span class="dot"></span>
            <span class="txt"></span>
            <button type="button" class="x" onclick="document.getElementById('infraBanner').style.display='none'">×</button>
        </div>

        <div class="grid-2" style="margin-top:14px;">
            <div class="field">
                <label>Area (Km²) <span class="req">*</span></label>
                <input id="infra_areaKm2" type="text" inputmode="decimal" value="@Model?.AreaKm2" />
            </div>

            <div class="field">
                <label>Number of Colleges <span class="req">*</span></label>
                <input id="infra_campusesCount" type="text" inputmode="numeric" value="@Model?.CampusesCount" />
            </div>

            <div class="field">
                <label>Number of Classrooms and Lecture Halls <span class="req">*</span></label>
                <input id="infra_classroomsCount" type="text" inputmode="numeric" value="@Model?.ClassroomsAndLectureHallsCount" />
            </div>

            <div class="field">
                <label>Number of Laboratories <span class="req">*</span></label>
                <input id="infra_librariesCount" type="text" inputmode="numeric" value="@Model?.LibrariesCount" />
            </div>

            <div class="field">
                <label>Number of Stadiums <span class="req">*</span></label>
                <input id="infra_stadiumsCount" type="text" inputmode="numeric" value="@Model?.StadiumsCount" />
            </div>
        </div>

        <div class="actions" style="justify-content:flex-end; margin-top:14px;">
            <button type="button" id="btnSaveInfrastructure" class="btn-primary">Save</button>
        </div>
    </div>
</div>