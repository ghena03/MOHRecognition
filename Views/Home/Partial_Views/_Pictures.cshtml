@model DTOs.PicturesDto
@using System.Linq

@{
    var rows = Model?.Rows ?? new List<DTOs.PictureRowDto>();

    var librarySubject = "Library photos";
    var hospitalSubject = "Hospital photos";
    var facultiesSubject = "Colleges photos";
    var laboratoriesSubject = "Laboratories photos";

    var libraryRows = rows.Where(x =>
        string.Equals(x.Subject, librarySubject, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Library photos (PDF)", StringComparison.OrdinalIgnoreCase)).ToList();
    var hospitalRows = rows.Where(x =>
        string.Equals(x.Subject, hospitalSubject, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Hospital photos (PDF)", StringComparison.OrdinalIgnoreCase)).ToList();
    var facultiesRows = rows.Where(x =>
        string.Equals(x.Subject, facultiesSubject, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Colleges photos (PDF)", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Faculties photos", StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Faculties photos (PDF)", StringComparison.OrdinalIgnoreCase)).ToList();
    var laboratoriesRows = rows.Where(x =>
        string.Equals(x.Subject, laboratoriesSubject, StringComparison.OrdinalIgnoreCase) ||
        string.Equals(x.Subject, "Laboratories photos (PDF)", StringComparison.OrdinalIgnoreCase)).ToList();

    var uploadedCount = 0;
    if (libraryRows.Any()) uploadedCount++;
    if (hospitalRows.Any()) uploadedCount++;
    if (facultiesRows.Any()) uploadedCount++;
    if (laboratoriesRows.Any()) uploadedCount++;
}

<div class="pic-modern-wrap">
    <div id="picBanner" class="banner warn" style="display:none; margin-bottom:12px;">
        <span class="dot"></span>
        <span class="txt"></span>
        <button type="button" class="x" onclick="document.getElementById('picBanner').style.display='none'">×</button>
    </div>

    <div class="pic-head-card">
        <div>
            <h3>Photos / Media Upload</h3>
            <p>Upload PDF or image files in each section. Multiple files are allowed.</p>
        </div>
        <div class="pic-progress" id="picProgressText" data-uploaded="@uploadedCount" data-total="4">Uploaded @uploadedCount of 4 files</div>
    </div>

    <div class="pic-sections">
        <section class="pic-section-block">
            @await Html.PartialAsync("Partial_Views/_PicturesCard", new ViewDataDictionary(ViewData)
            {
                { "CardId", "library" },
                { "Title", "1) Library Photos" },
                { "Subject", librarySubject },
                { "Rows", libraryRows }
            })
        </section>

        <section class="pic-section-block">
            @await Html.PartialAsync("Partial_Views/_PicturesCard", new ViewDataDictionary(ViewData)
            {
                { "CardId", "hospital" },
                { "Title", "2) Hospital Photos" },
                { "Subject", hospitalSubject },
                { "Rows", hospitalRows }
            })
        </section>

        <section class="pic-section-block">
            @await Html.PartialAsync("Partial_Views/_PicturesCard", new ViewDataDictionary(ViewData)
            {
                { "CardId", "faculties" },
                { "Title", "3) Colleges Photos" },
                { "Subject", facultiesSubject },
                { "Rows", facultiesRows }
            })
        </section>

        <section class="pic-section-block">
            @await Html.PartialAsync("Partial_Views/_PicturesCard", new ViewDataDictionary(ViewData)
            {
                { "CardId", "laboratories" },
                { "Title", "4) Laboratories Photos" },
                { "Subject", laboratoriesSubject },
                { "Rows", laboratoriesRows }
            })
        </section>
    </div>

</div>