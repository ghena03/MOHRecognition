@model DTOs.MedicineDentistryDto

@{
    string N(int? v) => v.HasValue ? v.Value.ToString() : "";
}

<div class="duration-wrap medden-wrap" style="margin-top:0;">

    <!-- ── Header ─────────────────────────────────────────────── -->
    <div class="medden-page-hd">
        <div class="medden-page-hd-icon">🩺</div>
        <div>
            <div class="medden-page-hd-title">Doctors / Medicine Colleges</div>
            <div class="medden-page-hd-sub">Enter academic staff counts for Medicine and Dentistry. All full-time fields are required.</div>
        </div>
    </div>

    <div id="medDenBanner" class="banner warn medden-banner" style="display:none;">
        <span class="dot"></span>
        <span class="txt"></span>
        <button type="button" class="x" onclick="document.getElementById('medDenBanner').style.display='none'">×</button>
    </div>

    <!-- ── Academic Staff Table ───────────────────────────────── -->
    <div class="medden-table-wrap">
        <table class="tbl staff-split-table">
            <thead>
                <tr>
                    <th class="sst-cat-col">Category</th>
                    <th class="sst-coll-col">🏥 College of Medicine</th>
                    <th class="sst-coll-col">🦷 College of Dentistry</th>
                </tr>
            </thead>
            <tbody>

                <tr class="sst-total-row">
                    <td class="sst-cat">Total Students</td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row">
                                <span class="irow-lbl">Students</span>
                                <input class="num" id="med_totalStudents" type="number" min="0" step="1" value="@N(Model.Med_TotalStudents)" />
                            </div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row">
                                <span class="irow-lbl">Students</span>
                                <input class="num" id="den_totalStudents" type="number" min="0" step="1" value="@N(Model.Den_TotalStudents)" />
                            </div>
                        </div>
                    </td>
                </tr>

                <tr class="sst-phd-row">
                    <td class="sst-cat">Professor</td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="med_partTimeClinicalProfessor" type="number" min="0" step="1" value="@N(Model.Med_PartTimeClinicalProfessor)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="den_partTimeClinicalProfessor" type="number" min="0" step="1" value="@N(Model.Den_PartTimeClinicalProfessor)" /></div>
                        </div>
                    </td>
                </tr>

                <tr class="sst-phd-row">
                    <td class="sst-cat">Associate Professor</td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssociateProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="med_partTimeClinicalAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Med_PartTimeClinicalAssociateProfessor)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssociateProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="den_partTimeClinicalAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Den_PartTimeClinicalAssociateProfessor)" /></div>
                        </div>
                    </td>
                </tr>

                <tr class="sst-phd-row">
                    <td class="sst-cat">Assistant Professor</td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="med_partTimeClinicalAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Med_PartTimeClinicalAssistantProfessor)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantProfessor)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="den_partTimeClinicalAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Den_PartTimeClinicalAssistantProfessor)" /></div>
                        </div>
                    </td>
                </tr>

                <tr class="sst-phd-row">
                    <td class="sst-cat">Lecturer <span class="sst-qual">(PhD)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeLecturerPhd" type="number" min="0" step="1" value="@N(Model.Med_FullTimeLecturerPhd)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="med_partTimeClinicalLecturerPhd" type="number" min="0" step="1" value="@N(Model.Med_PartTimeClinicalLecturerPhd)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeLecturerPhd" type="number" min="0" step="1" value="@N(Model.Den_FullTimeLecturerPhd)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="den_partTimeClinicalLecturerPhd" type="number" min="0" step="1" value="@N(Model.Den_PartTimeClinicalLecturerPhd)" /></div>
                        </div>
                    </td>
                </tr>

                <tr class="sst-phd-row">
                    <td class="sst-cat">Assistant Lecturer <span class="sst-qual">(PhD)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeAssistantLecturerPhd" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantLecturerPhd)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="med_partTimeClinicalAssistantLecturerPhd" type="number" min="0" step="1" value="@N(Model.Med_PartTimeClinicalAssistantLecturerPhd)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeAssistantLecturerPhd" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantLecturerPhd)" /></div>
                            <div class="input-row"><span class="irow-lbl pt">Part-Time</span><input class="num" id="den_partTimeClinicalAssistantLecturerPhd" type="number" min="0" step="1" value="@N(Model.Den_PartTimeClinicalAssistantLecturerPhd)" /></div>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td class="sst-cat">Lecturer <span class="sst-qual">(MSc)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeLecturerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimeLecturerMsc)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeLecturerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimeLecturerMsc)" /></div>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td class="sst-cat">Assistant Lecturer <span class="sst-qual">(MSc)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimeAssistantLecturerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantLecturerMsc)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimeAssistantLecturerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantLecturerMsc)" /></div>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td class="sst-cat">Practitioner <span class="sst-qual">(BSc)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimePractitionerPsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimePractitionerPsc)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimePractitionerPsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimePractitionerPsc)" /></div>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td class="sst-cat">Practitioner <span class="sst-qual">(MSc)</span></td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="med_fullTimePractitionerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimePractitionerMsc)" /></div>
                        </div>
                    </td>
                    <td class="sst-cell">
                        <div class="input-stack">
                            <div class="input-row"><span class="irow-lbl ft">Full-Time</span><input class="num" id="den_fullTimePractitionerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimePractitionerMsc)" /></div>
                        </div>
                    </td>
                </tr>

            </tbody>
        </table>
    </div>

    <!-- ── Student : Staff Ratio Cards ───────────────────────── -->
    <div class="medden-ratio-grid">

        <div class="medden-ratio-col">
            <div class="medden-ratio-col-head">🏥 College of Medicine — Ratio</div>
            <div class="medden-ratio-item"><span>FT PhD-Level Staff</span><b id="med_ftClinicalPhd">—</b></div>
            <div class="medden-ratio-item"><span>Actual Part-Time</span><b id="med_actualPt">—</b></div>
            <div class="medden-ratio-item"><span>Allowed Part-Time</span><b id="med_allowedPt">—</b></div>
            <div class="medden-ratio-item"><span>Counted Part-Time</span><b id="med_countedPt">—</b></div>
            <div class="medden-ratio-item"><span>Effective Staff Count</span><b id="med_countedStaff">—</b></div>
            <div class="medden-ratio-item medden-ratio-status-row">
                <span>Student : Staff Ratio</span>
                <b id="med_ratio">—</b>
            </div>
            <div class="medden-ratio-item medden-ratio-status-row">
                <span>Status</span>
                <span id="med_ratioStatus" class="medden-status-badge">N/A</span>
            </div>
        </div>

        <div class="medden-ratio-col">
            <div class="medden-ratio-col-head">🦷 College of Dentistry — Ratio</div>
            <div class="medden-ratio-item"><span>FT PhD-Level Staff</span><b id="den_ftClinicalPhd">—</b></div>
            <div class="medden-ratio-item"><span>Actual Part-Time</span><b id="den_actualPt">—</b></div>
            <div class="medden-ratio-item"><span>Allowed Part-Time</span><b id="den_allowedPt">—</b></div>
            <div class="medden-ratio-item"><span>Counted Part-Time</span><b id="den_countedPt">—</b></div>
            <div class="medden-ratio-item"><span>Effective Staff Count</span><b id="den_countedStaff">—</b></div>
            <div class="medden-ratio-item medden-ratio-status-row">
                <span>Student : Staff Ratio</span>
                <b id="den_ratio">—</b>
            </div>
            <div class="medden-ratio-item medden-ratio-status-row">
                <span>Status</span>
                <span id="den_ratioStatus" class="medden-status-badge">N/A</span>
            </div>
        </div>

    </div>

    <!-- ── Computed Read-Only Summary ─────────────────────────── -->
    <div class="medden-summary-wrap">
        <div class="medden-summary-title">Computed Read-Only Summary</div>
        <div class="medden-summary-sub">Totals are automatically calculated for each college.</div>
        <div class="medden-summary-grid">
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time PhD (Medicine)</div>
                <input class="medden-summary-value" id="med_phdHolders" type="number" value="@Model.Med_PhdHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time PhD (Dentistry)</div>
                <input class="medden-summary-value" id="den_phdHolders" type="number" value="@Model.Den_PhdHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time MSc (Medicine)</div>
                <input class="medden-summary-value" id="med_mscHolders" type="number" value="@Model.Med_MscHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time MSc (Dentistry)</div>
                <input class="medden-summary-value" id="den_mscHolders" type="number" value="@Model.Den_MscHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time PSc (Medicine)</div>
                <input class="medden-summary-value" id="med_pscHolders" type="number" value="@Model.Med_PscHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">Full-Time PSc (Dentistry)</div>
                <input class="medden-summary-value" id="den_pscHolders" type="number" value="@Model.Den_PscHolders" readonly />
            </div>
            <div class="medden-summary-item medden-summary-item--pt">
                <div class="medden-summary-label">Part-Time Total (Medicine)</div>
                <input class="medden-summary-value" id="med_totalPartTime" type="number" value="@Model.Med_TotalPartTime" readonly />
            </div>
            <div class="medden-summary-item medden-summary-item--pt">
                <div class="medden-summary-label">Part-Time Total (Dentistry)</div>
                <input class="medden-summary-value" id="den_totalPartTime" type="number" value="@Model.Den_TotalPartTime" readonly />
            </div>
        </div>
    </div>

</div>
