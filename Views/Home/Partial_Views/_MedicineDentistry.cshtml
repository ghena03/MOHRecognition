@model DTOs.MedicineDentistryDto

@{
    string N(int? v) => v.HasValue ? v.Value.ToString() : "";
}

<div class="duration-wrap medden-wrap" style="margin-top:0;">
    <div class="duration-titlebar">
        Doctors / Medicine Colleges
    </div>
    <div class="medden-kicker">Full-time academic staff by category for Medicine and Dentistry colleges.</div>

    <div id="medDenBanner" class="banner warn medden-banner" style="display:none;">
        <span class="dot"></span>
        <span class="txt"></span>
        <button type="button" class="x" onclick="document.getElementById('medDenBanner').style.display='none'">×</button>
    </div>

    <div class="table-wrap medden-table-wrap">
        <table class="tbl medden-table">
            <thead>
                <tr>
                    <th class="medden-col-label">Full-Time Academic Category</th>
                    <th>College of Medicine</th>
                    <th>College of Dentistry</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="medden-row-label">1. Full-Time Professor</td>
                    <td><input class="num" id="med_fullTimeProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeProfessor)" /></td>
                    <td><input class="num" id="den_fullTimeProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeProfessor)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">2. Full-Time Associate Professor</td>
                    <td><input class="num" id="med_fullTimeAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssociateProfessor)" /></td>
                    <td><input class="num" id="den_fullTimeAssociateProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssociateProfessor)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">3. Full-Time Assistant Professor</td>
                    <td><input class="num" id="med_fullTimeAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantProfessor)" /></td>
                    <td><input class="num" id="den_fullTimeAssistantProfessor" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantProfessor)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">4. Full-Time Lecturer (PhD Holders)</td>
                    <td><input class="num" id="med_fullTimeLecturerPhd" type="number" min="0" step="1" value="@N(Model.Med_FullTimeLecturerPhd)" /></td>
                    <td><input class="num" id="den_fullTimeLecturerPhd" type="number" min="0" step="1" value="@N(Model.Den_FullTimeLecturerPhd)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">5. Full-Time Lecturer (MSC Holders)</td>
                    <td><input class="num" id="med_fullTimeLecturerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimeLecturerMsc)" /></td>
                    <td><input class="num" id="den_fullTimeLecturerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimeLecturerMsc)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">6. Full-Time Assistant Lecturer (MSC Holders)</td>
                    <td><input class="num" id="med_fullTimeAssistantLecturerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantLecturerMsc)" /></td>
                    <td><input class="num" id="den_fullTimeAssistantLecturerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantLecturerMsc)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">7. Full-Time Assistant Lecturer (PSC Holders)</td>
                    <td><input class="num" id="med_fullTimeAssistantLecturerPsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimeAssistantLecturerPsc)" /></td>
                    <td><input class="num" id="den_fullTimeAssistantLecturerPsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimeAssistantLecturerPsc)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">8. Full-Time Practitioner (PSC Holders)</td>
                    <td><input class="num" id="med_fullTimePractitionerPsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimePractitionerPsc)" /></td>
                    <td><input class="num" id="den_fullTimePractitionerPsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimePractitionerPsc)" /></td>
                </tr>
                <tr>
                    <td class="medden-row-label">9. Full-Time Practitioner (MSC Holders)</td>
                    <td><input class="num" id="med_fullTimePractitionerMsc" type="number" min="0" step="1" value="@N(Model.Med_FullTimePractitionerMsc)" /></td>
                    <td><input class="num" id="den_fullTimePractitionerMsc" type="number" min="0" step="1" value="@N(Model.Den_FullTimePractitionerMsc)" /></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="medden-summary-wrap">
        <div class="medden-summary-title">Computed Read-Only Summary</div>
        <div class="medden-summary-sub">Totals are automatically calculated for each college.</div>

        <div class="medden-summary-grid">
            <div class="medden-summary-item">
                <div class="medden-summary-label">PhD Holders (Medicine)</div>
                <input class="medden-summary-value" id="med_phdHolders" type="number" value="@Model.Med_PhdHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">PhD Holders (Dentistry)</div>
                <input class="medden-summary-value" id="den_phdHolders" type="number" value="@Model.Den_PhdHolders" readonly />
            </div>

            <div class="medden-summary-item">
                <div class="medden-summary-label">MSC Holders (Medicine)</div>
                <input class="medden-summary-value" id="med_mscHolders" type="number" value="@Model.Med_MscHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">MSC Holders (Dentistry)</div>
                <input class="medden-summary-value" id="den_mscHolders" type="number" value="@Model.Den_MscHolders" readonly />
            </div>

            <div class="medden-summary-item">
                <div class="medden-summary-label">PSC Holders (Medicine)</div>
                <input class="medden-summary-value" id="med_pscHolders" type="number" value="@Model.Med_PscHolders" readonly />
            </div>
            <div class="medden-summary-item">
                <div class="medden-summary-label">PSC Holders (Dentistry)</div>
                <input class="medden-summary-value" id="den_pscHolders" type="number" value="@Model.Den_PscHolders" readonly />
            </div>
        </div>
    </div>

    <div class="medden-actions">
        <button type="button" class="btn-primary medden-save-btn" onclick="MedDenSave()">Save</button>
    </div>
</div>
