@model DTOs.SubmitApplicationDto
@using System.Collections.Generic
@{
    var additionalFiles = (ViewBag.AdditionalFiles as List<DTOs.AdditionalFileDto>) ?? new List<DTOs.AdditionalFileDto>();
}

<div class="submitapp-wrap" style="margin-top:0;">
    <div class="duration-titlebar">
        Submit Application
    </div>

    <div id="subAppBanner" class="banner warn" style="display:none; margin-top:12px;">
        <span class="dot"></span>
        <span class="txt"></span>
        <button type="button" class="x" onclick="document.getElementById('subAppBanner').style.display='none'">×</button>
    </div>

    <div class="submitapp-notes">
        <div class="submitapp-note"><span class="req">*</span> Make sure all fields followed by (*) are filled.</div>
        <div class="submitapp-note"><span class="req">*</span> Make sure all data are correct and complete, otherwise it will not be considered.</div>
        <div class="submitapp-note"><span class="req">*</span> After submitting the application, you cannot add or modify data.</div>
    </div>

    <div class="submitapp-grid">
        <div class="field">
            <label>Applicant Name <span class="req">*</span></label>
            <input id="subapp_name" name="ApplicantName" type="text" maxlength="200" value="@(Model?.ApplicantName ?? "")" />
        </div>

        <div class="field">
            <label>Work Place <span class="req">*</span></label>
            <input id="subapp_workplace" name="WorkPlace" type="text" maxlength="200" value="@(Model?.WorkPlace ?? "")" />
        </div>
    </div>

    <!-- ── Additional Notes and Supporting Files ─────────────────────── -->
    <div class="subapp-extra">
        <div class="subapp-extra-label">Additional Notes <span class="subapp-extra-opt">(Optional)</span></div>
        <textarea id="subapp_additional_note"
                  name="AdditionalNote"
                  rows="2"
                  maxlength="2000"
                  placeholder="Any additional notes for the recognition committee..."
                  class="subapp-extra-textarea">@(Model?.AdditionalNote ?? "")</textarea>

        <div class="subapp-attach-row">
            <input type="file" id="subapp_additional_files_input" multiple
                   accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg"
                   style="display:none;" />
            <label for="subapp_additional_files_input" class="subapp-attach-btn">
                + Attach Files
            </label>
            <span id="subapp_additional_files_hint" class="subapp-attach-hint"></span>
        </div>

        @if (additionalFiles.Any())
        {
            <div class="subapp-file-list">
                @foreach (var f in additionalFiles)
                {
                    <div class="subapp-file-item">
                        <span class="subapp-file-tag">@f.FileType</span>
                        <a class="subapp-file-link" href="@f.FileUrl" target="_blank" rel="noopener">@f.FileName</a>
                        <button type="button" class="subapp-file-remove" title="Remove"
                                onclick="window.SubAppDeleteAdditionalFile('@f.StoredFileName')">×</button>
                    </div>
                }
            </div>
        }
    </div>

    <label class="submitapp-check" style="display:flex; align-items:center; gap:8px; margin-top:16px;">
        <input id="subapp_ack" name="IsAcknowledged" type="checkbox" @(Model != null && Model.IsAcknowledged ? "checked" : "") />
        <span>I acknowledge that all data are correct.</span>
    </label>

    <!-- Postgraduate continuation question (hidden until acknowledgment checked) -->
    <div id="subapp_postgrad_question" style="display:none; margin-top:12px;">
        <label style="font-weight:600; display:block; margin-bottom:6px;">
            Would you like to continue to postgraduate recognition?
        </label>

        <label style="margin-right:12px;">
            <input type="radio" id="subapp_continue_yes" name="subapp_continue_postgrad" value="yes" /> Yes
        </label>

        <label>
            <input type="radio" id="subapp_continue_no" name="subapp_continue_postgrad" value="no" checked /> No
        </label>
    </div>

    <div style="display:flex; justify-content:flex-start; margin-top:18px; gap:12px;">
        <button type="button" id="btnSubmitApplication" class="btn-primary">Submit</button>
        <button type="button" id="btnSaveAndApplyPostgraduate" class="btn-primary" style="display:none;">
            Save &amp; Apply for Postgraduate
        </button>
    </div>
</div>
