@model DTOs.HospitalsDto
@using System
@using System.Linq

@{
    var facilities = Model?.Facilities ?? new List<DTOs.HospitalFacilityDto>();
    var documents  = Model?.Documents  ?? new List<DTOs.HospitalFileDto>();

    string NormalizeDocType(string? rawType)
    {
        var type = (rawType ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(type)) return string.Empty;
        if (string.Equals(type, "HospitalAgreement", StringComparison.OrdinalIgnoreCase)) return "HospitalAgreement";
        if (string.Equals(type, "University-Hospital Agreement", StringComparison.OrdinalIgnoreCase)) return "HospitalAgreement";
        return type;
    }

    var agreementDocsByFacility = documents
        .Where(d => !string.IsNullOrWhiteSpace(d?.FileUrl))
        .Select(d => new { Doc = d, Type = NormalizeDocType(d.DocumentType) })
        .Where(x => x.Type == "HospitalAgreement")
        .GroupBy(x => (x.Doc.FacilityId ?? string.Empty).Trim(), StringComparer.OrdinalIgnoreCase)
        .ToDictionary(
            g => g.Key,
            g => g.Select(x => x.Doc)
                  .OrderByDescending(d => d.UploadedAt ?? DateTime.MinValue)
                  .ThenBy(d => d.OriginalFileName)
                  .ToList(),
            StringComparer.OrdinalIgnoreCase);
}

<div class="duration-wrap" style="margin-top:0;">
    <div class="card-hd">
        <h2>Hospitals</h2>
    </div>

    <div id="hospBanner" class="banner warn" style="display:none; margin:14px 14px 0;" role="status" aria-live="polite">
        <span class="dot"></span>
        <span class="txt"></span>
        <button type="button" class="x" onclick="document.getElementById('hospBanner').style.display='none'">×</button>
    </div>

    <div class="hosp-main-content">
        <div class="lab-section-card">
            <div class="lab-section-title"><strong>University Hospital Data</strong></div>
            <div class="lab-section-sub"><strong>Add each training hospital — name, specialization, and capacity.</strong></div>

            <input type="hidden" id="hosp_fac_editId" value="" />

            <div class="hosp-add-card add-facility-card">
                <div class="hosp-add-title" id="hosp_fac_formTitle">Add Facility</div>

                <div class="hosp-facility-grid hosp-facility-grid--full hospital-form-grid">
                    <div class="field">
                        <label>Facility / Hospital Name <span class="req">*</span></label>
                        <input id="hosp_fac_name" type="text" placeholder="e.g. King Hussein Medical Center" />
                    </div>
                    <div class="field">
                        <label>Specialization <span class="req">*</span></label>
                        <select id="hosp_fac_specialization" onchange="HospFacilityToggleCapacity()">
                            <option value="">-- Choose --</option>
                            <option value="Medicine">Medicine</option>
                            <option value="Dentistry">Dentistry</option>
                            <option value="Both">Both</option>
                        </select>
                    </div>
                    <div class="field hosp-capacity-field" id="hosp_fac_capacity_wrap">
                        <label>Beds / Dental Chairs</label>
                        <div class="hosp-capacity-inputs">
                            <div id="hosp_fac_capacity_empty" class="hosp-capacity-empty">Select specialization</div>
                            <div id="hosp_fac_beds_wrap" style="display:none;">
                                <input id="hosp_fac_beds" type="number" min="0" placeholder="Beds" inputmode="numeric" />
                            </div>
                            <div id="hosp_fac_dental_wrap" style="display:none;">
                                <input id="hosp_fac_dental" type="number" min="0" placeholder="Dental Chairs" inputmode="numeric" />
                            </div>
                        </div>
                    </div>
                    <div class="field hosp-upload-box">
                        <label>Agreement Files Upload</label>
                        <div class="agreement-upload-box">
                            <input id="hosp_fac_agreement_files" type="file" multiple accept=".pdf,.jpg,.jpeg,.png,.webp,.doc,.docx" style="display:none;" />
                            <label for="hosp_fac_agreement_files" class="attach-files-btn">Attach Files</label>
                            <span id="hosp_fac_agreement_files_hint" class="selected-file-name"></span>
                        </div>
                    </div>
                </div>

                <div class="hosp-form-footer">
                    <div id="hosp_fac_agreement_files_selected" class="hosp-selected-chips"></div>
                    <div class="form-actions">
                        <button type="button" class="btn-primary add-facility-btn" id="hosp_fac_addBtn" onclick="HospFacilityAdd()">Add Facility</button>
                        <button type="button" class="btn-ghost" id="hosp_fac_cancelBtn" style="display:none;" onclick="HospFacilityCancelEdit()">Cancel</button>
                    </div>
                </div>
            </div>

            <div class="table-wrap hosp-table-wrap">
                <table class="tbl">
                    <thead>
                        <tr>
                            <th style="width:44px;">#</th>
                            <th>Facility Name</th>
                            <th>Specialization</th>
                            <th>Beds</th>
                            <th>Dental Chairs</th>
                            <th>Agreement Files</th>
                            <th style="width:180px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!facilities.Any())
                        {
                            <tr><td colspan="7" style="color:#6b7280; font-weight:600;">No hospital data added yet.</td></tr>
                        }
                        else
                        {
                            var i = 1;
                            foreach (var r in facilities)
                            {
                                var facilityId = (r.Id ?? string.Empty).Trim();
                                var facilityDocs = agreementDocsByFacility.TryGetValue(facilityId, out var docsForFacility)
                                    ? docsForFacility
                                    : new List<DTOs.HospitalFileDto>();

                                <tr>
                                    <td>@i</td>
                                    <td><strong>@r.Name</strong></td>
                                    <td><span class="hosp-spec-tag">@r.Specialization</span></td>
                                    <td>@(r.BedCapacity.HasValue ? r.BedCapacity.Value.ToString() : "—")</td>
                                    <td>@(r.DentalChairCapacity.HasValue ? r.DentalChairCapacity.Value.ToString() : "—")</td>
                                    <td>
                                        @if (facilityDocs.Any())
                                        {
                                            <div class="hosp-agreement-cell">
                                                <span class="hosp-count-chip">@facilityDocs.Count file@(facilityDocs.Count == 1 ? "" : "s")</span>
                                                @if (facilityDocs.Count == 1)
                                                {
                                                    <a class="iconbtn iconbtn-edit iconbtn-text" href="@facilityDocs[0].FileUrl" target="_blank" rel="noopener" style="text-decoration:none;">View</a>
                                                }
                                                else
                                                {
                                                    <button type="button" class="iconbtn iconbtn-edit iconbtn-text" onclick="HospToggleFacilityFiles('@r.Id')">View</button>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <span style="color:#6b7280; font-weight:600;">No files</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="icon-actions">
                                            <button type="button" class="iconbtn iconbtn-edit" onclick="HospFacilityStartEdit('@r.Id')" title="Edit">
                                                <svg viewBox="0 0 24 24" aria-hidden="true"><path fill="currentColor" d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zm2.92 2.83H5v-.92l9.06-9.06.92.92L5.92 20.08zM20.71 7.04a1.003 1.003 0 0 0 0-1.42l-2.34-2.34a1.003 1.003 0 0 0-1.42 0l-1.83 1.83 3.75 3.75 1.84-1.82z"/></svg>
                                            </button>
                                            <button type="button" class="iconbtn iconbtn-del" onclick="HospFacilityDelete('@r.Id')" title="Delete">×</button>
                                        </div>

                                        <input type="hidden" id="hosp_fac_row_spec_@r.Id" value="@r.Specialization" />
                                        <input type="hidden" id="hosp_fac_row_name_@r.Id" value="@r.Name" />
                                        <input type="hidden" id="hosp_fac_row_bed_@r.Id" value="@(r.BedCapacity?.ToString() ?? "")" />
                                        <input type="hidden" id="hosp_fac_row_dental_@r.Id" value="@(r.DentalChairCapacity?.ToString() ?? "")" />
                                    </td>
                                </tr>
                                <tr id="hosp_files_row_@r.Id" class="hosp-files-expand-row" style="display:none;">
                                    <td colspan="7">
                                        <div class="hosp-files-panel">
                                            <table class="tbl hosp-files-table">
                                                <thead>
                                                    <tr>
                                                        <th>File Name</th>
                                                        <th style="width:220px;">Actions</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var doc in facilityDocs)
                                                    {
                                                        <tr>
                                                            <td><a class="hosp-doc-fn" href="@doc.FileUrl" target="_blank" rel="noopener">@doc.OriginalFileName</a></td>
                                                            <td>
                                                                <div class="icon-actions">
                                                                    <a class="iconbtn iconbtn-edit iconbtn-text" href="@doc.FileUrl" target="_blank" rel="noopener" style="text-decoration:none;">View</a>
                                                                    <a class="iconbtn iconbtn-edit iconbtn-text" href="@doc.FileUrl" download="@doc.OriginalFileName" style="text-decoration:none;">Download</a>
                                                                    <button type="button" class="iconbtn iconbtn-del" onclick="HospDeleteDocument('@doc.StoredFileName')" title="Delete File">×</button>
                                                                </div>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    </td>
                                </tr>
                                i++;
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
