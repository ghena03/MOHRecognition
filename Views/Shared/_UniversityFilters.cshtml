@model MOHRecognition.Models.UniversityFilterViewModel

<link rel="stylesheet" href="~/css/university-filters.css" />

<section class="mohe-filter-card">

    <form method="get" class="mohe-filter-form">

        <!-- Row 1 -->
        <div class="filter-row">

            <div class="filter-item">
                <label>Year:</label>

                <select class="filter-select">
                    <option>All</option>
                </select>
            </div>

            <div class="filter-group">

                <label class="filter-label">Session:</label>

                <select name="sessionNo" class="filter-select">

                    <option value="">All</option>

                    @if (ViewBag.Sessions != null)
                    {
                        foreach (var s in ViewBag.Sessions)
                        {
                            <option value="@s">
                                Meeting #@s
                            </option>
                        }
                    }

                </select>

            </div>

            <div class="filter-item">
                <label>Country:</label>

                <select name="SelectedCountry" class="filter-select">
                    <option value="">All Countries</option>

                    <option value="Jordan">Jordan</option>
                    <option value="Saudi Arabia">Saudi Arabia</option>
                    <option value="United Arab Emirates">United Arab Emirates</option>
                    <option value="Qatar">Qatar</option>
                    <option value="Kuwait">Kuwait</option>
                    <option value="Bahrain">Bahrain</option>
                    <option value="Oman">Oman</option>

                    <option value="Egypt">Egypt</option>
                    <option value="Iraq">Iraq</option>
                    <option value="Syria">Syria</option>
                    <option value="Lebanon">Lebanon</option>
                    <option value="Palestine">Palestine</option>

                    <option value="Turkey">Turkey</option>
                    <option value="Malaysia">Malaysia</option>
                    <option value="India">India</option>
                    <option value="Pakistan">Pakistan</option>
                    <option value="China">China</option>

                    <option value="United Kingdom">United Kingdom</option>
                    <option value="United States">United States</option>
                    <option value="Canada">Canada</option>
                    <option value="Germany">Germany</option>
                    <option value="France">France</option>
                    <option value="Italy">Italy</option>
                    <option value="Spain">Spain</option>

                    <option value="Russia">Russia</option>
                    <option value="Ukraine">Ukraine</option>
                    <option value="Azerbaijan">Azerbaijan</option>
                    <option value="Georgia">Georgia</option>

                    <option value="Australia">Australia</option>
                    <option value="New Zealand">New Zealand</option>

                    <option value="Sudan">Sudan</option>
                    <option value="Algeria">Algeria</option>
                    <option value="Morocco">Morocco</option>
                    <option value="Tunisia">Tunisia</option>
                </select>
            </div>

            <div class="filter-item">
                <label>University Type:</label>

                <select class="filter-select">
                    <option value="">All</option>
                    <option value="Governmental">Governmental</option>
                    <option value="PrivateProfit">Private Profit</option>
                    <option value="PrivateNonProfit">Private Nonprofit</option>
                    <option value="Other">Other</option>
                </select>
            </div>

        </div>

        <!-- Row 2 -->
        <div class="filter-row">

            <div class="filter-item">
                <label>Traditional Education:</label>

                <select class="filter-select">
                    <option value="">All</option>
                    <option value="Recognized">Recognition</option>
                    <option value="NotRecognized">No Recognition</option>
                    <option value="Delayed">Recognition Delay</option>
                    <option value="Confirmed">Decision Confirmation</option>
                    <option value="Withdrawn">Recognition Withdrawal</option>
                </select>
            </div>

            <div class="filter-item">
                <label>Distance Education:</label>

                <select class="filter-select">
                    <option value="">All</option>
                    <option value="Recognized">Recognition</option>
                    <option value="NotRecognized">No Recognition</option>
                    <option value="Delayed">Recognition Delay</option>
                    <option value="Confirmed">Decision Confirmation</option>
                    <option value="Withdrawn">Recognition Withdrawal</option>
                </select>
            </div>

            <div class="filter-item">
                <label>Medical Colleges:</label>

                <select class="filter-select">
                    <option value="">All</option>
                    <option value="FullMedical">Full Medical Recognition</option>
                    <option value="HumanMedicine">Human Medicine</option>
                    <option value="Dentistry">Dentistry</option>
                </select>
            </div>

            <div class="filter-item">
                <label>University Name:</label>

                <input type="text"
                       name="SearchTerm"
                       value="@Model?.SearchTerm"
                       class="filter-input"
                       placeholder="Search..." />
            </div>

        </div>

        <!-- Buttons -->
        <div class="filters-actions">

            <button type="submit" class="btn-search">
                Search
            </button>

            <button type="reset" class="btn-reset">
                Reset
            </button>

        </div>

    </form>

</section>