@model MOHRecognition.Services.RecognitionRequestRecord
@using System
@using DTOs
@{
    Layout = null;
    ViewData["Title"] = "Full Application View";

    var pub       = Model.PublicInfo        ?? new PublicInfoDto();
    var acad      = Model.AcademicInfo      ?? new AcademicInfoDto();
    var dur       = Model.StudyDuration     ?? new StudyDurationDto();
    var adm       = Model.AdmissionRequirements ?? new AdmissionRequirementsDto();
    var faculties = Model.Faculties         ?? new List<FacultyRowDto>();
    var programs  = Model.Programs          ?? new List<ProgramRowDto>();
    var progHrs   = Model.ProgramHours      ?? new List<ProgramHoursRowDto>();
    var medDen    = Model.MedicineDentistry ?? new MedicineDentistryDto();
    var hosp      = Model.Hospitals         ?? new HospitalsDto();
    var infra     = Model.Infrastructure    ?? new InfrastructureDto();
    var labs      = Model.Laboratories      ?? new LaboratoriesDto();
    var pictures  = Model.Pictures?.Rows    ?? new List<PictureRowDto>();
    var accBodies = Model.AccreditationBodies ?? new List<AccreditationBodyRowDto>();
    string NormalizeHospitalDocType(string? rawType)
    {
        var type = (rawType ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(type))
            return string.Empty;

        if (string.Equals(type, "LocalRecognition", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "LocalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "LocalAccreditation";
        if (string.Equals(type, "RegionalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "RegionalAccreditation";
        if (string.Equals(type, "InternationalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "InternationalAccreditation";
        if (string.Equals(type, "OtherAccreditation", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";
        if (string.Equals(type, "HospitalAgreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";

        if (string.Equals(type, "University-Hospital Agreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";
        if (string.Equals(type, "Local Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Recognition Document (", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Accreditation Document (", StringComparison.OrdinalIgnoreCase))
        {
            var open = type.IndexOf('(');
            var close = type.LastIndexOf(')');
            var inner = (open >= 0 && close > open)
                ? type.Substring(open + 1, close - open - 1).Trim()
                : string.Empty;

            if (inner.Equals("Local", StringComparison.OrdinalIgnoreCase))
                return "LocalAccreditation";
            if (inner.Equals("Regional", StringComparison.OrdinalIgnoreCase))
                return "RegionalAccreditation";
            if (inner.Equals("International", StringComparison.OrdinalIgnoreCase))
                return "InternationalAccreditation";

            return "OtherAccreditation";
        }

        if (string.Equals(type, "Accreditation Document", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";

        return type;
    }

    string HospitalDocLabel(string normalizedType) => normalizedType switch
    {
        "LocalRecognition" => "Local Recognition",
        "LocalAccreditation" => "Local Accreditation",
        "RegionalAccreditation" => "Regional Accreditation",
        "InternationalAccreditation" => "International Accreditation",
        "OtherAccreditation" => "Other Accreditation",
        "HospitalAgreement" => "University-Hospital Agreement",
        _ => string.IsNullOrWhiteSpace(normalizedType) ? "—" : normalizedType
    };

    // Section 12 — University Recognition and Accreditation (from UniRecAcc, not Hospitals.Documents)
    var uraRawDocs = (Model.UniRecAcc?.Documents ?? new List<UniRecAccDocumentDto>())
        .Where(x => !string.IsNullOrWhiteSpace(x.FileUrl))
        .OrderBy(x => x.DocumentType)
        .ThenByDescending(x => x.UploadedAt ?? DateTime.MinValue)
        .ToList();

    var localRecognitionDocs = uraRawDocs.Where(x => string.Equals(x.DocumentType, "LocalRecognition", StringComparison.OrdinalIgnoreCase)).ToList();
    var localAccreditationDocs = uraRawDocs.Where(x => string.Equals(x.DocumentType, "LocalAccreditation", StringComparison.OrdinalIgnoreCase)).ToList();
    var regionalAccreditationDocs = uraRawDocs.Where(x => string.Equals(x.DocumentType, "RegionalAccreditation", StringComparison.OrdinalIgnoreCase)).ToList();
    var internationalAccreditationDocs = uraRawDocs.Where(x => string.Equals(x.DocumentType, "InternationalAccreditation", StringComparison.OrdinalIgnoreCase)).ToList();
    var otherAccreditationDocs = uraRawDocs.Where(x => string.Equals(x.DocumentType, "OtherAccreditation", StringComparison.OrdinalIgnoreCase)).ToList();

    // Hospital agreement docs still come from Hospitals.Documents
    var typedHospDocs = (Model.Hospitals?.Documents ?? new List<HospitalFileDto>())
        .Where(x => !string.IsNullOrWhiteSpace(x.FileUrl))
        .Select(x => new { Doc = x, Type = NormalizeHospitalDocType(x.DocumentType) })
        .Where(x => !string.IsNullOrWhiteSpace(x.Type))
        .OrderBy(x => x.Type)
        .ThenByDescending(x => x.Doc.UploadedAt ?? DateTime.MinValue)
        .ThenBy(x => x.Doc.OriginalFileName)
        .ToList();

    var hospitalAgreementDocs = typedHospDocs.Where(x => x.Type == "HospitalAgreement").Select(x => x.Doc).ToList();
    var facilityAgreementDocs = hospitalAgreementDocs
        .Where(x => !string.IsNullOrWhiteSpace(x.FacilityId))
        .GroupBy(x => x.FacilityId.Trim(), StringComparer.OrdinalIgnoreCase)
        .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

    var hospDocs  = Model.Hospitals?.Documents ?? new List<HospitalFileDto>();
    var labFiles  = Model.Laboratories?.UploadedFiles ?? new List<LaboratoryFileDto>();
    var rankings  = Model.GlobalRankings    ?? new GlobalRankingsDto();

    string V(string? s) => string.IsNullOrWhiteSpace(s) ? "—" : s;
    string N(int? n)    => n.HasValue && n.Value > 0 ? n.Value.ToString("N0") : "—";
    string D(decimal? d) => d.HasValue && d.Value > 0 ? d.Value.ToString("0.##") : "—";
    bool F(string? s)   => !string.IsNullOrWhiteSpace(s);
    bool FN(int? n)     => n.HasValue && n.Value > 0;
    bool FD(decimal? d) => d.HasValue && d.Value > 0;

    int backId = ViewBag.BackId ?? 0;

    bool showRec     = ViewBag.ShowRecommendation ?? false;
    bool isInMeeting = ViewBag.IsInMeeting  ?? false;
    int  meetingIdRec = ViewBag.MeetingId   ?? 0;
    string reviewerName = ViewBag.ReviewerDisplayName ?? "Recognition Member";

    if (showRec) ViewData["Title"] = "Submitted University — Full Details";

    var recDecision = Model.BasicInfoAssessmentDecision ?? "";
    string DecCss(string d) => d switch {
        "Approve" => "dec-approve", "Conditional Approval" => "dec-conditional",
        var x when x.Contains("Reject", StringComparison.OrdinalIgnoreCase) => "dec-reject",
        _ => string.IsNullOrWhiteSpace(d) ? "dec-na" : "dec-neutral" };
    string DecIcon(string d) => d switch {
        "Approve" => "bi-check2-circle", "Conditional Approval" => "bi-arrow-repeat",
        var x when x.Contains("Reject", StringComparison.OrdinalIgnoreCase) => "bi-x-octagon-fill",
        _ => "bi-dash-circle" };
    static string BadgeCss(string s) => s switch {
        "Compliant" => "badge-compliant", "Needs Review" => "badge-review",
        "Not Compliant" => "badge-noncompliant", _ => "badge-na" };
    static string EnvMap(string? v) => (v ?? "").Trim() switch {
        "Meets Standards" => "Compliant", "Needs Improvement" => "Needs Review", _ => "Not Assessed" };
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — #@Model.Id</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --brand: #7f1627;
            --brand-dark: #5a0e1b;
            --brand-light: #faf4f5;
            --border: #ede4da;
            --text: #1a1a1a;
            --muted: #6b7280;
            --bg: #f3f0eb;
            --white: #fff;
            --sidebar-w: 240px;
            --header-h: 62px;
        }

        body { font-family: 'Segoe UI', Arial, sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; }

        /* ── Top bar ── */
        .top-ministry { background: var(--brand-dark); color: rgba(255,255,255,.65); font-size: 11px; font-weight: 500; letter-spacing: .4px; padding: 5px 32px; display: flex; align-items: center; gap: 6px; }

        .pg-header {
            position: fixed; top: 0; left: 0; right: 0; z-index: 200;
            background: var(--brand); color: #fff;
            height: var(--header-h);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px 0 16px;
            box-shadow: 0 2px 18px rgba(0,0,0,.25);
        }
        .hd-left { display: flex; align-items: center; gap: 14px; }
        .pg-header img { height: 38px; }
        .hd-sep { width: 1px; height: 32px; background: rgba(255,255,255,.25); margin: 0 4px; }
        .hd-text h1 { font-size: 16px; font-weight: 700; }
        .hd-text p { font-size: 11px; opacity: .7; margin-top: 2px; }
        .hd-right { display: flex; align-items: center; gap: 8px; }
        .badge-view-only { background: rgba(255,255,255,.18); border: 1.5px solid rgba(255,255,255,.35); border-radius: 999px; padding: 4px 12px; font-size: 11px; font-weight: 800; letter-spacing: .4px; color: #fff; display: flex; align-items: center; gap: 5px; }
        .btn-hd { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,.12); color: #fff; border: 1.5px solid rgba(255,255,255,.3); border-radius: 8px; padding: 7px 14px; font-size: 12.5px; font-weight: 600; text-decoration: none; cursor: pointer; transition: background .15s; white-space: nowrap; }
        .btn-hd:hover { background: rgba(255,255,255,.22); }
        .btn-hd.print-btn { background: rgba(255,255,255,.08); }
        .btn-hd-decision { display: inline-flex; align-items: center; gap: 6px; background: #F2C94C; color: #3A2500; border: 1.5px solid #D6A800; border-radius: 8px; padding: 7px 14px; font-size: 12.5px; font-weight: 700; text-decoration: none; cursor: pointer; transition: background .15s; white-space: nowrap; }
        .btn-hd-decision:hover { background: #e6bb38; }

        /* ── Layout ── */
        .layout { display: flex; padding-top: var(--header-h); min-height: 100vh; }

        /* ── Sidebar ── */
        .sidebar {
            position: fixed; top: var(--header-h); left: 0; bottom: 0;
            width: var(--sidebar-w);
            background: var(--white);
            border-right: 1px solid var(--border);
            overflow-y: auto;
            z-index: 100;
        }
        .sidebar-inner { padding: 16px 0 60px; }
        .sid-group { padding: 10px 16px 4px; font-size: 10px; font-weight: 800; color: #aaa; text-transform: uppercase; letter-spacing: .6px; }
        .sid-link {
            display: flex; align-items: center; gap: 10px;
            padding: 8px 16px; font-size: 12.5px; font-weight: 500; color: #374151;
            text-decoration: none; border-left: 3px solid transparent;
            transition: all .12s;
        }
        .sid-link:hover { background: var(--brand-light); color: var(--brand); border-left-color: var(--brand); }
        .sid-link.active { background: var(--brand-light); color: var(--brand); border-left-color: var(--brand); font-weight: 700; }
        .sid-num { width: 20px; height: 20px; border-radius: 50%; background: #f0e8e0; color: var(--brand); font-size: 10px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }

        /* ── Main content ── */
        .main { margin-left: var(--sidebar-w); flex: 1; padding: 28px 28px 120px; max-width: 1060px; }

        /* ── Summary strip ── */
        .summary-strip {
            background: var(--white); border: 1px solid var(--border); border-radius: 12px;
            padding: 20px 24px; margin-bottom: 20px;
            display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start;
        }
        .uni-title { font-size: 22px; font-weight: 800; color: #111; }
        .uni-sub { font-size: 13px; color: var(--muted); margin-top: 4px; }
        .meta-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px; }
        .chip { background: #f3f0eb; border: 1px solid #e3d9cf; border-radius: 8px; padding: 5px 10px; font-size: 11.5px; font-weight: 600; color: #374151; display: flex; align-items: center; gap: 5px; }
        .chip i { color: var(--brand); }
        .status-badge { border-radius: 999px; padding: 5px 14px; font-size: 12px; font-weight: 800; display: inline-flex; align-items: center; gap: 6px; }
        .sb-pending { background: #fef3c7; color: #92400e; }
        .sb-review  { background: #dbeafe; color: #1e40af; }
        .sb-done    { background: #dcfce7; color: #166534; }

        /* ── Section cards ── */
        .section-card { background: var(--white); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 20px; overflow: hidden; scroll-margin-top: calc(var(--header-h) + 16px); }
        .sec-hd { background: var(--brand); color: #fff; padding: 14px 20px; display: flex; align-items: center; gap: 12px; }
        .sec-hd .sec-num { width: 28px; height: 28px; background: rgba(255,255,255,.2); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; flex-shrink: 0; }
        .sec-hd h2 { font-size: 15px; font-weight: 700; }
        .sec-hd p { font-size: 11px; opacity: .75; margin-top: 2px; }
        .sec-bd { padding: 20px; }

        /* ── Sub-headers ── */
        .sub-hd { font-size: 11.5px; font-weight: 800; color: var(--brand); text-transform: uppercase; letter-spacing: .5px; margin: 20px 0 10px; padding-bottom: 6px; border-bottom: 1.5px solid #f0e8de; }
        .sub-hd:first-child { margin-top: 0; }

        /* ── Field grid ── */
        .fg { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .fg-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
        .fg-docs { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .fg-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .fg-wide { display: grid; grid-template-columns: 1fr; gap: 10px; }
        .field { background: #faf7f3; border: 1px solid #eee7de; border-radius: 8px; padding: 10px 12px; }
        .field .lbl { font-size: 10px; font-weight: 800; color: #999; text-transform: uppercase; letter-spacing: .5px; }
        .field .val { margin-top: 5px; font-size: 13.5px; font-weight: 600; color: #111; line-height: 1.45; word-break: break-word; }
        .field .val.mono { font-family: 'Courier New', monospace; font-size: 12px; }
        .field .val a { color: var(--brand); text-decoration: none; }
        .field .val a:hover { text-decoration: underline; }

        /* ── Checkboxes display ── */
        .check-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
        .check-tag { display: inline-flex; align-items: center; gap: 5px; border-radius: 6px; padding: 4px 10px; font-size: 12px; font-weight: 700; }
        .check-yes { background: #e8f5ea; color: #1a7a34; }
        .check-no  { background: #f0f0f0; color: #888; }

        /* ── Tables ── */
        .tbl-wrap { overflow-x: auto; }
        table.tbl { width: 100%; border-collapse: collapse; font-size: 12.5px; }
        table.tbl th { background: #faf7f4; color: var(--brand); font-size: 10.5px; font-weight: 800; text-transform: uppercase; letter-spacing: .5px; padding: 9px 10px; border-bottom: 2px solid #ede4da; text-align: left; white-space: nowrap; }
        table.tbl td { padding: 9px 10px; border-bottom: 1px solid #f3ede6; color: #1f2937; vertical-align: top; }
        table.tbl tr:last-child td { border-bottom: none; }
        table.tbl tr:hover td { background: #faf7f3; }
        .fg-docs table.tbl { table-layout: fixed; }
        .fg-docs table.tbl th:nth-child(1), .fg-docs table.tbl td:nth-child(1) { width: 32%; }
        .fg-docs table.tbl th:nth-child(2), .fg-docs table.tbl td:nth-child(2) { width: 16%; }
        .fg-docs table.tbl th:nth-child(3), .fg-docs table.tbl td:nth-child(3) { width: 18%; }
        .fg-docs table.tbl th:nth-child(4), .fg-docs table.tbl td:nth-child(4) { width: 18%; }
        .fg-docs table.tbl th:nth-child(5), .fg-docs table.tbl td:nth-child(5) { width: 16%; }

        /* ── Staff rank table ── */
        .rank-tbl th:nth-child(2), .rank-tbl th:nth-child(3), .rank-tbl th:nth-child(4) { text-align: center; }
        .rank-tbl td:nth-child(2), .rank-tbl td:nth-child(3), .rank-tbl td:nth-child(4) { text-align: center; font-weight: 700; }
        .rank-total { font-weight: 800; color: var(--brand); }

        /* ── Study duration table ── */
        .dur-tbl td:first-child { font-weight: 700; color: #374151; }

        /* ── File rows ── */
        .file-grid { display: grid; gap: 8px; }
        .file-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; border: 1px solid #ede4da; border-radius: 8px; padding: 10px 14px; background: #fdfbf8; }
        .file-info .fn { font-size: 13px; font-weight: 700; color: #1f2937; }
        .file-info .fs { font-size: 11.5px; color: var(--muted); margin-top: 2px; }
        .btn-view { text-decoration: none; border-radius: 7px; padding: 5px 12px; font-size: 11.5px; font-weight: 700; border: 1.5px solid #d5c9bb; color: #5b4636; background: #fff; white-space: nowrap; }
        .btn-view:hover { background: #f9f4ee; }

        /* ── Admission requirements ── */
        .req-list { list-style: none; display: grid; gap: 6px; }
        .req-list li { background: #faf7f3; border: 1px solid #ede4da; border-radius: 6px; padding: 8px 12px; font-size: 13px; display: flex; align-items: flex-start; gap: 8px; }
        .req-list li::before { content: '•'; color: var(--brand); font-weight: 900; flex-shrink: 0; margin-top: 1px; }

        /* ── Stat cards ── */
        .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }
        .stat-card { background: linear-gradient(135deg, var(--brand) 0%, #a0223a 100%); color: #fff; border-radius: 10px; padding: 14px 16px; }
        .stat-card .sv { font-size: 26px; font-weight: 800; line-height: 1; }
        .stat-card .sk { font-size: 10.5px; opacity: .8; margin-top: 4px; font-weight: 600; text-transform: uppercase; letter-spacing: .4px; }
        .stat-card.light { background: #faf7f3; color: var(--text); border: 1px solid var(--border); }
        .stat-card.light .sv { color: var(--brand); }

        /* ── Empty state ── */
        .empty-state { text-align: center; padding: 28px; color: var(--muted); font-size: 13px; }
        .empty-state i { font-size: 28px; display: block; margin-bottom: 8px; opacity: .4; }

        /* ── Notes ── */
        .note-box { background: #f8fbff; border: 1px solid #dbeafe; border-radius: 8px; padding: 12px 14px; font-size: 13px; line-height: 1.6; color: #1f2937; margin-top: 8px; }

        /* ── Assessment pills ── */
        .ap { display: inline-flex; align-items: center; gap: 5px; border-radius: 999px; padding: 5px 12px; font-size: 12px; font-weight: 800; }
        .ap-compliant    { background: #e8f5ea; color: #1a7a34; }
        .ap-review       { background: #fff8db; color: #b45309; }
        .ap-noncomp      { background: #fef2f2; color: #b91c1c; }
        .ap-missing      { background: #f0f0f0; color: #888; }

        /* ── Bottom action bar ── */
        .bottom-bar {
            position: fixed; bottom: 0; left: var(--sidebar-w); right: 0; z-index: 150;
            background: #fff; border-top: 2px solid var(--border);
            display: flex; align-items: center; justify-content: flex-end; gap: 10px;
            padding: 12px 28px;
            box-shadow: 0 -2px 16px rgba(0,0,0,.08);
        }
        .btn-bar { display: inline-flex; align-items: center; gap: 6px; border-radius: 8px; padding: 9px 18px; font-size: 13px; font-weight: 600; text-decoration: none; cursor: pointer; border: 1.5px solid var(--border); background: #fff; color: #374151; transition: background .15s; white-space: nowrap; }
        .btn-bar:hover { background: #f5f0ea; }
        .btn-bar-decision { background: #F2C94C; color: #3A2500; border-color: #D6A800; font-weight: 700; }
        .btn-bar-decision:hover { background: #e6bb38; }
        /* ── Recommendation section ── */
        .sec-hd-rec { background: #92400e; }
        .sid-rec { background: #fef3c7 !important; color: #92400e !important; }

        .badge { display: inline-flex; align-items: center; gap: 5px; border-radius: 999px; padding: 5px 11px; font-size: 11.5px; font-weight: 800; }
        .badge-compliant    { background: #dcfce7; color: #15803d; }
        .badge-review       { background: #fef9c3; color: #a16207; }
        .badge-noncompliant { background: #fee2e2; color: #b91c1c; }
        .badge-na           { background: #f3f4f6; color: #6b7280; }

        .score-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; margin-bottom: 16px; }
        .score-cell { border: 1px solid #f0ece6; border-radius: 8px; padding: 14px; text-align: center; }
        .score-num-r { font-size: 22px; font-weight: 900; color: #aaa; margin-bottom: 6px; }
        .score-name { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .4px; color: #666; margin-bottom: 10px; }

        .env-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 4px; }
        .env-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; background: #f8f9fa; border-radius: 6px; font-size: 13px; }
        .env-label { font-weight: 600; color: #444; }
        .env-note { font-size: 12px; color: #888; margin-top: 3px; }

        .dec-badge { display: inline-flex; align-items: center; gap: 8px; border-radius: 999px; padding: 8px 20px; font-size: 14px; font-weight: 800; }
        .dec-approve      { background: #dcfce7; color: #15803d; }
        .dec-conditional  { background: #fef9c3; color: #a16207; }
        .dec-reject       { background: #fee2e2; color: #b91c1c; }
        .dec-na           { background: #f3f4f6; color: #6b7280; }
        .dec-neutral      { background: #dbeafe; color: #1e40af; }

        .note-box { background: #f8fbff; border: 1px solid #dbeafe; border-radius: 8px; padding: 12px 14px; font-size: 13px; line-height: 1.6; color: #1f2937; white-space: pre-wrap; }
        .note-box.empty { color: #aaa; font-style: italic; background: #faf7f3; border-color: #ede4da; }

        @@media print {
            .pg-header, .sidebar, .hd-right, .bottom-bar { display: none !important; }
            .layout { padding-top: 0 !important; }
            .main { margin-left: 0 !important; max-width: 100% !important; }
            .section-card { break-inside: avoid; }
        }
        @@media (max-width: 900px) {
            .sidebar { display: none; }
            .main { margin-left: 0; }
            .fg { grid-template-columns: 1fr 1fr; }
            .fg-4, .stat-grid, .score-grid { grid-template-columns: 1fr 1fr; }
        }
        .field-empty { color: #9ca3af; font-size: 13px; font-style: italic; margin: 4px 0 0; }
        .ro-note-block {
            background: #fdfaf8;
            border: 1px solid #e8dfd8;
            border-radius: 10px;
            padding: 12px 16px;
            font-size: 14px;
            color: #3d2e2e;
            line-height: 1.7;
            white-space: pre-wrap;
            word-break: break-word;
        }
    </style>
</head>
<body>

<div class="pg-header">
    <div class="hd-left">
        <img src="/images/mohelogo.png" alt="Ministry Logo" />
        <div class="hd-sep"></div>
        <div class="hd-text">
            @if (showRec && backId > 0)
            {
                <h1>Full Application View</h1>
                <p>Read-only · All sections + doctor recommendation · Request #@Model.Id</p>
            }
            else if (showRec)
            {
                <h1>Submitted University — Full Details</h1>
                <p>Read-only · Full application + doctor recommendation · #@Model.Id</p>
            }
            else
            {
                <h1>Full Application View</h1>
                <p>Read-only · All sections · Request #@Model.Id</p>
            }
        </div>
    </div>
    <div class="hd-right">
        @if (!showRec)
        {
            <span class="badge-view-only"><i class="bi bi-eye"></i> View Only</span>
        }
        @if (showRec && backId == 0)
        {
            <a class="btn-hd" href="/Home/SubmittedUniversities"><i class="bi bi-arrow-left"></i> Back to List</a>
            @if (!isInMeeting)
            {
                <a class="btn-hd btn-hd-decision" href="/Home/CreateMeeting?preselectRequestId=@Model.Id"><i class="bi bi-calendar-plus"></i> Add to Meeting</a>
            }
            else
            {
                <a class="btn-hd" href="/Home/SessionDashboard?id=@meetingIdRec"><i class="bi bi-calendar2-check"></i> View Meeting</a>
            }
        }
        else if (backId > 0)
        {
            <a class="btn-hd" href="/Home/SessionDashboard?id=@backId"><i class="bi bi-arrow-left"></i> Back to Meeting</a>
        }
        else
        {
            <a class="btn-hd" href="/Home/Requests"><i class="bi bi-arrow-left"></i> Back</a>
        }
    </div>
</div>

<div class="layout">

    <!-- ── Sidebar Navigation ── -->
    <nav class="sidebar">
        <div class="sidebar-inner">
            <div class="sid-group">@(showRec ? "Overview" : "Application")</div>
            <a class="sid-link active" href="#sec-overview"><span class="sid-num"><i class="bi bi-info-circle" style="font-size:9px"></i></span> @(showRec ? "Summary" : "Overview")</a>

            <div class="sid-group">@(showRec ? "University Application" : "Sections")</div>
            <a class="sid-link" href="#sec-public"><span class="sid-num">1</span> Public Info</a>
            <a class="sid-link" href="#sec-academic"><span class="sid-num">2</span> Academic Info &amp; Accreditation</a>
            <a class="sid-link" href="#sec-admission"><span class="sid-num">3</span> Admission &amp; Duration</a>
            <a class="sid-link" href="#sec-faculties"><span class="sid-num">4</span> Colleges</a>
            <a class="sid-link" href="#sec-programs"><span class="sid-num">5</span> Programs</a>
            <a class="sid-link" href="#sec-medicine"><span class="sid-num">6</span> Medicine &amp; Dentistry</a>
            <a class="sid-link" href="#sec-hospitals"><span class="sid-num">7</span> Hospitals</a>
            <a class="sid-link" href="#sec-infra"><span class="sid-num">8</span> University Infrastructure</a>
            <a class="sid-link" href="#sec-labs"><span class="sid-num">9</span> Laboratories</a>
            <a class="sid-link" href="#sec-library"><span class="sid-num">10</span> Library</a>
            <a class="sid-link" href="#sec-photos"><span class="sid-num">11</span> Photos / Media</a>
            <a class="sid-link" href="#sec-documents"><span class="sid-num">12</span> Recognition &amp; Accreditation</a>
            <a class="sid-link" href="#sec-additional-notes"><span class="sid-num">13</span> Additional Notes</a>

            @if (showRec)
            {
                <div class="sid-group">Recommendation</div>
                <a class="sid-link sid-rec" href="#sec-recommendation"><span class="sid-num" style="background:#fde68a;color:#92400e">R</span> Doctor's Recommendation</a>
            }
        </div>
    </nav>

    <!-- ── Main Content ── -->
    <main class="main">

        <!-- Overview strip -->
        <div class="summary-strip" id="sec-overview">
            <div>
                <div class="uni-title">@V(Model.UniversityName)</div>
                <div class="uni-sub">@V(Model.Country) · Reference: @V(Model.ReferenceNumber) · Submitted @Model.SubmittedAt.ToString("dd MMM yyyy")</div>
                <div class="meta-chips">
                    <span class="chip"><i class="bi bi-hash"></i> Request #@Model.Id</span>
                    <span class="chip"><i class="bi bi-envelope"></i> @V(Model.UniversityEmail)</span>
                    <span class="chip"><i class="bi bi-person"></i> @V(Model.ApplicantName)</span>
                    <span class="chip"><i class="bi bi-building"></i> @V(Model.WorkPlace)</span>
                    <span class="chip"><i class="bi bi-person-badge"></i> Assigned: @V(Model.AssignedMember)</span>
                </div>
            </div>
            <div>
                @{
                    var st = Model.Status ?? "";
                    var stClass = st.Contains("Pending") ? "sb-pending" : st.Contains("Review") ? "sb-review" : "sb-done";
                }
                <span class="status-badge @stClass"><i class="bi bi-circle-fill" style="font-size:7px"></i> @V(st)</span>
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 1 — PUBLIC INFORMATION                            -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-public">
            <div class="sec-hd">
                <div class="sec-num">1</div>
                <div>
                    <h2>Public Information</h2>
                    <p>General institution details, contact info and identity statements</p>
                </div>
            </div>
            <div class="sec-bd">
                @{
                    bool hasInstDetails = F(pub.InstitutionName)||F(pub.PartyForwardingForm)||F(pub.City)||F(pub.FoundationDate)||F(pub.DateOfEstablishment)||F(pub.StartOfTeaching)||F(pub.ModeOfStudy)||F(pub.LanguageOfInstruction)||F(pub.OversightRightsEntity);
                    bool hasPresident   = F(pub.PresidentName)||F(pub.PresidentHighestAcademicDegree)||F(pub.PresidentMajorAreaOfStudy);
                    bool hasContact     = F(pub.MailingFullAddress)||F(pub.DirectPhoneNumber)||F(pub.FaxNumber)||F(pub.EmailAddress)||F(pub.InstitutionalWebAddress)||F(pub.LastDateWebsiteUpdated);
                    bool hasIdentity    = F(pub.InstitutionalVisionStatement)||F(pub.InstitutionalMissionStatement)||F(pub.InstitutionalTargettedObjectives)||F(pub.InstitutionalValues);
                }
                @if (hasInstDetails)
                {
                    <div class="sub-hd">Institution Details</div>
                    <div class="fg">
                        @if (F(pub.InstitutionName))          { <div class="field"><div class="lbl">Institution Name</div><div class="val">@pub.InstitutionName</div></div> }
                        @if (F(pub.PartyForwardingForm))       { <div class="field"><div class="lbl">Party Forwarding Form</div><div class="val">@pub.PartyForwardingForm</div></div> }
                        @if (F(pub.City))                      { <div class="field"><div class="lbl">City</div><div class="val">@pub.City</div></div> }
                        @if (F(pub.FoundationDate))            { <div class="field"><div class="lbl">Foundation Date</div><div class="val">@pub.FoundationDate</div></div> }
                        @if (F(pub.DateOfEstablishment))       { <div class="field"><div class="lbl">Date of Establishment</div><div class="val">@pub.DateOfEstablishment</div></div> }
                        @if (F(pub.StartOfTeaching))           { <div class="field"><div class="lbl">Start of Teaching</div><div class="val">@pub.StartOfTeaching</div></div> }
                        @if (F(pub.ModeOfStudy))               { <div class="field"><div class="lbl">Mode of Study</div><div class="val">@pub.ModeOfStudy</div></div> }
                        @if (F(pub.LanguageOfInstruction))     { <div class="field"><div class="lbl">Language of Instruction</div><div class="val">@pub.LanguageOfInstruction</div></div> }
                        @if (F(pub.OversightRightsEntity))     { <div class="field"><div class="lbl">Oversight Rights Entity</div><div class="val">@pub.OversightRightsEntity</div></div> }
                    </div>
                }
                @if (hasPresident)
                {
                    <div class="sub-hd">President / Leadership</div>
                    <div class="fg">
                        @if (F(pub.PresidentName))                     { <div class="field"><div class="lbl">President Name</div><div class="val">@pub.PresidentName</div></div> }
                        @if (F(pub.PresidentHighestAcademicDegree))    { <div class="field"><div class="lbl">Highest Academic Degree</div><div class="val">@pub.PresidentHighestAcademicDegree</div></div> }
                        @if (F(pub.PresidentMajorAreaOfStudy))         { <div class="field"><div class="lbl">Major Area of Study</div><div class="val">@pub.PresidentMajorAreaOfStudy</div></div> }
                    </div>
                }
                @if (hasContact)
                {
                    <div class="sub-hd">Contact Information</div>
                    <div class="fg">
                        @if (F(pub.MailingFullAddress))        { <div class="field"><div class="lbl">Mailing Address</div><div class="val">@pub.MailingFullAddress</div></div> }
                        @if (F(pub.DirectPhoneNumber))         { <div class="field"><div class="lbl">Direct Phone</div><div class="val mono">@pub.DirectPhoneNumber</div></div> }
                        @if (F(pub.FaxNumber))                 { <div class="field"><div class="lbl">Fax Number</div><div class="val mono">@pub.FaxNumber</div></div> }
                        @if (F(pub.EmailAddress))              { <div class="field"><div class="lbl">Email Address</div><div class="val"><a href="mailto:@pub.EmailAddress">@pub.EmailAddress</a></div></div> }
                        @if (F(pub.InstitutionalWebAddress))   { <div class="field"><div class="lbl">Website</div><div class="val"><a href="@pub.InstitutionalWebAddress" target="_blank" rel="noopener">@pub.InstitutionalWebAddress</a></div></div> }
                        @if (F(pub.LastDateWebsiteUpdated))    { <div class="field"><div class="lbl">Last Website Update</div><div class="val">@pub.LastDateWebsiteUpdated</div></div> }
                    </div>
                }
                @if (hasIdentity)
                {
                    <div class="sub-hd">Institutional Identity</div>
                    <div class="fg-wide">
                        @if (F(pub.InstitutionalVisionStatement))      { <div class="field"><div class="lbl">Vision Statement</div><div class="val">@pub.InstitutionalVisionStatement</div></div> }
                        @if (F(pub.InstitutionalMissionStatement))     { <div class="field"><div class="lbl">Mission Statement</div><div class="val">@pub.InstitutionalMissionStatement</div></div> }
                        @if (F(pub.InstitutionalTargettedObjectives))  { <div class="field"><div class="lbl">Targeted Objectives</div><div class="val">@pub.InstitutionalTargettedObjectives</div></div> }
                        @if (F(pub.InstitutionalValues))               { <div class="field"><div class="lbl">Institutional Values</div><div class="val">@pub.InstitutionalValues</div></div> }
                    </div>
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 2 — ACADEMIC INFORMATION                          -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-academic">
            <div class="sec-hd">
                <div class="sec-num">2</div>
                <div>
                    <h2>Academic Information</h2>
                    <p>Institution type, student population, academic staff and curriculum details</p>
                </div>
            </div>
            <div class="sec-bd">

                @{
                    bool hasInstType = F(acad.TypeOfAcademicInstitution)||F(acad.OfficialRecognitionInHomeCountry)||F(acad.OfficialAccreditationQualityInHomeCountry);
                    var checkedCats  = (acad.CollegeCategoriesCsv ?? "")
                        .Split(new char[]{',', ';'}, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                        .Distinct(StringComparer.OrdinalIgnoreCase)
                        .ToList();
                    var checkedDegrees = new List<string>();
                    if (acad.DegreeDiploma)       checkedDegrees.Add("Diploma");
                    if (acad.DegreeBSC)            checkedDegrees.Add("BSc");
                    if (acad.DegreeHigherDiploma)  checkedDegrees.Add("Higher Diploma");
                    if (acad.DegreeMaster)         checkedDegrees.Add("Master");
                    if (acad.DegreePhD)            checkedDegrees.Add("PhD");
                    var checkedSystems = new List<string>();
                    if (acad.SystemYearlyProgram)   checkedSystems.Add("Yearly Program");
                    if (acad.SystemSemesterProgram) checkedSystems.Add("Semester Program");
                    if (acad.SystemCreditHours)     checkedSystems.Add("Credit Hours");
                    if (acad.SystemECTS)            checkedSystems.Add("ECTS");
                    var ranks = new[]
                    {
                        new { Name = "Professor",            Key = "Professor",          Ft = acad.StaffProfessorFullTimeCount,           Pt = acad.StaffProfessorPartTimeCount,          FtFile = acad.ProfessorFullTimeExcelFileName,           PtFile = acad.ProfessorPartTimeExcelFileName },
                        new { Name = "Associate Professor",  Key = "AssociateProfessor", Ft = acad.StaffAssociateProfessorFullTimeCount,  Pt = acad.StaffAssociateProfessorPartTimeCount, FtFile = acad.AssociateProfessorFullTimeExcelFileName,  PtFile = acad.AssociateProfessorPartTimeExcelFileName },
                        new { Name = "Assistant Professor",  Key = "AssistantProfessor", Ft = acad.StaffAssistantProfessorFullTimeCount,  Pt = acad.StaffAssistantProfessorPartTimeCount, FtFile = acad.AssistantProfessorFullTimeExcelFileName,  PtFile = acad.AssistantProfessorPartTimeExcelFileName },
                        new { Name = "Lecturer (PhD)",       Key = "Teacher",            Ft = acad.StaffTeacherFullTimeCount,             Pt = acad.StaffTeacherPartTimeCount,            FtFile = acad.TeacherFullTimeExcelFileName,             PtFile = acad.TeacherPartTimeExcelFileName },
                        new { Name = "Lecturer (MSc)",       Key = "Researcher",         Ft = acad.StaffResearcherFullTimeCount,          Pt = acad.StaffResearcherPartTimeCount,         FtFile = acad.ResearcherFullTimeExcelFileName,          PtFile = acad.ResearcherPartTimeExcelFileName },
                        new { Name = "Asst. Lecturer (MSc)", Key = "AssistantTeacher",   Ft = acad.StaffAssistantTeacherFullTimeCount,    Pt = acad.StaffAssistantTeacherPartTimeCount,   FtFile = acad.AssistantTeacherFullTimeExcelFileName,    PtFile = acad.AssistantTeacherPartTimeExcelFileName },
                        new { Name = "Asst. Lecturer (BSc)", Key = "Others",             Ft = acad.StaffOthersFullTimeCount,              Pt = acad.StaffOthersPartTimeCount,             FtFile = acad.OthersFullTimeExcelFileName,              PtFile = acad.OthersPartTimeExcelFileName },
                        new { Name = "Practitioner (PSc)",   Key = "PractitionerPsc",    Ft = acad.StaffPractitionerPscFullTimeCount,     Pt = acad.StaffPractitionerPscPartTimeCount,    FtFile = acad.PractitionerPscFullTimeExcelFileName,     PtFile = acad.PractitionerPscPartTimeExcelFileName },
                        new { Name = "Practitioner (MSc)",   Key = "PractitionerMsc",    Ft = acad.StaffPractitionerMscFullTimeCount,     Pt = acad.StaffPractitionerMscPartTimeCount,    FtFile = acad.PractitionerMscFullTimeExcelFileName,     PtFile = acad.PractitionerMscPartTimeExcelFileName },
                    };
                    var filledRanks = ranks.Where(r => (r.Ft ?? 0) + (r.Pt ?? 0) > 0 || F(r.FtFile) || F(r.PtFile)).ToList();
                    bool hasStudentPop = FN(acad.TotalStudentPopulation)||FN(acad.LocalStudentPopulation)||FN(acad.ForeignStudentPopulation)||FN(acad.JordanianStudentPopulation);
                    bool hasStudentExtra = acad.DoctorateHoldersPercentage.HasValue||acad.AssociateProfessorPercentage.HasValue||F(acad.ForeignStudentsJointClassroomsWithLocal)||F(acad.LanguageForDomesticStudents)||F(acad.LanguageForForeignStudents);
                }
                @if (hasInstType)
                {
                    <div class="sub-hd">Institution Type &amp; Recognition</div>
                    <div class="fg">
                        @if (F(acad.TypeOfAcademicInstitution))                    { <div class="field"><div class="lbl">Type of Academic Institution</div><div class="val">@acad.TypeOfAcademicInstitution</div></div> }
                        @if (F(acad.OfficialRecognitionInHomeCountry))              { <div class="field"><div class="lbl">Official Recognition (Home Country)</div><div class="val">@acad.OfficialRecognitionInHomeCountry</div></div> }
                        @if (F(acad.OfficialAccreditationQualityInHomeCountry))    { <div class="field"><div class="lbl">Official Accreditation &amp; QA (Home Country)</div><div class="val">@acad.OfficialAccreditationQualityInHomeCountry</div></div> }
                    </div>
                }
                @if (checkedDegrees.Any())
                {
                    <div class="sub-hd">Degrees Offered</div>
                    <div class="check-row" style="margin-bottom:4px">
                        @foreach (var deg in checkedDegrees)
                        {
                            <span class="check-tag check-yes"><i class="bi bi-check-circle-fill"></i> @deg</span>
                        }
                    </div>
                }
                @if (checkedCats.Any())
                {
                    <div class="sub-hd">College Categories</div>
                    <div class="check-row" style="margin-bottom:4px">
                        @foreach (var cat in checkedCats)
                        {
                            <span class="check-tag check-yes"><i class="bi bi-check-circle-fill"></i> @cat Colleges</span>
                        }
                    </div>
                }
                @if (hasStudentPop)
                {
                    <div class="sub-hd">Student Population</div>
                    <div class="stat-grid">
                        @if (FN(acad.TotalStudentPopulation))      { <div class="stat-card"><div class="sv">@N(acad.TotalStudentPopulation)</div><div class="sk">Total Students</div></div> }
                        @if (FN(acad.LocalStudentPopulation))       { <div class="stat-card light"><div class="sv">@N(acad.LocalStudentPopulation)</div><div class="sk">Local Students</div></div> }
                        @if (FN(acad.ForeignStudentPopulation))     { <div class="stat-card light"><div class="sv">@N(acad.ForeignStudentPopulation)</div><div class="sk">Foreign Students</div></div> }
                        @if (FN(acad.JordanianStudentPopulation))   { <div class="stat-card light"><div class="sv">@N(acad.JordanianStudentPopulation)</div><div class="sk">Jordanian Students</div></div> }
                    </div>
                }
                @if (hasStudentExtra)
                {
                    <div class="fg" style="margin-top:10px">
                        @if (acad.DoctorateHoldersPercentage.HasValue)      { <div class="field"><div class="lbl">Doctorate Holders %</div><div class="val">@acad.DoctorateHoldersPercentage.Value%</div></div> }
                        @if (acad.AssociateProfessorPercentage.HasValue)    { <div class="field"><div class="lbl">Associate Professor %</div><div class="val">@acad.AssociateProfessorPercentage.Value%</div></div> }
                        @if (F(acad.ForeignStudentsJointClassroomsWithLocal)){ <div class="field"><div class="lbl">Foreign Students in Joint Classrooms</div><div class="val">@acad.ForeignStudentsJointClassroomsWithLocal</div></div> }
                        @if (F(acad.LanguageForDomesticStudents))           { <div class="field"><div class="lbl">Language (Domestic Students)</div><div class="val">@acad.LanguageForDomesticStudents</div></div> }
                        @if (F(acad.LanguageForForeignStudents))            { <div class="field"><div class="lbl">Language (Foreign Students)</div><div class="val">@acad.LanguageForForeignStudents</div></div> }
                    </div>
                }
                @if (filledRanks.Any())
                {
                    <div class="sub-hd">Academic Staff Head Count by Rank</div>
                    <div class="tbl-wrap">
                        <table class="tbl rank-tbl">
                            <thead>
                                <tr><th>Academic Rank</th><th>Full-Time</th><th>FT Excel File</th><th>Part-Time</th><th>PT Excel File</th><th>Total</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var rank in filledRanks)
                                {
                                    int total = (rank.Ft ?? 0) + (rank.Pt ?? 0);
                                    <tr>
                                        <td>@rank.Name</td>
                                        <td>@(FN(rank.Ft) ? rank.Ft!.Value.ToString() : "—")</td>
                                        <td>
                                            @if (F(rank.FtFile))
                                            {
                                                <div style="display:flex;gap:5px;flex-wrap:wrap">
                                                    <a class="btn-view" href="@Url.Action("AcademicRankFilePreview", "Home", new { id = Model.Id, rankKey = rank.Key, employmentType = "fulltime" })" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                                    <a class="btn-view" href="@Url.Action("DownloadAcademicRankStaffFile", "Home", new { id = Model.Id, rankKey = rank.Key, employmentType = "fulltime" })" target="_blank" rel="noopener"><i class="bi bi-download"></i></a>
                                                </div>
                                            }
                                            else { <span style="color:var(--muted);font-size:12px">—</span> }
                                        </td>
                                        <td>@(FN(rank.Pt) ? rank.Pt!.Value.ToString() : "—")</td>
                                        <td>
                                            @if (F(rank.PtFile))
                                            {
                                                <div style="display:flex;gap:5px;flex-wrap:wrap">
                                                    <a class="btn-view" href="@Url.Action("AcademicRankFilePreview", "Home", new { id = Model.Id, rankKey = rank.Key, employmentType = "parttime" })" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                                    <a class="btn-view" href="@Url.Action("DownloadAcademicRankStaffFile", "Home", new { id = Model.Id, rankKey = rank.Key, employmentType = "parttime" })" target="_blank" rel="noopener"><i class="bi bi-download"></i></a>
                                                </div>
                                            }
                                            else { <span style="color:var(--muted);font-size:12px">—</span> }
                                        </td>
                                        <td class="rank-total">@total</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (checkedSystems.Any())
                {
                    <div class="sub-hd">Educational Systems</div>
                    <div class="check-row">
                        @foreach (var sys in checkedSystems)
                        {
                            <span class="check-tag check-yes"><i class="bi bi-check-circle-fill"></i> @sys</span>
                        }
                    </div>
                }
                @if (accBodies.Any())
                {
                    <div class="sub-hd">Accreditation Bodies</div>
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr><th>#</th><th>Accreditation Body</th><th>Type</th><th style="width:160px">Document</th></tr>
                            </thead>
                            <tbody>
                                @{ int abIdx = 1; }
                                @foreach (var ab in accBodies)
                                {
                                    <tr>
                                        <td style="color:var(--muted);width:36px">@abIdx</td>
                                        <td style="font-weight:600">@V(ab.AccreditationBodyName)</td>
                                        <td>@V(ab.AccreditationType)</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(ab.PdfFileUrl))
                                            {
                                                <div style="display:flex;gap:6px">
                                                    <a class="btn-view" href="@ab.PdfFileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                                    <a class="btn-view" href="@ab.PdfFileUrl" download="@ab.PdfOriginalFileName"><i class="bi bi-download"></i></a>
                                                </div>
                                            }
                                            else { <span style="color:var(--muted);font-size:12px">No document</span> }
                                        </td>
                                    </tr>
                                    abIdx++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 3 — ADMISSION REQUIREMENTS & STUDY DURATION       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-admission">
            <div class="sec-hd">
                <div class="sec-num">3</div>
                <div>
                    <h2>Admission Requirements &amp; Study Duration</h2>
                    <p>Entry requirements per degree level and enrollment/graduation durations</p>
                </div>
            </div>
            <div class="sec-bd">
                @{
                    var adsr = Model.AdmissionStudyDurationReview;
                    var durRows = new[]
                    {
                        new { Degree = "Diploma",        Duration = dur.DiplomaObtain,        Level = "Diploma",       PdfFile = adsr?.DiplomaSamplePdfFileName },
                        new { Degree = "Bachelor (BSc)", Duration = dur.BachelorObtain,       Level = "BSc",           PdfFile = adsr?.BScSamplePdfFileName },
                        new { Degree = "Higher Diploma", Duration = dur.HigherDiplomaObtain,  Level = "HigherDiploma", PdfFile = adsr?.HigherDiplomaSamplePdfFileName },
                        new { Degree = "Master",         Duration = dur.MasterObtain,         Level = "Master",        PdfFile = adsr?.MasterSamplePdfFileName },
                        new { Degree = "PhD",            Duration = dur.PhDObtain,            Level = "Phd",           PdfFile = adsr?.PhdSamplePdfFileName },
                    }.Where(r => F(r.Duration) || F(r.PdfFile)).ToList();
                }
                @if (durRows.Any())
                {
                    <div class="sub-hd">Study Duration by Degree</div>
                    <div class="tbl-wrap">
                        <table class="tbl dur-tbl">
                            <thead>
                                <tr><th>Degree</th><th>Duration</th><th>Sample PDF</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var row in durRows)
                                {
                                    <tr>
                                        <td>@row.Degree</td>
                                        <td>@(F(row.Duration) ? row.Duration : "—")</td>
                                        <td>
                                            @if (F(row.PdfFile))
                                            {
                                                <a class="btn-view" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = Model.Id, level = row.Level, inline = true })" target="_blank">View</a>
                                                <a class="btn-view" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = Model.Id, level = row.Level })" target="_blank">↓</a>
                                            }
                                            else
                                            {
                                                @:—
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @{
                    var admGroups = new[]
                    {
                        ("Diploma",        adm.Diploma),
                        ("BSc",            adm.BSC),
                        ("Higher Diploma", adm.HigherDiploma),
                        ("Master",         adm.Master),
                        ("PhD",            adm.PhD),
                    };
                }
                @foreach (var (degName, reqs) in admGroups)
                {
                    if (reqs != null && reqs.Any())
                    {
                        <div class="sub-hd">@degName — Admission Requirements</div>
                        <ul class="req-list">
                            @foreach (var r in reqs)
                            {
                                <li>@r.Requirement</li>
                            }
                        </ul>
                    }
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 4 — COLLEGES / FACULTIES                          -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-faculties">
            <div class="sec-hd">
                <div class="sec-num">4</div>
                <div>
                    <h2>Colleges / Faculties</h2>
                    <p>All registered college units with student counts and categories</p>
                </div>
            </div>
            <div class="sec-bd">
                @if (!faculties.Any())
                {
                    <div class="empty-state"><i class="bi bi-buildings"></i>No colleges entered.</div>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr><th>#</th><th>College / Faculty Name</th><th>Students</th><th>Category</th></tr>
                            </thead>
                            <tbody>
                                @{ int fi = 1; }
                                @foreach (var f in faculties)
                                {
                                    <tr>
                                        <td style="color:var(--muted);width:36px">@fi</td>
                                        <td style="font-weight:600">@V(f.FacultyName)</td>
                                        <td>@(f.StudentsCount.HasValue && f.StudentsCount.Value > 0 ? f.StudentsCount.Value.ToString("N0") : "—")</td>
                                        <td>@V(f.CollegeType)</td>
                                    </tr>
                                    fi++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 5 — PROGRAMS                                      -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-programs">
            <div class="sec-hd">
                <div class="sec-num">5</div>
                <div>
                    <h2>Programs</h2>
                    <p>Academic programs with degree, duration, educational system and program hours</p>
                </div>
            </div>
            <div class="sec-bd">
                @if (!programs.Any())
                {
                    <div class="empty-state"><i class="bi bi-journal-bookmark"></i>No programs entered.</div>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr><th>#</th><th>Program</th><th>Faculty</th><th>Degree</th><th>Years</th><th>System</th><th>Accreditation Date</th><th>Last Graduation</th></tr>
                            </thead>
                            <tbody>
                                @{ int pi = 1; }
                                @foreach (var p in programs)
                                {
                                    <tr>
                                        <td style="color:var(--muted);width:36px">@pi</td>
                                        <td style="font-weight:600">@V(p.Program)</td>
                                        <td>@V(p.FacultyName)</td>
                                        <td>@V(p.DegreeAwarded)</td>
                                        <td>@(p.NumberOfYears > 0 ? p.NumberOfYears.ToString() : "—")</td>
                                        <td>@V(p.EducationalSystem)</td>
                                        <td>@(p.AccreditationDate.HasValue ? p.AccreditationDate.Value.ToString("dd MMM yyyy") : "—")</td>
                                        <td>@(p.GraduationDateOfLastRegiment.HasValue ? p.GraduationDateOfLastRegiment.Value.ToString("dd MMM yyyy") : "—")</td>
                                    </tr>
                                    pi++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (progHrs.Any())
                {
                    <div class="sub-hd" style="margin-top:20px">Program Credit Hours</div>
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr><th>Program</th><th>Theoretical Hours</th><th>Practical Hours</th><th>Total</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var h in progHrs)
                                {
                                    int tot = (h.TheoreticalHours > 0 ? h.TheoreticalHours : 0) + (h.PracticalHours > 0 ? h.PracticalHours : 0);
                                    <tr>
                                        <td style="font-weight:600">@V(h.ProgramName)</td>
                                        <td>@(h.TheoreticalHours > 0 ? h.TheoreticalHours.ToString() : "—")</td>
                                        <td>@(h.PracticalHours > 0 ? h.PracticalHours.ToString() : "—")</td>
                                        <td class="rank-total">@(tot > 0 ? tot.ToString() : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        @{
            var medFtAll = new[]
            {
                ("Professor",               medDen.Med_FullTimeProfessor,               medDen.Den_FullTimeProfessor),
                ("Associate Professor",     medDen.Med_FullTimeAssociateProfessor,       medDen.Den_FullTimeAssociateProfessor),
                ("Assistant Professor",     medDen.Med_FullTimeAssistantProfessor,       medDen.Den_FullTimeAssistantProfessor),
                ("Lecturer (PhD)",          medDen.Med_FullTimeLecturerPhd,              medDen.Den_FullTimeLecturerPhd),
                ("Asst. Lecturer (PhD)",    medDen.Med_FullTimeAssistantLecturerPhd,     medDen.Den_FullTimeAssistantLecturerPhd),
                ("Lecturer (MSc)",          medDen.Med_FullTimeLecturerMsc,              medDen.Den_FullTimeLecturerMsc),
                ("Asst. Lecturer (MSc)",    medDen.Med_FullTimeAssistantLecturerMsc,     medDen.Den_FullTimeAssistantLecturerMsc),
                ("Practitioner (PSc)",      medDen.Med_FullTimePractitionerPsc,          medDen.Den_FullTimePractitionerPsc),
                ("Practitioner (MSc)",      medDen.Med_FullTimePractitionerMsc,          medDen.Den_FullTimePractitionerMsc),
            };
            var medPtAll = new[]
            {
                ("Professor",               medDen.Med_PartTimeClinicalProfessor,               medDen.Den_PartTimeClinicalProfessor),
                ("Associate Professor",     medDen.Med_PartTimeClinicalAssociateProfessor,       medDen.Den_PartTimeClinicalAssociateProfessor),
                ("Assistant Professor",     medDen.Med_PartTimeClinicalAssistantProfessor,       medDen.Den_PartTimeClinicalAssistantProfessor),
                ("Lecturer (PhD)",          medDen.Med_PartTimeClinicalLecturerPhd,              medDen.Den_PartTimeClinicalLecturerPhd),
                ("Asst. Lecturer (PhD)",    medDen.Med_PartTimeClinicalAssistantLecturerPhd,     medDen.Den_PartTimeClinicalAssistantLecturerPhd),
                ("Lecturer (MSc)",          medDen.Med_PartTimeClinicalLecturerMsc,              medDen.Den_PartTimeClinicalLecturerMsc),
                ("Asst. Lecturer (MSc)",    medDen.Med_PartTimeClinicalAssistantLecturerMsc,     medDen.Den_PartTimeClinicalAssistantLecturerMsc),
                ("Practitioner (PSc)",      medDen.Med_PartTimeClinicalPractitionerPsc,          medDen.Den_PartTimeClinicalPractitionerPsc),
                ("Practitioner (MSc)",      medDen.Med_PartTimeClinicalPractitionerMsc,          medDen.Den_PartTimeClinicalPractitionerMsc),
            };
            var medFtFilled = medFtAll.Where(r => FN(r.Item2) || FN(r.Item3)).ToList();
            var medPtFilled = medPtAll.Where(r => FN(r.Item2) || FN(r.Item3)).ToList();
            bool hasMedRatio = medDen.Med_StudentFacultyRatio.HasValue || medDen.Den_StudentFacultyRatio.HasValue;
            bool hasMedSection = FN(medDen.Med_TotalStudents) || FN(medDen.Den_TotalStudents) || medFtFilled.Any() || medPtFilled.Any() || hasMedRatio;
        }
        @if (hasMedSection)
        {
        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 6 — MEDICINE & DENTISTRY                          -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-medicine">
            <div class="sec-hd">
                <div class="sec-num">6</div>
                <div>
                    <h2>Medicine &amp; Dentistry</h2>
                    <p>Academic staff breakdown for medicine and dentistry colleges</p>
                </div>
            </div>
            <div class="sec-bd">
                @if (FN(medDen.Med_TotalStudents) || FN(medDen.Den_TotalStudents))
                {
                    <div class="fg-2" style="margin-bottom:16px">
                        @if (FN(medDen.Med_TotalStudents)) { <div class="stat-card light"><div class="sv">@N(medDen.Med_TotalStudents)</div><div class="sk">Medicine Students</div></div> }
                        @if (FN(medDen.Den_TotalStudents)) { <div class="stat-card light"><div class="sv">@N(medDen.Den_TotalStudents)</div><div class="sk">Dentistry Students</div></div> }
                    </div>
                }
                @if (medFtFilled.Any())
                {
                    <div class="sub-hd">Full-Time Academic Staff</div>
                    <div class="tbl-wrap">
                        <table class="tbl rank-tbl">
                            <thead><tr><th>Rank</th><th>Medicine</th><th>Dentistry</th></tr></thead>
                            <tbody>
                                @foreach (var (rn, mv, dv) in medFtFilled)
                                {
                                    <tr>
                                        <td>@rn</td>
                                        <td>@(FN(mv) ? mv!.Value.ToString() : "—")</td>
                                        <td>@(FN(dv) ? dv!.Value.ToString() : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (medPtFilled.Any())
                {
                    <div class="sub-hd">Part-Time Clinical Staff</div>
                    <div class="tbl-wrap">
                        <table class="tbl rank-tbl">
                            <thead><tr><th>Rank</th><th>Medicine</th><th>Dentistry</th></tr></thead>
                            <tbody>
                                @foreach (var (rn, mv, dv) in medPtFilled)
                                {
                                    <tr>
                                        <td>@rn</td>
                                        <td>@(FN(mv) ? mv!.Value.ToString() : "—")</td>
                                        <td>@(FN(dv) ? dv!.Value.ToString() : "—")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        }

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 7 — HOSPITALS                                     -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-hospitals">
            <div class="sec-hd">
                <div class="sec-num">7</div>
                <div>
                    <h2>Hospitals</h2>
                    <p>Affiliated hospital facilities, recognition and accreditation</p>
                </div>
            </div>
            <div class="sec-bd">

                @if (!hosp.Rows.Any() && !hosp.Facilities.Any())
                {
                    <div class="empty-state"><i class="bi bi-hospital"></i>No hospital records entered.</div>
                }
                else
                {
                    var hospRows = hosp.Rows.Any() ? hosp.Rows : hosp.Facilities.Select(f => new HospitalRowDto
                    {
                        Id = f.Id, Specialization = f.Specialization, Name = f.Name,
                        BedCapacity = f.BedCapacity, DentalChairCapacity = f.DentalChairCapacity
                    }).ToList();

                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr><th>#</th><th>Specialization</th><th>Facility Name</th><th>Beds</th><th>Dental Chairs</th><th>Agreement Files</th></tr>
                            </thead>
                            <tbody>
                                @{ int hi = 1; }
                                @foreach (var h in hospRows)
                                {
                                    var rowId = (h.Id ?? string.Empty).Trim();
                                    var rowDocs = facilityAgreementDocs.TryGetValue(rowId, out var docs) ? docs : new List<HospitalFileDto>();
                                    <tr>
                                        <td style="color:var(--muted);width:36px">@hi</td>
                                        <td>@V(h.Specialization)</td>
                                        <td style="font-weight:600">@V(h.Name)</td>
                                        <td>@N(h.BedCapacity)</td>
                                        <td>@N(h.DentalChairCapacity)</td>
                                        <td>
                                            @if (rowDocs.Any())
                                            {
                                                <div style="display:flex;flex-direction:column;gap:6px">
                                                    @foreach (var rd in rowDocs)
                                                    {
                                                        <div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap">
                                                            <span style="font-size:12px;color:var(--muted);flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="@rd.OriginalFileName">@rd.OriginalFileName</span>
                                                            <a class="btn-view" href="@rd.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                                            <a class="btn-view" href="@rd.FileUrl" download="@rd.OriginalFileName"><i class="bi bi-download"></i></a>
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                @:—
                                            }
                                        </td>
                                    </tr>
                                    hi++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 8 — INFRASTRUCTURE                                -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-infra">
            <div class="sec-hd">
                <div class="sec-num">8</div>
                <div>
                    <h2>University Infrastructure</h2>
                    <p>Campus area, university facilities counts and laboratory details</p>
                </div>
            </div>
            <div class="sec-bd">
                @{bool hasInfraFields = F(infra.AreaKm2)||F(infra.CampusesCount)||F(infra.StadiumsCount)||F(infra.ClassroomsAndLectureHallsCount)||F(infra.LibrariesCount);}
                @if (hasInfraFields)
                {
                    <div class="fg-2">
                        @if (F(infra.AreaKm2))                          { <div class="field"><div class="lbl">Area (km²)</div><div class="val">@infra.AreaKm2</div></div> }
                        @if (F(infra.CampusesCount))                    { <div class="field"><div class="lbl">Campuses Count</div><div class="val">@infra.CampusesCount</div></div> }
                        @if (F(infra.StadiumsCount))                    { <div class="field"><div class="lbl">Stadiums Count</div><div class="val">@infra.StadiumsCount</div></div> }
                        @if (F(infra.ClassroomsAndLectureHallsCount))   { <div class="field"><div class="lbl">Classrooms &amp; Lecture Halls</div><div class="val">@infra.ClassroomsAndLectureHallsCount</div></div> }
                        @if (F(infra.LibrariesCount))                   { <div class="field"><div class="lbl">Libraries Count</div><div class="val">@infra.LibrariesCount</div></div> }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(infra.LaboratoriesDetails))
                {
                    <div class="sub-hd">Laboratories Details</div>
                    <div class="field fg-wide"><div class="val">@infra.LaboratoriesDetails</div></div>
                }
                @if (!string.IsNullOrWhiteSpace(infra.StudentServicingBuildingsDetails))
                {
                    <div class="sub-hd">Student Servicing Buildings</div>
                    <div class="field fg-wide"><div class="val">@infra.StudentServicingBuildingsDetails</div></div>
                }
            </div>
        </div>

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 9 — LABORATORIES                                  -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-labs">
            <div class="sec-hd">
                <div class="sec-num">9</div>
                <div>
                    <h2>Laboratories</h2>
                    <p>Lab and facility counts per faculty with uploaded evidence</p>
                </div>
            </div>
            <div class="sec-bd">
                @if (FN(labs.TotalLaboratoriesCount)||FN(labs.TotalFacilitiesCount)||FN(labs.TeachingHallsCount)||FN(labs.StadiumsCount))
                {
                    <div class="fg-4" style="margin-bottom:16px">
                        @if (FN(labs.TotalLaboratoriesCount)) { <div class="stat-card light"><div class="sv">@N(labs.TotalLaboratoriesCount)</div><div class="sk">Laboratories</div></div> }
                        @if (FN(labs.TotalFacilitiesCount))   { <div class="stat-card light"><div class="sv">@N(labs.TotalFacilitiesCount)</div><div class="sk">Total Facilities</div></div> }
                        @if (FN(labs.TeachingHallsCount))     { <div class="stat-card light"><div class="sv">@N(labs.TeachingHallsCount)</div><div class="sk">Teaching Halls</div></div> }
                        @if (FN(labs.StadiumsCount))          { <div class="stat-card light"><div class="sv">@N(labs.StadiumsCount)</div><div class="sk">Stadiums</div></div> }
                    </div>
                }

                @if (labs.Rows.Any())
                {
                    <div class="tbl-wrap">
                        <table class="tbl rank-tbl">
                            <thead>
                                <tr><th>Faculty</th><th>Computers</th><th>Laboratories</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var lr in labs.Rows)
                                {
                                    <tr>
                                        <td style="font-weight:600">@V(lr.FacultyName)</td>
                                        <td>@N(lr.Computers)</td>
                                        <td>@N(lr.Laboratories)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!labFiles.Any())
                {
                    <div class="empty-state"><i class="bi bi-flask"></i>No laboratory records entered.</div>
                }
                @if (labFiles.Any())
                {
                    var labFileGroups = labFiles
                        .GroupBy(f => string.IsNullOrWhiteSpace(f.Subject) ? "General" : f.Subject.Trim())
                        .OrderBy(g => g.Key)
                        .ToList();
                    <div class="sub-hd" style="margin-top:16px">Uploaded Laboratory Files</div>
                    @foreach (var grp in labFileGroups)
                    {
                        @if (labFileGroups.Count > 1)
                        {
                            <div style="font-size:11.5px;font-weight:700;color:var(--muted);margin:10px 0 6px">@grp.Key</div>
                        }
                        <div class="file-grid" style="margin-bottom:8px">
                            @foreach (var lf in grp)
                            {
                                <div class="file-row">
                                    <div class="file-info">
                                        <div class="fn">@V(lf.OriginalFileName)</div>
                                        <div class="fs">@lf.UploadedAt.ToString("dd MMM yyyy")</div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(lf.FileUrl))
                                    {
                                        <div style="display:flex;gap:6px">
                                            <a class="btn-view" href="@lf.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                            <a class="btn-view" href="@lf.FileUrl" download="@lf.OriginalFileName"><i class="bi bi-download"></i></a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 10 — LIBRARY                                      -->
        <!-- ══════════════════════════════════════════════════════════ -->
        @{
            var lib = Model.Library ?? new DTOs.LibraryDto();
            bool hasLibData = FN(lib.Area) || FN(lib.TotalStudentCapacity) || FN(lib.NumberOfBooks)
                           || FN(lib.NumberOfPaperJournals) || FN(lib.NumberOfElectronicBooks) || FN(lib.NumberOfElectronicJournals);
        }
        @if (hasLibData)
        {
        <div class="section-card" id="sec-library">
            <div class="sec-hd">
                <div class="sec-num">10</div>
                <div>
                    <h2>Library</h2>
                    <p>Library facilities and resources submitted by the university</p>
                </div>
            </div>
            <div class="sec-bd">
                <div class="fg">
                    @if (FN(lib.Area))
                    {
                        <div class="field"><div class="lbl">Area (m²)</div><div class="val">@lib.Area!.Value.ToString("N0")</div></div>
                    }
                    @if (FN(lib.TotalStudentCapacity))
                    {
                        <div class="field"><div class="lbl">Student Seating Capacity</div><div class="val">@lib.TotalStudentCapacity!.Value.ToString("N0")</div></div>
                    }
                    @if (FN(lib.NumberOfBooks))
                    {
                        <div class="field"><div class="lbl">Total Books</div><div class="val">@lib.NumberOfBooks!.Value.ToString("N0")</div></div>
                    }
                    @if (FN(lib.NumberOfPaperJournals))
                    {
                        <div class="field"><div class="lbl">Paper Journals</div><div class="val">@lib.NumberOfPaperJournals!.Value.ToString("N0")</div></div>
                    }
                    @if (FN(lib.NumberOfElectronicBooks))
                    {
                        <div class="field"><div class="lbl">Electronic Books</div><div class="val">@lib.NumberOfElectronicBooks!.Value.ToString("N0")</div></div>
                    }
                    @if (FN(lib.NumberOfElectronicJournals))
                    {
                        <div class="field"><div class="lbl">Electronic Journals</div><div class="val">@lib.NumberOfElectronicJournals!.Value.ToString("N0")</div></div>
                    }
                </div>
            </div>
        </div>
        }

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION — PHOTOS / MEDIA                                  -->
        <!-- ══════════════════════════════════════════════════════════ -->
        @if (pictures.Any())
        {
            var photoGroups = pictures
                .GroupBy(p => string.IsNullOrWhiteSpace(p.Subject) ? "General" : p.Subject.Trim())
                .OrderBy(g => g.Key == "General" ? 1 : 0)
                .ThenBy(g => g.Key)
                .ToList();
        <div class="section-card" id="sec-photos">
            <div class="sec-hd">
                <div class="sec-num">11</div>
                <div>
                    <h2>Photos &amp; Media</h2>
                    <p>Uploaded campus and facility photographs (@pictures.Count total)</p>
                </div>
            </div>
            <div class="sec-bd">
                @foreach (var grp in photoGroups)
                {
                    <div class="sub-hd">@grp.Key <span style="font-weight:500;font-size:10.5px;opacity:.7">(@grp.Count())</span></div>
                    <div class="file-grid" style="margin-bottom:8px">
                        @foreach (var pic in grp)
                        {
                            <div class="file-row">
                                <div class="file-info">
                                    <div class="fn">@V(pic.FileName)</div>
                                    <div class="fs">@pic.UploadedAt.ToString("dd MMM yyyy")</div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(pic.FileUrl))
                                {
                                    <div style="display:flex;gap:6px">
                                        <a class="btn-view" href="@pic.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                        <a class="btn-view" href="@pic.FileUrl" download="@pic.FileName"><i class="bi bi-download"></i></a>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        }

        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 12 — UNIVERSITY RECOGNITION & ACCREDITATION       -->
        <!-- ══════════════════════════════════════════════════════════ -->
        @{
            bool hasUraDocs = localRecognitionDocs.Any() || localAccreditationDocs.Any() || regionalAccreditationDocs.Any() || internationalAccreditationDocs.Any() || otherAccreditationDocs.Any();
        }
        @if (hasUraDocs)
        {
        <div class="section-card" id="sec-documents">
            <div class="sec-hd">
                <div class="sec-num">12</div>
                <div>
                    <h2>University Recognition and Accreditation</h2>
                    <p>Local recognition and accreditation documents submitted by the university</p>
                </div>
            </div>
            <div class="sec-bd">
                @{
                    var allAccredDocs = localAccreditationDocs
                        .Concat(regionalAccreditationDocs)
                        .Concat(internationalAccreditationDocs)
                        .Concat(otherAccreditationDocs)
                        .ToList();
                }

                @if (localRecognitionDocs.Any())
                {
                    <div class="sub-hd">Local Recognition Files</div>
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead><tr><th>File Name</th><th style="width:160px;">Actions</th></tr></thead>
                            <tbody>
                                @foreach (var doc in localRecognitionDocs)
                                {
                                    <tr>
                                        <td>@V(doc.OriginalFileName)</td>
                                        <td><div style="display:flex;gap:6px;flex-wrap:wrap;"><a class="btn-view" href="@doc.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a><a class="btn-view" href="@doc.FileUrl" download="@doc.OriginalFileName"><i class="bi bi-download"></i> Download</a></div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (allAccredDocs.Any())
                {
                    <div class="sub-hd" style="margin-top:16px">Accreditation Files</div>
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead><tr><th>File Name</th><th>Type</th><th style="width:160px;">Actions</th></tr></thead>
                            <tbody>
                                @foreach (var doc in allAccredDocs)
                                {
                                    <tr>
                                        <td>@V(doc.OriginalFileName)</td>
                                        <td>@HospitalDocLabel(doc.DocumentType ?? "")</td>
                                        <td><div style="display:flex;gap:6px;flex-wrap:wrap;"><a class="btn-view" href="@doc.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a><a class="btn-view" href="@doc.FileUrl" download="@doc.OriginalFileName"><i class="bi bi-download"></i> Download</a></div></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
        }


        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION 13 — ADDITIONAL NOTES AND SUPPORTING FILES        -->
        <!-- ══════════════════════════════════════════════════════════ -->
        <div class="section-card" id="sec-additional-notes">
            <div class="sec-hd">
                <div class="sec-num">13</div>
                <div>
                    <h2>Additional Notes and Supporting Files</h2>
                    <p>Optional note and files submitted by the university with the application</p>
                </div>
            </div>
            <div class="sec-bd">
                <div class="sub-hd">Additional Note</div>
                @if (string.IsNullOrWhiteSpace(Model.AdditionalNote))
                {
                    <p class="field-empty">No additional note provided.</p>
                }
                else
                {
                    <div class="ro-note-block">@Model.AdditionalNote</div>
                }

                <div class="sub-hd" style="margin-top:18px;">Supporting Files</div>
                @{
                    var addFiles = Model.AdditionalFiles ?? new List<AdditionalFileDto>();
                }
                @if (!addFiles.Any())
                {
                    <p class="field-empty">No additional supporting files uploaded.</p>
                }
                else
                {
                    <div class="tbl-wrap">
                        <table class="tbl">
                            <thead>
                                <tr>
                                    <th>File Name</th>
                                    <th>Type</th>
                                    <th style="width:160px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var af in addFiles)
                                {
                                    <tr>
                                        <td>@V(af.FileName)</td>
                                        <td><span style="font-size:11px;font-weight:700;color:#7f1627;background:#fce8eb;border-radius:4px;padding:2px 6px;">@V(af.FileType)</span></td>
                                        <td>
                                            <div style="display:flex;gap:6px;flex-wrap:wrap;">
                                                <a class="btn-view" href="@af.FileUrl" target="_blank" rel="noopener"><i class="bi bi-eye"></i> View</a>
                                                <a class="btn-view" href="@af.FileUrl" download="@af.FileName"><i class="bi bi-download"></i> Download</a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>


        <!-- ══════════════════════════════════════════════════════════ -->
        <!-- SECTION R — DOCTOR'S SUBMITTED RECOMMENDATION             -->
        <!-- ══════════════════════════════════════════════════════════ -->
        @if (showRec)
        {
        <div class="section-card" id="sec-recommendation">
            <div class="sec-hd sec-hd-rec">
                <div class="sec-num" style="background:rgba(255,255,255,.2)">R</div>
                <div>
                    <h2>Doctor's Submitted Recommendation</h2>
                    <p>Assessment and final recommendation submitted by the assigned reviewer</p>
                </div>
            </div>
            <div class="sec-bd">

                <div class="sub-hd">Reviewer</div>
                <div class="fg-2">
                    <div class="field">
                        <div class="lbl">Reviewer Name</div>
                        <div class="val">@reviewerName</div>
                    </div>
                    <div class="field">
                        <div class="lbl">Submitted to Admin</div>
                        <div class="val">
                            @if (Model.SubmittedToAdminAt.HasValue)
                            {
                                @Model.SubmittedToAdminAt.Value.ToString("dd MMM yyyy, HH:mm")
                            }
                            else
                            {
                                @:—
                            }
                        </div>
                    </div>
                </div>

                @{
                    var recRankings = Model.GlobalRankings ?? new DTOs.GlobalRankingsDto();
                    bool hasArwu   = recRankings.ArwuIsNa  || !string.IsNullOrWhiteSpace(recRankings.ArwuValue);
                    bool hasQs     = recRankings.QsIsNa    || !string.IsNullOrWhiteSpace(recRankings.QsValue);
                    bool hasThe    = recRankings.TheIsNa   || !string.IsNullOrWhiteSpace(recRankings.TheValue);
                    bool hasScopus = recRankings.ScopusIsNa|| !string.IsNullOrWhiteSpace(recRankings.ScopusValue);
                    bool hasRankings = hasArwu || hasQs || hasThe || hasScopus;
                    string RankVal(string v, bool na) => na ? "Not Applicable" : string.IsNullOrWhiteSpace(v) ? "—" : v;
                }
                @if (hasRankings)
                {
                    <div class="sub-hd">Global University Rankings</div>
                    <div class="fg-4" style="margin-bottom:4px">
                        @if (hasArwu)
                        {
                            <div class="field">
                                <div class="lbl">ARWU (Shanghai)</div>
                                <div class="val">@RankVal(recRankings.ArwuValue, recRankings.ArwuIsNa)</div>
                            </div>
                        }
                        @if (hasQs)
                        {
                            <div class="field">
                                <div class="lbl">QS World Rankings</div>
                                <div class="val">@RankVal(recRankings.QsValue, recRankings.QsIsNa)</div>
                            </div>
                        }
                        @if (hasThe)
                        {
                            <div class="field">
                                <div class="lbl">THE Rankings</div>
                                <div class="val">@RankVal(recRankings.TheValue, recRankings.TheIsNa)</div>
                            </div>
                        }
                        @if (hasScopus)
                        {
                            <div class="field">
                                <div class="lbl">Scopus h-Index</div>
                                <div class="val">@RankVal(recRankings.ScopusValue, recRankings.ScopusIsNa)</div>
                            </div>
                        }
                    </div>
                }

                @{
                    var A2 = Model.AcademicInfo ?? new DTOs.AcademicInfoDto();
                    var md2 = Model.MedicineDentistry ?? new DTOs.MedicineDentistryDto();

                    var profFT   = A2.StaffProfessorFullTimeCount ?? 0;
                    var assocFT  = A2.StaffAssociateProfessorFullTimeCount ?? 0;
                    var assistFT = A2.StaffAssistantProfessorFullTimeCount ?? 0;
                    var teachFT  = A2.StaffTeacherFullTimeCount ?? 0;
                    var resFT    = A2.StaffResearcherFullTimeCount ?? 0;
                    var assisTFT = A2.StaffAssistantTeacherFullTimeCount ?? 0;
                    var totalFacFT = profFT + assocFT + assistFT + teachFT + resFT + assisTFT + (A2.StaffOthersFullTimeCount ?? 0);
                    var phdHolders = profFT + assocFT + assistFT + teachFT;
                    var docPct2 = totalFacFT > 0 ? (int)Math.Floor(((decimal)phdHolders * 100m) / totalFacFT) : 0;
                    string docComp2 = totalFacFT == 0 ? "Not Assessed" : docPct2 >= 50 ? "Compliant" : "Not Compliant";

                    var ratioVal = A2.StudentsToFacultyRatio ?? 0m;
                    var selCats  = (A2.CollegeCategoriesCsv ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                    var catRatio = new Dictionary<string,decimal>(StringComparer.OrdinalIgnoreCase) { ["Scientific"]=20m, ["Humanities"]=35m, ["Medical"]=25m, ["Applied"]=20m };
                    var avgRatio = selCats.Where(k => catRatio.ContainsKey(k)).Select(k => catRatio[k]).DefaultIfEmpty(0m).Average();
                    string ratioComp;
                    if (ratioVal <= 0 || avgRatio <= 0) ratioComp = "Not Assessed";
                    else { var tol = avgRatio * 1.25m; ratioComp = ratioVal <= avgRatio ? "Compliant" : ratioVal <= tol ? "Needs Review" : "Not Compliant"; }

                    string clinComp;
                    if (!md2.Med_StudentFacultyRatio.HasValue && !md2.Den_StudentFacultyRatio.HasValue) clinComp = "Needs Review";
                    else {
                        var mc = !md2.Med_StudentFacultyRatio.HasValue ? "" : md2.Med_StudentFacultyRatio.Value <= 4 ? "green" : md2.Med_StudentFacultyRatio.Value <= 5 ? "orange" : "red";
                        var dc = !md2.Den_StudentFacultyRatio.HasValue ? "" : md2.Den_StudentFacultyRatio.Value <= 4 ? "green" : md2.Den_StudentFacultyRatio.Value <= 5 ? "orange" : "red";
                        clinComp = (mc=="red"||dc=="red") ? "Not Compliant" : (mc=="orange"||dc=="orange"||mc==""||dc=="") ? "Needs Review" : "Compliant";
                    }

                    var p1 = string.IsNullOrWhiteSpace(Model.AccreditationStatus) ? "Not Assessed" : Model.AccreditationStatus;
                    var envAll2 = new[] { EnvMap(Model.FacultiesAssessment), EnvMap(Model.HospitalsAssessment), EnvMap(Model.LaboratoriesFacilitiesAssessment), EnvMap(Model.LibraryAssessment) };
                    string envOverall2 = envAll2.Any(s => s=="Not Compliant") ? "Not Compliant" : envAll2.Any(s=>s=="Needs Review") ? "Needs Review" : envAll2.All(s=>s=="Compliant") ? "Compliant" : "Not Assessed";
                }

                <div class="sub-hd">5-Point Compliance Assessment</div>
                <div class="score-grid">
                    <div class="score-cell">
                        <div class="score-num-r">1</div>
                        <div class="score-name">Accreditation</div>
                        <span class="badge @BadgeCss(p1)">@p1</span>
                        @if (!string.IsNullOrWhiteSpace(Model.AccreditationNote)) { <div style="font-size:11px;color:#888;margin-top:6px;">@Model.AccreditationNote</div> }
                    </div>
                    <div class="score-cell">
                        <div class="score-num-r">2</div>
                        <div class="score-name">Faculty Ratio</div>
                        <span class="badge @BadgeCss(ratioComp)">@ratioComp</span>
                        @if (ratioVal > 0) { <div style="font-size:11px;color:#888;margin-top:6px;">1:@((int)ratioVal)</div> }
                    </div>
                    <div class="score-cell">
                        <div class="score-num-r">3</div>
                        <div class="score-name">Doctorate %</div>
                        <span class="badge @BadgeCss(docComp2)">@docComp2</span>
                        @if (totalFacFT > 0) { <div style="font-size:11px;color:#888;margin-top:6px;">@docPct2%</div> }
                    </div>
                    <div class="score-cell">
                        <div class="score-num-r">4</div>
                        <div class="score-name">Clinical Capacity</div>
                        <span class="badge @BadgeCss(clinComp)">@clinComp</span>
                    </div>
                    <div class="score-cell">
                        <div class="score-num-r">5</div>
                        <div class="score-name">Environment</div>
                        <span class="badge @BadgeCss(envOverall2)">@envOverall2</span>
                    </div>
                </div>

                @{
                    bool hasEnv = !string.IsNullOrWhiteSpace(Model.FacultiesAssessment)
                               || !string.IsNullOrWhiteSpace(Model.HospitalsAssessment)
                               || !string.IsNullOrWhiteSpace(Model.HospitalEnvironmentAssessment)
                               || !string.IsNullOrWhiteSpace(Model.LaboratoriesFacilitiesAssessment)
                               || !string.IsNullOrWhiteSpace(Model.LibraryAssessment);
                }
                @if (hasEnv)
                {
                    <div class="sub-hd">Environment Assessment Detail</div>
                    <div class="env-grid">
                        @if (!string.IsNullOrWhiteSpace(Model.FacultiesAssessment))
                        {
                            <div class="env-row">
                                <div><div class="env-label">Colleges / Faculties</div>@if (!string.IsNullOrWhiteSpace(Model.FacultiesAssessmentNote)) { <div class="env-note">@Model.FacultiesAssessmentNote</div> }</div>
                                <span class="badge @BadgeCss(EnvMap(Model.FacultiesAssessment))">@EnvMap(Model.FacultiesAssessment)</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.HospitalsAssessment))
                        {
                            <div class="env-row">
                                <div><div class="env-label">Hospitals (General)</div>@if (!string.IsNullOrWhiteSpace(Model.HospitalsAssessmentNote)) { <div class="env-note">@Model.HospitalsAssessmentNote</div> }</div>
                                <span class="badge @BadgeCss(EnvMap(Model.HospitalsAssessment))">@EnvMap(Model.HospitalsAssessment)</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.HospitalEnvironmentAssessment))
                        {
                            <div class="env-row">
                                <div><div class="env-label">Hospital Environment</div>@if (!string.IsNullOrWhiteSpace(Model.HospitalEnvironmentAssessmentNote)) { <div class="env-note">@Model.HospitalEnvironmentAssessmentNote</div> }</div>
                                <span class="badge @BadgeCss(EnvMap(Model.HospitalEnvironmentAssessment))">@EnvMap(Model.HospitalEnvironmentAssessment)</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.LaboratoriesFacilitiesAssessment))
                        {
                            <div class="env-row">
                                <div><div class="env-label">Laboratories</div>@if (!string.IsNullOrWhiteSpace(Model.LaboratoriesFacilitiesAssessmentNote)) { <div class="env-note">@Model.LaboratoriesFacilitiesAssessmentNote</div> }</div>
                                <span class="badge @BadgeCss(EnvMap(Model.LaboratoriesFacilitiesAssessment))">@EnvMap(Model.LaboratoriesFacilitiesAssessment)</span>
                            </div>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.LibraryAssessment))
                        {
                            <div class="env-row">
                                <div><div class="env-label">Library</div>@if (!string.IsNullOrWhiteSpace(Model.LibraryAssessmentNote)) { <div class="env-note">@Model.LibraryAssessmentNote</div> }</div>
                                <span class="badge @BadgeCss(EnvMap(Model.LibraryAssessment))">@EnvMap(Model.LibraryAssessment)</span>
                            </div>
                        }
                    </div>
                }

                <div class="sub-hd">Final Recommendation Decision</div>
                @if (!string.IsNullOrWhiteSpace(recDecision))
                {
                    <span class="dec-badge @DecCss(recDecision)"><i class="bi @DecIcon(recDecision)"></i> @recDecision</span>
                }
                else
                {
                    <span class="dec-badge dec-na"><i class="bi bi-dash-circle"></i> Not Submitted Yet</span>
                }

                <div class="sub-hd">Justification / Notes</div>
                @if (!string.IsNullOrWhiteSpace(Model.BasicInfoAssessmentReason))
                {
                    <div class="note-box">@Model.BasicInfoAssessmentReason</div>
                }
                else
                {
                    <div class="note-box empty">No justification note provided.</div>
                }

            </div>
        </div>
        }

        <!-- Footer -->
        <div style="text-align:center;padding:24px 0;color:#aaa;font-size:11.5px;">
            Ministry of Higher Education and Scientific Research · Read-Only Admin View · Request #@Model.Id
        </div>

    </main>
</div>

<!-- ── Bottom action bar ── -->
<div class="bottom-bar">
    @if (backId > 0)
    {
        <a class="btn-bar" href="/Home/SessionDashboard?id=@backId"><i class="bi bi-arrow-left"></i> Back to Meeting</a>
    }
    else if (showRec)
    {
        <a class="btn-bar" href="/Home/SubmittedUniversities"><i class="bi bi-arrow-left"></i> Back to Submitted Universities</a>
    }
    else
    {
        <a class="btn-bar" href="/Home/Requests"><i class="bi bi-arrow-left"></i> Back</a>
    }
    @if (backId > 0)
    {
        <a class="btn-bar btn-bar-decision" href="/Home/MeetingDecision?meetingId=@backId&requestId=@Model.Id">
            <i class="bi bi-check2-circle"></i> Final Decision
        </a>
    }
</div>

<script>
    // Highlight active sidebar link on scroll
    const links = document.querySelectorAll('.sid-link[href^="#"]');
    const sections = Array.from(links).map(l => document.querySelector(l.getAttribute('href'))).filter(Boolean);

    function onScroll() {
        let current = sections[0];
        for (const s of sections) {
            if (s.getBoundingClientRect().top <= 80) current = s;
        }
        links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + current.id));
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
</script>
</body>
</html>
