@using MOHRecognition.DTOs
@using MOHRecognition.Services
@model List<RecognitionRequestRecord>

@{
    ViewData["Title"] = "Session Agenda";
    Layout = null;

    var meeting   = (MeetingDto)ViewBag.Meeting;
    var meetingId = meeting.Id;
    var decisions = ViewBag.Decisions as Dictionary<(int, int), MeetingDecisionDto>;
    int total     = Model?.Count ?? 0;

    int decided = 0;
    if (Model != null)
        foreach (var r in Model)
        {
            MeetingDecisionDto? d = null;
            decisions?.TryGetValue((meetingId, r.Id), out d);
            if (d != null && !string.IsNullOrWhiteSpace(d.Decision)) decided++;
        }
    int pending  = total - decided;
    int pct      = total > 0 ? decided * 100 / total : 0;

    string sb = meeting.Status == "Open"      ? "sb-open"
              : meeting.Status == "Closed"    ? "sb-closed"
              : meeting.Status == "Scheduled" ? "sb-scheduled"
              : "sb-other";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Session #@meeting.SessionNumber</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f3f0eb;
            color: #1a1a1a;
            min-height: 100vh;
        }

        /* ── Ministry bar ── */
        .ministry-bar {
            background: #5a0e1b;
            color: rgba(255,255,255,.68);
            font-size: 11.5px;
            font-weight: 500;
            letter-spacing: .4px;
            padding: 6px 48px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* ── Header ── */
        .pg-header {
            background: #7f1627;
            color: #fff;
            padding: 0 48px;
            height: 66px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 2px 18px rgba(127,22,39,.32);
        }
        .hd-left { display: flex; align-items: center; gap: 16px; }
        .pg-header img { height: 42px; }
        .hd-sep { width: 1px; height: 34px; background: rgba(255,255,255,.28); margin: 0 6px; }
        .hd-text h1 { font-size: 17px; font-weight: 700; }
        .hd-text p  { font-size: 11.5px; opacity: .72; margin-top: 2px; }

        /* ── Breadcrumb ── */
        .breadcrumb-bar {
            background: #fff;
            border-bottom: 1px solid #ece5dd;
            padding: 0 48px;
            height: 44px;
            display: flex;
            align-items: center;
        }
        .bc-item {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 12.5px; font-weight: 600; color: #999; text-decoration: none;
        }
        .bc-item:hover { color: #7f1627; }
        .bc-sep { font-size: 12px; color: #ccc; margin: 0 10px; }
        .bc-current { color: #7f1627; font-weight: 700; }

        /* ── Agenda banner ── */
        .agenda-banner {
            background: #fff;
            border-bottom: 3px solid #7f1627;
            padding: 32px 48px;
        }
        .ab-top {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 24px;
            flex-wrap: wrap;
            margin-bottom: 24px;
        }
        .ab-label {
            display: inline-flex; align-items: center; gap: 7px;
            background: #f5e8ea; color: #7f1627;
            border: 1.5px solid #e0b4be;
            border-radius: 6px;
            padding: 4px 14px;
            font-size: 11px; font-weight: 800;
            letter-spacing: .8px; text-transform: uppercase;
            margin-bottom: 10px;
        }
        .ab-title { font-size: 26px; font-weight: 900; color: #1a1a1a; line-height: 1.2; }
        .ab-meta  { font-size: 13px; color: #888; margin-top: 6px; display: flex; gap: 18px; flex-wrap: wrap; }
        .ab-meta-item { display: flex; align-items: center; gap: 5px; }
        .ab-meta-item i { color: #7f1627; font-size: 13px; }

        /* Progress bar */
        .ab-progress { margin-top: 0; }
        .prog-label {
            display: flex; justify-content: space-between; align-items: center;
            font-size: 12px; font-weight: 700; color: #aaa;
            margin-bottom: 8px;
        }
        .prog-label .prog-pct { color: @(pct == 100 ? "#1a7a34" : "#7f1627"); font-size: 14px; font-weight: 800; }
        .prog-track { height: 8px; background: #f0ebe4; border-radius: 10px; overflow: hidden; }
        .prog-fill  { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #7f1627, #b03050); width: @pct%; }

        /* Status badge */
        .sbadge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; font-size: 12.5px; font-weight: 700; }
        .sdot { width: 7px; height: 7px; border-radius: 50%; }
        .sb-open      { background: #e8f5ea; color: #1a7a34; } .sb-open      .sdot { background: #1a7a34; }
        .sb-scheduled { background: #e8f0fe; color: #1a56db; } .sb-scheduled .sdot { background: #1a56db; }
        .sb-closed    { background: #f0f0f0; color: #777; }    .sb-closed    .sdot { background: #aaa; }
        .sb-other     { background: #fff3cd; color: #856404; } .sb-other     .sdot { background: #856404; }

        /* ── Stats row ── */
        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-top: 1px solid #f0ebe4;
        }
        .stat-cell {
            padding: 16px 24px;
            border-right: 1px solid #f0ebe4;
            text-align: center;
        }
        .stat-cell:last-child { border-right: none; }
        .stat-val   { font-size: 24px; font-weight: 900; color: #7f1627; line-height: 1; }
        .stat-lbl   { font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: .6px; margin-top: 4px; }

        /* ── Body ── */
        .pg-body { max-width: 1160px; margin: 0 auto; padding: 36px 24px 72px; }

        /* ── University cards ── */
        .uni-list { display: flex; flex-direction: column; gap: 16px; }

        .uni-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 16px rgba(0,0,0,.06);
            overflow: hidden;
            border-left: 5px solid #e0d0d4;
            transition: border-color .15s, box-shadow .15s;
        }
        .uni-card:hover { border-left-color: #7f1627; box-shadow: 0 4px 24px rgba(127,22,39,.1); }
        .uni-card.decided { border-left-color: #1a7a34; }
        .uni-card.decided:hover { border-left-color: #1a7a34; }

        .uni-card-inner {
            display: grid;
            grid-template-columns: 40px 1fr auto auto;
            align-items: center;
            gap: 0;
            padding: 24px 28px;
        }

        .uni-idx {
            font-size: 20px; font-weight: 900; color: #d4bec4;
            text-align: center; padding-right: 20px;
        }

        .uni-info { padding-right: 32px; border-right: 1px solid #f0ebe4; }
        .uni-name { font-size: 16px; font-weight: 800; color: #1a1a1a; margin-bottom: 4px; }
        .uni-sub  { font-size: 12.5px; color: #aaa; display: flex; gap: 14px; flex-wrap: wrap; }
        .uni-sub-item { display: flex; align-items: center; gap: 4px; }
        .uni-sub-item i { font-size: 11px; }

        .uni-rec { padding: 0 32px; border-right: 1px solid #f0ebe4; min-width: 200px; }
        .uni-rec-lbl {
            font-size: 10px; font-weight: 800; color: #bbb;
            text-transform: uppercase; letter-spacing: .7px; margin-bottom: 6px;
        }
        .uni-rec-val { font-size: 13px; font-weight: 600; color: #444; }
        .uni-rec-val.empty { color: #ccc; font-style: italic; font-weight: 400; }

        .uni-actions { padding-left: 28px; display: flex; flex-direction: column; gap: 8px; align-items: flex-end; min-width: 160px; }

        /* Decision badge */
        .dec-badge {
            display: inline-flex; align-items: center; gap: 5px;
            padding: 5px 13px; border-radius: 20px; font-size: 12px; font-weight: 700;
            margin-bottom: 8px;
        }
        .dec-recognized     { background: #e8f5ea; color: #1a7a34; }
        .dec-not-recognized { background: #fde8e8; color: #b91c1c; }
        .dec-needs-more     { background: #fff3cd; color: #856404; }
        .dec-pending        { background: #f4f1ec; color: #bbb; font-weight: 500; font-style: italic; }

        /* Action buttons */
        .btn-view {
            display: inline-flex; align-items: center; gap: 6px;
            background: #f0f5ff; color: #1a56db;
            border: 1px solid #c5d8f8; border-radius: 8px;
            padding: 8px 16px; font-size: 12.5px; font-weight: 600;
            text-decoration: none; white-space: nowrap;
            transition: background .12s;
        }
        .btn-view:hover { background: #deeafc; }

        .btn-decide {
            display: inline-flex; align-items: center; gap: 6px;
            background: #7f1627; color: #fff;
            border: none; border-radius: 8px;
            padding: 8px 16px; font-size: 12.5px; font-weight: 700;
            text-decoration: none; white-space: nowrap;
            transition: background .12s;
        }
        .btn-decide:hover { background: #6a1020; }

        .btn-decide-edit {
            background: #fff; color: #7f1627;
            border: 1.5px solid #d0a0b0;
        }
        .btn-decide-edit:hover { background: #fdf0f2; }

        /* ── Close Meeting button ── */
        .btn-close-meeting {
            display: inline-flex; align-items: center; gap: 8px;
            background: #fff; color: #7f1627;
            border: 2px solid #7f1627; border-radius: 9px;
            padding: 9px 20px; font-size: 13px; font-weight: 700;
            cursor: pointer; font-family: inherit;
            transition: background .15s, color .15s;
        }
        .btn-close-meeting:hover { background: #7f1627; color: #fff; }
        .btn-close-meeting:disabled { opacity: .45; cursor: not-allowed; }

        /* ── Confirm modal ── */
        .cm-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45); z-index: 1000;
            align-items: center; justify-content: center;
        }
        .cm-overlay.show { display: flex; }
        .cm-box {
            background: #fff; border-radius: 16px;
            box-shadow: 0 12px 48px rgba(0,0,0,.22);
            padding: 36px 40px; max-width: 440px; width: 90%;
            text-align: center;
        }
        .cm-icon {
            width: 60px; height: 60px; border-radius: 50%;
            background: #fde8e8; color: #7f1627;
            display: flex; align-items: center; justify-content: center;
            font-size: 26px; margin: 0 auto 18px;
        }
        .cm-title { font-size: 20px; font-weight: 800; color: #1a1a1a; margin-bottom: 10px; }
        .cm-desc  { font-size: 14px; color: #666; line-height: 1.6; margin-bottom: 24px; }
        .cm-warn  {
            background: #fff8e1; border: 1px solid #ffe082;
            border-radius: 8px; padding: 10px 14px;
            font-size: 12.5px; color: #7a5900; font-weight: 600;
            margin-bottom: 24px; text-align: left;
        }
        .cm-actions { display: flex; gap: 12px; justify-content: center; }
        .cm-btn-cancel {
            padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 700;
            border: 1.5px solid #ddd; background: #fff; color: #555; cursor: pointer;
        }
        .cm-btn-cancel:hover { background: #f5f5f5; }
        .cm-btn-confirm {
            padding: 10px 24px; border-radius: 8px; font-size: 14px; font-weight: 700;
            border: none; background: #7f1627; color: #fff; cursor: pointer;
        }
        .cm-btn-confirm:hover { background: #6a1020; }

        /* ── Empty state ── */
        .empty-wrap {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 16px rgba(0,0,0,.06);
            padding: 80px 32px;
            text-align: center;
        }
        .empty-wrap i     { font-size: 60px; color: #d4bec4; display: block; margin-bottom: 22px; }
        .empty-wrap h3    { font-size: 19px; font-weight: 800; color: #555; margin-bottom: 10px; }
        .empty-wrap p     { font-size: 14px; color: #aaa; line-height: 1.7; max-width: 420px; margin: 0 auto 28px; }
        .btn-add-uni {
            display: inline-flex; align-items: center; gap: 8px;
            background: #7f1627; color: #fff;
            border: none; border-radius: 9px;
            padding: 12px 26px; font-size: 14px; font-weight: 700;
            text-decoration: none; font-family: inherit; cursor: pointer;
            transition: background .15s;
        }
        .btn-add-uni:hover { background: #6a1020; }
    </style>
</head>
<body>

    <div class="ministry-bar">
        <i class="bi bi-bank2"></i>
        Ministry of Higher Education and Scientific Research — Hashemite Kingdom of Jordan
    </div>

    <div class="pg-header">
        <div class="hd-left">
            <img src="/images/mohelogo.png" alt="Logo" />
            <div class="hd-sep"></div>
            <div class="hd-text">
                <h1>Session Agenda</h1>
                <p>Committee Working Area — Phase 2</p>
            </div>
        </div>
        @if (meeting.Status != "Closed")
        {
            if (pending > 0)
            {
                <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
                    <button class="btn-close-meeting" disabled style="opacity:.4;cursor:not-allowed;pointer-events:none;">
                        <i class="bi bi-lock-fill"></i> Close Meeting
                    </button>
                    <span style="font-size:12px;color:#fca5a5;font-weight:600;">
                        <i class="bi bi-exclamation-circle"></i>
                        @pending decision@(pending == 1 ? "" : "s") still pending
                    </span>
                </div>
            }
            else
            {
                <button class="btn-close-meeting" onclick="document.getElementById('cmOverlay').classList.add('show')">
                    <i class="bi bi-lock-fill"></i> Close Meeting
                </button>
            }
        }
        else
        {
            <span style="background:rgba(255,255,255,.15);color:#fff;padding:8px 16px;border-radius:8px;font-size:13px;font-weight:700;">
                <i class="bi bi-lock-fill"></i> Meeting Closed
            </span>
        }
    </div>

    <!-- Confirmation modal -->
    <div class="cm-overlay" id="cmOverlay">
        <div class="cm-box">
            <div class="cm-icon"><i class="bi bi-lock-fill"></i></div>
            <div class="cm-title">Close This Meeting?</div>
            <div class="cm-desc">
                You are about to close <strong>Session #@meeting.SessionNumber</strong>.<br>
                This action will finalise all decisions and cannot be undone.
            </div>
            @if (pending > 0)
            {
                <div class="cm-warn">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>@pending</strong> @(pending == 1 ? "university has" : "universities have") no decision recorded yet.
                    You can still close, but those requests will be marked as incomplete.
                </div>
            }
            else
            {
                <div class="cm-warn" style="background:#e8f5ea;border-color:#a7f3d0;color:#166534;">
                    <i class="bi bi-check-circle-fill"></i>
                    All @total @(total == 1 ? "university has" : "universities have") a recorded decision. Safe to close.
                </div>
            }
            <div class="cm-actions">
                <button class="cm-btn-cancel" onclick="document.getElementById('cmOverlay').classList.remove('show')">Cancel</button>
                <form method="post" action="/Home/CloseMeeting?id=@meetingId" style="margin:0;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="cm-btn-confirm">
                        <i class="bi bi-lock-fill"></i> Yes, Close Meeting
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="breadcrumb-bar">
        <a class="bc-item" href="/Home/Meetings"><i class="bi bi-calendar3"></i> Committee Sessions</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <a class="bc-item" href="/Home/SessionDashboard?id=@meetingId"><i class="bi bi-grid-1x2"></i> Session #@meeting.SessionNumber</a>
        <span class="bc-sep"><i class="bi bi-chevron-right"></i></span>
        <span class="bc-item bc-current"><i class="bi bi-journal-text"></i> Session Agenda</span>
    </div>

    <!-- Agenda banner -->
    <div class="agenda-banner">
        <div class="ab-top">
            <div>
                <div class="ab-label"><i class="bi bi-journal-text"></i> Committee Agenda</div>
                <div class="ab-title">Session #@meeting.SessionNumber — @meeting.MeetingDate.Year</div>
                <div class="ab-meta">
                    <div class="ab-meta-item"><i class="bi bi-calendar3"></i> @meeting.MeetingDate.ToString("dd MMMM yyyy")</div>
                    @if (!string.IsNullOrWhiteSpace(meeting.LocationOrPlatform))
                    {
                        <div class="ab-meta-item"><i class="bi bi-geo-alt"></i> @meeting.LocationOrPlatform</div>
                    }
                    <div class="ab-meta-item">
                        <span class="sbadge @sb"><span class="sdot"></span>@meeting.Status</span>
                    </div>
                </div>
            </div>
            @if (total > 0)
            {
                <div style="min-width:240px;">
                    <div class="prog-label">
                        <span>Decision Progress</span>
                        <span class="prog-pct">@pct%</span>
                    </div>
                    <div class="prog-track"><div class="prog-fill"></div></div>
                </div>
            }
        </div>
        <div class="stats-strip">
            <div class="stat-cell">
                <div class="stat-val">@total</div>
                <div class="stat-lbl">Universities</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@decided</div>
                <div class="stat-lbl">Decided</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@pending</div>
                <div class="stat-lbl">Pending</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@pct%</div>
                <div class="stat-lbl">Complete</div>
            </div>
        </div>
    </div>

    <div class="pg-body">

        @if (Model != null && Model.Count > 0)
        {
            <div class="uni-list">
                @{
                    int rowNum = 1;
                    foreach (var r in Model)
                    {
                        MeetingDecisionDto? dec = null;
                        decisions?.TryGetValue((meetingId, r.Id), out dec);

                        bool hasDecision = dec != null && !string.IsNullOrWhiteSpace(dec.Decision);

                        string decBadge = "dec-pending";
                        string decLabel = "Pending Decision";
                        if (hasDecision)
                        {
                            switch (dec!.Decision)
                            {
                                case "Recognized":          decBadge = "dec-recognized";     decLabel = "Recognized"; break;
                                case "Not Recognized":      decBadge = "dec-not-recognized"; decLabel = "Not Recognized"; break;
                                case "Needs More Information": decBadge = "dec-needs-more";  decLabel = "Needs More Info"; break;
                                default: decLabel = dec.Decision; break;
                            }
                        }

                        string docRec = string.IsNullOrWhiteSpace(r.BasicInfoAssessmentDecision) ? "" : r.BasicInfoAssessmentDecision;

                        <div class="uni-card @(hasDecision ? "decided" : "")">
                            <div class="uni-card-inner">
                                <div class="uni-idx">@rowNum</div>
                                <div class="uni-info">
                                    <div class="uni-name">@(string.IsNullOrWhiteSpace(r.UniversityName) ? "Unnamed University" : r.UniversityName)</div>
                                    <div class="uni-sub">
                                        @if (!string.IsNullOrWhiteSpace(r.Country))
                                        {
                                            <span class="uni-sub-item"><i class="bi bi-geo-alt"></i> @r.Country</span>
                                        }
                                        <span class="uni-sub-item"><i class="bi bi-hash"></i> Request ID: @r.Id</span>
                                        @if (!string.IsNullOrWhiteSpace(r.ReferenceNumber))
                                        {
                                            <span class="uni-sub-item"><i class="bi bi-file-text"></i> Ref: @r.ReferenceNumber</span>
                                        }
                                    </div>
                                </div>
                                <div class="uni-rec">
                                    <div class="uni-rec-lbl">Doctor's Recommendation</div>
                                    @if (string.IsNullOrWhiteSpace(docRec))
                                    {
                                        <div class="uni-rec-val empty">Not submitted</div>
                                    }
                                    else
                                    {
                                        <div class="uni-rec-val">@docRec</div>
                                    }
                                </div>
                                <div class="uni-actions">
                                    <span class="dec-badge @decBadge">@decLabel</span>
                                    <a class="btn-view" href="/Home/CommitteeApplicationView?requestId=@r.Id&meetingId=@meetingId">
                                        <i class="bi bi-eye"></i> View Application
                                    </a>
                                    @if (hasDecision)
                                    {
                                        <a class="btn-decide btn-decide-edit"
                                           href="/Home/MeetingDecision?meetingId=@meetingId&requestId=@r.Id">
                                            <i class="bi bi-pencil"></i> Edit Decision
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="btn-decide"
                                           href="/Home/MeetingDecision?meetingId=@meetingId&requestId=@r.Id">
                                            <i class="bi bi-check2-circle"></i> Record Decision
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>

                        rowNum++;
                    }
                }
            </div>
        }
        else
        {
            <div class="empty-wrap">
                <i class="bi bi-journal-x"></i>
                <h3>No University Requests Linked</h3>
                <p>
                    No university requests have been linked to this session yet.<br>
                    Return to session preparation to add universities to this agenda.
                </p>
                <a href="/Home/SessionDashboard?id=@meetingId" class="btn-add-uni">
                    <i class="bi bi-arrow-left"></i> Back to Session Dashboard
                </a>
            </div>
        }

    </div>
    <script>
        document.getElementById('cmOverlay').addEventListener('click', function(e) {
            if (e.target === this) this.classList.remove('show');
        });
    </script>
</body>
</html>
