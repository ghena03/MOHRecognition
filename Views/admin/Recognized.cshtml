@using MOHRecognition.DTOs
@{
    ViewData["Title"] = "Recognized Universities";
    Layout = null;
    var items = ViewBag.Items as List<DecisionItemDto> ?? new List<DecisionItemDto>();

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Recognized Universities</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f3f0eb; color: #1a1a1a; min-height: 100vh; }

        .ministry-bar { background: #5a0e1b; color: rgba(255,255,255,.68); font-size: 11.5px; font-weight: 500; letter-spacing: .4px; padding: 6px 48px; display: flex; align-items: center; gap: 6px; }

        .pg-header { background: #7f1627; color: #fff; padding: 0 48px; height: 66px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 18px rgba(127,22,39,.32); }
        .hd-left { display: flex; align-items: center; gap: 16px; }
        .pg-header img { height: 42px; }
        .hd-sep { width: 1px; height: 34px; background: rgba(255,255,255,.28); margin: 0 6px; }
        .hd-text h1 { font-size: 17px; font-weight: 700; }
        .hd-text p  { font-size: 11.5px; opacity: .72; margin-top: 2px; }
        .btn-back { display: inline-flex; align-items: center; gap: 7px; background: rgba(255,255,255,.15); color: #fff; border: 1.5px solid rgba(255,255,255,.35); border-radius: 8px; padding: 8px 18px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background .15s; }
        .btn-back:hover { background: rgba(255,255,255,.25); }

        /* ── Green accent banner ── */
        .accent-banner {
            background: #fff;
            border-bottom: 3px solid #1a7a34;
            padding: 24px 48px;
            display: flex; align-items: center; gap: 20px;
        }
        .accent-icon { width: 56px; height: 56px; border-radius: 16px; background: #e8f5ea; color: #1a7a34; display: flex; align-items: center; justify-content: center; font-size: 26px; flex-shrink: 0; }
        .accent-text h2 { font-size: 20px; font-weight: 900; color: #1a7a34; }
        .accent-text p  { font-size: 13px; color: #888; margin-top: 3px; }
        .accent-count { margin-left: auto; background: #e8f5ea; color: #1a7a34; border-radius: 12px; padding: 10px 22px; font-size: 28px; font-weight: 900; border: 2px solid #b8e8c8; }
        .accent-count span { font-size: 12px; font-weight: 600; display: block; text-align: center; margin-top: 2px; }

        /* ── Body ── */
        .pg-body { max-width: 1100px; margin: 0 auto; padding: 36px 24px 72px; }

        .tbl-card { background: #fff; border-radius: 16px; box-shadow: 0 2px 24px rgba(0,0,0,.07); overflow: hidden; }
        .tbl-card-top { padding: 20px 28px 16px; border-bottom: 1px solid #f0ebe4; display: flex; align-items: center; justify-content: space-between; }
        .tbl-card-top h3 { font-size: 14px; font-weight: 700; color: #333; }
        .tbl-card-top p  { font-size: 12px; color: #aaa; margin-top: 2px; }

        table { width: 100%; border-collapse: collapse; }
        thead th { background: #f4fbf5; color: #1a7a34; font-size: 11px; font-weight: 700; letter-spacing: .8px; text-transform: uppercase; padding: 13px 24px; text-align: left; border-bottom: 2px solid #b8e8c8; white-space: nowrap; }
        tbody tr { border-bottom: 1px solid #f5f0eb; transition: background .1s; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #f4fbf5; }
        tbody td { padding: 18px 24px; vertical-align: middle; }

        .uni-name { font-size: 14px; font-weight: 700; color: #1a1a1a; }
        .uni-sub  { font-size: 12px; color: #aaa; margin-top: 3px; }

        .badge-green { display: inline-flex; align-items: center; gap: 5px; background: #e8f5ea; color: #1a7a34; border-radius: 20px; padding: 5px 13px; font-size: 12px; font-weight: 700; }

        .btn-view { display: inline-flex; align-items: center; gap: 6px; background: #e8f5ea; color: #1a7a34; border: 1.5px solid #b8e8c8; border-radius: 8px; padding: 7px 14px; font-size: 12px; font-weight: 600; text-decoration: none; transition: background .12s; white-space: nowrap; }
        .btn-view:hover { background: #d0f0da; }

        .empty-state { padding: 72px 32px; text-align: center; }
        .empty-state i  { font-size: 52px; color: #b8e8c8; display: block; margin-bottom: 18px; }
        .empty-state h3 { font-size: 17px; font-weight: 700; color: #555; margin-bottom: 8px; }
        .empty-state p  { font-size: 13.5px; color: #aaa; max-width: 380px; margin: 0 auto; line-height: 1.7; }

        /* Application type — colored left border indicator */
        tr.app-row-bachelor td:first-child    { border-left: 5px solid #3b82f6 !important; padding-left: 11px !important; }
        tr.app-row-postgraduate td:first-child { border-left: 5px solid #8b5cf6 !important; padding-left: 11px !important; }
        tr.app-row-online td:first-child       { border-left: 5px solid #10b981 !important; padding-left: 11px !important; }
        .app-row-bachelor    { border-left: 5px solid #3b82f6 !important; }
        .app-row-postgraduate { border-left: 5px solid #8b5cf6 !important; }
        .app-row-online       { border-left: 5px solid #10b981 !important; }
    </style>
</head>
<body>

    <div class="ministry-bar">
        <i class="bi bi-bank2"></i>
        Ministry of Higher Education and Scientific Research — Hashemite Kingdom of Jordan
    </div>

    <div class="pg-header">
        <div class="hd-left">
            <img src="/images/mohelogo.png" alt="Logo" />
            <div class="hd-sep"></div>
            <div class="hd-text">
                <h1>Recognized Universities</h1>
                <p>Final committee decisions — Recognized</p>
            </div>
        </div>
        <a href="/Home/AdminDashboard" class="btn-back">
            <i class="bi bi-arrow-left"></i> Dashboard
        </a>
    </div>

    <div class="accent-banner">
        <div class="accent-icon"><i class="bi bi-patch-check-fill"></i></div>
        <div class="accent-text">
            <h2>Recognized</h2>
            <p>Universities that received final recognition approval from the committee</p>
        </div>
        <div class="accent-count">
            @items.Count
            <span>universities</span>
        </div>
    </div>

    <div class="pg-body">
        <div class="tbl-card">
            <div class="tbl-card-top">
                <div>
                    <h3>Recognized Universities</h3>
                    <p>Automatically populated when committee decision = Recognized</p>
                </div>
            </div>
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>University Name</th>
                        <th>Type</th>
                        <th>Country</th>
                        <th>Request ID</th>
                        <th>Session</th>
                        <th>Decision Date</th>
                        <th>Status</th>
                        <th style="text-align:right;padding-right:28px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (items.Any())
                    {
                        int i = 1;
                        foreach (var item in items)
                        {
                            <tr class="@RowClass(item.ApplicationType)">
                                <td style="font-size:14px;font-weight:700;color:#bbb;">@i</td>
                                <td>
                                    <div class="uni-name">@(string.IsNullOrWhiteSpace(item.UniversityName) ? "—" : item.UniversityName)</div>
                                    @if (!string.IsNullOrWhiteSpace(item.ReferenceNumber))
                                    {
                                        <div class="uni-sub"><i class="bi bi-file-text" style="font-size:10px;"></i> @item.ReferenceNumber</div>
                                    }
                                </td>
                                <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11.5px;font-weight:700;@AppTypeStyle(item.ApplicationType)">@(item.ApplicationType ?? "Bachelor")</span></td>
                                <td style="font-size:13px;color:#555;">@(string.IsNullOrWhiteSpace(item.Country) ? "—" : item.Country)</td>
                                <td style="font-size:13px;font-weight:600;color:#555;">#@item.RequestId</td>
                                <td>
                                    <span style="font-size:13px;font-weight:700;color:#1a1a1a;">Meeting #@item.SessionNumber</span>
                                    <div style="font-size:11px;color:#bbb;margin-top:2px;">@item.MeetingDate.ToString("dd MMM yyyy")</div>
                                </td>
                                <td style="font-size:13px;color:#555;">
                                    @(item.DecisionDate.HasValue ? item.DecisionDate.Value.ToString("dd MMM yyyy") : "—")
                                </td>
                                <td><span class="badge-green"><i class="bi bi-patch-check-fill"></i> Recognized</span></td>
                                <td style="text-align:right;">
                                    <a class="btn-view" href="/Home/MeetingDecision?meetingId=@item.MeetingId&requestId=@item.RequestId">
                                        <i class="bi bi-eye"></i> View Decision
                                    </a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="9">
                                <div class="empty-state">
                                    <i class="bi bi-patch-check"></i>
                                    <h3>No recognized universities yet</h3>
                                    <p>Universities will appear here automatically once the committee records a "Recognized" decision inside إدارة الجلسات.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>
