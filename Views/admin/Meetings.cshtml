@using MOHRecognition.DTOs
@model List<MeetingDto>

@{
    ViewData["Title"] = "Meetings";
    Layout = null;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meetings</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f3f0eb;
            color: #1a1a1a;
            min-height: 100vh;
        }

        .ministry-bar {
            background: #5a0e1b;
            color: rgba(255,255,255,.7);
            font-size: 11.5px; font-weight: 500; letter-spacing: .4px;
            padding: 6px 48px;
            display: flex; align-items: center; gap: 6px;
        }

        .pg-header {
            background: #7f1627; color: #fff;
            padding: 0 48px; height: 66px;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: 0 2px 18px rgba(127,22,39,.32);
        }
        .hd-left { display: flex; align-items: center; gap: 16px; }
        .pg-header img { height: 42px; }
        .hd-sep { width: 1px; height: 34px; background: rgba(255,255,255,.28); margin: 0 6px; }
        .hd-text h1 { font-size: 17px; font-weight: 700; }
        .hd-text p  { font-size: 11.5px; opacity: .72; margin-top: 2px; }

        .btn-new {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(255,255,255,.15); color: #fff;
            border: 1.5px solid rgba(255,255,255,.38);
            border-radius: 8px; padding: 9px 20px;
            font-size: 13px; font-weight: 700;
            text-decoration: none; transition: background .15s; white-space: nowrap;
        }
        .btn-new:hover { background: rgba(255,255,255,.28); }

        .btn-back {
            display: inline-flex; align-items: center; gap: 7px;
            background: rgba(255,255,255,.12); color: rgba(255,255,255,.85);
            border: 1.5px solid rgba(255,255,255,.25);
            border-radius: 8px; padding: 9px 16px;
            font-size: 13px; font-weight: 600;
            text-decoration: none; transition: background .15s;
            margin-right: 10px;
        }
        .btn-back:hover { background: rgba(255,255,255,.22); }

        .hd-actions { display: flex; align-items: center; gap: 0; }

        /* ── Body ── */
        .pg-body { max-width: 1080px; margin: 0 auto; padding: 40px 24px 72px; }

        /* ── Table card ── */
        .tbl-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 2px 24px rgba(0,0,0,.07);
            overflow: hidden;
        }

        .tbl-card-top {
            padding: 22px 32px 18px;
            border-bottom: 1px solid #f0ebe4;
            display: flex; align-items: center; justify-content: space-between;
        }
        .tbl-card-top h3 { font-size: 15px; font-weight: 700; color: #333; }
        .tbl-card-top p  { font-size: 12.5px; color: #aaa; margin-top: 2px; }

        .count-pill {
            display: inline-flex; align-items: center; gap: 6px;
            background: #f5e8ea; color: #7f1627;
            border-radius: 20px; padding: 4px 14px;
            font-size: 12px; font-weight: 700;
        }

        table { width: 100%; border-collapse: collapse; }

        thead th {
            background: #faf7f4;
            color: #7f1627;
            font-size: 11px; font-weight: 700;
            letter-spacing: .8px; text-transform: uppercase;
            padding: 14px 28px; text-align: left;
            border-bottom: 2px solid #ecddd5; white-space: nowrap;
        }

        tbody tr {
            border-bottom: 1px solid #f5f0eb;
            cursor: pointer;
            transition: background .12s;
        }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #fdf8f5; }

        tbody td { padding: 20px 28px; vertical-align: middle; }

        .cell-num { font-size: 24px; font-weight: 900; color: #7f1627; letter-spacing: -1px; line-height: 1; }
        .cell-year { font-size: 15px; font-weight: 700; color: #444; }
        .cell-date { font-size: 14px; font-weight: 600; color: #333; }

        .cell-uni-count { font-size: 18px; font-weight: 800; color: #333; }
        .cell-uni-lbl   { font-size: 11.5px; color: #aaa; margin-top: 2px; }

        .sbadge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; }
        .sdot { width: 7px; height: 7px; border-radius: 50%; }
        .sb-open      { background: #e8f5ea; color: #1a7a34; } .sb-open      .sdot { background: #1a7a34; }
        .sb-scheduled { background: #e8f0fe; color: #1a56db; } .sb-scheduled .sdot { background: #1a56db; }
        .sb-closed    { background: #f0f0f0; color: #777; }    .sb-closed    .sdot { background: #aaa; }
        .sb-other     { background: #fff3cd; color: #856404; } .sb-other     .sdot { background: #856404; }

        /* Edit / Delete buttons */
        .edit-btn {
            display: inline-flex; align-items: center; gap: 6px;
            background: #fff; color: #7f1627;
            border: 1.5px solid #e0b4be; border-radius: 8px;
            padding: 8px 16px; font-size: 12.5px; font-weight: 700;
            text-decoration: none; transition: background .12s, border-color .12s;
            white-space: nowrap;
        }
        .edit-btn:hover { background: #fde8ec; border-color: #c08090; }

        .del-btn {
            display: inline-flex; align-items: center; gap: 6px;
            background: #fff; color: #b91c1c;
            border: 1.5px solid #fecaca; border-radius: 8px;
            padding: 8px 14px; font-size: 12.5px; font-weight: 700;
            cursor: pointer; transition: background .12s, border-color .12s;
            white-space: nowrap; margin-left: 6px;
        }
        .del-btn:hover { background: #fef2f2; border-color: #f87171; }

        /* Confirm delete overlay */
        .del-overlay {
            display: none; position: fixed; inset: 0;
            background: rgba(0,0,0,.45); z-index: 1000;
            align-items: center; justify-content: center;
        }
        .del-overlay.show { display: flex; }
        .del-modal {
            background: #fff; border-radius: 16px; padding: 36px 40px;
            max-width: 420px; width: 90%; box-shadow: 0 8px 48px rgba(0,0,0,.18);
            text-align: center;
        }
        .del-modal i { font-size: 44px; color: #f87171; display: block; margin-bottom: 16px; }
        .del-modal h3 { font-size: 18px; font-weight: 800; color: #1a1a1a; margin-bottom: 8px; }
        .del-modal p  { font-size: 13.5px; color: #888; margin-bottom: 28px; line-height: 1.6; }
        .del-modal-btns { display: flex; gap: 12px; justify-content: center; }
        .btn-cancel { padding: 10px 24px; border-radius: 8px; border: 1.5px solid #ddd; background: #fff; font-size: 14px; font-weight: 600; color: #555; cursor: pointer; }
        .btn-cancel:hover { background: #f5f5f5; }
        .btn-confirm-del { padding: 10px 24px; border-radius: 8px; border: none; background: #b91c1c; color: #fff; font-size: 14px; font-weight: 700; cursor: pointer; }
        .btn-confirm-del:hover { background: #991b1b; }

        /* Empty state */
        .empty-state { padding: 80px 32px; text-align: center; }
        .empty-state i  { font-size: 56px; color: #d4bec4; display: block; margin-bottom: 18px; }
        .empty-state h3 { font-size: 17px; font-weight: 700; color: #666; margin-bottom: 10px; }
        .empty-state p  { font-size: 13.5px; color: #aaa; max-width: 360px; margin: 0 auto 24px; line-height: 1.7; }
        .empty-state a  {
            display: inline-flex; align-items: center; gap: 8px;
            background: #7f1627; color: #fff;
            border-radius: 9px; padding: 12px 24px;
            font-size: 14px; font-weight: 700; text-decoration: none;
            transition: background .15s;
        }
        .empty-state a:hover { background: #6a1020; }
    </style>
</head>
<body>

    <div class="ministry-bar">
        <i class="bi bi-bank2"></i>
        Ministry of Higher Education and Scientific Research — Hashemite Kingdom of Jordan
    </div>

    <div class="pg-header">
        <div class="hd-left">
            <img src="/images/mohelogo.png" alt="Logo" />
            <div class="hd-sep"></div>
            <div class="hd-text">
                <h1>Meetings</h1>
                <p>Schedule and manage committee meetings</p>
            </div>
        </div>
        <div class="hd-actions">
            <a href="/Home/AdminDashboard" class="btn-back">
                <i class="bi bi-arrow-left"></i> Dashboard
            </a>
            <a href="/Home/CreateMeeting" class="btn-new">
                <i class="bi bi-plus-lg"></i> New Meeting
            </a>
        </div>
    </div>

    <div class="pg-body">

        <div class="tbl-card">
            <div class="tbl-card-top">
                <div>
                    <h3>Scheduled Meetings</h3>
                    <p>Click any row to open the meeting workspace</p>
                </div>
                @if (Model != null && Model.Count > 0)
                {
                    <span class="count-pill">
                        <i class="bi bi-calendar3"></i>
                        @Model.Count @(Model.Count == 1 ? "meeting" : "meetings")
                    </span>
                }
            </div>

            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Year</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Universities</th>
                        <th style="text-align:right; padding-right:32px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var m in Model)
                        {
                            string sc = m.Status == "Open"      ? "sb-open"
                                      : m.Status == "Closed"    ? "sb-closed"
                                      : m.Status == "Scheduled" ? "sb-scheduled"
                                      : "sb-other";
                            int uniCount = m.RequestIds?.Count ?? 0;

                            <tr onclick="window.location='/Home/SessionDashboard?id=@m.Id'">
                                <td><span class="cell-num">#@m.SessionNumber</span></td>
                                <td><span class="cell-year">@m.MeetingDate.Year</span></td>
                                <td><span class="cell-date">@m.MeetingDate.ToString("dd MMM yyyy")</span></td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(m.MeetingTime))
                                    {
                                        <span style="font-size:13.5px;font-weight:600;color:#555;">@m.MeetingTime</span>
                                    }
                                    else
                                    {
                                        <span style="color:#ccc;font-size:13px;">—</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(m.LocationOrPlatform))
                                    {
                                        <span style="font-size:13px;color:#555;">@m.LocationOrPlatform</span>
                                    }
                                    else
                                    {
                                        <span style="color:#ccc;font-size:13px;">—</span>
                                    }
                                </td>
                                <td>
                                    <span class="sbadge @sc">
                                        <span class="sdot"></span>@m.Status
                                    </span>
                                </td>
                                <td>
                                    <div class="cell-uni-count">@uniCount</div>
                                    <div class="cell-uni-lbl">@(uniCount == 1 ? "university" : "universities")</div>
                                </td>
                                <td style="text-align:right;" onclick="event.stopPropagation()">
                                    <a class="edit-btn" href="/Home/EditMeeting/@m.Id">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <button class="del-btn" onclick="confirmDelete(@m.Id, '@Html.Raw(m.SessionNumber)')">
                                        <i class="bi bi-trash3"></i> Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">
                                <div class="empty-state">
                                    <i class="bi bi-calendar2-plus"></i>
                                    <h3>No meetings yet</h3>
                                    <p>Schedule your first committee meeting to get started.</p>
                                    <a href="/Home/CreateMeeting">
                                        <i class="bi bi-plus-lg"></i> New Meeting
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- Delete confirmation modal -->
    <div class="del-overlay" id="delOverlay">
        <div class="del-modal">
            <i class="bi bi-trash3-fill"></i>
            <h3>Remove Meeting?</h3>
            <p id="delModalMsg">This will permanently delete the meeting and all its decisions. This action cannot be undone.</p>
            <div class="del-modal-btns">
                <button class="btn-cancel" onclick="closeDelete()">Cancel</button>
                <form id="delForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-confirm-del">Yes, Remove</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        function confirmDelete(id, sessionNum) {
            document.getElementById('delModalMsg').textContent =
                'This will permanently delete Meeting #' + sessionNum + ' and all its associated decisions. This cannot be undone.';
            document.getElementById('delForm').action = '/Home/DeleteMeeting/' + id;
            document.getElementById('delOverlay').classList.add('show');
        }
        function closeDelete() {
            document.getElementById('delOverlay').classList.remove('show');
        }
        document.getElementById('delOverlay').addEventListener('click', function(e) {
            if (e.target === this) closeDelete();
        });
    </script>
</body>
</html>
