@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>
@{
    ViewData["Title"] = "Meetings";
    Layout = null;
}

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />
</head>

<!-- HEADER -->
<div class="header">
    <div class="header-left">
        <img src="/images/mohelogo.png" class="logo" />
        <div class="divider"></div>

        <div class="title-box">
            <h1>Meetings</h1>
            <p>Manage and schedule discussion sessions</p>
        </div>
    </div>
</div>

<div class="main-container">

    <!-- TITLE -->
    <div class="page-head">
        <h2>Meetings</h2>
    </div>

    <!-- BUTTON -->
    <div style="margin-bottom: 20px;">
        <a asp-controller="Home" asp-action="CreateMeeting" class="action-btn">
            + Schedule Meeting
        </a>
    </div>

    <!-- TABLE -->
    <div class="table-box">
        <table>
            <thead>
                <tr>
                    <th>Session #</th>
                    <th>Date</th>
                    <th>Notes</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                <!-- Temporary data -->
                <tr>
                    <td>1</td>
                    <td>2026-05-01</td>
                    <td>Discussion about universities</td>
                    <td>
                        <a href="#" class="action-btn">View</a>
                    </td>
                </tr>
            </tbody>

        </table>
    </div>

</div>