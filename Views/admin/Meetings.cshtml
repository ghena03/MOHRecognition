@using MOHRecognition.DTOs
@model List<MeetingDto>

@{
    ViewData["Title"] = "Meetings";
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<!-- HEADER -->
<div class="header">
    <div class="header-left">
        <img src="/images/mohelogo.png" class="logo" />
        <div class="divider"></div>

        <div class="title-box">
            <h1>Meetings</h1>
            <p>Manage and schedule discussion sessions</p>
        </div>
    </div>
</div>

<div class="main-container">

    <!-- TITLE -->
    <div class="page-head">
        <h2>Meetings</h2>
    </div>

    <!-- BUTTON -->
    <div style="margin-bottom: 20px;">
        <a asp-controller="Home" asp-action="CreateMeeting" class="action-btn">
            + Schedule Meeting
        </a>
    </div>

    <!-- TABLE -->
    <div class="table-box table-box-theme2">
        <table class="meeting-theme-table">
            <thead>
                <tr>
                    <th>Session #</th>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Location / Platform</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.SessionNumber</td>
                            <td>@m.MeetingDate.ToString("yyyy-MM-dd")</td>
                            <td>@(string.IsNullOrWhiteSpace(m.MeetingTime) ? "—" : m.MeetingTime)</td>
                            <td>@(string.IsNullOrWhiteSpace(m.LocationOrPlatform) ? "—" : m.LocationOrPlatform)</td>
                            <td>
                                <a href="/Home/MeetingDetails?id=@m.Id" class="action-btn">
                                    View
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                <tr>
                    <td colspan="5" class="meeting-empty">No meetings yet</td>
                </tr>
            }
            </tbody>
        </table>
    </div>

</div>
