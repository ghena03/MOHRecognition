@using MOHRecognition.Services
@model List<RecognitionRequestRecord>

@{
    Layout = null;

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<div class="main-container decisions-page">

    <!-- HEADER -->
   
    <div class="header">
        <div class="header-left">
            <img src="~/images/mohelogo.png" class="logo" />

            <div class="title-box">
                <h1>Decisions</h1>
                <p>Final results from recognition members</p>
            </div>
        </div>
    </div>

    <!-- CARD -->
    <div class="details-card">

        <h2 class="section-title">Decisions Overview</h2>

        <table class="modern-table">
            <thead>
                <tr>
                    <th>University</th>
                    <th>Type</th>
                    <th>Decision</th>
                    <th>Notes</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in Model)
                {
                    var decisionClass = "badge-default";

                    if (r.BasicInfoAssessmentDecision == "Approve")
                        decisionClass = "badge-approve";
                    else if (r.BasicInfoAssessmentDecision == "Conditional Approval")
                        decisionClass = "badge-conditional";
                    else if (r.BasicInfoAssessmentDecision == "Reject / Committee Review")
                        decisionClass = "badge-reject";

                    <tr class="@RowClass(r.ApplicationType)">
                        <td>@r.UniversityName</td>
                        <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11.5px;font-weight:700;@AppTypeStyle(r.ApplicationType)">@(r.ApplicationType ?? "Bachelor")</span></td>
                        <td>
                            <span class="decision-badge @decisionClass">
                                @r.BasicInfoAssessmentDecision
                            </span>
                        </td>

                        <td class="note-cell">
                            @r.BasicInfoAssessmentReason
                        </td>

                        <td>
                            <a href="/Home/DecisionDetails/@r.Id" class="view-btn">
                                View
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>

</div>