@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>
@using System

@{
    Layout = null;
    ViewData["Title"] = "Requests";

    var nameMap = ViewBag.MemberNameMap as Dictionary<string, string>
                  ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    string MemberName(string? email)
    {
        if (string.IsNullOrWhiteSpace(email) || email == "Unassigned") return "Unassigned";
        var key = email.Trim().ToLowerInvariant();
        return nameMap.TryGetValue(key, out var n) ? n : email;
    }

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };

}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />
</head>

<body>

    <!-- 🔴 TOP BAR -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />
            <div class="divider"></div>

            <div class="title-box">
                <h1>Requests</h1>
                <p>Manage all submitted requests</p>
            </div>
        </div>

        <a class="back-btn" href="@Url.Action("AdminDashboard", "Home")">← Back to Dashboard</a>
    </div>

    <!-- MAIN -->
    <div class="main-container">

        <!-- TITLE ROW -->
        <div class="page-head">
            <h2>All Requests</h2>
        </div>

        <!-- FILTERS -->
        <div class="table-box" style="padding:16px 20px;margin-bottom:0;border-bottom:none;border-radius:12px 12px 0 0;">
            <div style="display:flex;gap:12px;flex-wrap:wrap;align-items:flex-end;">
                <div style="display:flex;flex-direction:column;gap:4px;flex:1;min-width:160px;">
                    <label style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.4px;">Search</label>
                    <input id="req-search" type="text" placeholder="University, reference, country…"
                           style="border:1px solid #ddd;border-radius:8px;padding:8px 12px;font-size:13px;font-family:inherit;" oninput="filterRequests()" />
                </div>
                <div style="display:flex;flex-direction:column;gap:4px;min-width:140px;">
                    <label style="font-size:11px;font-weight:700;color:#6b7280;text-transform:uppercase;letter-spacing:.4px;">Status</label>
                    <select id="req-status" style="border:1px solid #ddd;border-radius:8px;padding:8px 12px;font-size:13px;font-family:inherit;" onchange="filterRequests()">
                        <option value="">All Statuses</option>
                        <option>Pending</option>
                        <option>Assigned</option>
                        <option>Requires Admin Review</option>
                        <option>Under Review</option>
                        <option>Approved</option>
                        <option>Rejected</option>
                    </select>
                </div>
                <button type="button" onclick="document.getElementById('req-search').value='';document.getElementById('req-status').value='';filterRequests();"
                        class="action-btn" style="height:36px;">Clear</button>
            </div>
        </div>

        <!-- TABLE -->
        <div class="table-box">

            <table>
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Type</th>
                        <th>Applicant</th>
                        <th>University</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody id="req-tbody">
                    @foreach (var item in Model)
                    {
                        <tr data-search="@((item.ReferenceNumber + " " + item.UniversityName + " " + item.Country + " " + item.ApplicantName + " " + item.ApplicationType).ToLower())"
                            data-status="@item.Status.ToLower()"
                            class="@RowClass(item.ApplicationType)">
                            <td>@item.ReferenceNumber</td>
                            <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11.5px;font-weight:700;@AppTypeStyle(item.ApplicationType)">@(item.ApplicationType ?? "Bachelor")</span></td>
                            <td>@item.ApplicantName</td>
                            <td>@item.UniversityName</td>
                            <td>@item.Country</td>
                            <td>@item.Status</td>
                            <td>@MemberName(item.AssignedMember)</td>

                            <td style="display:flex;gap:6px;align-items:center">
                                <a asp-controller="Home"
                                   asp-action="AdminRequestDetails"
                                   asp-route-id="@item.Id"
                                   class="action-btn">
                                    View
                                </a>
                                <a asp-controller="Home"
                                   asp-action="AdminFullApplicationView"
                                   asp-route-id="@item.Id"
                                   class="action-btn"
                                   style="background:#7f1627;color:#fff;border-color:#7f1627">
                                    Full Application
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>

<script>
    function filterRequests() {
        var q = (document.getElementById('req-search').value || '').toLowerCase();
        var s = (document.getElementById('req-status').value || '').toLowerCase();
        document.querySelectorAll('#req-tbody tr').forEach(function (row) {
            var search = (row.dataset.search || '').toLowerCase();
            var status = (row.dataset.status || '').toLowerCase();
            var show = (!q || search.includes(q)) && (!s || status === s);
            row.style.display = show ? '' : 'none';
        });
    }
</script>
</body>
</html>