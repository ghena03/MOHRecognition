@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>

@{
    Layout = null;
    ViewData["Title"] = "Requests";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />
</head>

<body>

    <!-- 🔴 TOP BAR -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />
            <div class="divider"></div>

            <div class="title-box">
                <h1>Requests</h1>
                <p>Manage all submitted requests</p>
            </div>
        </div>

        <a class="back-btn" href="@Url.Action("AdminDashboard", "Home")">← Back to Dashboard</a>
    </div>

    <!-- MAIN -->
    <div class="main-container">

        <!-- TITLE ROW -->
        <div class="page-head">
            <h2>All Requests</h2>
        </div>

        <!-- TABLE -->
        <div class="table-box">

            <table>
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Applicant</th>
                        <th>University</th>
                        <th>Country</th>
                        <th>Status</th>
                        <th>Assigned To</th>
                        <th>Action</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ReferenceNumber</td>
                            <td>@item.ApplicantName</td>
                            <td>@item.UniversityName</td>
                            <td>@item.Country</td>
                            <td>@item.Status</td>
                            <td>@item.AssignedMember</td>

                            <td style="display:flex;gap:6px;align-items:center">
                                <a asp-controller="Home"
                                   asp-action="AdminRequestDetails"
                                   asp-route-id="@item.Id"
                                   class="action-btn">
                                    View
                                </a>
                                <a asp-controller="Home"
                                   asp-action="AdminFullApplicationView"
                                   asp-route-id="@item.Id"
                                   class="action-btn"
                                   style="background:#7f1627;color:#fff;border-color:#7f1627">
                                    Full Application
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>

    </div>

</body>
</html>