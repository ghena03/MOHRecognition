@using MOHRecognition.Services
@{
    ViewData["Title"] = "Create Meeting";
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<!-- HEADER -->
<div class="header">
    <div class="header-left">
        <img src="~/images/mohelogo.png" class="logo" />
        <div class="header-text">
            <h1>Create meeting</h1>
        </div>
    </div>

    <a class="back-btn" href="@Url.Action("Requests", "Home")">← Back</a>
</div>
<div class="main-container">

    <!-- TITLE -->
    <div class="page-head">
        <h2>Schedule Meeting</h2>
    </div>

    <!-- FORM CARD -->
    <div class="details-card">

        <form method="post" action="/Home/CreateMeeting">

            <!-- SELECT REQUESTS -->
            <div style="margin-bottom:20px;">
                <h4>Select related requests (universities)</h4>

                @{
                    var requests = ViewBag.AvailableRequests as IEnumerable<RecognitionRequestRecord>
                    ?? Enumerable.Empty<RecognitionRequestRecord>();
                }

                @foreach (var req in requests)
                {
                    <div style="margin-bottom:5px;">
                        <label>
                            <input type="checkbox" name="RequestIds" value="@req.Id" />
                            @req.UniversityName
                        </label>
                    </div>
                }
            </div>

            <div class="details-grid">
                <div style="grid-column: span 2;">
                    <label>Meeting Title</label>
                    <input type="text" name="MeetingTitle" class="mini-select" placeholder="Committee review meeting" required />
                </div>

                <!-- SESSION -->
                <div>
                    <label>Session Number</label>
                    <input type="text" name="SessionNumber" value="@(ViewBag.NextSessionNumber ?? 1)" readonly class="mini-select" />
                </div>

                <!-- DATE -->
                <div>
                    <label>Date</label>
                    <input type="date" name="MeetingDate" class="mini-select" required />
                </div>

                <div>
                    <label>Time</label>
                    <input type="time" name="MeetingTime" class="mini-select" />
                </div>

                <div>
                    <label>Location / Platform</label>
                    <input type="text" name="LocationOrPlatform" class="mini-select" placeholder="MOHE Hall / Zoom / Teams" />
                </div>

                <!-- NOTES -->
                <div style="grid-column: span 2;">
                    <label>Notes</label>
                    <textarea name="Notes" class="mini-select" rows="4" style="width:100%;"></textarea>
                </div>

            </div>

            <div style="margin-top:20px;">
                <button type="submit" class="mini-save-btn">
                    Save Meeting
                </button>
            </div>

        </form>

    </div>

</div>
