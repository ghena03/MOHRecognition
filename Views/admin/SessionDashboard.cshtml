@using MOHRecognition.DTOs
@using MOHRecognition.Services
@model MeetingDto
@{
    var employees    = (ViewBag.Employees as List<EmployeeDto> ?? new List<EmployeeDto>())
                       .OrderBy(e => e.Workplace == "Ministry of Higher Education and Scientific Research" ? 0 : 1)
                       .ToList();
    var attendanceRaw = ViewBag.Attendance as Dictionary<int, bool> ?? new Dictionary<int, bool>();
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}

@{
    ViewData["Title"] = "Meeting Workspace";
    Layout = null;

    var linkedRequests = ViewBag.LinkedRequests as List<RecognitionRequestRecord> ?? new List<RecognitionRequestRecord>();
    var decisions      = ViewBag.Decisions as Dictionary<(int, int), MeetingDecisionDto>;

    int meetingId    = Model.Id;
    int total        = linkedRequests.Count;
    int decidedCount = 0;
    foreach (var r in linkedRequests)
    {
        MeetingDecisionDto? d = null;
        decisions?.TryGetValue((meetingId, r.Id), out d);
        if (d != null && !string.IsNullOrWhiteSpace(d.Decision)) decidedCount++;
    }
    int pending = total - decidedCount;
    int pct     = total > 0 ? decidedCount * 100 / total : 0;

    bool isClosed = Model.Status == "Closed";

    string sb = Model.Status == "Open"      ? "sb-open"
              : Model.Status == "Closed"    ? "sb-closed"
              : Model.Status == "Scheduled" ? "sb-scheduled"
              : "sb-other";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Meeting #@Model.SessionNumber — إدارة الجلسات</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f3f0eb;
            color: #1a1a1a;
            min-height: 100vh;
        }

        .ministry-bar {
            background: #5a0e1b;
            color: rgba(255,255,255,.68);
            font-size: 11.5px; font-weight: 500; letter-spacing: .4px;
            padding: 6px 48px;
            display: flex; align-items: center; gap: 6px;
        }

        .pg-header {
            background: #7f1627; color: #fff;
            padding: 0 48px; height: 66px;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: 0 2px 18px rgba(127,22,39,.32);
        }
        .hd-left { display: flex; align-items: center; gap: 16px; }
        .pg-header img { height: 42px; }
        .hd-sep { width: 1px; height: 34px; background: rgba(255,255,255,.28); margin: 0 6px; }
        .hd-text h1 { font-size: 17px; font-weight: 700; }
        .hd-text p  { font-size: 11.5px; opacity: .72; margin-top: 2px; }
        .btn-back {
            display: inline-flex; align-items: center; gap: 7px;
            background: rgba(255,255,255,.15); color: #fff;
            border: 1.5px solid rgba(255,255,255,.35);
            border-radius: 8px; padding: 8px 18px;
            font-size: 13px; font-weight: 600;
            text-decoration: none; transition: background .15s;
        }
        .btn-back:hover { background: rgba(255,255,255,.25); }

        .breadcrumb-bar {
            background: #fff; border-bottom: 1px solid #ece5dd;
            padding: 0 48px; height: 44px;
            display: flex; align-items: center;
        }
        .bc-item {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 12.5px; font-weight: 600; color: #999; text-decoration: none;
        }
        .bc-item:hover { color: #7f1627; }
        .bc-sep { font-size: 12px; color: #ccc; margin: 0 10px; }
        .bc-current { color: #7f1627; font-weight: 700; }

        /* ── Meeting info banner ── */
        .info-banner {
            background: #fff;
            border-bottom: 3px solid #7f1627;
            padding: 28px 48px 0;
        }
        .ib-top {
            display: flex; align-items: flex-start;
            justify-content: space-between;
            gap: 24px; flex-wrap: wrap; margin-bottom: 20px;
        }
        .ib-session-num {
            font-size: 13px; font-weight: 800; color: #7f1627;
            text-transform: uppercase; letter-spacing: .6px; margin-bottom: 6px;
        }
        .ib-title { font-size: 26px; font-weight: 900; color: #1a1a1a; }
        .ib-meta  { display: flex; gap: 20px; flex-wrap: wrap; margin-top: 10px; }
        .ib-meta-item { display: flex; align-items: center; gap: 5px; font-size: 13px; color: #777; }
        .ib-meta-item i { font-size: 13px; color: #7f1627; }

        .sbadge { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; border-radius: 20px; font-size: 12.5px; font-weight: 700; }
        .sdot { width: 7px; height: 7px; border-radius: 50%; }
        .sb-open      { background: #e8f5ea; color: #1a7a34; } .sb-open      .sdot { background: #1a7a34; }
        .sb-scheduled { background: #e8f0fe; color: #1a56db; } .sb-scheduled .sdot { background: #1a56db; }
        .sb-closed    { background: #f0f0f0; color: #777; }    .sb-closed    .sdot { background: #aaa; }
        .sb-other     { background: #fff3cd; color: #856404; } .sb-other     .sdot { background: #856404; }

        .stats-strip {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            border-top: 1px solid #f0ebe4;
        }
        .stat-cell {
            padding: 16px 24px;
            border-right: 1px solid #f0ebe4;
            text-align: center;
        }
        .stat-cell:last-child { border-right: none; }
        .stat-val { font-size: 24px; font-weight: 900; color: #7f1627; line-height: 1; }
        .stat-lbl { font-size: 11px; font-weight: 700; color: #bbb; text-transform: uppercase; letter-spacing: .6px; margin-top: 4px; }

        /* ── Body ── */
        .pg-body { max-width: 1160px; margin: 0 auto; padding: 36px 24px 80px; }

        .sec-hd { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
        .sec-lbl { font-size: 11.5px; font-weight: 800; color: #bbb; text-transform: uppercase; letter-spacing: 1px; }

        /* Progress bar */
        .prog-wrap { margin-bottom: 20px; }
        .prog-row { display: flex; justify-content: space-between; align-items: center; font-size: 12px; font-weight: 700; color: #aaa; margin-bottom: 7px; }
        .prog-pct { color: @(pct == 100 ? "#1a7a34" : "#7f1627"); font-size: 14px; font-weight: 800; }
        .prog-track { height: 7px; background: #f0ebe4; border-radius: 10px; overflow: hidden; }
        .prog-fill  { height: 100%; border-radius: 10px; background: linear-gradient(90deg, #7f1627, #b03050); width: @pct%; }
        .prog-fill.full { background: linear-gradient(90deg, #1a7a34, #2da84e); }

        /* ── University cards ── */
        .uni-list { display: flex; flex-direction: column; gap: 14px; }

        .uni-card {
            background: #fff;
            border-radius: 14px;
            box-shadow: 0 2px 14px rgba(0,0,0,.06);
            overflow: hidden;
            border-left: 5px solid #e0d0d4;
            transition: border-color .15s;
        }
        .uni-card:hover { border-left-color: #7f1627; }
        .uni-card.decided { border-left-color: #1a7a34; }
        .uni-card.decided:hover { border-left-color: #1a7a34; }

        .uni-inner {
            display: flex;
            align-items: center;
            gap: 0;
            padding: 22px 26px;
        }

        .uni-idx { font-size: 20px; font-weight: 900; color: #d4bec4; width: 44px; text-align: center; flex-shrink: 0; }

        .uni-info { flex: 1; padding: 0 24px 0 8px; border-right: 1px solid #f0ebe4; }
        .uni-name { font-size: 15px; font-weight: 800; color: #1a1a1a; margin-bottom: 5px; }
        .uni-sub  { font-size: 12px; color: #aaa; display: flex; gap: 12px; flex-wrap: wrap; }
        .uni-sub-item { display: flex; align-items: center; gap: 4px; }
        .uni-sub-item i { font-size: 11px; }

        .uni-dec { width: 160px; padding: 0 20px; border-right: 1px solid #f0ebe4; flex-shrink: 0; }
        .uni-dec-lbl { font-size: 10px; font-weight: 800; color: #bbb; text-transform: uppercase; letter-spacing: .7px; margin-bottom: 6px; }

        .dec-badge { display: inline-flex; align-items: center; gap: 5px; padding: 5px 12px; border-radius: 20px; font-size: 11.5px; font-weight: 700; }
        .dec-recognized     { background: #e8f5ea; color: #1a7a34; }
        .dec-not-recognized { background: #fde8e8; color: #b91c1c; }
        .dec-needs-more     { background: #fff3cd; color: #856404; }
        .dec-pending        { background: #f4f1ec; color: #bbb; font-style: italic; font-weight: 500; }

        .uni-actions { padding-left: 22px; display: flex; flex-direction: column; gap: 8px; align-items: flex-end; min-width: 200px; flex-shrink: 0; }

        .btn-action {
            display: inline-flex; align-items: center; gap: 6px;
            border-radius: 8px; padding: 7px 14px;
            font-size: 12px; font-weight: 600;
            text-decoration: none; white-space: nowrap; transition: background .12s;
            border: 1.5px solid transparent;
        }
        .btn-view-app  { background: #f0f5ff; color: #1a56db; border-color: #c5d8f8; }
        .btn-view-app:hover { background: #deeafc; }
        .btn-doctors   { background: #f0fbf4; color: #1a7a34; border-color: #b8e8c8; }
        .btn-doctors:hover { background: #ddf5e7; }
        .btn-decide    { background: #7f1627; color: #fff; border-color: #7f1627; font-weight: 700; }
        .btn-decide:hover { background: #6a1020; }
        .btn-edit-dec  { background: #fff; color: #7f1627; border-color: #d0a0b0; font-weight: 700; }
        .btn-edit-dec:hover { background: #fdf0f2; }

        /* ── Empty state ── */
        .empty-wrap {
            background: #fff; border-radius: 14px;
            box-shadow: 0 2px 14px rgba(0,0,0,.06);
            padding: 64px 32px; text-align: center;
        }
        .empty-wrap i  { font-size: 52px; color: #d4bec4; display: block; margin-bottom: 18px; }
        .empty-wrap h3 { font-size: 18px; font-weight: 700; color: #555; margin-bottom: 8px; }
        .empty-wrap p  { font-size: 13.5px; color: #aaa; line-height: 1.7; max-width: 420px; margin: 0 auto; }

        /* ── Close meeting ── */
        .close-footer {
            margin-top: 48px;
            padding-top: 28px;
            border-top: 1px solid #e8e0d8;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .close-note { font-size: 12.5px; color: #bbb; }
        .btn-close-meeting {
            display: inline-flex; align-items: center; gap: 8px;
            background: #fff; color: #b91c1c;
            border: 2px solid #f0c0c0; border-radius: 10px;
            padding: 11px 24px; font-size: 14px; font-weight: 700;
            cursor: pointer; font-family: inherit; transition: background .15s, border-color .15s;
        }
        .btn-close-meeting:hover { background: #fde8e8; border-color: #e07070; }
        .session-closed-note {
            display: inline-flex; align-items: center; gap: 8px;
            background: #f0f0f0; color: #888;
            border-radius: 10px; padding: 11px 24px;
            font-size: 14px; font-weight: 700;
        }

        /* ── Attendance card ── */
        .attend-card {
            background: #fff;
            border: 1px solid #e8e0d8;
            border-top: 3px solid #7f1627;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
            margin-bottom: 28px;
            overflow: hidden;
        }
        .attend-hd {
            display: flex; align-items: center; justify-content: space-between;
            padding: 15px 22px; gap: 12px; flex-wrap: wrap;
            background: #faf8f6; border-bottom: 1px solid #ede7e0;
        }
        .attend-hd-left { display: flex; align-items: center; gap: 10px; }
        .attend-hd-icon { font-size: 15px; color: #7f1627; }
        .attend-hd-title { font-size: 13.5px; font-weight: 800; color: #1a1a1a; letter-spacing: .1px; }
        .attend-pill {
            display: inline-flex; align-items: center; gap: 4px;
            background: #fff; color: #7f1627;
            border: 1px solid #e0c8cc; border-radius: 6px;
            padding: 3px 10px; font-size: 12px; font-weight: 800;
        }
        .attend-hd-right { display: flex; gap: 8px; }
        .btn-att {
            display: inline-flex; align-items: center; gap: 6px;
            border-radius: 7px; padding: 6px 14px;
            font-size: 12px; font-weight: 700; cursor: pointer;
            font-family: inherit; transition: all .15s; white-space: nowrap;
        }
        .btn-att-ghost { background: #fff; color: #666; border: 1px solid #ddd; }
        .btn-att-ghost:hover { background: #f5f5f5; border-color: #bbb; color: #333; }
        .btn-att-primary { background: #7f1627; color: #fff; border: 1px solid #7f1627; }
        .btn-att-primary:hover { background: #6a1020; border-color: #6a1020; }

        .attend-prog-track { height: 3px; background: #f0ebe4; }
        .attend-prog-fill  { height: 100%; background: linear-gradient(90deg,#7ba7d4,#4f7fbf); transition: width .4s ease; }

        .attend-grid { display: grid; grid-template-columns: repeat(3,1fr); }
        .attend-row {
            display: flex; align-items: flex-start; gap: 13px;
            padding: 14px 20px 14px 17px;
            border-left: 3px solid transparent;
            border-right: 1px solid #f0ebe4;
            border-bottom: 1px solid #f0ebe4;
            cursor: pointer; transition: background .14s, border-left-color .14s;
            user-select: none;
        }
        .attend-row:nth-child(3n) { border-right: none; }
        .attend-row:hover { background: #faf8f6; }
        .attend-row input[type=checkbox] { display: none; }

        .attend-cb {
            width: 17px; height: 17px; border-radius: 4px; flex-shrink: 0; margin-top: 1px;
            border: 1.5px solid #ccc; background: #fff;
            display: flex; align-items: center; justify-content: center;
            transition: all .15s;
        }
        .attend-cb i { font-size: 10px; color: #fff; display: none; }

        .attend-text { flex: 1; min-width: 0; }
        .attend-name { font-size: 13px; font-weight: 700; color: #222; line-height: 1.4; }
        .attend-org  { font-size: 11px; color: #aaa; margin-top: 2px; }

        /* Present */
        .attend-row.present { background: #f0f5fc; border-left-color: #5b87c8; }
        .attend-row.present .attend-cb { background: #4f7fbf; border-color: #4f7fbf; }
        .attend-row.present .attend-cb i { display: block; }
        .attend-row.present .attend-name { color: #1a3560; }
        .attend-row.present .attend-org  { color: #90aed4; }

        /* ── Modal ── */
        .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 600; align-items: center; justify-content: center; }
        .modal-overlay.open { display: flex; }
        .modal-box { background: #fff; border-radius: 18px; padding: 44px 48px 38px; max-width: 420px; width: 100%; text-align: center; box-shadow: 0 20px 60px rgba(0,0,0,.22); }
        .modal-icon  { font-size: 42px; color: #b91c1c; margin-bottom: 18px; }
        .modal-title { font-size: 20px; font-weight: 800; margin-bottom: 10px; }
        .modal-body  { font-size: 13.5px; color: #888; line-height: 1.7; margin-bottom: 30px; }
        .modal-actions { display: flex; gap: 12px; }
        .btn-mc { flex: 1; padding: 12px; border: 1.5px solid #d0d0d0; border-radius: 9px; background: #fff; color: #555; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }
        .btn-mc:hover { border-color: #7f1627; color: #7f1627; }
        .btn-mconf { flex: 1; padding: 12px; border: none; border-radius: 9px; background: #b91c1c; color: #fff; font-size: 14px; font-weight: 700; cursor: pointer; font-family: inherit; }
        .btn-mconf:hover { background: #991b1b; }

        /* Application type — colored left border indicator */
        tr.app-row-bachelor td:first-child    { border-left: 5px solid #3b82f6 !important; padding-left: 11px !important; }
        tr.app-row-postgraduate td:first-child { border-left: 5px solid #8b5cf6 !important; padding-left: 11px !important; }
        tr.app-row-online td:first-child       { border-left: 5px solid #10b981 !important; padding-left: 11px !important; }
        .app-row-bachelor    { border-left: 5px solid #3b82f6 !important; }
        .app-row-postgraduate { border-left: 5px solid #8b5cf6 !important; }
        .app-row-online       { border-left: 5px solid #10b981 !important; }
    </style>
</head>
<body>

    <div class="ministry-bar">
        <i class="bi bi-bank2"></i>
        Ministry of Higher Education and Scientific Research — Hashemite Kingdom of Jordan
    </div>

    <div class="pg-header">
        <div class="hd-left">
            <img src="/images/mohelogo.png" alt="Logo" />
            <div class="hd-sep"></div>
            <div class="hd-text">
                <h1>إدارة الجلسات</h1>
                <p>Committee Working Area</p>
            </div>
        </div>
        <a href="/Home/SessionWorkflow" class="btn-back">
            <i class="bi bi-arrow-left"></i> إدارة الجلسات
        </a>
    </div>


    <!-- Meeting Info Banner -->
    <div class="info-banner">
        <div class="ib-top">
            <div>
                <div class="ib-session-num">Meeting #@Model.SessionNumber</div>
                <div class="ib-title">
                    @(string.IsNullOrWhiteSpace(Model.MeetingTitle)
                        ? "Committee Meeting — " + Model.MeetingDate.ToString("dd MMMM yyyy")
                        : Model.MeetingTitle)
                </div>
                <div class="ib-meta">
                    <div class="ib-meta-item"><i class="bi bi-calendar3"></i> @Model.MeetingDate.ToString("dd MMMM yyyy")</div>
                    @if (!string.IsNullOrWhiteSpace(Model.MeetingTime))
                    {
                        <div class="ib-meta-item"><i class="bi bi-clock"></i> @Model.MeetingTime</div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.LocationOrPlatform))
                    {
                        <div class="ib-meta-item"><i class="bi bi-geo-alt"></i> @Model.LocationOrPlatform</div>
                    }
                </div>
            </div>
            <span class="sbadge @sb"><span class="sdot"></span>@Model.Status</span>
        </div>
        <div class="stats-strip">
            <div class="stat-cell">
                <div class="stat-val">@total</div>
                <div class="stat-lbl">Universities</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@decidedCount</div>
                <div class="stat-lbl">Decided</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@pending</div>
                <div class="stat-lbl">Pending</div>
            </div>
            <div class="stat-cell">
                <div class="stat-val">@pct%</div>
                <div class="stat-lbl">Complete</div>
            </div>
        </div>
    </div>

    <div class="pg-body">

        @{
            int presentCount = attendanceRaw.Count(kvp => kvp.Value);
            int totalMembers = employees.Count;
            int attendPct    = totalMembers > 0 ? presentCount * 100 / totalMembers : 0;
        }
        <!-- Attendance Card -->
        <div class="attend-card" id="attendCard">
            <div class="attend-hd">
                <div class="attend-hd-left">
                    <i class="bi bi-people-fill attend-hd-icon"></i>
                    <span class="attend-hd-title">Attendance</span>
                    <span class="attend-pill">
                        <i class="bi bi-person-check"></i>
                        <span id="presentNum">@presentCount</span> / @totalMembers present
                    </span>
                </div>
                <div class="attend-hd-right">
                    <button class="btn-att btn-att-ghost" onclick="setAllAttendance(false)">
                        <i class="bi bi-x-lg"></i> Clear All
                    </button>
                    <button class="btn-att btn-att-primary" onclick="setAllAttendance(true)">
                        <i class="bi bi-check2-all"></i> Mark All Present
                    </button>
                </div>
            </div>
            <div class="attend-prog-track">
                <div class="attend-prog-fill" id="attendProgFill" style="width:@attendPct%"></div>
            </div>
            <div class="attend-grid">
                @foreach (var emp in employees)
                {
                    bool isPresent = attendanceRaw.TryGetValue(emp.Id, out var ap) && ap;
                    <label class="attend-row @(isPresent ? "present" : "")" id="attend-item-@emp.Id">
                        <input type="checkbox" id="chk-@emp.Id" data-emp-id="@emp.Id"
                               @(isPresent ? "checked" : "")
                               onchange="toggleAttendance(@emp.Id, this.checked)" />
                        <div class="attend-cb"><i class="bi bi-check-lg"></i></div>
                        <div class="attend-text">
                            <div class="attend-name">@emp.Name</div>
                            <div class="attend-org">@emp.Workplace</div>
                        </div>
                    </label>
                }
            </div>
        </div>

        <div class="sec-hd">
            <div class="sec-lbl"><i class="bi bi-building" style="font-size:13px;color:#7f1627;margin-right:6px;"></i>Universities Discussed in this Meeting</div>
        </div>

        @if (total > 0)
        {
            <div class="prog-wrap">
                <div class="prog-row">
                    <span>Decision Progress</span>
                    <span class="prog-pct">@decidedCount / @total decisions recorded</span>
                </div>
                <div class="prog-track">
                    <div class="prog-fill @(pct == 100 ? "full" : "")"></div>
                </div>
            </div>

            <div class="uni-list">
                @{
                    int rowNum = 1;
                    foreach (var r in linkedRequests)
                    {
                        MeetingDecisionDto? dec = null;
                        decisions?.TryGetValue((meetingId, r.Id), out dec);
                        bool hasDecision = dec != null && !string.IsNullOrWhiteSpace(dec.Decision);

                        string decBadge = "dec-pending";
                        string decLabel = "Pending";
                        if (hasDecision)
                        {
                            switch (dec!.Decision)
                            {
                                case "Recognized":             decBadge = "dec-recognized";     decLabel = "Recognized";       break;
                                case "Not Recognized":         decBadge = "dec-not-recognized"; decLabel = "Not Recognized";   break;
                                case "Needs More Information": decBadge = "dec-needs-more";     decLabel = "Needs More Info";  break;
                                default: decLabel = dec.Decision; break;
                            }
                        }

                        <div class="uni-card @(hasDecision ? "decided" : "") @RowClass(r.ApplicationType)">
                            <div class="uni-inner">
                                <div class="uni-idx">@rowNum</div>

                                <div class="uni-info">
                                    <div class="uni-name" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;">
                                        @(string.IsNullOrWhiteSpace(r.UniversityName) ? "Unnamed University" : r.UniversityName)
                                        @{
                                            var sdAtStyle = (r.ApplicationType ?? "Bachelor") switch
                                            {
                                                "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
                                                "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
                                                _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
                                            };
                                        }
                                        <span style="display:inline-block;border-radius:20px;padding:2px 9px;font-size:10.5px;font-weight:700;@sdAtStyle">@(r.ApplicationType ?? "Bachelor")</span>
                                    </div>
                                    <div class="uni-sub">
                                        @if (!string.IsNullOrWhiteSpace(r.Country))
                                        {
                                            <span class="uni-sub-item"><i class="bi bi-geo-alt"></i> @r.Country</span>
                                        }
                                        <span class="uni-sub-item"><i class="bi bi-hash"></i> Request ID: @r.Id</span>
                                        @if (!string.IsNullOrWhiteSpace(r.ReferenceNumber))
                                        {
                                            <span class="uni-sub-item"><i class="bi bi-file-text"></i> Ref: @r.ReferenceNumber</span>
                                        }
                                    </div>
                                </div>

                                <div class="uni-dec">
                                    <div class="uni-dec-lbl">Final Decision</div>
                                    <span class="dec-badge @decBadge">@decLabel</span>
                                </div>

                                <div class="uni-actions">
                                    <a class="btn-action btn-view-app" href="/Home/AdminMeetingApplicationView?requestId=@r.Id&meetingId=@meetingId">
                                        <i class="bi bi-eye"></i> View Application
                                    </a>
                                </div>
                            </div>
                        </div>

                        rowNum++;
                    }
                }
            </div>
        }
        else
        {
            <div class="empty-wrap">
                <i class="bi bi-journal-x"></i>
                <h3>No Universities Linked</h3>
                <p>No university requests have been linked to this meeting. Go to <strong>Meetings</strong> to edit this meeting and select the universities to be discussed.</p>
            </div>
        }

        <!-- Close Meeting -->
        <div class="close-footer">
            <span class="close-note">
                @if (isClosed)
                {
                    <span>This meeting has been officially closed and finalized.</span>
                }
                else
                {
                    <span>After all decisions are recorded, you can officially close this meeting.</span>
                }
            </span>
            @if (!isClosed)
            {
                var allDecided = total > 0 && decidedCount == total;
                if (allDecided)
                {
                    <button class="btn-close-meeting" onclick="document.getElementById('closeModal').classList.add('open')">
                        <i class="bi bi-lock-fill"></i> Close Meeting
                    </button>
                }
                else
                {
                    <div style="display:flex; flex-direction:column; align-items:flex-end; gap:6px;">
                        <button class="btn-close-meeting" disabled
                                style="opacity:.4; cursor:not-allowed; pointer-events:none;">
                            <i class="bi bi-lock-fill"></i> Close Meeting
                        </button>
                        <span style="font-size:12px; color:#b91c1c; font-weight:600;">
                            <i class="bi bi-exclamation-circle"></i>
                            @(total - decidedCount) decision@(total - decidedCount == 1 ? "" : "s") still pending — record all before closing.
                        </span>
                    </div>
                }
            }
            else
            {
                <span class="session-closed-note">
                    <i class="bi bi-lock-fill"></i> Meeting Closed
                </span>
            }
        </div>

    </div>

    <!-- Close confirmation modal -->
    <div class="modal-overlay" id="closeModal">
        <div class="modal-box">
            <div class="modal-icon"><i class="bi bi-lock-fill"></i></div>
            <div class="modal-title">Close Meeting #@Model.SessionNumber?</div>
            <div class="modal-body">
                This will officially finalize and close the meeting.<br>
                All decisions will be locked. This action cannot be undone.
            </div>
            <div class="modal-actions">
                <button class="btn-mc" onclick="document.getElementById('closeModal').classList.remove('open')">Cancel</button>
                <button class="btn-mconf" onclick="document.getElementById('closeForm').submit()">Close Meeting</button>
            </div>
        </div>
    </div>

    <form id="closeForm" method="post" action="/Home/CloseMeeting" style="display:none;">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
    </form>

    <script>
        document.getElementById('closeModal').addEventListener('click', function (e) {
            if (e.target === this) this.classList.remove('open');
        });

        var _meetingId = @Model.Id;

        function toggleAttendance(empId, present) {
            var item = document.getElementById('attend-item-' + empId);
            if (present) item.classList.add('present');
            else         item.classList.remove('present');
            updatePill();
            fetch('/Home/ToggleAttendance', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: 'meetingId=' + _meetingId + '&employeeId=' + empId + '&present=' + present
            });
        }

        function setAllAttendance(present) {
            var checkboxes = document.querySelectorAll('#attendCard input[type=checkbox]');
            checkboxes.forEach(function(cb) {
                if (cb.checked !== present) {
                    cb.checked = present;
                    toggleAttendance(parseInt(cb.dataset.empId), present);
                }
            });
        }

        function updatePill() {
            var checkboxes = document.querySelectorAll('#attendCard input[type=checkbox]');
            var count = 0;
            checkboxes.forEach(function(cb) { if (cb.checked) count++; });
            document.getElementById('presentNum').textContent = count;
            var pct = checkboxes.length > 0 ? Math.round(count * 100 / checkboxes.length) : 0;
            document.getElementById('attendProgFill').style.width = pct + '%';
        }
    </script>
</body>
</html>
