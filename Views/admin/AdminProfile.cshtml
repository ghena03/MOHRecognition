@model DTOs.AdminProfileDto

@{
    ViewData["Title"] = "Admin Profile";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Admin Profile</title>

    <link rel="stylesheet"
          href="~/css/admin/AdminProfile.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/css/admin/AdminDashboard.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>

<body>

    <!-- TOP BAR -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">

        <div class="header-left">

            <img src="/images/mohelogo.png"
                 class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Admin Profile</h1>
            </div>

        </div>

        <a class="back-btn"
           href="@Url.Action("AdminDashboard", "Home")">

            ← Back to Dashboard

        </a>

    </div>

   
    @if (TempData["ProfileSuccess"] != null)
    {
        <div class="success-alert">

            <i class="bi bi-check-circle-fill"></i>

            @TempData["ProfileSuccess"]

        </div>
    }

   
    <!-- MAIN -->
    <div class="profile-container">

        <!-- PROFILE HEADER -->
        <div class="profile-header">

            <div class="profile-avatar">

                @Model.Username.Substring(0, 1).ToUpper()

            </div>

            <div class="profile-name">
                <h1>@Model.Username</h1>
                <p>System Administrator</p>
            </div>

        </div>

        <!-- GRID -->
        <div class="profile-grid">

            <!-- ACCOUNT INFO -->
            <div class="profile-card">

                <div class="card-top">

                    <h3>Account Information</h3>

                    <button type="button"
                            class="edit-btn"
                            onclick="toggleEditMode()">

                        <i class="bi bi-pencil-square"></i>
                        Edit

                    </button>

                </div>

                <form method="post"
                      asp-action="SaveProfile">

                    <!-- USERNAME -->
                    <div class="info-row">

                        <div class="info-label">
                            Username
                        </div>

                        <input type="text"
                               id="usernameInput"
                               asp-for="Username"
                               class="profile-input"
                               disabled />

                    </div>

                    <!-- EMAIL -->
                    <div class="info-row">

                        <div class="info-label">
                            Email
                        </div>

                        <input type="email"
                               id="emailInput"
                               asp-for="Email"
                               class="profile-input"
                               disabled />

                    </div>

                    <!-- PHONE -->
                    <div class="info-row">

                        <div class="info-label">
                            Phone Number
                        </div>

                        <input type="text"
                               id="phoneInput"
                               asp-for="PhoneNumber"
                               class="profile-input"
                               disabled />

                    </div>

                    <!-- SAVE BUTTON -->
                    <button type="submit"
                            id="saveBtn"
                            class="save-btn"
                            style="display:none;">

                        <i class="bi bi-check-circle"></i>
                        Save Changes

                    </button>

                </form>

            </div>

            <!-- SYSTEM INFO -->
            <div class="profile-card">

                <h3>System Information</h3>

                <div class="info-row">

                    <div class="info-label">
                        Access Level
                    </div>

                    <div class="info-value">
                        Full Access
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Department
                    </div>

                    <div class="info-value">
                        Recognition Committee
                    </div>

                </div>

                <div class="info-row">

                    <div class="info-label">
                        Status
                    </div>

                    <div class="info-value">
                        Active
                    </div>

                </div>

            </div>

            <!-- PASSWORD -->
            <div class="profile-card password-card">

                <button class="toggle-password-btn"
                        type="button"
                        onclick="togglePasswordSection()">

                    <i class="bi bi-shield-lock"></i>
                    Change Password

                </button>

                <form method="post"
                      asp-action="UpdatePassword">
                    <div id="passwordSection"
                         class="password-section"
                         style="display:@(TempData["Error"] != null || TempData["Success"] != null ? "block" : "none");">

                        @if (TempData["Error"] != null)
                        {
                            <div class="password-error">

                                <i class="bi bi-exclamation-triangle-fill"></i>

                                @TempData["Error"]

                            </div>
                        }

                        @if (TempData["Success"] != null)
                        {
                            <div class="password-success">

                                <i class="bi bi-check-circle-fill"></i>

                                @TempData["Success"]

                            </div>
                        }

                        <!-- CURRENT PASSWORD -->
                        <div class="info-row">

                            <div class="info-label">
                                Current Password
                            </div>

                            <input type="password"
                                   name="currentPassword"
                                   class="profile-input" />

                        </div>

                        <!-- NEW PASSWORD -->
                        <div class="info-row">

                            <div class="info-label">
                                New Password
                            </div>

                            <input type="password"
                                   name="newPassword"
                                   class="profile-input" />

                        </div>

                        <!-- CONFIRM PASSWORD -->
                        <div class="info-row">

                            <div class="info-label">
                                Confirm Password
                            </div>

                            <input type="password"
                                   name="confirmPassword"
                                   class="profile-input" />

                        </div>

                        <!-- UPDATE BUTTON -->
                        <button type="submit"
                                class="save-btn">

                            <i class="bi bi-check-circle"></i>
                            Update Password

                        </button>

                    </div>

                </form>

            </div>

        </div>

    </div>

    <!-- JAVASCRIPT -->
    <script>

        // PASSWORD TOGGLE
        function togglePasswordSection() {

            const section =
                document.getElementById("passwordSection");

            if (section.style.display === "none" ||
                section.style.display === "") {

                section.style.display = "block";

            }
            else {

                section.style.display = "none";

            }
        }

        // EDIT MODE
        function toggleEditMode() {

            const username =
                document.getElementById("usernameInput");

            const email =
                document.getElementById("emailInput");

            const phone =
                document.getElementById("phoneInput");

            const saveBtn =
                document.getElementById("saveBtn");

            const isDisabled =
                username.disabled;

            username.disabled = !isDisabled;
            email.disabled = !isDisabled;
            phone.disabled = !isDisabled;

            if (isDisabled) {

                saveBtn.style.display = "block";

            }
            else {

                saveBtn.style.display = "none";

            }
        }
                window.onload = function () {

            const passwordSection =
                document.getElementById("passwordSection");

            const hasMessage =
                document.querySelector(".password-error") ||
                document.querySelector(".password-success");

            if (hasMessage && passwordSection) {

                passwordSection.scrollIntoView({
                    behavior: "smooth",
                    block: "center"
                });

            }
        };
    </script>

</body>
</html>