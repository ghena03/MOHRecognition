@using MOHRecognition.Services
@{
    ViewData["Title"] = "Submitted Universities";
    Layout = null;
    var items = ViewBag.Items as List<RecognitionRequestRecord> ?? new List<RecognitionRequestRecord>();
    var memberNameMap = ViewBag.MemberNameMap as Dictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Submitted Universities</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background: #f3f0eb; color: #1a1a1a; min-height: 100vh; }
        .ministry-bar { background: #5a0e1b; color: rgba(255,255,255,.68); font-size: 11.5px; font-weight: 500; letter-spacing: .4px; padding: 6px 48px; display: flex; align-items: center; gap: 6px; }
        .pg-header { background: #7f1627; color: #fff; padding: 0 48px; height: 66px; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 2px 18px rgba(127,22,39,.32); }
        .hd-left { display: flex; align-items: center; gap: 16px; min-width: 0; }
        .pg-header img { height: 42px; }
        .hd-sep { width: 1px; height: 34px; background: rgba(255,255,255,.28); margin: 0 6px; }
        .hd-text h1 { font-size: 17px; font-weight: 700; }
        .hd-text p { font-size: 11.5px; opacity: .72; margin-top: 2px; }
        .btn-back { display: inline-flex; align-items: center; gap: 7px; background: rgba(255,255,255,.15); color: #fff; border: 1.5px solid rgba(255,255,255,.35); border-radius: 8px; padding: 8px 18px; font-size: 13px; font-weight: 600; text-decoration: none; transition: background .15s; white-space: nowrap; }
        .btn-back:hover { background: rgba(255,255,255,.25); }
        .pg-body { max-width: 1180px; margin: 0 auto; padding: 34px 24px 72px; }
        .top-card { background: #fff; border: 1px solid #dbeafe; border-left: 5px solid #1d4ed8; border-radius: 8px; padding: 20px 22px; margin-bottom: 16px; }
        .top-card h2 { font-size: 22px; color: #1d4ed8; font-weight: 900; }
        .top-card p { margin-top: 5px; color: #666; font-size: 13.5px; }
        .tbl-card { background: #fff; border-radius: 8px; box-shadow: 0 2px 24px rgba(0,0,0,.07); overflow: hidden; }
        .tbl-top { padding: 18px 22px; border-bottom: 1px solid #f0ebe4; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .tbl-top h3 { font-size: 15px; font-weight: 800; }
        .count-pill { display: inline-flex; align-items: center; gap: 6px; background: #eff6ff; color: #1d4ed8; border-radius: 999px; padding: 5px 12px; font-size: 12px; font-weight: 800; }
        .table-wrap { overflow-x: auto; }
        table { width: 100%; min-width: 980px; border-collapse: collapse; }
        thead th { background: #f8fbff; color: #1d4ed8; font-size: 11px; font-weight: 800; letter-spacing: .7px; text-transform: uppercase; padding: 13px 18px; text-align: left; border-bottom: 2px solid #dbeafe; white-space: nowrap; }
        tbody tr { border-bottom: 1px solid #f5f0eb; }
        tbody tr:last-child { border-bottom: none; }
        tbody tr:hover { background: #fcfdff; }
        tbody td { padding: 15px 18px; font-size: 13px; color: #444; vertical-align: middle; }
        .uni-name { font-size: 14px; font-weight: 800; color: #1a1a1a; }
        .rec-badge { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 5px 11px; font-size: 11.5px; font-weight: 800; background: #f5e8ea; color: #7f1627; }
        .btn-add { display: inline-flex; align-items: center; gap: 6px; text-decoration: none; border-radius: 7px; padding: 8px 12px; font-size: 12px; font-weight: 800; background: #1d4ed8; color: #fff; border: 1px solid #1d4ed8; }
        .btn-add:hover { background: #1e40af; border-color: #1e40af; }
        .empty-state { padding: 70px 32px; text-align: center; }
        .empty-state i { font-size: 50px; color: #bfdbfe; display: block; margin-bottom: 14px; }
        .empty-state h3 { font-size: 18px; color: #555; margin-bottom: 8px; }
        .empty-state p { color: #888; font-size: 13.5px; max-width: 430px; margin: 0 auto; line-height: 1.7; }
    </style>
</head>
<body>
    <div class="ministry-bar"><i class="bi bi-bank2"></i> Ministry of Higher Education and Scientific Research - Hashemite Kingdom of Jordan</div>
    <div class="pg-header">
        <div class="hd-left">
            <img src="/images/mohelogo.png" alt="Logo" />
            <div class="hd-sep"></div>
            <div class="hd-text">
                <h1>Submitted Universities</h1>
                <p>Ready universities from doctor submissions</p>
            </div>
        </div>
        <a href="/Home/AdminDashboard" class="btn-back"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
    </div>

    <main class="pg-body">
        <section class="top-card">
            <h2>Submitted Universities</h2>
            <p>Universities submitted by doctors and ready to be added to meetings.</p>
        </section>

        <section class="tbl-card">
            <div class="tbl-top">
                <h3>Ready for Meeting Scheduling</h3>
                <span class="count-pill"><i class="bi bi-send-check-fill"></i> @items.Count submitted</span>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>University Name</th>
                            <th>Country</th>
                            <th>Request ID</th>
                            <th>Doctor Name</th>
                            <th>Doctor Recommendation Status</th>
                            <th>Submitted Date</th>
                            <th style="text-align:right;padding-right:24px;">View</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (items.Any())
                        {
                            foreach (var item in items)
                            {
                                var recommendation = string.IsNullOrWhiteSpace(item.BasicInfoAssessmentDecision) ? "Recommendation Not Saved" : item.BasicInfoAssessmentDecision;
                                <tr>
                                    <td><span class="uni-name">@(string.IsNullOrWhiteSpace(item.UniversityName) ? "-" : item.UniversityName)</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Country) ? "-" : item.Country)</td>
                                    <td><strong>#@item.Id</strong></td>
                                    <td>
                                        @if (!string.IsNullOrWhiteSpace(item.SubmittedToAdminBy) && memberNameMap.TryGetValue(item.SubmittedToAdminBy, out var displayName))
                                        {
                                            @displayName
                                        }
                                        else
                                        {
                                            <span>Recognition Member</span>
                                        }
                                    </td>
                                    <td><span class="rec-badge"><i class="bi bi-clipboard2-check"></i> @recommendation</span></td>
                                    <td>@((item.SubmittedToAdminAt ?? item.SubmittedAt).ToString("dd MMM yyyy"))</td>
                                    <td style="text-align:right;">
                                        <a class="btn-add" href="/Home/AdminViewRecommendation?id=@item.Id">
                                            <i class="bi bi-eye"></i> View Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7">
                                    <div class="empty-state">
                                        <i class="bi bi-inbox"></i>
                                        <h3>No submitted universities yet</h3>
                                        <p>Universities will appear here after doctors finish recommendation and click Submit to Admin.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</body>
</html>
