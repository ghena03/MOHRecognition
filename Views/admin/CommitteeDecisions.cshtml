@using MOHRecognition.DTOs

@{
    ViewData["Title"] = "Committee Decisions";
    Layout = null;

    var items = ViewBag.Items as List<DecisionItemDto> ?? new List<DecisionItemDto>();

    int totalDecisions = Convert.ToInt32(ViewBag.TotalDecisions ?? 0);
    int recognizedCount = Convert.ToInt32(ViewBag.RecognizedCount ?? 0);
    int nonRecognizedCount = Convert.ToInt32(ViewBag.NonRecognizedCount ?? 0);
    int pendingCount = Convert.ToInt32(ViewBag.PendingCount ?? 0);

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}

<!doctype html>
<html lang="en" dir="ltr">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Committee Decisions</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f3f0eb;
            color: #222;
        }

        /* TOP BAR */

        .ministry-bar {
            background: #5a0e1b;
            color: rgba(255,255,255,.75);
            font-size: 11px;
            padding: 6px 40px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        /* HEADER */

        .pg-header {
            background: #7f1627;
            color: #fff;
            padding: 0 42px;
            height: 74px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: 0 3px 18px rgba(0,0,0,.18);
        }

        .hd-left {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .pg-header img {
            height: 46px;
        }

        .hd-sep {
            width: 1px;
            height: 36px;
            background: rgba(255,255,255,.25);
        }

        .hd-text h1 {
            font-size: 20px;
            font-weight: 800;
        }

        .hd-text p {
            font-size: 12px;
            opacity: .8;
            margin-top: 2px;
        }

        .btn-back {
            background: rgba(255,255,255,.12);
            border: 1px solid rgba(255,255,255,.3);
            color: #fff;
            padding: 10px 20px;
            border-radius: 10px;
            text-decoration: none;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

            .btn-back:hover {
                background: rgba(255,255,255,.2);
            }

        /* BODY */

        .pg-body {
            max-width: 1250px;
            margin: auto;
            padding: 36px 24px 70px;
        }

        .page-title {
            margin-bottom: 26px;
        }

            .page-title h2 {
                font-size: 30px;
                color: #7f1627;
                font-weight: 900;
            }

            .page-title p {
                margin-top: 6px;
                color: #777;
                font-size: 14px;
            }

        /* SUMMARY */

        .summary-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 18px;
            margin-bottom: 28px;
        }

        .summary-card {
            background: #fff;
            border-radius: 12px;
            padding: 22px;
            border: 1px solid #eee3d7;
            box-shadow: 0 2px 14px rgba(0,0,0,.05);
        }

            .summary-card p {
                color: #777;
                font-size: 12px;
                font-weight: 800;
                text-transform: uppercase;
            }

            .summary-card h3 {
                margin-top: 10px;
                font-size: 36px;
                color: #1f2937;
            }

            .summary-card.total {
                border-top: 4px solid #7f1627;
            }

            .summary-card.green {
                border-top: 4px solid #15803d;
            }

            .summary-card.red {
                border-top: 4px solid #b91c1c;
            }

            .summary-card.orange {
                border-top: 4px solid #d97706;
            }

        /* FILTERS */

        .decision-filter-card {
            background: #fff;
            border-radius: 12px;
            padding: 28px;
            margin-bottom: 28px;
            border: 1px solid #eee3d7;
            box-shadow: 0 2px 14px rgba(0,0,0,.05);
        }

        .filter-grid {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 20px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
        }

            .filter-group label {
                margin-bottom: 8px;
                font-size: 13px;
                font-weight: 800;
                color: #7f1627;
            }

        .filter-input {
            width: 100%;
            height: 54px;
            border: 1px solid #ddd2c7;
            border-radius: 12px;
            padding: 0 16px;
            font-size: 15px;
            background: #fff;
            outline: none;
            transition: .15s;
        }

            .filter-input:focus {
                border-color: #7f1627;
                box-shadow: 0 0 0 3px rgba(127,22,39,.08);
            }

        .search-group {
            grid-column: span 4;
        }

        .filter-actions {
            margin-top: 24px;
            display: flex;
            justify-content: center;
        }

        .search-btn {
            height: 54px;
            border: none;
            border-radius: 12px;
            padding: 0 30px;
            background: #7f1627;
            color: #fff;
            font-size: 15px;
            font-weight: 800;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: .15s;
        }

            .search-btn:hover {
                background: #63101f;
                transform: translateY(-1px);
            }

        /* TABLE */

        .tbl-card {
            background: #fff;
            border-radius: 12px;
            overflow: hidden;
            border-top: 4px solid #7f1627;
            box-shadow: 0 2px 18px rgba(0,0,0,.06);
        }

        .tbl-card-top {
            padding: 22px 24px;
            border-bottom: 1px solid #f0ebe4;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .tbl-card-top h3 {
                font-size: 18px;
                font-weight: 900;
            }

            .tbl-card-top p {
                margin-top: 4px;
                color: #777;
                font-size: 13px;
            }

        .status-pill {
            background: #f3e8ea;
            color: #7f1627;
            padding: 7px 14px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
        }

        .table-wrap {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 950px;
        }

        thead th {
            background: #faf7f4;
            color: #7f1627;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: .7px;
            padding: 14px 18px;
            text-align: left;
            border-bottom: 2px solid #ecddd5;
        }

        tbody td {
            padding: 18px;
            border-bottom: 1px solid #f5f0eb;
            font-size: 14px;
        }

        tbody tr:hover {
            background: #fcfaf8;
        }

        .uni-name {
            font-weight: 800;
            color: #222;
        }

        .uni-sub {
            margin-top: 4px;
            font-size: 12px;
            color: #888;
        }

        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 800;
        }

            .badge-status.green {
                background: #e8f5ea;
                color: #15803d;
            }

            .badge-status.red {
                background: #fef2f2;
                color: #b91c1c;
            }

            .badge-status.orange {
                background: #fff7ed;
                color: #d97706;
            }

        .action-cell {
            text-align: right;
        }

        .btn-view {
            background: #f5e8ea;
            color: #7f1627;
            border: 1px solid #e0b0bb;
            padding: 9px 14px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 800;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

            .btn-view:hover {
                background: #edd6dc;
            }

        .empty-state {
            padding: 70px 30px;
            text-align: center;
        }

            .empty-state i {
                font-size: 50px;
                color: #d5c4b7;
                margin-bottom: 16px;
                display: block;
            }

            .empty-state h3 {
                font-size: 20px;
                color: #555;
                margin-bottom: 8px;
            }

            .empty-state p {
                color: #888;
                font-size: 14px;
            }

        /* RESPONSIVE */

        @@media(max-width:1000px) {

            .summary-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .filter-grid {
                grid-template-columns: repeat(2,1fr);
            }

            .search-group {
                grid-column: span 2;
            }
        }

        @@media(max-width:700px) {

            .summary-grid {
                grid-template-columns: 1fr;
            }

            .filter-grid {
                grid-template-columns: 1fr;
            }

            .search-group {
                grid-column: span 1;
            }
        }


        /* Application type — colored left border indicator */
        tr.app-row-bachelor td:first-child    { border-left: 5px solid #3b82f6 !important; padding-left: 11px !important; }
        tr.app-row-postgraduate td:first-child { border-left: 5px solid #8b5cf6 !important; padding-left: 11px !important; }
        tr.app-row-online td:first-child       { border-left: 5px solid #10b981 !important; padding-left: 11px !important; }
        .app-row-bachelor    { border-left: 5px solid #3b82f6 !important; }
        .app-row-postgraduate { border-left: 5px solid #8b5cf6 !important; }
        .app-row-online       { border-left: 5px solid #10b981 !important; }
    </style>

</head>

<body>

    <div class="ministry-bar">
        <i class="bi bi-bank2"></i>
        Ministry of Higher Education and Scientific Research - Hashemite Kingdom of Jordan
    </div>

    <div class="pg-header">

        <div class="hd-left">

            <img src="/images/mohelogo.png" alt="Logo" />

            <div class="hd-sep"></div>

            <div class="hd-text">
                <h1>Committee Decisions</h1>
                <p>Final committee outcomes and recognition statuses</p>
            </div>

        </div>

        <a href="/Home/AdminDashboard" class="btn-back">
            <i class="bi bi-grid-1x2-fill"></i>
            Dashboard
        </a>

    </div>

    <main class="pg-body">

        <div class="page-title">

            <div>
                <h2>Committee Decisions</h2>
                <p>View final committee outcomes and recognition statuses.</p>
            </div>

        </div>

        <!-- SUMMARY -->

        <section class="summary-grid">

            <div class="summary-card total">
                <p>Total Decisions</p>
                <h3>@totalDecisions</h3>
            </div>

            <div class="summary-card green">
                <p>Recognized Count</p>
                <h3>@recognizedCount</h3>
            </div>

            <div class="summary-card red">
                <p>Non-Recognized Count</p>
                <h3>@nonRecognizedCount</h3>
            </div>

            <div class="summary-card orange">
                <p>Pending Count</p>
                <h3>@pendingCount</h3>
            </div>

        </section>

        <!-- FILTERS -->

        <section class="decision-filter-card">

            
                <form method="get" asp-action="CommitteeDecisions" onchange="this.submit()">
                <div class="filter-grid">

                    <!-- YEAR -->
                    <div class="filter-group">

                        <label>Year</label>

                        <select name="year" class="filter-input">

                            <option value="">All Years</option>

                            @if (ViewBag.Years != null)
                            {
                                foreach (var y in ViewBag.Years)
                                {
                                    <option value="@y">@y</option>
                                }
                            }

                        </select>

                    </div>

                    <!-- SESSION -->
                    <div class="filter-group">

                        <label>Session</label>

                        <select name="session" class="filter-input">

                            <option value="">All Sessions</option>

                            @if (ViewBag.Sessions != null)
                            {
                                foreach (var s in ViewBag.Sessions)
                                {
                                    <option value="@s">
                                        Meeting #@s
                                    </option>
                                }
                            }

                        </select>

                    </div>

                    <!-- COUNTRY -->
                    <div class="filter-group">

                        <label>Country</label>

                        <select name="country" class="filter-input">

                            <option value="">All Countries</option>

                            <option>Jordan</option>
                            <option>Saudi Arabia</option>
                            <option>United Arab Emirates</option>
                            <option>Qatar</option>
                            <option>Kuwait</option>
                            <option>Bahrain</option>
                            <option>Oman</option>
                            <option>Egypt</option>
                            <option>Iraq</option>
                            <option>Syria</option>
                            <option>Lebanon</option>
                            <option>Palestine</option>
                            <option>Turkey</option>
                            <option>Malaysia</option>
                            <option>Indonesia</option>
                            <option>Pakistan</option>
                            <option>India</option>
                            <option>China</option>
                            <option>South Korea</option>
                            <option>Japan</option>
                            <option>Germany</option>
                            <option>France</option>
                            <option>Italy</option>
                            <option>Spain</option>
                            <option>Netherlands</option>
                            <option>Sweden</option>
                            <option>Russia</option>
                            <option>United Kingdom</option>
                            <option>United States</option>
                            <option>Canada</option>
                            <option>Australia</option>
                            <option>New Zealand</option>

                        </select>

                    </div>

                    <!-- STATUS -->
                    <div class="filter-group">

                        <label>Status</label>

                        <select name="status" class="filter-input">

                            <option value="">All Statuses</option>

                            <option value="Recognized">
                                Recognized
                            </option>

                            <option value="Not Recognized">
                                Non-Recognized
                            </option>

                            <option value="Needs More Information">
                                Pending
                            </option>

                        </select>

                    </div>

                    <!-- SEARCH -->
                    <div class="filter-group search-group">

                        <label>University Name</label>

                        <input type="text"
                               name="search"
                               class="filter-input"
                               placeholder="Search university..." />

                    </div>

                </div>

                <div class="filter-actions">

                    <button type="submit" class="search-btn">

                        <i class="bi bi-search"></i>
                        Search

                    </button>

                </div>

            </form>

        </section>

        <!-- TABLE -->

        <section class="tbl-card">

            <div class="tbl-card-top">

                <div>
                    <h3>Committee Universities</h3>
                    <p>Recognition decisions issued by the committee.</p>
                </div>

                <span class="status-pill">
                    @items.Count universities
                </span>

            </div>

            <div class="table-wrap">

                <table>

                    <thead>

                        <tr>
                            <th>Type</th>
                            <th>University Name</th>
                            <th>Request ID</th>
                            <th>Meeting / Session</th>
                            <th>Decision Date</th>
                            <th>Status</th>
                            <th style="text-align:right;">Actions</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (items.Any())
                        {
                            foreach (var item in items)
                            {
                                <tr class="@RowClass(item.ApplicationType)">
                                    <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11.5px;font-weight:700;@AppTypeStyle(item.ApplicationType)">@(item.ApplicationType ?? "Bachelor")</span></td>

                                    <td>

                                        <div class="uni-name">
                                            @(string.IsNullOrWhiteSpace(item.UniversityName)
                                                                                ? "-"
                                                                                : item.UniversityName)
                                        </div>

                                        <div class="uni-sub">
                                            @(string.IsNullOrWhiteSpace(item.Country)
                                                                                ? "Country not specified"
                                                                                : item.Country)
                                        </div>

                                    </td>

                                    <td>
                                        <strong>#@item.RequestId</strong>
                                    </td>

                                    <td>

                                        <strong>
                                            Meeting #@item.SessionNumber
                                        </strong>

                                        <div class="uni-sub">
                                            @item.MeetingDate.ToString("dd MMM yyyy")
                                        </div>

                                    </td>

                                    <td>

                                        @(item.DecisionDate.HasValue
                                                                        ? item.DecisionDate.Value.ToString("dd MMM yyyy")
                                                                        : "-")

                                    </td>

                                    <td>

                                        @{
                                            var statusClass =
                                            item.Decision == "Recognized"
                                            ? "green"
                                            : item.Decision == "Not Recognized"
                                            ? "red"
                                            : "orange";
                                        }

                                        <span class="badge-status @statusClass">
                                            @item.Decision
                                        </span>

                                    </td>

                                    <td class="action-cell">

                                        <a class="btn-view"
                                           href="/Home/MeetingDecision?meetingId=@item.MeetingId&requestId=@item.RequestId">

                                            <i class="bi bi-eye"></i>
                                            View Decision

                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="6">

                                    <div class="empty-state">

                                        <i class="bi bi-clipboard2-check"></i>

                                        <h3>
                                            No decisions found
                                        </h3>

                                        <p>
                                            Universities will appear here after committee decisions are saved.
                                        </p>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </section>

    </main>

</body>
</html>