@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>

@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin/AdminDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        .nav-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 18px;
        }

        .nav-card {
            background: #fff;
            border-radius: 16px;
            padding: 28px 30px;
            text-decoration: none;
            display: flex;
            align-items: flex-start;
            gap: 18px;
            border: 2px solid #f0ebe4;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            transition: transform .18s, box-shadow .18s, border-color .18s;
        }
        .nav-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 32px rgba(127,22,39,.12);
            border-color: #d4a8b4;
        }

        .nav-icon {
            width: 52px; height: 52px;
            border-radius: 14px;
            background: #fde8ec;
            color: #7f1627;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; flex-shrink: 0;
        }

        .nav-body { flex: 1; }
        .nav-body h3 {
            font-size: 16px;
            font-weight: 800;
            color: #1a1a1a;
            margin-bottom: 6px;
        }
        .nav-body p {
            font-size: 13px;
            color: #888;
            line-height: 1.55;
        }

        .nav-arrow {
            font-size: 16px;
            color: #ddd;
            align-self: center;
            flex-shrink: 0;
            transition: color .15s, transform .15s;
        }
        .nav-card:hover .nav-arrow { color: #7f1627; transform: translateX(4px); }


        .decision-mini-counts { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 12px; }
        .decision-mini {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            border-radius: 999px;
            padding: 5px 10px;
            font-size: 11px;
            font-weight: 800;
        }
        .decision-mini.green { background: #e8f5ea; color: #1a7a34; }
        .decision-mini.red   { background: #fef2f2; color: #b91c1c; }
        .decision-mini.amber { background: #fffbeb; color: #d97706; }
    </style>
</head>

<body class="admin-page">

    <div class="top-bar"></div>

    <div class="header">
        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />
            <div class="divider"></div>
            <div class="title-box">
                <h1>Admin Dashboard</h1>
                <p>Recognition Committee — Operations &amp; Management Portal</p>
            </div>
        </div>
        <div class="user-box">

            <a asp-controller="Home"
               asp-action="AdminProfile"
               class="profile-link">

                <div class="avatar">A</div>

                <div>
                    <strong>Admin User</strong><br>
                    <span>System Administrator</span>
                </div>

            </a>

            <a href="@Url.Action("Logout", "Home")"
               style="margin-left:16px;display:inline-flex;align-items:center;gap:6px;padding:7px 16px;background:#fff;border:1.5px solid #d1d5db;border-radius:8px;color:#374151;font-size:13px;font-weight:600;text-decoration:none;transition:background .15s;"
               onmouseover="this.style.background='#f3f4f6'"
               onmouseout="this.style.background='#fff'">

                <i class="bi bi-box-arrow-right"></i> Logout

            </a>

        </div>
    </div>

    <div class="main-container">

        <section class="overview-section">
            <h2 class="overview-title">Overview</h2>
            <div class="overview-cards">
                <div class="overview-card">
                    <p>Total Requests</p>
                    <h2>@Model.Count()</h2>
                </div>
                <div class="overview-card">
                    <p>Pending</p>
                    <h2>@Model.Count(x => x.Status == "Pending")</h2>
                </div>
                <div class="overview-card">
                    <p>Assigned</p>
                    <h2>@Model.Count(x => x.AssignedMember != "Unassigned")</h2>
                </div>
                <div class="overview-card">
                    <p>Needs Review</p>
                    <h2>@Model.Count(x => x.Status == "Requires Admin Review")</h2>
                </div>
            </div>
        </section>

        <div class="nav-grid">

            <a asp-controller="Home" asp-action="Requests" class="nav-card">
                <div class="nav-icon"><i class="bi bi-inbox-fill"></i></div>
                <div class="nav-body">
                    <h3>Requests</h3>
                    <p>Manage all submitted university recognition requests.</p>
                    <div class="decision-mini-counts">
                        <span class="decision-mini" style="background:#fde8ec;color:#7f1627;">@Model.Count() total</span>
                    </div>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="SubmittedUniversities" class="nav-card">
                <div class="nav-icon"><i class="bi bi-send-check-fill"></i></div>
                <div class="nav-body">
                    <h3>Submitted Universities</h3>
                    <p>Universities submitted by doctors and ready to be added to meetings.</p>
                    <div class="decision-mini-counts">
                        <span class="decision-mini" style="background:#fde8ec;color:#7f1627;">@(ViewBag.SubmittedUniversitiesCount ?? 0) ready</span>
                    </div>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="Meetings" class="nav-card">
                <div class="nav-icon"><i class="bi bi-calendar3"></i></div>
                <div class="nav-body">
                    <h3>Meetings</h3>
                    <p>Schedule meetings, set date, time, and location, and pick the universities to be discussed.</p>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="SessionWorkflow" class="nav-card">
                <div class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></div>
                <div class="nav-body">
                    <h3>إدارة الجلسات</h3>
                    <p>Review doctors' recommendations, enter final committee decisions, and close the meeting.</p>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="Employees" class="nav-card">
                <div class="nav-icon"><i class="bi bi-people-fill"></i></div>
                <div class="nav-body">
                    <h3>Advisors</h3>
                    <p>Manage recognition committee member profiles and information.</p>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="CommitteeDecisions" class="nav-card">
                <div class="nav-icon"><i class="bi bi-clipboard2-check-fill"></i></div>
                <div class="nav-body">
                    <h3>Committee Decisions</h3>
                    <p>View final committee outcomes and recognition statuses.</p>
                    <div class="decision-mini-counts">
                        <span class="decision-mini green">@(ViewBag.RecognizedCount ?? 0) Recognized</span>
                        <span class="decision-mini red">@(ViewBag.NonRecognizedCount ?? 0) Non-Recognized</span>
                        <span class="decision-mini amber">@(ViewBag.PendingCount ?? 0) Pending</span>
                    </div>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

            <a asp-controller="Home" asp-action="AllUniversities" class="nav-card">
                <div class="nav-icon"><i class="bi bi-buildings-fill"></i></div>
                <div class="nav-body">
                    <h3>All Universities</h3>
                    <p>View all universities with their final recognition status.</p>
                    <div class="decision-mini-counts">
                        <span class="decision-mini" style="background:#fde8ec;color:#7f1627;">@(ViewBag.AllUniversitiesCount ?? 0) finalized</span>
                    </div>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>
            <a asp-controller="Home"
               asp-action="AddEducationalInstitution"
               class="nav-card">
                <div class="nav-icon">
                    <i class="bi bi-building-add"></i>
                </div>
                <div class="nav-body">
                    <h3>Add Educational Institution</h3>
                    <p>
                        Create a manual recognition request
                        and assign it to a recognition member.
                    </p>
                </div>
                <i class="bi bi-arrow-right nav-arrow"></i>
            </a>

        </div>

    </div>

</body>
</html>
