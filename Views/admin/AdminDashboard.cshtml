@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>

@{
    Layout = null;
    ViewData["Title"] = "Admin Dashboard";
}

<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin/AdminDashboard.css" asp-append-version="true" />
</head>

<body class="admin-page">

    <!-- 🔴 RED TOP LINE -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">

        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Admin Dashboard</h1>
                <p>Manage requests, assignments, and workflow in one place</p>
            </div>
        </div>

        <div class="user-box">
            <div class="avatar">A</div>
            <div>
                <strong>Admin User</strong><br>
                <span>System Administrator</span>
            </div>
        </div>

    </div>

    <!-- MAIN -->
    <div class="main-container">

        <!-- OVERVIEW  -->
        <section class="overview-section">

            <h2 class="overview-title">Overview</h2>

            <div class="overview-cards">

                <div class="overview-card">
                    <p>Total Requests</p>
                    <h2>@Model.Count</h2>
                </div>

                <div class="overview-card">
                    <p>Pending</p>
                    <h2>@Model.Count(x => x.Status == "Pending")</h2>
                </div>

                <div class="overview-card">
                    <p>Assigned</p>
                    <h2>@Model.Count(x => x.AssignedMember != "Unassigned")</h2>
                </div>

                <div class="overview-card">
                    <p>Needs Review</p>
                    <h2>@Model.Count(x => x.Status == "Requires Admin Review")</h2>
                </div>

            </div>

        </section>


        <!--ACTION BUTTONS -->
        <div class="main-actions">

            <a asp-controller="Home" asp-action="Requests" class="action-card">
                <h3>Requests</h3>
                <p>Manage all submitted requests</p>
            </a>


            <a asp-controller="Home" asp-action="Meetings" class="action-card">
                <h3>Meetings</h3>
                <p>Manage and schedule discussion sessions</p>
            </a>

            <a asp-controller="Home" asp-action="Employees" class="action-card">
                <h3>Employees</h3>
                <p>Manage recognition members</p>
            </a>

           
            <a asp-controller="Admin" asp-action="Audit" class="action-card">
                <h3>Audit Log</h3>
                <p>Track system activity</p>
            </a>

        </div>

    </div>

    </div>

</body>
</html>