@using MOHRecognition.DTOs
@using MOHRecognition.Services
@model MeetingDto

@{
    ViewData["Title"] = "Meeting Details";
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<!-- HEADER -->
<div class="header">
    <div class="header-left">
        <img src="~/images/mohelogo.png" class="logo" />
        <div class="divider"></div>

        <div class="title-box">
            <h1>Meeting Details</h1>
            <p>Discussion session overview</p>
        </div>
    </div>
</div>

<div class="main-container">

    <!-- TITLE -->
    <div class="page-head">
        <h2>Meeting Information</h2>
    </div>

    <!-- DETAILS CARD -->
    <div class="details-card">

        <div class="details-grid">

            <div>
                <strong>Meeting Title</strong>
                <p>@(string.IsNullOrWhiteSpace(Model.MeetingTitle) ? "—" : Model.MeetingTitle)</p>
            </div>

            <div>
                <strong>Session #</strong>
                <p>@Model.SessionNumber</p>
            </div>

            <div>
                <strong>Date</strong>
                <p>@Model.MeetingDate.ToString("yyyy-MM-dd")</p>
            </div>

            <div>
                <strong>Time</strong>
                <p>@(string.IsNullOrWhiteSpace(Model.MeetingTime) ? "—" : Model.MeetingTime)</p>
            </div>

            <div>
                <strong>Location / Platform</strong>
                <p>@(string.IsNullOrWhiteSpace(Model.LocationOrPlatform) ? "—" : Model.LocationOrPlatform)</p>
            </div>

            <div style="grid-column: span 2;">
                <strong>Notes</strong>
                <p>@(string.IsNullOrWhiteSpace(Model.Notes) ? "—" : Model.Notes)</p>
            </div>

        </div>

    </div>

    <!-- BACK BUTTON -->
    <div style="margin-top: 20px;">
        <a href="@((ViewBag.BackToMember as bool? ?? false) ? "/Home/RecognitionMemberMeetings" : "/Home/Meetings")" class="action-btn">
            ← Back to Meetings
        </a>
    </div>

</div>
