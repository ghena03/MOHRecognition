@using MOHRecognition.DTOs
@{
    ViewData["Title"] = "All Universities";
    Layout = null;
    var items = ViewBag.Items as List<DecisionItemDto> ?? new List<DecisionItemDto>();

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}
<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />
<link rel="stylesheet" href="~/css/admin/AllUniversities.css" />

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>All Universities</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

</head>
<body>
    <!-- HEADER -->
    <div class="top-bar"></div>
    <div class="header">
        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />
            <div class="divider"></div>
            <div class="title-box">
                <h1>All Universities</h1>
                <p>Final recognition outcomes after committee decisions</p>
            </div>
        </div>
        <a class="back-btn"
           href="@Url.Action("AdminDashboard", "Home")">
            ← Back to Dashboard
        </a>
    </div>


    <main class="pg-body">

        <section class="top-card">
            <h2>All Universities</h2>
            <p>View all universities with their final recognition status.</p>
        </section>

        <partial name="_UniversityFilters"
                 model="new MOHRecognition.Models.UniversityFilterViewModel()" />

        <section class="tbl-card">
            <div class="tbl-top">
                <h3>Finalized Universities</h3>
                <span class="count-pill"><i class="bi bi-buildings-fill"></i> @items.Count finalized</span>
            </div>
            <div class="table-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>University Name</th>
                            <th>Type</th>
                            <th>Country</th>
                            <th>Request ID</th>
                            <th>Meeting/Session</th>
                            <th>Final Status</th>
                            <th>Decision Date</th>
                            <th style="text-align:right;padding-right:24px;">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (items.Any())
                        {
                            foreach (var item in items)
                            {
                                var statusClass = item.Decision == "Recognized" ? "status-green"
                                    : item.Decision == "Not Recognized" ? "status-red"
                                    : "status-amber";
                                var statusLabel = item.Decision == "Needs More Information" ? "Pending / Needs More Information" : item.Decision;
                                <tr class="@RowClass(item.ApplicationType)">
                                    <td><span class="uni-name">@(string.IsNullOrWhiteSpace(item.UniversityName) ? "-" : item.UniversityName)</span></td>
                                    <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11.5px;font-weight:700;@AppTypeStyle(item.ApplicationType)">@(item.ApplicationType ?? "Bachelor")</span></td>
                                    <td>@(string.IsNullOrWhiteSpace(item.Country) ? "-" : item.Country)</td>
                                    <td><strong>#@item.RequestId</strong></td>
                                    <td>
                                        <strong>Meeting #@item.SessionNumber</strong>
                                        <div style="color:#888;font-size:11.5px;margin-top:3px;">@item.MeetingDate.ToString("dd MMM yyyy")</div>
                                    </td>
                                    <td><span class="status-badge @statusClass">@statusLabel</span></td>
                                    <td>@(item.DecisionDate.HasValue ? item.DecisionDate.Value.ToString("dd MMM yyyy") : "-")</td>
                                    <td style="text-align:right;">
                                        <a class="btn-view" href="/Home/MeetingDecision?meetingId=@item.MeetingId&requestId=@item.RequestId">
                                            <i class="bi bi-eye"></i> View Final Recommendation
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="empty-state">
                                        <h3>No finalized universities yet</h3>
                                        <p>Universities will appear here automatically after the final committee decision is saved inside إدارة الجلسات.</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</body>
</html>
