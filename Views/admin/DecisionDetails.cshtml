@using MOHRecognition.Services
@model RecognitionRequestRecord

@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<div class="main-container">

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <img src="~/images/mohelogo.png" class="logo" />
            <div class="header-text">
                <h1>Decision Details</h1>
                <p>Final evaluation summary</p>
            </div>
        </div>

        <a class="back-btn" href="/Home/Decisions">← Back</a>
    </div>

    <!-- CONTENT -->
    <div class="details-card">

        <h2 class="section-title">@Model.UniversityName</h2>

        <!-- Accreditation -->
        <div class="mini-card">
            <h4>Accreditation & Recognition</h4>

            <span class="badge-status">
                @Model.AccreditationStatus
            </span>

            <p>@Model.AccreditationNote</p>
        </div>

        <hr />

        <!-- Final Decision -->
        <div class="final-decision-box">

            <h3>Final Decision</h3>

            @{
                var decision = Model.BasicInfoAssessmentDecision;
                var decisionClass = "decision-default";

                if (decision == "Approve")
                    decisionClass = "decision-approve";
                else if (decision == "Conditional Approval")
                    decisionClass = "decision-conditional";
                else if (decision == "Reject / Committee Review")
                    decisionClass = "decision-reject";
            }

            <span class="decision-badge @decisionClass">
                @decision
            </span>

            @if (!string.IsNullOrWhiteSpace(Model.BasicInfoAssessmentReason))
            {
                <p class="decision-note">
                    @Model.BasicInfoAssessmentReason
                </p>
            }

        </div>

    </div>

</div>