@using MOHRecognition.Services
@model RecognitionRequestRecord

@{
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

<div class="main-container">

    <!-- 🔴 RED TOP LINE -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Decision Details</h1>
                <p>Recognition request full information</p>
            </div>
        </div>
    </div>

    <!-- CARD -->
    <div class="details-card">

        <h2 class="section-title">Basic Information</h2>

        <div class="info-grid">

            <div class="info-box">
                <label>University</label>
                <p>@Model.UniversityName</p>
            </div>

            <div class="info-box">
                <label>Request ID</label>
                <p>#@Model.Id</p>
            </div>

            <div class="info-box">
                <label>Final Decision</label>
                <p>@Model.BasicInfoAssessmentDecision</p>
            </div>

            <div class="info-box">
                <label>Decision Notes</label>
                <p>@(string.IsNullOrEmpty(Model.BasicInfoAssessmentReason) ? "-" : Model.BasicInfoAssessmentReason)</p>
            </div>

        </div>

    </div>

</div>