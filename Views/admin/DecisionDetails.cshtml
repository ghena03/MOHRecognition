@{
    ViewData["Title"] = "Decision Details";
    Layout = null;
}

<link rel="stylesheet" href="~/css/admin/AdminDashboard.css" />

<div class="main-container">

    <!-- HEADER -->
    <div class="page-head">
        <h2>Decision Details</h2>
        <p>Final evaluation summary</p>
    </div>

    <!-- MAIN CARD -->
    <div class="details-card">

        <h2 class="uni-title">University of Jordan</h2>

        <!-- SECTION -->
        <div class="section">
            <h3>Accreditation & Recognition</h3>
            <div class="section-content">
                <span class="status approved">Approved</span>
                <p>Meets all accreditation requirements.</p>
            </div>
        </div>

        <!-- SECTION -->
        <div class="section">
            <h3>Students to Faculty Ratio</h3>
            <div class="section-content">
                <span class="status approved">Acceptable</span>
            </div>
        </div>

        <!-- SECTION -->
        <div class="section">
            <h3>Doctorate Holders</h3>
            <div class="section-content">
                <span class="status approved">Above minimum requirement</span>
            </div>
        </div>

        <!-- SECTION -->
        <div class="section">
            <h3>Environment Assessment</h3>
            <div class="section-content">
                <span class="status approved">Good</span>
            </div>
        </div>

        <!-- FINAL -->
        <div class="final-box">
            <h3>Final Recommendation</h3>
            <span class="status approved big">Approved</span>
            <p>Final decision based on all evaluation criteria.</p>
        </div>

    </div>

    <!-- BACK BUTTON -->
    <div style="margin-top:20px;">
        <a href="/Home/Decisions" class="action-btn">
            ← Back to Decisions
        </a>
    </div>

</div>