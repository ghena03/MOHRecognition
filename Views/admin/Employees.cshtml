@using MOHRecognition.DTOs
@model IReadOnlyList<AdvisorDto>

@{
    ViewData["Title"] = "Advisors";
    Layout = null;

    var recognitionMembers = Model.Where(a => a.Type == AdvisorType.RecognitionMember).ToList();
    var ministryAdvisors = Model.Where(a => a.Type == AdvisorType.MinistryAdvisor).ToList();
}

<!doctype html>
<html lang="en" dir="ltr">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet">

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            transition: background .2s ease, color .2s ease, border-color .2s ease, box-shadow .2s ease, transform .2s ease;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: radial-gradient(circle at top left, #f8f1f3 0%, transparent 30%), radial-gradient(circle at bottom right, #f4f6fb 0%, transparent 30%), #f6f7fb;
            min-height: 100vh;
            color: #111827;
        }


        .top-bar {
            height: 4px;
            background: #7f1627;
        }

        .header {
            background: #e9e6e2;
            border-bottom: 1px solid rgba(0,0,0,.05);
            padding: 22px 38px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .logo {
            height: 54px;
        }

        .divider {
            width: 1px;
            height: 48px;
            background: #d2d2d2;
        }

        .title-box h1 {
            font-size: 28px;
            font-weight: 800;
            color: #1e2b50;
        }

        .title-box p {
            margin-top: 6px;
            font-size: 14px;
            color: #667085;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
            border: 1px solid #d6d6d6;
            background: rgba(255,255,255,.7);
            padding: 13px 22px;
            border-radius: 16px;
            font-size: 14px;
            font-weight: 700;
            color: #374151;
        }

            .btn-back:hover {
                border-color: #7f1627;
                color: #7f1627;
                transform: translateY(-2px);
            }

        /* =========================================================
                   PAGE INTRO
                ========================================================= */

        .page-intro {
            padding: 55px 60px 18px;
        }

            .page-intro h1 {
                font-size: 44px;
                font-weight: 800;
                letter-spacing: -1px;
                color: #111827;
            }

            .page-intro p {
                margin-top: 14px;
                font-size: 17px;
                color: #6b7280;
                max-width: 850px;
                line-height: 1.7;
            }

        /* =========================================================
                   PAGE BODY
                ========================================================= */

        .page-body {
            padding: 24px 60px 80px;
        }

        /* =========================================================
                   SECTION
                ========================================================= */

        .section {
            background: rgba(255,255,255,.75);
            backdrop-filter: blur(14px);
            border: 1px solid rgba(255,255,255,.7);
            border-radius: 34px;
            padding: 34px;
            margin-bottom: 42px;
            box-shadow: 0 10px 30px rgba(15,23,42,.05), 0 2px 8px rgba(15,23,42,.03);
        }

        /* =========================================================
                   SECTION HEADER
                ========================================================= */

        .section-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .section-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .section-label {
            font-size: 24px;
            font-weight: 800;
            letter-spacing: -.6px;
            color: #111827;
        }

        .section-count {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            background: #f3f4f6;
            border: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: #6b7280;
        }

        /* =========================================================
                   BUTTONS
                ========================================================= */

        .btn-add {
            background: linear-gradient(135deg, #7f1627, #a51d35);
            color: white;
            border: none;
            border-radius: 18px;
            padding: 15px 24px;
            font-size: 14px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 9px;
            cursor: pointer;
            box-shadow: 0 12px 25px rgba(127,22,39,.20);
        }

            .btn-add:hover {
                transform: translateY(-3px);
                box-shadow: 0 20px 40px rgba(127,22,39,.25);
            }

        /* =========================================================
                   CARD
                ========================================================= */

        .card {
            background: white;
            border-radius: 28px;
            overflow: hidden;
            border: 1px solid #f1f1f1;
        }

        /* =========================================================
                   TABLE
                ========================================================= */

        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
        }

        thead th {
            background: #faf7f8;
            padding: 22px 24px;
            text-align: left;
            font-size: 13px;
            font-weight: 800;
            color: #6b7280;
            letter-spacing: .5px;
            border-bottom: 1px solid #ececec;
        }

            thead th:first-child {
                width: 75px;
                text-align: center;
            }

        tbody tr {
            transition: .2s ease;
        }

            tbody tr:hover td {
                background: #fcfcfd;
            }

        tbody td {
            padding: 28px 24px;
            vertical-align: middle;
            border-bottom: 1px solid #f5f5f5;
        }

            tbody td:first-child {
                text-align: center;
                font-weight: 700;
                color: #9ca3af;
            }

        /* =========================================================
                   PERSON
                ========================================================= */

        .person {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .av {
            width: 56px;
            height: 56px;
            border-radius: 18px;
            background: linear-gradient(135deg, #7f1627, #a51d35);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 16px;
            font-weight: 700;
            flex-shrink: 0;
            box-shadow: 0 10px 20px rgba(127,22,39,.18);
        }

        .p-name {
            font-size: 18px;
            font-weight: 700;
            color: #111827;
            line-height: 1.5;
        }

        .tag {
            display: inline-flex;
            align-items: center;
            margin-top: 10px;
            padding: 8px 14px;
            border-radius: 999px;
            background: #f3f4f6;
            color: #6b7280;
            font-size: 12px;
            font-weight: 700;
        }

        /* =========================================================
                   CONTACT
                ========================================================= */

        .c-main {
            font-size: 16px;
            font-weight: 600;
            color: #1f2937;
            line-height: 1.6;
        }

        .c-sub {
            margin-top: 8px;
            font-size: 14px;
            color: #9ca3af;
        }

        /* =========================================================
                   ACTIONS
                ========================================================= */

        .actions {
            display: flex;
            gap: 12px;
        }

        .btn-edit,
        .btn-del {
            border-radius: 16px;
            padding: 12px 18px;
            font-size: 13px;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 7px;
            cursor: pointer;
            transition: .2s ease;
        }

        /* EDIT */

        .btn-edit {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            color: #334155;
        }

            .btn-edit:hover {
                background: #eef2ff;
                border-color: #c7d2fe;
                color: #4338ca;
                transform: translateY(-1px);
            }

        /* DELETE */

        .btn-del {
            background: #fff5f5;
            border: 1px solid #fecaca;
            color: #dc2626;
        }

            .btn-del:hover {
                background: #dc2626;
                color: white;
                transform: translateY(-1px);
            }

        /* =========================================================
                   EMPTY
                ========================================================= */

        .empty {
            text-align: center;
            padding: 70px;
            color: #9ca3af;
            font-size: 16px;
        }

            .empty i {
                font-size: 42px;
                margin-bottom: 16px;
                display: block;
            }

        /* =========================================================
                   DIVIDER
                ========================================================= */

        .section-divider {
            border: none;
            border-top: 1px solid #ececec;
            margin: 15px 0 40px;
        }

        /* =========================================================
                   RESPONSIVE
                ========================================================= */

        @@media(max-width:1100px) {

            .section {
                overflow-x: auto;
            }

            table {
                min-width: 1000px;
            }

            .page-body,
            .page-intro {
                padding-left: 24px;
                padding-right: 24px;
            }
        }
        /* =========================================================
           MODALS
        ========================================================= */

        .modal-bg {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.4);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

            .modal-bg.open {
                display: flex;
            }

        .modal {
            background: white;
            width: 100%;
            max-width: 520px;
            border-radius: 28px;
            padding: 30px;
            box-shadow: 0 25px 60px rgba(0,0,0,.15);
            animation: modalIn .2s ease;
        }

        @@keyframes modalIn {
           

            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .modal-sm {
            max-width: 420px;
            text-align: center;
        }

        .modal-hd {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
        }

        .modal-title {
            font-size: 22px;
            font-weight: 800;
        }

        .modal-x {
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 14px;
            background: #f3f4f6;
            cursor: pointer;
        }

        .form-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        .ff {
            grid-column: 1/-1;
        }

        .fld {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .flabel {
            font-size: 12px;
            font-weight: 700;
            color: #6b7280;
        }

        .finput {
            border: 1px solid #e5e7eb;
            border-radius: 16px;
            padding: 14px 16px;
            font-size: 14px;
            font-family: inherit;
        }

            .finput:focus {
                outline: none;
                border-color: #7f1627;
                box-shadow: 0 0 0 4px rgba(127,22,39,.08);
            }

        .modal-foot {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            margin-top: 28px;
        }

        .btn-cancel {
            background: white;
            border: 1px solid #d1d5db;
            border-radius: 16px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-save {
            background: linear-gradient(135deg, #7f1627, #a51d35);
            color: white;
            border: none;
            border-radius: 16px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-danger {
            background: #dc2626;
            color: white;
            border: none;
            border-radius: 16px;
            padding: 12px 18px;
            font-weight: 700;
            cursor: pointer;
        }

        .delete-icon {
            width: 72px;
            height: 72px;
            margin: 0 auto 20px;
            border-radius: 50%;
            background: #fff1f2;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #dc2626;
            font-size: 28px;
        }

        .delete-title {
            font-size: 24px;
            font-weight: 800;
            margin-bottom: 12px;
        }

        .delete-text {
            font-size: 15px;
            color: #6b7280;
            line-height: 1.7;
        }
    </style>
</head>

<body>

    <div class="top-bar"></div>

    <!-- HEADER -->

    <div class="header">

        <div class="header-left">

            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Advisors</h1>
                <p>Ministry of Higher Education</p>
            </div>

        </div>

        <div class="header-right">

            <a class="btn-back"
               href="@Url.Action("AdminDashboard", "Home")">

                <i class="bi bi-arrow-left"></i>

                Back to Dashboard

            </a>

        </div>

    </div>

    <!-- PAGE INTRO -->

    <div class="page-intro">

        <h1>Advisors Management</h1>

        <p>
            Recognition Members and Ministry Advisors —
            manage assignments, expertise, and contact details.
        </p>

    </div>

    <!-- PAGE BODY -->

    <div class="page-body">

        <!-- MINISTRY ADVISORS -->

        <div class="section">

            <div class="section-head">

                <div class="section-left">

                    <span class="section-label">
                        Ministry Advisors / Presidents
                    </span>

                    <span class="section-count">
                        @ministryAdvisors.Count
                    </span>

                </div>

                <button class="btn-add"
                        type="button"
                        onclick="openAdd('MinistryAdvisor')">

                    <i class="bi bi-plus-lg"></i>

                    Add Advisor

                </button>

            </div>

            <div class="card">

                @if (ministryAdvisors.Any())
                {
                    <table>

                        <thead>

                            <tr>
                                <th>#</th>
                                <th>Name / Position</th>
                                <th>Workplace</th>
                                <th>Contact</th>
                                <th></th>
                            </tr>

                        </thead>

                        <tbody>

                            @{
                                int mn = 1;
                            }

                            @foreach (var a in ministryAdvisors)
                            {
                                <tr>

                                    <td>@(mn++)</td>

                                    <td>

                                        <div class="person">

                                            <div class="av">
                                                @(a.FullName.Length > 0
                                                                                        ? a.FullName[0].ToString()
                                                                                        : "?")
                                            </div>

                                            <div>

                                                <div class="p-name">
                                                    @a.FullName
                                                </div>

                                                <div class="tag">
                                                    @a.Specialization
                                                </div>

                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        <div class="c-main">
                                            @a.Workplace
                                        </div>

                                    </td>

                                    <td>

                                        <div class="c-main">
                                            @a.Email
                                        </div>

                                        <div class="c-sub">
                                            @a.Phone
                                        </div>

                                    </td>

                                    <td>

                                        <div class="actions">

                                            <button class="btn-edit"
                                                    type="button"
                                                    onclick="openEdit(
                                                            @a.Id,
                                                            '@Html.Raw(a.FullName.Replace("'", "\\'"))',
                                                            '@a.Email',
                                                            '@a.Phone',
                                                            '@Html.Raw(a.Specialization.Replace("'", "\\'"))',
                                                            '@Html.Raw(a.Workplace.Replace("'", "\\'"))',
                                                            'MinistryAdvisor')">

                                                <i class="bi bi-pencil"></i>

                                                Edit

                                            </button>

                                            <button class="btn-del"
                                                    type="button"
                                                    onclick="openDelete(
                                                            @a.Id,
                                                            '@Html.Raw(a.FullName.Replace("'", "\\'"))')">

                                                <i class="bi bi-trash3"></i>

                                                Delete

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }
                else
                {
                    <div class="empty">

                        <i class="bi bi-building-x"></i>

                        No ministry advisors yet.

                    </div>
                }

            </div>

        </div>

        <!-- RECOGNITION MEMBERS -->

        <div class="section">

            <div class="section-head">

                <div class="section-left">

                    <span class="section-label">
                        Recognition Members
                    </span>

                    <span class="section-count">
                        @recognitionMembers.Count
                    </span>

                </div>

                <button class="btn-add"
                        type="button"
                        onclick="openAdd('RecognitionMember')">

                    <i class="bi bi-plus-lg"></i>

                    Add Member

                </button>

            </div>

            <div class="card">

                @if (recognitionMembers.Any())
                {
                    <table>

                        <thead>

                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Workplace</th>
                                <th>Contact</th>
                                <th></th>
                            </tr>

                        </thead>

                        <tbody>

                            @{
                                int rn = 1;
                            }

                            @foreach (var a in recognitionMembers)
                            {
                                <tr>

                                    <td>@(rn++)</td>

                                    <td>

                                        <div class="person">

                                            <div class="av">
                                                @(a.FullName.Length > 0
                                                                                        ? a.FullName[0].ToString()
                                                                                        : "?")
                                            </div>

                                            <div>

                                                <div class="p-name">
                                                    @a.FullName
                                                </div>

                                                <div class="tag">
                                                    @a.Specialization
                                                </div>

                                            </div>

                                        </div>

                                    </td>

                                    <td>

                                        <div class="c-main">
                                            @a.Workplace
                                        </div>

                                    </td>

                                    <td>

                                        <div class="c-main">
                                            @a.Email
                                        </div>

                                        <div class="c-sub">
                                            @a.Phone
                                        </div>

                                    </td>

                                    <td>

                                        <div class="actions">

                                            <button class="btn-edit"
                                                    type="button"
                                                    onclick="openEdit(
                                                            @a.Id,
                                                            '@Html.Raw(a.FullName.Replace("'", "\\'"))',
                                                            '@a.Email',
                                                            '@a.Phone',
                                                            '@Html.Raw(a.Specialization.Replace("'", "\\'"))',
                                                            '@Html.Raw(a.Workplace.Replace("'", "\\'"))',
                                                            'RecognitionMember')">

                                                <i class="bi bi-pencil"></i>

                                                Edit

                                            </button>

                                            <button class="btn-del"
                                                    type="button"
                                                    onclick="openDelete(
                                                            @a.Id,
                                                            '@Html.Raw(a.FullName.Replace("'", "\\'"))')">

                                                <i class="bi bi-trash3"></i>

                                                Delete

                                            </button>

                                        </div>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                }
                else
                {
                    <div class="empty">

                        <i class="bi bi-person-x"></i>

                        No recognition members yet.

                    </div>
                }

            </div>

        </div>

        <hr class="section-divider" />

    </div>
    <!-- EDIT MODAL -->

    <div class="modal-bg" id="editModal">

        <div class="modal">

            <div class="modal-hd">

                <div class="modal-title">
                    Edit Advisor
                </div>

                <button class="modal-x"
                        onclick="closeEdit()">

                    <i class="bi bi-x-lg"></i>

                </button>

            </div>

            <form method="post"
                  asp-action="EditAdvisor"
                  asp-controller="Home">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       id="editId" />

                <input type="hidden"
                       name="type"
                       id="editType" />

                <div class="form-grid">

                    <div class="fld ff">

                        <label class="flabel">
                            Full Name
                        </label>

                        <input class="finput"
                               type="text"
                               name="fullName"
                               id="editName"
                               required />

                    </div>

                    <div class="fld">

                        <label class="flabel">
                            Email
                        </label>

                        <input class="finput"
                               type="email"
                               name="email"
                               id="editEmail" />

                    </div>

                    <div class="fld">

                        <label class="flabel">
                            Phone
                        </label>

                        <input class="finput"
                               type="text"
                               name="phone"
                               id="editPhone" />

                    </div>

                    <div class="fld ff">

                        <label class="flabel">
                            Specialization
                        </label>

                        <input class="finput"
                               type="text"
                               name="specialization"
                               id="editSpec" />

                    </div>

                    <div class="fld ff">

                        <label class="flabel">
                            Workplace
                        </label>

                        <input class="finput"
                               type="text"
                               name="workplace"
                               id="editWork" />

                    </div>

                </div>

                <div class="modal-foot">

                    <button type="button"
                            class="btn-cancel"
                            onclick="closeEdit()">

                        Cancel

                    </button>

                    <button type="submit"
                            class="btn-save">

                        <i class="bi bi-check-lg"></i>

                        Save Changes

                    </button>

                </div>

            </form>

        </div>

    </div>
    <!-- DELETE MODAL -->

    <div class="modal-bg" id="delModal">

        <div class="modal modal-sm">

            <div class="delete-icon">

                <i class="bi bi-trash3"></i>

            </div>

            <div class="delete-title">
                Delete Advisor
            </div>

            <div class="delete-text">

                Are you sure you want to delete
                <strong id="delName"></strong> ?

            </div>

            <form method="post"
                  asp-action="DeleteAdvisor"
                  asp-controller="Home">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="id"
                       id="delId" />

                <div class="modal-foot">

                    <button type="button"
                            class="btn-cancel"
                            onclick="closeDelete()">

                        Cancel

                    </button>

                    <button type="submit"
                            class="btn-danger">

                        <i class="bi bi-trash3"></i>

                        Delete

                    </button>

                </div>

            </form>

        </div>

    </div>
    <!-- ADD MODAL -->

    <div class="modal-bg" id="addModal">

        <div class="modal">

            <div class="modal-hd">

                <div class="modal-title"
                     id="addTitle">

                    Add Advisor

                </div>

                <button class="modal-x"
                        onclick="closeAdd()">

                    <i class="bi bi-x-lg"></i>

                </button>

            </div>

            <form method="post"
                  asp-action="AddAdvisor"
                  asp-controller="Home">

                @Html.AntiForgeryToken()

                <input type="hidden"
                       name="type"
                       id="addType"
                       value="RecognitionMember" />

                <div class="form-grid">

                    <div class="fld ff">

                        <label class="flabel">
                            Full Name / Position
                        </label>

                        <input class="finput"
                               type="text"
                               name="fullName"
                               required />

                    </div>

                    <div class="fld">

                        <label class="flabel">
                            Email
                        </label>

                        <input class="finput"
                               type="email"
                               name="email" />

                    </div>

                    <div class="fld">

                        <label class="flabel">
                            Phone
                        </label>

                        <input class="finput"
                               type="text"
                               name="phone" />

                    </div>

                    <div class="fld ff">

                        <label class="flabel">
                            Specialization
                        </label>

                        <input class="finput"
                               type="text"
                               name="specialization" />

                    </div>

                    <div class="fld ff">

                        <label class="flabel">
                            Workplace
                        </label>

                        <input class="finput"
                               type="text"
                               name="workplace" />

                    </div>

                </div>

                <div class="modal-foot">

                    <button type="button"
                            class="btn-cancel"
                            onclick="closeAdd()">

                        Cancel

                    </button>

                    <button type="submit"
                            class="btn-save">

                        <i class="bi bi-plus-lg"></i>

                        Add Advisor

                    </button>

                </div>

            </form>

        </div>

    </div>

    <script>

        /* =========================================================
           EDIT
        ========================================================= */

        function openEdit(id, name, email, phone, spec, work, type) {

            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editEmail').value = email;
            document.getElementById('editPhone').value = phone;
            document.getElementById('editSpec').value = spec;
            document.getElementById('editWork').value = work;
            document.getElementById('editType').value = type;

            document.getElementById('editModal')
                .classList.add('open');
        }

        function closeEdit() {

            document.getElementById('editModal')
                .classList.remove('open');
        }

        /* =========================================================
           DELETE
        ========================================================= */

        function openDelete(id, name) {

            document.getElementById('delId').value = id;

            document.getElementById('delName').innerText = name;

            document.getElementById('delModal')
                .classList.add('open');
        }

        function closeDelete() {

            document.getElementById('delModal')
                .classList.remove('open');
        }

        /* =========================================================
           CLOSE WHEN CLICKING OUTSIDE
        ========================================================= */

        ['addModal', 'editModal', 'delModal'].forEach(function (id) {

            document.getElementById(id)
                .addEventListener('click', function (e) {

                    if (e.target === this) {

                        this.classList.remove('open');
                    }
                });
        });

                /* =======================          ADD
        ====================== */

        function openAdd(type) {

            document.getElementById('addType').value = type;

            document.getElementById('addTitle').innerText =
                type === 'MinistryAdvisor'
                ? 'Add Ministry Advisor'
                : 'Add Recognition Member';

            document.getElementById('addModal')
                .classList.add('open');
        }

        function closeAdd() {

            document.getElementById('addModal')
                .classList.remove('open');
        }
    </script>

</body>
</html>