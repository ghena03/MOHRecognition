    <!-- ===================== Programs refresh helper (used by Faculties) ===================== -->
    <script>
        async function refreshProgramsNoJump() {
          const container = document.getElementById("programs-container");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("ProgramsPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

    <!-- ✅ NEW: Students refresh helper (so dropdown always gets latest programs) -->
    <script>
        async function refreshStudentsNumbersNoJump() {
          const container = document.getElementById("studentsNumbersContainer");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("StudentsNumbersPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;

            // ✅ VERY IMPORTANT: re-init students JS after replacing HTML
            if (window.initStudentsNumbers) {
              window.initStudentsNumbers();
            }
          } catch (err) {
            console.error(err);
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

   
