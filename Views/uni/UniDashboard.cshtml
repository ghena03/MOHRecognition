                <!-- ===================== Colleges ===================== -->
                <section id="sec-faculties" class="card">
                    <div class="card-hd">
                        <h2>Colleges</h2>
                        <p>Add all colleges in your institution.</p>
                    </div>

                    <div class="card-bd">
                        @{
                            var collegeCategories = (A.CollegeCategoriesCsv ?? "")
                                .Split(';', StringSplitOptions.RemoveEmptyEntries)
                                .Select(x => x.Trim())
                                .Where(x => !string.IsNullOrWhiteSpace(x))
                                .ToList();
                        }

                        <div class="field" style="margin-bottom:12px;">
                            <label>Selected College Categories</label>
                            <div class="degree-options" id="selectedCollegeCategories" style="margin-top:6px;">
                                @if (collegeCategories.Any())
                                {
                                    foreach (var cat in collegeCategories)
                                    {
                                        <span class="degree-pill" style="pointer-events:none;">
                                            <span>@cat</span>
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span style="color:#6b7280;">No categories selected.</span>
                                }
                            </div>
                        </div>

                        <div id="faculties-container"
                             data-add-url="@Url.Action("FacultiesAdd","Home")"
                             data-del-url="@Url.Action("FacultiesDelete","Home")"
                             data-update-url="@Url.Action("FacultiesUpdate","Home")">
                            @await Html.PartialAsync("Partial_Views/_Faculties", (DTOs.FacultiesDto)ViewBag.Faculties)
                        </div>
                    </div>
                </section>
                <!-- ===================== Programs ===================== -->
