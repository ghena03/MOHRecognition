    <script>
        // ── Medical Sections: show/hide based on "Medical" college category ──────
        (function () {
            function hasMedicalSelected() {
                const csv = document.getElementById('CollegeCategoriesCsv')?.value || '';
                return csv.split(';').some(s => s.trim() === 'Medical');
            }

            function syncMedicalSections() {
                const medical = hasMedicalSelected();

                // Section overlays / content wrappers
                const ids = [
                    { overlay: 'med-na-overlay',  content: 'med-real-content',  badge: 'med-na-badge',  desc: 'med-na-desc',  side: 'side-med'  },
                    { overlay: 'hosp-na-overlay', content: 'hosp-real-content', badge: 'hosp-na-badge', desc: 'hosp-na-desc', side: 'side-hosp' },
                ];
                ids.forEach(({ overlay, content, badge, desc, side }) => {
                    const ov  = document.getElementById(overlay);
                    const ct  = document.getElementById(content);
                    const bg  = document.getElementById(badge);
                    const ds  = document.getElementById(desc);
                    const si  = document.getElementById(side);

                    if (ov)  ov.style.display  = medical ? 'none'         : 'flex';
                    if (ct)  ct.style.display  = medical ? 'block'        : 'none';
                    if (bg)  bg.style.display  = medical ? 'none'         : 'inline-flex';
                    if (ds)  ds.style.display  = medical ? 'none'         : 'block';
                    if (si) {
                        const tag = si.querySelector('.side-na-tag');
                        if (tag) tag.style.display = medical ? 'none' : 'inline';
                        si.classList.toggle('side-item--na', !medical);
                    }
                });
            }

            document.addEventListener('DOMContentLoaded', function () {
                syncMedicalSections();
                // Re-sync whenever a college-category checkbox changes
                document.querySelectorAll('input[data-group="college-categories"]').forEach(cb => {
                    cb.addEventListener('change', syncMedicalSections);
                });
            });

            // Expose for SubmitApplication.js validation
            window.hasMedicalSelected = hasMedicalSelected;
        })();
    </script>
