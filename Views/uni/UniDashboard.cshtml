    <!-- ===================== Programs refresh helper (used by Colleges) ===================== -->
    <script>
        async function refreshProgramsNoJump() {
          const container = document.getElementById("programs-container");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("ProgramsPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

    <!-- ✅ NEW: Students refresh helper (so dropdown always gets latest programs) -->
    <script>
        async function refreshStudentsNumbersNoJump() {
          const container = document.getElementById("studentsNumbersContainer");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("StudentsNumbersPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;

            // ✅ VERY IMPORTANT: re-init students JS after replacing HTML
            if (window.initStudentsNumbers) {
              window.initStudentsNumbers();
            }
          } catch (err) {
            console.error(err);
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

    <script>
        (function () {
            async function saveAdmissionStudyDurations() {
                const btn = document.getElementById("btnSaveAdmissionRequirement");
                if (!btn) return;

                const sec = document.getElementById("sec-admission-duration");
                if (!sec) return;

                const diploma = sec.querySelector('input[name="AdmissionStudy.DiplomaDuration"]')?.value?.trim() || "";
                const bsc = sec.querySelector('input[name="AdmissionStudy.BScDuration"]')?.value?.trim() || "";
                const higherDiploma = sec.querySelector('input[name="AdmissionStudy.HigherDiplomaDuration"]')?.value?.trim() || "";
                const master = sec.querySelector('input[name="AdmissionStudy.MasterDuration"]')?.value?.trim() || "";
                const phd = sec.querySelector('input[name="AdmissionStudy.PhDDuration"]')?.value?.trim() || "";

                const body = new URLSearchParams({
                    "Duration.DiplomaObtain": diploma,
                    "Duration.BachelorObtain": bsc,
                    "Duration.HigherDiplomaObtain": higherDiploma,
                    "Duration.MasterObtain": master,
                    "Duration.PhDObtain": phd
                });

                const formData = new FormData();
                formData.append("diplomaDuration", diploma);
                formData.append("bScDuration", bsc);
                formData.append("higherDiplomaDuration", higherDiploma);
                formData.append("masterDuration", master);
                formData.append("phdDuration", phd);

                const diplomaPdf = sec.querySelector('input[name="AdmissionStudy.DiplomaSamplePdf"]')?.files?.[0];
                const bScPdf = sec.querySelector('input[name="AdmissionStudy.BScSamplePdf"]')?.files?.[0];
                const higherDiplomaPdf = sec.querySelector('input[name="AdmissionStudy.HigherDiplomaSamplePdf"]')?.files?.[0];
                const masterPdf = sec.querySelector('input[name="AdmissionStudy.MasterSamplePdf"]')?.files?.[0];
                const phdPdf = sec.querySelector('input[name="AdmissionStudy.PhDSamplePdf"]')?.files?.[0];

                if (diplomaPdf) formData.append("diplomaSamplePdf", diplomaPdf);
                if (bScPdf) formData.append("bScSamplePdf", bScPdf);
                if (higherDiplomaPdf) formData.append("higherDiplomaSamplePdf", higherDiplomaPdf);
                if (masterPdf) formData.append("masterSamplePdf", masterPdf);
                if (phdPdf) formData.append("phdSamplePdf", phdPdf);

                btn.disabled = true;
                try {
                    const durationRes = await fetch("@Url.Action("AutoSaveDuration", "Home")", {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                        body: body.toString()
                    });

                    const admissionRes = await fetch("@Url.Action("SaveAdmissionStudyFromUni", "Home")", {
                        method: "POST",
                        body: formData
                    });

                    if (!durationRes.ok || !admissionRes.ok) {
                        throw new Error("Save failed");
                    }
                    alert("Saved successfully.");
                } catch {
                    alert("Save failed. Please try again.");
                } finally {
                    btn.disabled = false;
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                const btn = document.getElementById("btnSaveAdmissionRequirement");
                if (!btn) return;

                btn.addEventListener("click", saveAdmissionStudyDurations);
            });
        })();
    </script>

   
