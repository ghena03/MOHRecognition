                <!-- ===================== Admission Requirements + Study Duration ===================== -->
                <section id="sec-admission-duration" class="card">
                    <div class="card-hd">
                        <h2>Admission Requirements and Study Duration</h2>
                        <p>Both the study duration and the sample requirement PDF are <strong>required</strong> for each selected degree.</p>
                    </div>

                    <div class="card-bd">
                        @{
                            var D = (DTOs.StudyDurationDto)(ViewBag.Duration ?? new DTOs.StudyDurationDto());
                        }

                        <p id="adm-no-degrees-msg" style="color:#888; font-size:.9rem; margin-bottom:1rem; display:none;">
                            No degrees selected yet. Please select the degrees your institution offers in the Academic Information section above.
                        </p>

                        <div class="adm-study-grid">
                            <article class="adm-study-card" id="adm-card-diploma" style="display:@(A.DegreeDiploma ? "block" : "none")">
                                <h3>Diploma</h3>
                                <div class="field">
                                    <label>Upload sample requirement PDF <span style="color:#e53e3e;">*</span></label>
                                    <input type="file" name="AdmissionStudy.DiplomaSamplePdf" accept=".pdf,application/pdf" />
                                </div>
                                <div class="field">
                                    <label>Study duration <span style="color:#e53e3e;">*</span></label>
                                    <input type="text" name="AdmissionStudy.DiplomaDuration" value="@(string.IsNullOrWhiteSpace(D.DiplomaObtain) ? D.DiplomaEnrollment : D.DiplomaObtain)" placeholder="e.g., 2 years" />
                                </div>
                            </article>

                            <article class="adm-study-card" id="adm-card-bsc" style="display:@(A.DegreeBSC ? "block" : "none")">
                                <h3>BSc</h3>
                                <div class="field">
                                    <label>Upload sample requirement PDF <span style="color:#e53e3e;">*</span></label>
                                    <input type="file" name="AdmissionStudy.BScSamplePdf" accept=".pdf,application/pdf" />
                                </div>
                                <div class="field">
                                    <label>Study duration <span style="color:#e53e3e;">*</span></label>
                                    <input type="text" name="AdmissionStudy.BScDuration" value="@(string.IsNullOrWhiteSpace(D.BachelorObtain) ? D.BachelorEnrollment : D.BachelorObtain)" placeholder="e.g., 4 years" />
                                </div>
                            </article>

                            <article class="adm-study-card" id="adm-card-higherdiploma" style="display:@(A.DegreeHigherDiploma ? "block" : "none")">
                                <h3>Higher Diploma</h3>
                                <div class="field">
                                    <label>Upload sample requirement PDF <span style="color:#e53e3e;">*</span></label>
                                    <input type="file" name="AdmissionStudy.HigherDiplomaSamplePdf" accept=".pdf,application/pdf" />
                                </div>
                                <div class="field">
                                    <label>Study duration <span style="color:#e53e3e;">*</span></label>
                                    <input type="text" name="AdmissionStudy.HigherDiplomaDuration" value="@(string.IsNullOrWhiteSpace(D.HigherDiplomaObtain) ? D.HigherDiplomaEnrollment : D.HigherDiplomaObtain)" placeholder="e.g., 1 year" />
                                </div>
                            </article>

