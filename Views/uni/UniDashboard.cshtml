@using DTOs
@{
    Layout = null;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Submit Application</title>

    <link rel="stylesheet" href="~/css/uni/UniDashboard.css" asp-append-version="true" />

  
</head>

<body class="submitapp-page ltr">

    <!-- HEADER -->
    <header class="top-header en">
        <div class="hdr-grid">
            <div class="hdr-lang"></div>

            <nav class="hdr-nav">
                <a class="hdr-link" href="@Url.Action("UniStatus", "Home")">← Back</a>
                <a class="hdr-link" href="https://www.mohe.gov.jo/" target="_blank" rel="noopener">Ministry Website</a>
                <a class="hdr-link" href="/Instructions">Instructions</a>
                <a class="hdr-link" href="@Url.Action("UniStatus", "Home")#faqs">FAQs</a>
            </nav>

            <div class="hdr-logo">
                <a href="https://www.mohe.gov.jo/" target="_blank" rel="noopener">
                                     <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />

                </a>
            </div>
        </div>

        <div class="brand-bar"></div>
    </header>

    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <a href="@Url.Action("UniStatus", "Home")" class="side-user">
                <div class="user-avatar">UN</div>
                <div class="user-info">
                    <span class="user-name">University Account</span>
                    <span class="user-link">Show account</span>
                </div>
            </a>

            <a class="side-item" href="#sec-instructions">Instructions</a>

            <a class="side-item" href="#sec-general">Public Info</a>
            <a class="side-item" href="#sec-academic">Academic Info</a>
            <a class="side-item" href="#sec-admission-duration">Admission Requirements and Study Duration</a>
            <a class="side-item" href="#sec-faculties">Colleges</a>
            <a class="side-item" href="#sec-programs">Programs</a>
            <a class="side-item" href="#sec-med">Medicine Colleges</a>
            <a class="side-item" href="#sec-hosp">Hospitals</a>
            <a class="side-item" href="#sec-infra">Infrastructure</a>
            <a class="side-item" href="#sec-labs">Laboratories</a>
            <a class="side-item" href="#sec-library">Library</a>
            <a class="side-item" href="#sec-pictures">Photos / Media</a>
            <a class="side-item" href="#sec-accreditation-bodies">Accreditation Bodies</a>
            <a class="side-item" href="#sec-submit-application">Finish &amp; Submit</a>
           

            <div class="side-footer">
                <a class="logout" href="@Url.Action("Logout", "Home")">Logout</a>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="content">

            <!-- WELCOME -->
            <section class="welcome" id="sec-instructions">
                <div class="welcome-card">
                    <div class="welcome-icon" aria-hidden="true">📝</div>

                    <h1 class="welcome-title">Welcome to the Submission System</h1>
                    <p class="welcome-text">
                        Fill each section then click Save. You can submit only after everything is complete.
                    </p>

                    <div class="mini-check">
                        <div class="mini-row"><span class="dot"></span>Public Info</div>
                        <div class="mini-row"><span class="dot"></span>Academic Info</div>
                        <div class="mini-row"><span class="dot"></span>Attachments</div>
                        <div class="mini-row"><span class="dot"></span>Finish & Submit</div>
                    </div>

                    <a class="btn-primary" href="#sec-general">Start with Public Info</a>
                </div>
            </section>

            <!-- ✅ ONE MAIN FORM ONLY (no nested forms) -->
            <form method="post" class="form-root" novalidate enctype="multipart/form-data">

                <!-- ===================== Public / General Info ===================== -->
                @{
                    var P = ViewBag.Public as DTOs.PublicInfoDto ?? new DTOs.PublicInfoDto();
                    var languageOfInstruction = (P.LanguageOfInstruction ?? "").Trim();
                    var languageInstructionOptions = new[]
                    {
                        "English only",
                        "Arabic only",
                        "English + Arabic",
                        "English + Spanish",
                        "English + French",
                        "English + Hindi",
                        "English + Turkish",
                        "English + German",
                        "English + Portuguese",
                        "English + Chinese (Mandarin)",
                        "English + Russian",
                        "English + Japanese",
                        "English + Korean",
                        "English + Italian",
                        "English + Urdu",
                        "English + Bengali",
                        "English + Persian",
                        "English + Indonesian",
                        "English + Malay",
                        "English + Dutch",
                        "English + Swahili",
                        "English + Tamil",
                        "English + Punjabi",
                        "English + Vietnamese",
                        "English + Thai",
                        "English + Filipino (Tagalog)",
                        "English + Greek",
                        "English + Polish",
                        "English + Ukrainian"
                    };
                    var isKnownLanguageOption = languageInstructionOptions.Any(opt =>
                        languageOfInstruction.Equals(opt, StringComparison.OrdinalIgnoreCase));
                    var isOtherLanguage = !string.IsNullOrWhiteSpace(languageOfInstruction)
                        && !isKnownLanguageOption
                        && !languageOfInstruction.Equals("Others", StringComparison.OrdinalIgnoreCase);
                    var showOtherLanguageInput = isOtherLanguage || languageOfInstruction.Equals("Others", StringComparison.OrdinalIgnoreCase);
                }

                <section class="card" id="sec-general">
                    <div class="card-hd">
                        <h2>Public Info</h2>
                        <p>Fields marked with (*) are required.</p>
                    </div>

                    <div class="card-bd">

                        <!-- Top basic -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Name of Institution <span class="req">*</span></label>
                                <input name="InstitutionName" value="@P.InstitutionName" />
                            </div>

                            <div class="field">
                                <label>Official Entity Possessing Oversight Rights</label>
                                <select name="OversightRightsEntity">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(P.OversightRightsEntity == "Ministry")">Ministry</option>
                                    <option selected="@(P.OversightRightsEntity == "Accreditation Body")">Accreditation Body</option>
                                    <option selected="@(P.OversightRightsEntity == "Other")">Other</option>
                                </select>
                            </div>
                        </div>

                        <!-- Dates + Oversight -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Founding Date <span class="req">*</span></label>
                                <input name="FoundationDate" type="date" value="@P.FoundationDate" />
                            </div>

                            <div class="field">
                                <label>Date of Establishment <span class="req">*</span></label>
                                <input name="DateOfEstablishment" type="date" value="@P.DateOfEstablishment" />
                            </div>

                            <div class="field">
                                <label>Mode of Study <span class="req">*</span></label>
                                <select name="ModeOfStudy">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(P.ModeOfStudy == "On-campus")">On-campus</option>
                                    <option selected="@(P.ModeOfStudy == "Blended")">Blended</option>
                                    <option selected="@(P.ModeOfStudy == "Online")">Online</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Language of Instruction <span class="req">*</span></label>
                                <select name="LanguageOfInstruction" id="LanguageOfInstruction">
                                    <option value="">-- Choose --</option>
                                    @foreach (var languageOption in languageInstructionOptions)
                                    {
                                        <option value="@languageOption" selected="@(languageOfInstruction.Equals(languageOption, StringComparison.OrdinalIgnoreCase))">@languageOption</option>
                                    }
                                    <option value="Others" selected="@showOtherLanguageInput">Others</option>
                                </select>

                                <div id="LanguageOfInstructionOtherWrap" style="margin-top:10px; display:@(showOtherLanguageInput ? "block" : "none");">
                                    <input type="text" name="LanguageOfInstructionOther" id="LanguageOfInstructionOther" placeholder="Please specify" value="@(isOtherLanguage ? languageOfInstruction : "")" />
                                </div>
                            </div>

                            <div class="field">
                                <label>Start of Teaching <span class="req">*</span></label>
                                <input name="StartOfTeaching" type="date" value="@P.StartOfTeaching" />
                            </div>

                        </div>

                        <!-- President info -->
                        <div class="subhead">Information of President of Institution</div>
                        <div class="grid-3">
                            <div class="field">
                                <label>Name</label>
                                <input name="PresidentName" value="@P.PresidentName" />
                            </div>
                        </div>

                        <!-- Contact info -->
                        <div class="subhead">Contact Information</div>
                        <div class="grid-2">
                            <div class="field">
                                <label>Mailing Full Address <span class="req">*</span></label>
                                <input name="MailingFullAddress" value="@P.MailingFullAddress" />
                            </div>

                            <div class="field">
                                <label>Direct Phone Number <span class="req">*</span></label>
                                <input name="DirectPhoneNumber" value="@P.DirectPhoneNumber" inputmode="tel" />
                            </div>

                            <div class="field">
                                <label>Email Address <span class="req">*</span></label>
                                <input name="EmailAddress" value="@P.EmailAddress" type="email" />
                            </div>

                            <div class="field">
                                <label>Institutional Web Address <span class="req">*</span></label>
                                <input name="InstitutionalWebAddress" value="@P.InstitutionalWebAddress" type="url" placeholder="https://..." />
                            </div>

                        </div>

                        <!-- Save (AJAX - NO RELOAD, NO SCROLL) -->
                        <div class="actions" style="justify-content:center; margin-top:14px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSavePublic"
                                    data-save-url="@Url.Action("SavePublicInfo","Home")">
                                Save Public Info
                            </button>
                        </div>
                    </div>
                </section>

                <!-- ===================== AcademicInfo ===================== -->
                @{
                    var A = ViewBag.Academic as DTOs.AcademicInfoDto ?? new DTOs.AcademicInfoDto();
                    var rankStaffFileNames = ViewBag.AcademicRankStaffFiles as IDictionary<string, string> ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);
                    string GetRankStaffFileName(string rankKey, string employmentType)
                    {
                        var key = $"{rankKey}:{employmentType}";
                        return rankStaffFileNames.TryGetValue(key, out var fileName) ? fileName : "";
                    }
                    var institutionType = (A.TypeOfAcademicInstitution ?? "").Trim();
                    var isOtherInstitutionType = !string.IsNullOrWhiteSpace(institutionType)
                        && !institutionType.Equals("Governmental", StringComparison.OrdinalIgnoreCase)
                        && !institutionType.Equals("National", StringComparison.OrdinalIgnoreCase)
                        && !institutionType.Equals("Private", StringComparison.OrdinalIgnoreCase)
                        && !institutionType.Equals("Public", StringComparison.OrdinalIgnoreCase)
                        && !institutionType.Equals("Others", StringComparison.OrdinalIgnoreCase);
                    var showOtherInstitutionTypeInput = isOtherInstitutionType || institutionType.Equals("Others", StringComparison.OrdinalIgnoreCase);
                }

                <section id="sec-academic" class="card">
                    <div class="card-hd">
                        <h2>Academic Info</h2>
                        <p>Fill academic information and save this section.</p>
                    </div>

                    <div class="card-bd">

                        <!-- Type of Academic Institution -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Type of Academic Institution <span class="req">*</span></label>
                                <select name="TypeOfAcademicInstitution" id="TypeOfAcademicInstitution">
                                    <option value="">-- Choose --</option>
                                    <option value="Governmental" selected="@(institutionType.Equals("Governmental", StringComparison.OrdinalIgnoreCase))">Governmental</option>
                                    <option value="National" selected="@(institutionType.Equals("National", StringComparison.OrdinalIgnoreCase))">National</option>
                                    <option value="Private" selected="@(institutionType.Equals("Private", StringComparison.OrdinalIgnoreCase))">Private</option>
                                    <option value="Public" selected="@(institutionType.Equals("Public", StringComparison.OrdinalIgnoreCase))">Public</option>
                                    <option value="Others" selected="@showOtherInstitutionTypeInput">Others</option>
                                </select>

                                <div id="TypeOfAcademicInstitutionOtherWrap" style="margin-top:10px; display:@(showOtherInstitutionTypeInput ? "block" : "none");">
                                    <input type="text" name="TypeOfAcademicInstitutionOther" id="TypeOfAcademicInstitutionOther" placeholder="Please specify" value="@(isOtherInstitutionType ? institutionType : "")" />
                                </div>
                            </div>
                            <div class="field">
                                <label></label>
                                <div class="degrees-institution-title" style="margin-top:10px;">Degrees in institution <span class="req">*</span></div>

                                <div class="degree-options" style="margin-top:10px;">
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeDiploma" value="true" @(A.DegreeDiploma ? "checked" : "") />
                                        <span>Diploma</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeBSC" value="true" @(A.DegreeBSC ? "checked" : "") />
                                        <span>BSC</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeHigherDiploma" value="true" @(A.DegreeHigherDiploma ? "checked" : "") />
                                        <span>Higher Diploma</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeMaster" value="true" @(A.DegreeMaster ? "checked" : "") />
                                        <span>Master</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreePhD" value="true" @(A.DegreePhD ? "checked" : "") />
                                        <span>PhD</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Official recognition / accreditation -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Has there been Official Recognition in Home Country? <span class="req">*</span></label>
                                <select name="OfficialRecognitionInHomeCountry">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.OfficialRecognitionInHomeCountry == "Yes")">Yes</option>
                                    <option selected="@(A.OfficialRecognitionInHomeCountry == "No")">No</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Has there been Official Accreditation & Quality Assurance in Home Country? <span class="req">*</span></label>
                                <select name="OfficialAccreditationQualityInHomeCountry">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.OfficialAccreditationQualityInHomeCountry == "Yes")">Yes</option>
                                    <option selected="@(A.OfficialAccreditationQualityInHomeCountry == "No")">No</option>
                                </select>
                            </div>
                        </div>

                        <!-- College Categories -->
                        <div class="subhead">College Categories <span class="req">*</span></div>
                        <div class="card" style="padding:16px; border:1px solid #e5e7eb; border-radius:12px; margin-top:10px;">
                            <div class="degree-options" style="margin-top:0;">
                                <label class="degree-pill">
                                    <input type="checkbox" data-group="college-categories" value="Scientific" />
                                    <span>Scientific Colleges</span>
                                </label>
                                <label class="degree-pill">
                                    <input type="checkbox" data-group="college-categories" value="Humanities" />
                                    <span>Humanities Colleges</span>
                                </label>
                                <label class="degree-pill">
                                    <input type="checkbox" data-group="college-categories" value="Medical" />
                                    <span>Medical Colleges</span>
                                </label>
                                <label class="degree-pill">
                                    <input type="checkbox" data-group="college-categories" value="Applied" />
                                    <span>Applied Colleges</span>
                                </label>
                            </div>
                            <input type="hidden" name="CollegeCategoriesCsv" id="CollegeCategoriesCsv" value="@A.CollegeCategoriesCsv" />
                            <input type="hidden" name="StudentsToFacultyRatio" id="StudentsToFacultyRatio" value="@(A.StudentsToFacultyRatio?.ToString() ?? "")" />
                        </div>

                        <!-- Student population -->
                        <div class="subhead">Overall Student Population of Applying Institution <span class="req">*</span></div>
                        <div class="grid-4">
                            <div class="field">
                                <label>Local Student Population</label>
                                <input type="number" min="0" name="LocalStudentPopulation" value="@(A.LocalStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label>Foreign Student Population</label>
                                <input type="number" min="0" name="ForeignStudentPopulation" value="@(A.ForeignStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label class="inline-required">Jordanian Student Population <span class="req">*</span></label>
                                <input type="number" min="0" name="JordanianStudentPopulation" value="@(A.JordanianStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label>Total <span class="req">*</span></label>
                                <input type="number" min="0" name="TotalStudentPopulation" value="@(A.TotalStudentPopulation?.ToString() ?? "")" readonly />
                            </div>
                        </div>

                        <!-- Staff headcount -->
                        <div class="subhead subhead-rank">Academic Staff Head Count Per Academic Rank <span class="req">*</span></div>
                        <div class="academic-rank-section">
                            <div class="rank-section-header">
                                <div>
                                    <div class="rank-section-kicker">Academic Staffing Matrix</div>
                                    <h4>Academic Staff by Rank</h4>
                                    <p>Enter Full-Time and Part-Time headcounts for each rank, then upload the supporting Excel files.</p>
                                </div>
                            </div>

                            <div class="rank-section-tools">
                                <a class="rank-template-btn" href="@Url.Action("DownloadAcademicRankExcelTemplate", "Home", new { staffType = "fulltime" })">
                                    Download Full-Time Excel Template
                                </a>
                                <a class="rank-template-btn" href="@Url.Action("DownloadAcademicRankExcelTemplate", "Home", new { staffType = "parttime" })">
                                    Download Part-Time Excel Template
                                </a>
                            </div>

                            <div id="academicRankUploadBanner" class="banner warn rank-info-banner" style="display:none;">
                                <span class="dot"></span>
                                <span class="txt"></span>
                                <button type="button" class="x" onclick="document.getElementById('academicRankUploadBanner').style.display='none'">×</button>
                            </div>

                            <div class="rank-group-grid">
                                <div class="rank-group-card">
                                    <div class="rank-group-title">Professor</div>
                                    <div class="rank-group-columns">
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Full-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffProfessorFullTimeCount" value="@(A.StaffProfessorFullTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="Professor" data-employment-type="fulltime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("Professor", "fulltime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Part-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffProfessorPartTimeCount" value="@(A.StaffProfessorPartTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="Professor" data-employment-type="parttime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("Professor", "parttime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rank-group-card">
                                    <div class="rank-group-title">Associate Professor</div>
                                    <div class="rank-group-columns">
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Full-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffAssociateProfessorFullTimeCount" value="@(A.StaffAssociateProfessorFullTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="AssociateProfessor" data-employment-type="fulltime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("AssociateProfessor", "fulltime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Part-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffAssociateProfessorPartTimeCount" value="@(A.StaffAssociateProfessorPartTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="AssociateProfessor" data-employment-type="parttime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("AssociateProfessor", "parttime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rank-group-card">
                                    <div class="rank-group-title">Assistant Professor</div>
                                    <div class="rank-group-columns">
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Full-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffAssistantProfessorFullTimeCount" value="@(A.StaffAssistantProfessorFullTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="AssistantProfessor" data-employment-type="fulltime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("AssistantProfessor", "fulltime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Part-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffAssistantProfessorPartTimeCount" value="@(A.StaffAssistantProfessorPartTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
                                                        <label class="rank-upload-trigger">
                                                            <input type="file" class="rank-staff-upload" data-rank-key="AssistantProfessor" data-employment-type="parttime" accept=".xlsx,.xls" />
                                                            Select Excel File
                                                        </label>
                                                        <div class="file-note rank-upload-note">@GetRankStaffFileName("AssistantProfessor", "parttime")</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rank-group-card">
                                    <div class="rank-group-title">Lecturer (PhD Holders)</div>
                                    <div class="rank-group-columns">
                                        <div class="rank-mini-section">
                                            <div class="rank-mini-title">Full-Time</div>
                                            <div class="rank-mini-grid">
                                                <div class="field rank-mini-field">
                                                    <label>Count <span class="req">*</span></label>
                                                    <input type="number" min="0" name="StaffTeacherFullTimeCount" value="@(A.StaffTeacherFullTimeCount?.ToString() ?? "")" />
                                                </div>
                                                <div class="field rank-mini-field rank-upload-field">
                                                    <div class="rank-upload-shell">
