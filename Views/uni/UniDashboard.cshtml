    <script>
        async function refreshProgramsNoJump() {
          const container = document.getElementById("programs-container");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("ProgramsPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

    
    <script>
        async function refreshStudentsNumbersNoJump() {
          const container = document.getElementById("studentsNumbersContainer");
          if (!container) return;

          const y = window.scrollY || 0;
          const h = container.offsetHeight;
          container.style.minHeight = h + "px";

          try {
            const res = await fetch("@Url.Action("StudentsNumbersPartial", "Home")");
            const html = await res.text();
            container.innerHTML = html;

           
            if (window.initStudentsNumbers) {
              window.initStudentsNumbers();
            }
          } catch (err) {
            console.error(err);
          } finally {
            window.scrollTo(0, y);
            container.style.minHeight = "";
          }
        }
    </script>

    <script>
        (function () {
            window.showAppToast = function (message, type) {
                let host = document.getElementById("uniToastHost");
                if (!host) {
                    host = document.createElement("div");
                    host.id = "uniToastHost";
                    host.className = "uni-toast-host";
                    document.body.appendChild(host);
                }

                const toast = document.createElement("div");
                toast.className = "uni-toast" + (type === "error" ? " is-error" : " is-success");
                toast.textContent = message;
                host.appendChild(toast);

                setTimeout(() => {
                    toast.classList.add("fade-out");
                    setTimeout(() => toast.remove(), 220);
                }, 2200);
            };
        })();
    </script>

    <script>
        (function () {
            async function saveAdmissionStudyDurations() {
                const btn = document.getElementById("btnSaveAdmissionRequirement");
                if (!btn) return;

                const sec = document.getElementById("sec-admission-duration");
                if (!sec) return;

                // ── Validation: duration + PDF required for every visible degree card ──
                const cardFields = [
                    { cardId: 'adm-card-diploma',      durationName: 'AdmissionStudy.DiplomaDuration',       pdfName: 'AdmissionStudy.DiplomaSamplePdf',       label: 'Diploma' },
                    { cardId: 'adm-card-bsc',           durationName: 'AdmissionStudy.BScDuration',           pdfName: 'AdmissionStudy.BScSamplePdf',           label: 'BSc' },
                    { cardId: 'adm-card-higherdiploma', durationName: 'AdmissionStudy.HigherDiplomaDuration', pdfName: 'AdmissionStudy.HigherDiplomaSamplePdf', label: 'Higher Diploma' },
                    { cardId: 'adm-card-master',        durationName: 'AdmissionStudy.MasterDuration',        pdfName: 'AdmissionStudy.MasterSamplePdf',        label: 'Master' },
                    { cardId: 'adm-card-phd',           durationName: 'AdmissionStudy.PhDDuration',           pdfName: 'AdmissionStudy.PhDSamplePdf',           label: 'PhD' },
                ];
                const missingDuration = [], missingPdf = [];
                cardFields.forEach(f => {
                    const card = document.getElementById(f.cardId);
                    if (!card || card.style.display === 'none') return;

                    const durationInput = sec.querySelector(`input[name="${f.durationName}"]`);
                    if (durationInput) {
                        if (!durationInput.value.trim()) {
                            durationInput.style.borderColor = '#dc2626';
                            durationInput.style.boxShadow   = '0 0 0 2px rgba(220,38,38,.25)';
                            missingDuration.push(f.label);
                        } else {
                            durationInput.style.borderColor = '';
                            durationInput.style.boxShadow   = '';
                        }
                    }

                    const pdfInput = sec.querySelector(`input[name="${f.pdfName}"]`);
                    if (pdfInput && !pdfInput.files?.length) {
                        pdfInput.style.outline = '2px solid #dc2626';
                        missingPdf.push(f.label);
                    } else if (pdfInput) {
                        pdfInput.style.outline = '';
                    }
                });
                if (missingDuration.length > 0 || missingPdf.length > 0) {
                    const parts = [];
                    if (missingDuration.length) parts.push(`Study duration missing for: ${missingDuration.join(', ')}`);
                    if (missingPdf.length) parts.push(`Sample PDF missing for: ${missingPdf.join(', ')}`);
                    window.showAppToast?.(parts.join(' | '), 'error');
                    return;
                }

                const diploma = sec.querySelector('input[name="AdmissionStudy.DiplomaDuration"]')?.value?.trim() || "";
                const bsc = sec.querySelector('input[name="AdmissionStudy.BScDuration"]')?.value?.trim() || "";
                const higherDiploma = sec.querySelector('input[name="AdmissionStudy.HigherDiplomaDuration"]')?.value?.trim() || "";
                const master = sec.querySelector('input[name="AdmissionStudy.MasterDuration"]')?.value?.trim() || "";
                const phd = sec.querySelector('input[name="AdmissionStudy.PhDDuration"]')?.value?.trim() || "";

                const body = new URLSearchParams({
                    "Duration.DiplomaObtain": diploma,
                    "Duration.BachelorObtain": bsc,
                    "Duration.HigherDiplomaObtain": higherDiploma,
                    "Duration.MasterObtain": master,
                    "Duration.PhDObtain": phd
                });

                const formData = new FormData();
                formData.append("diplomaDuration", diploma);
                formData.append("bScDuration", bsc);
                formData.append("higherDiplomaDuration", higherDiploma);
                formData.append("masterDuration", master);
                formData.append("phdDuration", phd);

                const diplomaPdf = sec.querySelector('input[name="AdmissionStudy.DiplomaSamplePdf"]')?.files?.[0];
                const bScPdf = sec.querySelector('input[name="AdmissionStudy.BScSamplePdf"]')?.files?.[0];
                const higherDiplomaPdf = sec.querySelector('input[name="AdmissionStudy.HigherDiplomaSamplePdf"]')?.files?.[0];
                const masterPdf = sec.querySelector('input[name="AdmissionStudy.MasterSamplePdf"]')?.files?.[0];
                const phdPdf = sec.querySelector('input[name="AdmissionStudy.PhDSamplePdf"]')?.files?.[0];

                if (diplomaPdf) formData.append("diplomaSamplePdf", diplomaPdf);
                if (bScPdf) formData.append("bScSamplePdf", bScPdf);
                if (higherDiplomaPdf) formData.append("higherDiplomaSamplePdf", higherDiplomaPdf);
                if (masterPdf) formData.append("masterSamplePdf", masterPdf);
                if (phdPdf) formData.append("phdSamplePdf", phdPdf);

                btn.disabled = true;
                try {
                    const durationRes = await fetch("@Url.Action("AutoSaveDuration", "Home")", {
                        method: "POST",
                        headers: { "Content-Type": "application/x-www-form-urlencoded; charset=UTF-8" },
                        body: body.toString()
                    });

                    if (!durationRes.ok) {
                        const errText = await durationRes.text().catch(() => "");
                        window.showAppToast?.("Save failed (duration): " + (errText || durationRes.status), "error");
                        return;
                    }

                    const admissionRes = await fetch("@Url.Action("SaveAdmissionStudyFromUni", "Home")", {
                        method: "POST",
                        body: formData
                    });

                    if (!admissionRes.ok) {
                        const errText = await admissionRes.text().catch(() => "");
                        window.showAppToast?.("Save failed (admission): " + (errText || admissionRes.status), "error");
                        return;
                    }

                    window.showAppToast?.("Saved successfully.", "success");
                    window.scrollToNextSection("sec-admission-duration");
                } catch (err) {
                    window.showAppToast?.("Save failed: " + err.message, "error");
                } finally {
                    btn.disabled = false;
                }
            }

            document.addEventListener("DOMContentLoaded", function () {
                const btn = document.getElementById("btnSaveAdmissionRequirement");
                if (btn) btn.addEventListener("click", saveAdmissionStudyDurations);

                // Sync degree checkboxes → admission cards live
                const degreeMap = {
                    'DegreeDiploma':      'adm-card-diploma',
                    'DegreeBSC':          'adm-card-bsc',
                    'DegreeHigherDiploma':'adm-card-higherdiploma',
                    'DegreeMaster':       'adm-card-master',
                    'DegreePhD':          'adm-card-phd',
                };
                function syncAdmissionCards() {
                    let anyVisible = false;
                    Object.entries(degreeMap).forEach(([cbName, cardId]) => {
                        const cb   = document.querySelector(`input[name="${cbName}"]`);
                        const card = document.getElementById(cardId);
                        if (!cb || !card) return;
                        card.style.display = cb.checked ? 'block' : 'none';
                        if (cb.checked) anyVisible = true;
                    });
                    const msg = document.getElementById('adm-no-degrees-msg');
                    if (msg) msg.style.display = anyVisible ? 'none' : 'block';
                }
                Object.keys(degreeMap).forEach(cbName => {
                    const cb = document.querySelector(`input[name="${cbName}"]`);
                    if (cb) cb.addEventListener('change', syncAdmissionCards);
                });
                syncAdmissionCards();
            });
        })();
    </script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const pgRadios = document.querySelectorAll(
