@using DTOs
@{
    Layout = null;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Submit Application</title>

    <link rel="stylesheet" href="~/css/uni/UniDashboard.css" asp-append-version="true" />

  
</head>

<body class="submitapp-page ltr">

    <!-- HEADER -->
    <header class="top-header en">
        <div class="hdr-grid">
            <div class="hdr-lang"></div>

            <nav class="hdr-nav">
                <a class="hdr-link" href="@Url.Action("UniStatus", "Home")">← Back</a>
                <a class="hdr-link" href="https://www.mohe.gov.jo/" target="_blank" rel="noopener">Ministry Website</a>
                <a class="hdr-link" href="/Instructions">Instructions</a>
                <a class="hdr-link" href="@Url.Action("UniStatus", "Home")#faqs">FAQs</a>
            </nav>

            <div class="hdr-logo">
                <a href="https://www.mohe.gov.jo/" target="_blank" rel="noopener">
                                     <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />

                </a>
            </div>
        </div>

        <div class="brand-bar"></div>
    </header>

    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <a href="@Url.Action("UniStatus", "Home")" class="side-user">
                <div class="user-avatar">UN</div>
                <div class="user-info">
                    <span class="user-name">University Account</span>
                    <span class="user-link">Show account</span>
                </div>
            </a>

            <a class="side-item" href="#sec-instructions">Instructions</a>

            <a class="side-item" href="#sec-general">Public Info</a>
            <a class="side-item" href="#sec-academic">Academic Info</a>
            <a class="side-item" href="#sec-admission">Admission Requirements</a>
            <a class="side-item" href="#sec-duration">Studying Duration</a>
            <a class="side-item" href="#sec-faculties">Faculties</a>
            <a class="side-item" href="#sec-programs">Programs</a>
            <a class="side-item" href="#sec-students">Number of Students</a>
            <a class="side-item" href="#sec-hours">Number of Hours</a>
            <a class="side-item" href="#sec-ratios">Percentages</a>
            <a class="side-item" href="#sec-staff">Teaching Staff</a>
            <a class="side-item" href="#sec-phd">PhD Holders</a>
            <a class="side-item" href="#sec-med">Medicine Faculties</a>
            <a class="side-item" href="#sec-hosp">Hospitals</a>
            <a class="side-item" href="#sec-infra">Infrastructure</a>
            <a class="side-item" href="#sec-labs">Laboratories</a>
            <a class="side-item" href="#sec-library">Library</a>
            <a class="side-item" href="#sec-attachments">Attachments</a>
            <a class="side-item" href="#sec-pictures">Pictures</a>
            <a class="side-item" href="#sec-submit-application">Finish &amp; Submit</a>
           

            <div class="side-footer">
                <a class="logout" href="@Url.Action("Logout", "Home")">Logout</a>
            </div>
        </aside>

        <!-- MAIN -->
        <main class="content">

            <!-- WELCOME -->
            <section class="welcome" id="sec-instructions">
                <div class="welcome-card">
                    <div class="welcome-icon" aria-hidden="true">📝</div>

                    <h1 class="welcome-title">Welcome to the Submission System</h1>
                    <p class="welcome-text">
                        Fill each section then click Save. You can submit only after everything is complete.
                    </p>

                    <div class="mini-check">
                        <div class="mini-row"><span class="dot"></span>Public Info</div>
                        <div class="mini-row"><span class="dot"></span>Academic Info</div>
                        <div class="mini-row"><span class="dot"></span>Attachments</div>
                        <div class="mini-row"><span class="dot"></span>Finish & Submit</div>
                    </div>

                    <a class="btn-primary" href="#sec-general">Start with Public Info</a>
                </div>
            </section>

            <!-- ✅ ONE MAIN FORM ONLY (no nested forms) -->
            <form method="post" class="form-root" novalidate>

                <!-- ===================== Public / General Info ===================== -->
                @{
                    var P = ViewBag.Public as DTOs.PublicInfoDto ?? new DTOs.PublicInfoDto();
                }

                <section class="card" id="sec-general">
                    <div class="card-hd">
                        <h2>Public Info</h2>
                        <p>Fields marked with (*) are required.</p>
                    </div>

                    <div class="card-bd">

                        <!-- Top basic -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Name of Institution <span class="req">*</span></label>
                                <input name="InstitutionName" value="@P.InstitutionName" />
                            </div>

                            <div class="field">
                                <label>Party Forwarding Form <span class="req">*</span></label>
                                <input name="PartyForwardingForm" value="@P.PartyForwardingForm" />
                            </div>
                        </div>

                        <!-- Dates + Oversight -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Founding Date <span class="req">*</span></label>
                                <input name="FoundationDate" type="date" value="@P.FoundationDate" />
                            </div>

                            <div class="field">
                                <label>Date of Conventional Academic Offerings</label>
                                <input name="ConventionalAcademicOfferingsDate" type="date" value="@P.ConventionalAcademicOfferingsDate" />
                            </div>

                            <div class="field">
                                <label>Date of non-conventional Program Offerings</label>
                                <input name="NonConventionalProgramOfferingsDate" type="date" value="@P.NonConventionalProgramOfferingsDate" />
                            </div>

                            <div class="field">
                                <label>Official Entity Possessing Oversight Rights</label>
                                <select name="OversightRightsEntity">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(P.OversightRightsEntity == "Ministry")">Ministry</option>
                                    <option selected="@(P.OversightRightsEntity == "Accreditation Body")">Accreditation Body</option>
                                    <option selected="@(P.OversightRightsEntity == "Other")">Other</option>
                                </select>
                            </div>
                        </div>

                        <!-- President info -->
                        <div class="subhead">Information of President of Institution</div>
                        <div class="grid-3">
                            <div class="field">
                                <label>Name</label>
                                <input name="PresidentName" value="@P.PresidentName" />
                            </div>
                            <div class="field">
                                <label>Highest Academic Degree</label>
                                <input name="PresidentHighestAcademicDegree" value="@P.PresidentHighestAcademicDegree" />
                            </div>
                            <div class="field">
                                <label>Major Area of Study</label>
                                <input name="PresidentMajorAreaOfStudy" value="@P.PresidentMajorAreaOfStudy" />
                            </div>
                        </div>

                        <!-- Contact info -->
                        <div class="subhead">Contact Information</div>
                        <div class="grid-2">
                            <div class="field">
                                <label>Mailing Full Address <span class="req">*</span></label>
                                <input name="MailingFullAddress" value="@P.MailingFullAddress" />
                            </div>

                            <div class="field">
                                <label>Direct Phone Number <span class="req">*</span></label>
                                <input name="DirectPhoneNumber" value="@P.DirectPhoneNumber" inputmode="tel" />
                            </div>

                            <div class="field">
                                <label>Fax Number <span class="req">*</span></label>
                                <input name="FaxNumber" value="@P.FaxNumber" inputmode="tel" />
                            </div>

                            <div class="field">
                                <label>Email Address <span class="req">*</span></label>
                                <input name="EmailAddress" value="@P.EmailAddress" type="email" />
                            </div>

                            <div class="field">
                                <label>Institutional Web Address <span class="req">*</span></label>
                                <input name="InstitutionalWebAddress" value="@P.InstitutionalWebAddress" type="url" placeholder="https://..." />
                            </div>

                            <div class="field">
                                <label>Last Date Website Updated</label>
                                <input name="LastDateWebsiteUpdated" type="date" value="@P.LastDateWebsiteUpdated" />
                            </div>
                        </div>

                        <!-- Identity -->
                        <div class="subhead">Institution Identity</div>

                        <div class="field">
                            <label>Institutional Vision Statement</label>
                            <textarea name="InstitutionalVisionStatement" rows="3">@P.InstitutionalVisionStatement</textarea>
                        </div>

                        <div class="field">
                            <label>Institutional Mission Statement</label>
                            <textarea name="InstitutionalMissionStatement" rows="3">@P.InstitutionalMissionStatement</textarea>
                        </div>

                        <div class="field">
                            <label>Institutional Targetted Objectives</label>
                            <textarea name="InstitutionalTargettedObjectives" rows="3">@P.InstitutionalTargettedObjectives</textarea>
                        </div>

                        <div class="field">
                            <label>Institutional Values</label>
                            <textarea name="InstitutionalValues" rows="3">@P.InstitutionalValues</textarea>
                        </div>

                        <!-- Save (AJAX - NO RELOAD, NO SCROLL) -->
                        <div class="actions" style="justify-content:center; margin-top:14px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSavePublic"
                                    data-save-url="@Url.Action("SavePublicInfo","Home")">
                                Save Public Info
                            </button>
                        </div>
                    </div>
                </section>

                <!-- ===================== AcademicInfo ===================== -->
                @{
                    var A = ViewBag.Academic as DTOs.AcademicInfoDto ?? new DTOs.AcademicInfoDto();
                }

                <section id="sec-academic" class="card">
                    <div class="card-hd">
                        <h2>Academic Info</h2>
                        <p>Fill academic information and save this section.</p>
                    </div>

                    <div class="card-bd">

                        <!-- Type of Academic Institution -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Type of Academic Institution <span class="req">*</span></label>
                                <select name="TypeOfAcademicInstitution">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.TypeOfAcademicInstitution == "Governmental")">Governmental</option>
                                    <option selected="@(A.TypeOfAcademicInstitution == "Regional")">Regional</option>
                                    <option selected="@(A.TypeOfAcademicInstitution == "International")">International</option>
                                    <option selected="@(A.TypeOfAcademicInstitution == "Others")">Others</option>
                                </select>
                            </div>
                            <div class="field">
                                <label></label>
                                <div class="muted" style="margin-top:10px;">Degrees in institution <span class="req">*</span></div>

                                <div class="degree-options" style="margin-top:10px;">
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeDiploma" value="true" @(A.DegreeDiploma ? "checked" : "") />
                                        <span>Diploma</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeBSC" value="true" @(A.DegreeBSC ? "checked" : "") />
                                        <span>BSC</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeHigherDiploma" value="true" @(A.DegreeHigherDiploma ? "checked" : "") />
                                        <span>Higher Diploma</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreeMaster" value="true" @(A.DegreeMaster ? "checked" : "") />
                                        <span>Master</span>
                                    </label>
                                    <label class="degree-pill">
                                        <input type="checkbox" name="DegreePhD" value="true" @(A.DegreePhD ? "checked" : "") />
                                        <span>PhD</span>
                                    </label>
                                </div>
                            </div>
                        </div>

                        <!-- Official recognition / accreditation -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Has there been Official Recognition in Home Country? <span class="req">*</span></label>
                                <select name="OfficialRecognitionInHomeCountry">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.OfficialRecognitionInHomeCountry == "Yes")">Yes</option>
                                    <option selected="@(A.OfficialRecognitionInHomeCountry == "No")">No</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Has there been Official Accreditation & Quality Assurance in Home Country? <span class="req">*</span></label>
                                <select name="OfficialAccreditationQualityInHomeCountry">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.OfficialAccreditationQualityInHomeCountry == "Yes")">Yes</option>
                                    <option selected="@(A.OfficialAccreditationQualityInHomeCountry == "No")">No</option>
                                </select>
                            </div>
                        </div>

                        <!-- Language -->
                        <div class="subhead">Language of Instruction <span class="req">*</span></div>
                        <div class="grid-2">
                            <div class="field">
                                <label>For Domestic Students <span class="req">*</span></label>
                                <input name="LanguageForDomesticStudents" value="@A.LanguageForDomesticStudents" />
                            </div>
                            <div class="field">
                                <label>For Foreign Students <span class="req">*</span></label>
                                <input name="LanguageForForeignStudents" value="@A.LanguageForForeignStudents" />
                            </div>
                        </div>

                        <!-- Joint classrooms -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Are Foreign Students offered programs in joint classrooms with local students? <span class="req">*</span></label>
                                <select name="ForeignStudentsJointClassroomsWithLocal">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.ForeignStudentsJointClassroomsWithLocal == "Yes")">Yes</option>
                                    <option selected="@(A.ForeignStudentsJointClassroomsWithLocal == "No")">No</option>
                                </select>
                            </div>
                            <div class="field"></div>
                        </div>

                        <!-- Student population -->
                        <div class="subhead">Overall Student Population of Applying Institution <span class="req">*</span></div>
                        <div class="grid-4">
                            <div class="field">
                                <label>Local Student Population</label>
                                <input type="number" min="0" name="LocalStudentPopulation" value="@(A.LocalStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label>Foreign Student Population</label>
                                <input type="number" min="0" name="ForeignStudentPopulation" value="@(A.ForeignStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label>Jordanian Student Population <span class="req">*</span></label>
                                <input type="number" min="0" name="JordanianStudentPopulation" value="@(A.JordanianStudentPopulation?.ToString() ?? "")" />
                            </div>
                            <div class="field">
                                <label>Total <span class="req">*</span></label>
                                <input type="number" min="0" name="TotalStudentPopulation" value="@(A.TotalStudentPopulation?.ToString() ?? "")" />
                            </div>
                        </div>

                        <!-- Staff headcount -->
                        <div class="subhead">Academic Staff Head Count Per Academic Rank <span class="req">*</span></div>
                        <div class="grid-4">
                            <div class="field"><label>Professor <span class="req">*</span></label><input type="number" min="0" name="StaffProfessor" value="@(A.StaffProfessor?.ToString() ?? "")" /></div>
                            <div class="field"><label>Associate Professor <span class="req">*</span></label><input type="number" min="0" name="StaffAssociateProfessor" value="@(A.StaffAssociateProfessor?.ToString() ?? "")" /></div>
                            <div class="field"><label>Assistant Professor <span class="req">*</span></label><input type="number" min="0" name="StaffAssistantProfessor" value="@(A.StaffAssistantProfessor?.ToString() ?? "")" /></div>
                            <div class="field"><label>Lab Assistant <span class="req">*</span></label><input type="number" min="0" name="StaffLabAssistant" value="@(A.StaffLabAssistant?.ToString() ?? "")" /></div>

                            <div class="field"><label>Researcher <span class="req">*</span></label><input type="number" min="0" name="StaffResearcher" value="@(A.StaffResearcher?.ToString() ?? "")" /></div>
                            <div class="field"><label>Teacher <span class="req">*</span></label><input type="number" min="0" name="StaffTeacher" value="@(A.StaffTeacher?.ToString() ?? "")" /></div>
                            <div class="field"><label>Assistant Teacher <span class="req">*</span></label><input type="number" min="0" name="StaffAssistantTeacher" value="@(A.StaffAssistantTeacher?.ToString() ?? "")" /></div>
                            <div class="field"><label>Others</label><input type="number" min="0" name="StaffOthers" value="@(A.StaffOthers?.ToString() ?? "")" /></div>
                        </div>

                        <!-- Education system -->
                        <div class="subhead">Educational System in Effect</div>
                        <div class="grid-4">
                            <label class="check-label"><input type="checkbox" name="SystemYearlyProgram" value="true" @(A.SystemYearlyProgram ? "checked" : "") /> Yearly Program</label>
                            <label class="check-label"><input type="checkbox" name="SystemSemesterProgram" value="true" @(A.SystemSemesterProgram ? "checked" : "") /> Semester Program</label>
                            <label class="check-label"><input type="checkbox" name="SystemCreditHours" value="true" @(A.SystemCreditHours ? "checked" : "") /> Credit Hours</label>
                            <label class="check-label"><input type="checkbox" name="SystemECTS" value="true" @(A.SystemECTS ? "checked" : "") /> ECTS</label>
                        </div>

                        <!-- Semester hours -->
                        <div class="subhead">Allowable Semester Hours Allowed to Students</div>
                        <div class="grid-2">
                            <div class="field"><label>Min Hours</label><input type="number" min="0" name="MinHours" value="@(A.MinHours?.ToString() ?? "")" /></div>
                            <div class="field"><label>Max Hours</label><input type="number" min="0" name="MaxHours" value="@(A.MaxHours?.ToString() ?? "")" /></div>
                        </div>

                        <!-- Research -->
                        <div class="subhead">Research Activities By Faculty <span class="req">*</span></div>
                        <div class="grid-2">
                            <div class="field"><label>Items accounted by Scopus <span class="req">*</span></label><input type="number" min="0" name="ResearchItemsScopus" value="@(A.ResearchItemsScopus?.ToString() ?? "")" /></div>
                            <div class="field"><label>Items accounted by other search engines <span class="req">*</span></label><input type="number" min="0" name="ResearchItemsOtherSearchEngines" value="@(A.ResearchItemsOtherSearchEngines?.ToString() ?? "")" /></div>
                        </div>

                        <!-- Practice -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Are foreign graduates (Medicine/Dentistry/Pharmacy) allowed to practice in home country?</label>
                                <select name="ForeignGraduatesAllowedToPractice">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.ForeignGraduatesAllowedToPractice == "Yes")">Yes</option>
                                    <option selected="@(A.ForeignGraduatesAllowedToPractice == "No")">No</option>
                                </select>
                            </div>

                            <div class="field">
                                <label>Does institution enforce class attendance for all specialties?</label>
                                <select name="EnforceClassAttendance">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.EnforceClassAttendance == "Yes")">Yes</option>
                                    <option selected="@(A.EnforceClassAttendance == "No")">No</option>
                                </select>
                            </div>
                        </div>

                        <div class="field">
                            <label>Mention Exceptions</label>
                            <input name="MentionExceptions" value="@A.MentionExceptions" />
                        </div>

                        <!-- Transfers -->
                        <div class="grid-2">
                            <div class="field">
                                <label>Are part-time/correspondence students allowed to transfer?</label>
                                <select name="PartTimeStudentsAllowedToTransfer">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.PartTimeStudentsAllowedToTransfer == "Yes")">Yes</option>
                                    <option selected="@(A.PartTimeStudentsAllowedToTransfer == "No")">No</option>
                                </select>
                            </div>
                            <div class="field">
                                <label>Elaborate Requirements and Procedures</label>
                                <input name="TransferElaborateRequirements" value="@A.TransferElaborateRequirements" />
                            </div>
                        </div>

                        <div class="grid-2">
                            <div class="field">
                                <label>Are distance learning students admissible and allowed to join graduate programs?</label>
                                <select name="DistanceLearningStudentsAdmissible">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.DistanceLearningStudentsAdmissible == "Yes")">Yes</option>
                                    <option selected="@(A.DistanceLearningStudentsAdmissible == "No")">No</option>
                                </select>
                            </div>
                            <div class="field"></div>
                        </div>

                        <!-- Max transfer -->
                        <div class="subhead">Maximum Transfer Credits Counted Toward Graduation</div>
                        <div class="grid-3">
                            <div class="field"><label>Hours</label><input name="MaxTransferHours" value="@A.MaxTransferHours" /></div>
                            <div class="field"><label>Years</label><input name="MaxTransferYears" value="@A.MaxTransferYears" /></div>
                            <div class="field"><label>Semesters</label><input name="MaxTransferSemesters" value="@A.MaxTransferSemesters" /></div>
                        </div>

                        <div class="grid-2">
                            <div class="field">
                                <label>Accept intermediate degree students (2-year diplomas) toward higher degree programs?</label>
                                <select name="AcceptIntermediateDegreeStudents">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.AcceptIntermediateDegreeStudents == "Yes")">Yes</option>
                                    <option selected="@(A.AcceptIntermediateDegreeStudents == "No")">No</option>
                                </select>
                            </div>
                            <div class="field">
                                <label>Do you require matriculation/qualifying exam for diploma/community college transfers?</label>
                                <select name="MatriculationExamRequiredForTransfers">
                                    <option value="">-- Choose --</option>
                                    <option selected="@(A.MatriculationExamRequiredForTransfers == "Yes")">Yes</option>
                                    <option selected="@(A.MatriculationExamRequiredForTransfers == "No")">No</option>
                                </select>
                            </div>
                        </div>

                        <div class="field">
                            <label>Percentage of transfer credits allowed</label>
                            <input name="PercentageTransferCreditsAllowed" value="@A.PercentageTransferCreditsAllowed" />
                        </div>

                        <!-- Save (AJAX - NO RELOAD, NO SCROLL) -->
                        <div class="actions" style="justify-content:center; margin-top:14px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSaveAcademic"
                                    data-save-url="@Url.Action("SaveAcademicInfo","Home")">
                                Save Academic Info
                            </button>
                        </div>
                    </div>
                </section>

                @* ===================== Admission Requirements ===================== *@
                <section id="sec-admission">
                    <div class="card">
                        <div class="card-hd">
                            <div class="card-title">Admission Requirements</div>
                        </div>

                        <div id="admission-container"
                             data-add-url="@Url.Action("AdmissionAdd","Home")"
                             data-del-url="@Url.Action("AdmissionDelete","Home")">
                            @await Html.PartialAsync("Partial_Views/_AdmissionRequirements", (DTOs.AdmissionRequirementsDto)ViewBag.Admission)
                        </div>
                    </div>
                </section>

                <!-- ===================== Study Duration ===================== -->
                <section id="sec-duration" class="card">
                    <div class="card-hd">
                        <h2>Study Duration</h2>
                        <p>Minimum required duration for attendance and completion of the degree.</p>
                    </div>

                    <div class="card-bd">
                      

                       @{
    var D = (DTOs.StudyDurationDto)(ViewBag.Duration ?? new DTOs.StudyDurationDto());
}

                        <div class="duration-wrap">
                            <div class="duration-titlebar">
                                Minimum Required Duration for Attendance and Completion of the Degree
                            </div>

                            <div class="duration-table-scroll">
                                <table class="duration-table">
                                    <thead>
                                        <tr>
                                            <th class="col-degree"></th>
                                            <th class="col-metric">
                                                Minimum Period for Completion <span class="req">*</span>
                                            </th>
                                            <th class="col-metric">
                                                Minimum Period for Attendance <span class="req">*</span>
                                            </th>
                                        </tr>
                                    </thead>

                                    <tbody>
                                        <tr>
                                            <td class="degree-cell">Diploma <span class="req">*</span></td>
                                            <td>
                                                <input class="duration-input"
                                                       name="Duration.DiplomaObtain"
                                                       value="@D.DiplomaObtain"
                                                       placeholder="e.g., 2 years" />
                                            </td>
                                            <td>
                                                <input class="duration-input"
                                                       name="Duration.DiplomaEnrollment"
                                                       value="@D.DiplomaEnrollment"
                                                       placeholder="e.g., 1 year" />
                                            </td>
                                        </tr>

                                        <tr>
                                            <td class="degree-cell">BSC <span class="req">*</span></td>
                                            <td>
                                                <input class="duration-input"
                                                       name="Duration.BachelorObtain"
                                                       value="@D.BachelorObtain"
                                                       placeholder="e.g., 4 years" />
                                            </td>
                                            <td>
                                                <input class="duration-input"
                                                       name="Duration.BachelorEnrollment"
                                                       value="@D.BachelorEnrollment"
                                                       placeholder="e.g., 3 years" />
                                            </td>
                                        </tr>

                                        <tr>
                                            <td class="degree-cell">Higher Diploma <span class="req">*</span></td>
                                            <td>
