@{
    Layout = null;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Postgraduate Instructions</title>
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="~/css/uni/UniDashboard.css" asp-append-version="true" />
</head>

<body class="submitapp-page ltr">
    <!-- ghena -->

    <!-- HEADER -->
    <header class="top-header en">
        <div class="hdr-grid">

            <div></div>

            <nav class="hdr-nav">
                <a class="hdr-link" href="@Url.Action("UniDashboard", "Home")">← Back</a>
                <a class="hdr-link" href="https://www.mohe.gov.jo/" target="_blank">Ministry Website</a>
            </nav>

            <div class="hdr-logo">
                <img class="rm-logo" src="~/images/mohelogo.png" />
            </div>

        </div>

        <div class="brand-bar"></div>
    </header>

    <div class="layout">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <a href="@Url.Action("UniStatus", "Home")" class="side-user">
                <div class="user-avatar">UN</div>
                <div class="user-info">
                    <span class="user-name">University Account</span>
                    <span class="user-link">Show account</span>
                </div>
            </a>

            <a class="side-item" href="#sec-general">Public Info</a>
            <a class="side-item" href="#sec-programs">Postgraduate Programs</a>
            <a class="side-item" href="#sec-students">Number of students</a>
            <a class="side-item" href="#sec-faculty">Academic Staff</a>
            <a class="side-item" href="#sec-user">Applicant Info</a>

            <div class="side-footer">
                <a class="logout" href="@Url.Action("Logout", "Home")">Logout</a>
            </div>

        </aside>

        <!-- MAIN -->
        <main class="content">

            <!-- WELCOME -->
            <section class="welcome">
                <div class="welcome-card">
                    <div class="welcome-icon">📘</div>

                    <h1 class="welcome-title">Postgraduate Recognition Instructions</h1>

                    <p class="welcome-text">
                        To apply for postgraduate recognition (Master / PhD), the institution must meet all the following requirements.
                    </p>
                </div>
            </section>

            <!-- ===================== Public / General Info ===================== -->
            @{
                var P = ViewBag.Public as DTOs.PublicInfoDto ?? new DTOs.PublicInfoDto();
                var languageOfInstruction = (P.LanguageOfInstruction ?? "").Trim();
                var languageInstructionOptions = new[]
                {
                        "English only",
                        "Arabic only",
                        "English + Arabic",
                        "English + Spanish",
                        "English + French",
                        "English + Hindi",
                        "English + Turkish",
                        "English + German",
                        "English + Portuguese",
                        "English + Chinese (Mandarin)",
                        "English + Russian",
                        "English + Japanese",
                        "English + Korean",
                        "English + Italian",
                        "English + Urdu",
                        "English + Bengali",
                        "English + Persian",
                        "English + Indonesian",
                        "English + Malay",
                        "English + Dutch",
                        "English + Swahili",
                        "English + Tamil",
                        "English + Punjabi",
                        "English + Vietnamese",
                        "English + Thai",
                        "English + Filipino (Tagalog)",
                        "English + Greek",
                        "English + Polish",
                        "English + Ukrainian"
                        };
                var isKnownLanguageOption = languageInstructionOptions.Any(opt =>
                languageOfInstruction.Equals(opt, StringComparison.OrdinalIgnoreCase));
                var isOtherLanguage = !string.IsNullOrWhiteSpace(languageOfInstruction)
                && !isKnownLanguageOption
                && !languageOfInstruction.Equals("Others", StringComparison.OrdinalIgnoreCase);
                var showOtherLanguageInput = isOtherLanguage || languageOfInstruction.Equals("Others", StringComparison.OrdinalIgnoreCase);
            }

            <section class="card" id="sec-general">
                <div class="card-hd">
                    <h2>Public Info</h2>
                    <p>Fields marked with (*) are required.</p>
                </div>

                <div class="card-bd">

                    <!-- Top basic -->
                    <div class="grid-2">
                        <div class="field">
                            <label>Name of Institution <span class="req">*</span></label>
                            <input name="InstitutionName" value="@P.InstitutionName" />
                        </div>

                        <div class="field">
                            <label>Official Entity Possessing Oversight Rights</label>
                            <select name="OversightRightsEntity">
                                <option value="">-- Choose --</option>
                                <option selected="@(P.OversightRightsEntity == "Ministry")">Ministry</option>
                                <option selected="@(P.OversightRightsEntity == "Accreditation Body")">Accreditation Body</option>
                                <option selected="@(P.OversightRightsEntity == "Other")">Other</option>
                            </select>
                        </div>
                    </div>

                    <!-- Dates + Oversight -->
                    <div class="grid-2">
                        <div class="field">
                            <label>Founding Date <span class="req">*</span></label>
                            <input name="FoundationDate" type="date" value="@P.FoundationDate" />
                        </div>

                        <div class="field">
                            <label>Date of Establishment <span class="req">*</span></label>
                            <input name="DateOfEstablishment" type="date" value="@P.DateOfEstablishment" />
                        </div>

                        <div class="field">
                            <label>Mode of Study <span class="req">*</span></label>
                            <select name="ModeOfStudy">
                                <option value="">-- Choose --</option>
                                <option selected="@(P.ModeOfStudy == "On-campus")">On-campus</option>
                                <option selected="@(P.ModeOfStudy == "Blended")">Blended</option>
                                <option selected="@(P.ModeOfStudy == "Online")">Online</option>
                            </select>
                        </div>

                        <div class="field">
                            <label>Language of Instruction <span class="req">*</span></label>
                            <select name="LanguageOfInstruction" id="LanguageOfInstruction">
                                <option value="">-- Choose --</option>
                                @foreach (var languageOption in languageInstructionOptions)
                                {
                                    <option value="@languageOption" selected="@(languageOfInstruction.Equals(languageOption, StringComparison.OrdinalIgnoreCase))">@languageOption</option>
                                }
                                <option value="Others" selected="@showOtherLanguageInput">Others</option>
                            </select>

                            <div id="LanguageOfInstructionOtherWrap" style="margin-top:10px; display:@(showOtherLanguageInput ? "block" : "none");">
                                <input type="text" name="LanguageOfInstructionOther" id="LanguageOfInstructionOther" placeholder="Please specify" value="@(isOtherLanguage? languageOfInstruction : "")" />
                            </div>
                        </div>

                        <div class="field">
                            <label>Start of Teaching <span class="req">*</span></label>
                            <input name="StartOfTeaching" type="date" value="@P.StartOfTeaching" />
                        </div>

                    </div>

                    <!-- President info -->
                    <div class="subhead">Information of President of Institution</div>
                    <div class="grid-3">
                        <div class="field">
                            <label>Name</label>
                            <input name="PresidentName" value="@P.PresidentName" />
                        </div>
                    </div>

                    <!-- Contact info -->
                    <div class="subhead">Contact Information</div>
                    <div class="grid-2">
                        <div class="field">
                            <label>Mailing Full Address <span class="req">*</span></label>
                            <input name="MailingFullAddress" value="@P.MailingFullAddress" />
                        </div>

                        <div class="field">
                            <label>Direct Phone Number <span class="req">*</span></label>
                            <input name="DirectPhoneNumber" value="@P.DirectPhoneNumber" inputmode="tel" />
                        </div>

                        <div class="field">
                            <label>Email Address <span class="req">*</span></label>
                            <input name="EmailAddress" value="@P.EmailAddress" type="email" />
                        </div>

                        <div class="field">
                            <label>Institutional Web Address <span class="req">*</span></label>
                            <input name="InstitutionalWebAddress" value="@P.InstitutionalWebAddress" type="url" placeholder="https://..." />
                        </div>

                    </div>

                    <!-- Save -->
                    <div class="actions" style="justify-content:center; margin-top:14px;">
                        <button type="button"
                                class="btn-primary"
                                id="btnSavePublic"
                                data-save-url="@Url.Action("SavePublicInfo", "Home")">
                            Save Public Info
                        </button>
                    </div>
                </div>
            </section>

            <form method="post"
                  asp-controller="Home"
                  asp-action="SavePostgraduatePrograms"
                  enctype="multipart/form-data">

                <!-- ================= PROGRAMS ================= -->
                <section class="card" id="sec-programs">

                    <div class="card-hd">
                        <h2>Postgraduate Programs</h2>
                    </div>

                    <div class="card-bd">

                        <div class="degree-options">
                            <label class="degree-pill">
                                <input type="checkbox" id="chkMaster" hidden />
                                <span>Master</span>
                            </label>

                            <label class="degree-pill">
                                <input type="checkbox" id="chkPhD" hidden />
                                <span>PhD</span>
                            </label>

                            <label class="degree-pill">
                                <input type="checkbox" id="chkDiploma" hidden />
                                <span>Higher Diploma</span>
                            </label>
                        </div>

                        <div class="program-grid">

                            <div id="masterCard" class="upload-card" style="display:none;">
                                <h3>Master Programs *</h3>
                                <input type="file" name="MasterFile" />
                            </div>

                            <div id="phdCard" class="upload-card" style="display:none;">
                                <h3>PhD Programs *</h3>
                                <input type="file" name="PhDFile" />
                            </div>

                            <div id="diplomaCard" class="upload-card" style="display:none;">
                                <h3>Higher Diploma Programs *</h3>
                                <input type="file" name="DiplomaFile" />
                            </div>

                        </div>

                        <div class="actions" style="justify-content:center; margin-top:20px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSavePrograms"
                                    data-save-url="@Url.Action("SavePublicInfo", "Home")">
                                Save
                            </button>
                        </div>

                    </div>
                </section>

                <!-- ================= STUDENTS ================= -->
                <section class="card" id="sec-students">

                    <div class="card-hd modern-hd">
                        <div class="students-title-wrap">
                            <div>
                                <h2>Number of Students</h2>
                                <p>Enter the total number of enrolled postgraduate students.</p>
                            </div>
                        </div>
                    </div>

                    <div class="card-bd students-modern-body">

                        <!-- MASTER -->
                        <div id="masterStudents" class="student-modern-row" style="display:none;">
                            <div class="student-left">
                                <div class="student-mini-icon">
                                    <i class="fa-solid fa-graduation-cap"></i>
                                </div>
                                <div>
                                    <label>Master Students <span class="required">*</span></label>
                                    <small>Total enrolled master students</small>
                                </div>
                            </div>
                            <input type="number" name="MasterStudents" />
                        </div>

                        <!-- PHD -->
                        <div id="phdStudents" class="student-modern-row" style="display:none;">
                            <div class="student-left">
                                <div class="student-mini-icon">
                                    <i class="fa-solid fa-book-open-reader"></i>
                                </div>
                                <div>
                                    <label>PhD Students <span class="required">*</span></label>
                                    <small>Total enrolled PhD students</small>
                                </div>
                            </div>
                            <input type="number" name="PhDStudents" />
                        </div>

                        <!-- DIPLOMA -->
                        <div id="diplomaStudents" class="student-modern-row" style="display:none; border-bottom:none;">
                            <div class="student-left">
                                <div class="student-mini-icon">
                                    <i class="fa-solid fa-scroll"></i>
                                </div>
                                <div>
                                    <label>Diploma Students <span class="required">*</span></label>
                                    <small>Total enrolled diploma students</small>
                                </div>
                            </div>
                            <input type="number" name="DiplomaStudents" />
                        </div>

                        <div class="actions" style="justify-content:center; margin-top:20px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSaveStudents"
                                    data-save-url="@Url.Action("SavePublicInfo", "Home")">
                                Save
                            </button>
                        </div>

                    </div>
                </section>

                <!-- ================= FACULTY ================= -->
                <section class="card" id="sec-faculty">

                    <div class="card-hd">
                        <h2>Academic Staff</h2>
                    </div>

                    <div class="card-bd">

                        <!-- MASTER FACULTY -->
                        <div id="masterFaculty" class="faculty-modern-card" style="display:none;">
                            <div class="faculty-modern-head">
                                <div class="faculty-head-left">
                                    <div>
                                        <h3>Master Programs</h3>
                                        <p>Academic staff assigned to master programs.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faculty-modern-grid">
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-chalkboard-user"></i> Professor <span class="required">*</span></label>
                                    <input type="number" name="MasterProfessor" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-user-graduate"></i> Associate Professor <span class="required">*</span></label>
                                    <input type="number" name="MasterAssociate" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-book-open-reader"></i> Assistant Professor <span class="required">*</span></label>
                                    <input type="number" name="MasterAssistant" />
                                </div>
                            </div>
                        </div>

                        <!-- PHD FACULTY -->
                        <div id="phdFaculty" class="faculty-modern-card" style="display:none;">
                            <div class="faculty-modern-head">
                                <div class="faculty-head-left">
                                    <div>
                                        <h3>PhD Programs</h3>
                                        <p>Academic staff assigned to PhD programs.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faculty-modern-grid">
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-chalkboard-user"></i> Professor <span class="required">*</span></label>
                                    <input type="number" name="PhDProfessor" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-user-graduate"></i> Associate Professor <span class="required">*</span></label>
                                    <input type="number" name="PhDAssociate" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-book-open-reader"></i> Assistant Professor <span class="required">*</span></label>
                                    <input type="number" name="PhDAssistant" />
                                </div>
                            </div>
                        </div>

                        <!-- DIPLOMA FACULTY -->
                        <div id="diplomaFaculty" class="faculty-modern-card" style="display:none;">
                            <div class="faculty-modern-head">
                                <div class="faculty-head-left">
                                    <div>
                                        <h3>Diploma Programs</h3>
                                        <p>Academic staff assigned to diploma programs.</p>
                                    </div>
                                </div>
                            </div>
                            <div class="faculty-modern-grid">
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-chalkboard-user"></i> Professor <span class="required">*</span></label>
                                    <input type="number" name="DiplomaProfessor" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-user-graduate"></i> Associate Professor <span class="required">*</span></label>
                                    <input type="number" name="DiplomaAssociate" />
                                </div>
                                <div class="faculty-input-box">
                                    <label><i class="fa-solid fa-book-open-reader"></i> Assistant Professor <span class="required">*</span></label>
                                    <input type="number" name="DiplomaAssistant" />
                                </div>
                            </div>
                        </div>

                        <!-- ✅ ONE SAVE BUTTON FOR THE ENTIRE SECTION -->
                        <div class="actions" style="justify-content:center; margin-top:20px;">
                            <button type="button"
                                    class="btn-primary"
                                    id="btnSaveFaculty">
                                Save
                            </button>
                        </div>

                    </div>
                </section>

                <!-- ================= USER INFO ================= -->
                <section class="card" id="sec-user">

                    <div class="card-hd modern-applicant-hd">
                        <div class="applicant-title-wrap">
                            <div>
                                <h2>Applicant Information</h2>
                                <p>Please enter the official applicant details.</p>
                            </div>
                        </div>
                    </div>

                    <div class="card-bd applicant-modern-body">

                        <div class="applicant-grid">

                            <div class="applicant-field">
                                <label><i class="fa-solid fa-user"></i> Full Name <span class="required">*</span></label>
                                <input type="text" name="Name" placeholder="Enter applicant name" />
                            </div>

                            <div class="applicant-field">
                                <label><i class="fa-solid fa-envelope"></i> Email Address <span class="required">*</span></label>
                                <input type="email" name="Email" placeholder="example@email.com" />
                            </div>

                            <div class="applicant-field full-width">
                                <label><i class="fa-solid fa-location-dot"></i> Location <span class="required">*</span></label>
                                <input type="text" name="Location" placeholder="Country / City" />
                            </div>

                        </div>

                        <div class="submit-area">
                            <button type="submit" class="submit-modern-btn">
                                <i class="fa-solid fa-paper-plane"></i>
                                Submit Application
                            </button>
                        </div>

                    </div>
                </section>

            </form>

            <footer class="foot">© Ministry of Higher Education</footer>

        </main>
    </div>

    <!-- SWEET ALERT -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- EXTERNAL JS -->
    <script src="~/js/uni/PostgraduatePrograms.js" asp-append-version="true"></script>

</body>
</html>