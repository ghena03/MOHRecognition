@model MOHRecognition.Services.RecognitionRequestRecord
@using System
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Accreditation Bodies";
    ViewData["ActiveNav"] = "requests";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var adminMeetingId = (int)(ViewBag.AdminMeetingId ?? 0);

    var requestId = ViewBag.RequestId ?? Model?.Id ?? 0;
    var inst = ViewBag.InstitutionName ?? Model?.UniversityName ?? "—";
    var previousLink = adminReadOnly
        ? Url.Action("AdminDetailsAcademicInfo", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAcademicInfo", "Home", new { id = requestId });
    var nextLink = adminReadOnly
        ? Url.Action("AdminDetailsInfrastructure", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsInfrastructure", "Home", new { id = requestId });

    var accreditationRows = Model?.AccreditationBodies ?? new List<DTOs.AccreditationBodyRowDto>();
    var A        = Model?.AcademicInfo   ?? new DTOs.AcademicInfoDto();
    var rankings = Model?.GlobalRankings ?? new DTOs.GlobalRankingsDto();
    var hosp = Model?.Hospitals ?? new DTOs.HospitalsDto();
    string NormalizeHospitalDocType(string? rawType)
    {
        var type = (rawType ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(type))
            return string.Empty;

        if (string.Equals(type, "LocalRecognition", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "LocalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "LocalAccreditation";
        if (string.Equals(type, "RegionalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "RegionalAccreditation";
        if (string.Equals(type, "InternationalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "InternationalAccreditation";
        if (string.Equals(type, "OtherAccreditation", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";
        if (string.Equals(type, "HospitalAgreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";

        if (string.Equals(type, "University-Hospital Agreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";
        if (string.Equals(type, "Local Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Recognition Document (", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Accreditation Document (", StringComparison.OrdinalIgnoreCase))
        {
            var open = type.IndexOf('(');
            var close = type.LastIndexOf(')');
            var inner = (open >= 0 && close > open)
                ? type.Substring(open + 1, close - open - 1).Trim()
                : string.Empty;

            if (inner.Equals("Local", StringComparison.OrdinalIgnoreCase))
                return "LocalAccreditation";
            if (inner.Equals("Regional", StringComparison.OrdinalIgnoreCase))
                return "RegionalAccreditation";
            if (inner.Equals("International", StringComparison.OrdinalIgnoreCase))
                return "InternationalAccreditation";

            return "OtherAccreditation";
        }

        if (string.Equals(type, "Accreditation Document", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";

        return type;
    }

    string HospitalDocLabel(string normalizedType) => normalizedType switch
    {
        "LocalRecognition" => "Local Recognition",
        "LocalAccreditation" => "Local Accreditation",
        "RegionalAccreditation" => "Regional Accreditation",
        "InternationalAccreditation" => "International Accreditation",
        "OtherAccreditation" => "Other Accreditation",
        "HospitalAgreement" => "University-Hospital Agreement",
        _ => string.IsNullOrWhiteSpace(normalizedType) ? "—" : normalizedType
    };

    var typedHospitalDocuments = hosp.Documents
        .Where(x => !string.IsNullOrWhiteSpace(x.FileUrl))
        .Select(x => new { Doc = x, Type = NormalizeHospitalDocType(x.DocumentType) })
        .Where(x => !string.IsNullOrWhiteSpace(x.Type))
        .OrderBy(x => x.Type)
        .ThenByDescending(x => x.Doc.UploadedAt ?? DateTime.MinValue)
        .ThenBy(x => x.Doc.OriginalFileName)
        .ToList();

    var localRecognitionDocs = typedHospitalDocuments.Where(x => x.Type == "LocalRecognition").Select(x => x.Doc).ToList();
    var localAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "LocalAccreditation").Select(x => x.Doc).ToList();
    var regionalAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "RegionalAccreditation").Select(x => x.Doc).ToList();
    var internationalAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "InternationalAccreditation").Select(x => x.Doc).ToList();
    var otherAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "OtherAccreditation").Select(x => x.Doc).ToList();
    var hospitalAgreementDocs = typedHospitalDocuments.Where(x => x.Type == "HospitalAgreement").Select(x => x.Doc).ToList();
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAcademicInfo.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>

        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>

                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>@(adminReadOnly ? "Admin Review" : "Recognition Member")</b></span>
                    </div>

                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i>
                        Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @if (adminReadOnly)
        {
            @await Html.PartialAsync("_AdminReviewSidebar")
        }
        else
        {
            @await Html.PartialAsync("_MemberSidebar")
        }

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 5 of 7 — Accreditation Bodies.</p>
                </div>

                <div class="rd-meta">
                    <div class="meta-pill">
                        <span>Request ID</span>
                        <b>#@requestId</b>
                    </div>

                    <div class="meta-pill">
                        <span>Step</span>
                        <b>5 / 7</b>
                    </div>
                </div>
            </section>

            <!-- Recognition and Accreditation (unified table) -->
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Recognition and Accreditation</h2>
                    <p>All submitted recognition certificates, accreditation documents, and university-hospital agreements.</p>
                </div>

                @{ var accredDocs = typedHospitalDocuments.Where(x => !x.Type.Equals("HospitalAgreement", StringComparison.OrdinalIgnoreCase)).ToList(); }
                @if (accredDocs.Any())
                {
                    <div class="clean-table-wrap" style="margin-top:14px;">
                        <table class="clean-review-table">
                            <thead>
                                <tr>
                                    <th style="width:44px;">#</th>
                                    <th>File Name</th>
                                    <th style="width:220px;">Category</th>
                                    <th style="width:180px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var di = 1; }
                                @foreach (var item in accredDocs)
                                {
                                    var f = item.Doc;
                                    <tr>
                                        <td>@di</td>
                                        <td class="file-cell" style="word-break:break-all;">@(string.IsNullOrWhiteSpace(f.OriginalFileName) ? "—" : f.OriginalFileName)</td>
                                        <td><span class="hosp-spec-tag" style="white-space:nowrap;">@HospitalDocLabel(item.Type)</span></td>
                                        <td class="cell-actions">
                                            <div class="table-actions">
                                                <a class="rm-mini" href="@f.FileUrl" target="_blank" rel="noopener">View</a>
                                                <a class="rm-mini" href="@f.FileUrl" download="@f.OriginalFileName">Download</a>
                                            </div>
                                        </td>
                                    </tr>
                                    di++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="infra-empty" style="margin-top:14px;">No recognition or accreditation documents submitted.</div>
                }
            </section>

            <section id="sec-research-global-rankings" class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Research & Global Rankings</h2>
                    <p>University ranking information submitted or reviewed for the request.</p>
                </div>

                @if (TempData["RankingsSaved"] != null)
                {
                    <div class="adm-saved">@TempData["RankingsSaved"]</div>
                }

                @if (TempData["RankingsError"] != null)
                {
                    <div class="adm-error">@TempData["RankingsError"]</div>
                }

                <form asp-controller="Home" asp-action="SaveGlobalRankings" method="post">
                    @Html.AntiForgeryToken()

                    <input type="hidden" name="id" value="@requestId" />

                    <div class="rank-stack">
                        <div class="rd-field">
                            <label>Academic Ranking of World Universities (ARWU)</label>

                            <div class="rank-input">
                                <input type="text"
                                       name="arwuValue"
                                       value="@rankings.ArwuValue"
                                       placeholder="Enter ranking"
                                       data-rank-input="arwu"
                                       @(adminReadOnly ? "readonly disabled" : null) />

                                <label class="na-toggle">
                                    <input type="checkbox"
                                           name="arwuIsNa"
                                           value="true"
                                           @(rankings.ArwuIsNa ? "checked" : null)
                                           data-rank-na="arwu"
                                           @(adminReadOnly ? "disabled" : null) />
                                    N/A
                                </label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>QS - World University Ranking</label>

                            <div class="rank-input">
                                <input type="text"
                                       name="qsValue"
                                       value="@rankings.QsValue"
                                       placeholder="Enter ranking"
                                       data-rank-input="qs"
                                       @(adminReadOnly ? "readonly disabled" : null) />

                                <label class="na-toggle">
                                    <input type="checkbox"
                                           name="qsIsNa"
                                           value="true"
                                           @(rankings.QsIsNa ? "checked" : null)
                                           data-rank-na="qs"
                                           @(adminReadOnly ? "disabled" : null) />
                                    N/A
                                </label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>THE - World University Ranking (Times)</label>

                            <div class="rank-input">
                                <input type="text"
                                       name="theValue"
                                       value="@rankings.TheValue"
                                       placeholder="Enter ranking"
                                       data-rank-input="the"
                                       @(adminReadOnly ? "readonly disabled" : null) />

                                <label class="na-toggle">
                                    <input type="checkbox"
                                           name="theIsNa"
                                           value="true"
                                           @(rankings.TheIsNa ? "checked" : null)
                                           data-rank-na="the"
                                           @(adminReadOnly ? "disabled" : null) />
                                    N/A
                                </label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>Scopus Ranking</label>

                            <div class="rank-input">
                                <input type="text"
                                       name="scopusValue"
                                       value="@rankings.ScopusValue"
                                       placeholder="Enter ranking"
                                       data-rank-input="scopus"
                                       @(adminReadOnly ? "readonly disabled" : null) />

                                <label class="na-toggle">
                                    <input type="checkbox"
                                           name="scopusIsNa"
                                           value="true"
                                           @(rankings.ScopusIsNa ? "checked" : null)
                                           data-rank-na="scopus"
                                           @(adminReadOnly ? "disabled" : null) />
                                    N/A
                                </label>
                            </div>
                        </div>
                    </div>

                    @if (!adminReadOnly)
                    {
                        <div style="display:flex; justify-content:flex-end; margin-top:14px;">
                            <button class="rm-btn rm-btn-primary" type="submit"><i class="bi bi-save"></i> Save</button>
                        </div>
                    }

                </form>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light"
                       href="@previousLink">
                        Previous
                    </a>
                </div>

                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light"
                       href="@nextLink">
                        Next
                    </a>
                </div>
            </section>
        </main>
    </div>

    <div id="rank-toast" style="
        position:fixed; bottom:28px; right:28px; z-index:9999;
        background:#2d6a4f; color:#fff; padding:12px 22px; border-radius:10px;
        font-size:15px; font-weight:500; box-shadow:0 4px 18px rgba(0,0,0,0.18);
        display:none; align-items:center; gap:10px;">
        <i class="bi bi-check-circle-fill"></i> <span id="rank-toast-msg">Saved successfully.</span>
    </div>

    <script>
        (function () {
            const pairs = ["arwu", "qs", "the", "scopus"];

            function syncPair(key) {
                const input = document.querySelector(`[data-rank-input="${key}"]`);
                const check = document.querySelector(`[data-rank-na="${key}"]`);
                if (!input || !check) return;
                input.disabled = check.checked;
                if (check.checked) input.value = "";
            }

            pairs.forEach(function (key) {
                const check = document.querySelector(`[data-rank-na="${key}"]`);
                if (!check) return;
                check.addEventListener("change", function () { syncPair(key); });
                syncPair(key);
            });

            function showToast(msg) {
                var t = document.getElementById('rank-toast');
                document.getElementById('rank-toast-msg').textContent = msg;
                t.style.display = 'flex';
                clearTimeout(t._hide);
                t._hide = setTimeout(function () { t.style.display = 'none'; }, 3000);
            }

            var rankForm = document.querySelector('form[action*="SaveGlobalRankings"]');
            if (rankForm) {
                rankForm.addEventListener('submit', async function (e) {
                    e.preventDefault();
                    try {
                        await fetch(rankForm.action, { method: 'POST', body: new FormData(rankForm) });
                        showToast('Research & Global Rankings saved successfully.');
                    } catch (_) {
                        showToast('Unable to save. Please try again.');
                    }
                });
            }
        })();
    </script>
</body>
</html>
