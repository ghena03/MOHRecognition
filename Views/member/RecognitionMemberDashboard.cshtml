@model MOHRecognition.Models.RecognitionMemberDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Academic Recognition Review Workspace";
    ViewData["ActiveNav"] = "dashboard";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <!-- 🔴 RED TOP LINE -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">

        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Recognition Member Dashboard</h1>
                <p>Review applications, manage recommendations, and track progress</p>
            </div>
        </div>

        <div class="header-right">
            <div class="user-pill">
                <i class="bi bi-person-circle"></i>
                Welcome, <b>@Model.CurrentRecognitionMember</b>
            </div>

            <a class="logout-btn" href="@Url.Action("Logout", "Home")">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>

    </div>



  




    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-pagehead">
                <div class="rm-pagehead-left">
                    <h1>Academic Recognition Review Workspace</h1>
                    <p>Review assigned recognition applications, study submitted documents, and record your academic recommendation.</p>
                </div>
                <form class="rm-filters" method="get" asp-action="RecognitionMemberDashboard" asp-controller="Home">
                    <div class="rm-field">
                        <label for="sessionNo">Session No.</label>
                        <select id="sessionNo" name="sessionNo" onchange="this.form.submit()">
                            @foreach (var s in Model.AvailableSessions)
                            {
                                if (Model.SessionNo == s)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="rm-field">
                        <label for="year">Year</label>
                        <select id="year" name="year" onchange="this.form.submit()">
                            @foreach (var y in Model.AvailableYears)
                            {
                                if (Model.Year == y)
                                {
                                    <option value="@y" selected>@y</option>
                                }
                                else
                                {
                                    <option value="@y">@y</option>
                                }
                            }
                        </select>
                    </div>
                </form>
            </section>

            <section class="rm-kpis">
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-folder2-open"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Assigned Reviews</div>
                        <div class="rm-kpi-val">@Model.AssignedReviewsCount</div>
                        <div class="rm-kpi-sub">Applications assigned in this session and year.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Not Reviewed Yet</div>
                        <div class="rm-kpi-val">@Model.NotReviewedCount</div>
                        <div class="rm-kpi-sub">Applications waiting for first review action.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">In Progress Reviews</div>
                        <div class="rm-kpi-val">@Model.InProgressCount</div>
                        <div class="rm-kpi-sub">Reviews with active notes or draft work.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-check2-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Submitted Recommendations</div>
                        <div class="rm-kpi-val">@Model.SubmittedRecommendationsCount</div>
                        <div class="rm-kpi-sub">Final recommendations submitted by you.</div>
                    </div>
                </article>
            </section>

            @{
                int wsTotal     = Model.AssignedReviewsCount;
                int wsCompleted = Model.SubmittedRecommendationsCount;
                int wsPct       = wsTotal > 0 ? (int)Math.Round((double)wsCompleted / wsTotal * 100) : 0;
            }
            <!-- 3-column lower grid -->
            <div class="db-lower-grid">

                <!-- 1. Session Status card -->
                <div class="rm-card db-session-card">
                    <div class="db-sc-hd">
                        <div class="db-sc-icon"><i class="bi bi-clipboard2-pulse-fill"></i></div>
                        <div>
                            <div class="db-sc-title">Session Status</div>
                            <div class="db-sc-sub">Session @(Model.SessionNo?.ToString() ?? "—") &nbsp;·&nbsp; @(Model.Year?.ToString() ?? "—")</div>
                        </div>
                    </div>

                    <div class="db-sc-rows">
                        <div class="db-sc-row">
                            <span class="db-sc-dot" style="background:#2563eb;"></span>
                            <span class="db-sc-lbl">Not Reviewed</span>
                            <span class="db-sc-val">@Model.NotReviewedCount</span>
                        </div>
                        <div class="db-sc-row">
                            <span class="db-sc-dot" style="background:#c2410c;"></span>
                            <span class="db-sc-lbl">In Progress</span>
                            <span class="db-sc-val">@Model.InProgressCount</span>
                        </div>
                        <div class="db-sc-row">
                            <span class="db-sc-dot" style="background:#059669;"></span>
                            <span class="db-sc-lbl">Submitted</span>
                            <span class="db-sc-val">@Model.SubmittedRecommendationsCount</span>
                        </div>
                        <div class="db-sc-row db-sc-row-total">
                            <span class="db-sc-dot" style="background:var(--brand);"></span>
                            <span class="db-sc-lbl">Total Assigned</span>
                            <span class="db-sc-val">@Model.AssignedReviewsCount</span>
                        </div>
                    </div>

                    <div class="db-sc-prog-wrap">
                        <div class="ws-prog-track">
                            <div class="ws-prog-fill" style="width:@wsPct%"></div>
                        </div>
                        <div class="db-sc-prog-label">
                            <span>Completion</span>
                            <span style="font-weight:800; color:@(wsPct==100 ? "#059669" : "var(--brand)");">@wsPct%</span>
                        </div>
                    </div>

                    <a class="db-sc-cta" href="@Url.Action("ElectronicRequests", "Home")">
                        <i class="bi bi-folder2-open"></i> Open My Requests
                    </a>
                </div>

                <!-- 2. Meetings card -->
                <div class="rm-card db-meetings-card">
                    <div class="db-mc-hd">
                        <div class="db-sc-icon db-mc-icon"><i class="bi bi-calendar2-week-fill"></i></div>
                        <div>
                            <div class="db-sc-title">Upcoming Meetings</div>
                            <div class="db-sc-sub">Committee sessions for your cases</div>
                        </div>
                    </div>
                    @if (Model.Meetings.Any())
                    {
                        <div class="db-meeting-list">
                            @foreach (var meeting in Model.Meetings)
                            {
                                <a class="db-meeting-row" href="@Url.Action("MeetingDetails", "Home", new { id = meeting.Id, from = "member" })">
                                    <div class="db-meeting-date-box">
                                        <span class="db-meeting-day">@meeting.MeetingDate.ToString("dd")</span>
                                        <span class="db-meeting-mon">@meeting.MeetingDate.ToString("MMM")</span>
                                    </div>
                                    <div class="db-meeting-info">
                                        <div class="db-meeting-sess">Session @meeting.SessionNo</div>
                                        @if (!string.IsNullOrWhiteSpace(meeting.Notes))
                                        {
                                            <div class="db-meeting-note">@meeting.Notes</div>
                                        }
                                    </div>
                                    <i class="bi bi-chevron-right db-app-chevron"></i>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="db-mc-empty">
                            <i class="bi bi-calendar-x"></i>
                            <p>No meetings scheduled yet.</p>
                        </div>
                    }
                    <a class="db-sc-cta db-mc-cta" href="@Url.Action("RecognitionMemberMeetings", "Home")">
                        <i class="bi bi-calendar2-week"></i> View All Meetings
                    </a>
                </div>

                <!-- 3. Quick links card -->
                <div class="rm-card db-links-card">
                    <div class="db-sc-hd" style="margin-bottom:16px;">
                        <div class="db-sc-icon db-links-icon"><i class="bi bi-grid-fill"></i></div>
                        <div>
                            <div class="db-sc-title">Quick Access</div>
                            <div class="db-sc-sub">Navigate your workspace</div>
                        </div>
                    </div>
                    <div class="db-links-list">
                        <a class="db-link-row db-link-primary" href="@Url.Action("ElectronicRequests", "Home")">
                            <i class="bi bi-folder2-open"></i>
                            <span>My Assigned Requests</span>
                            <i class="bi bi-arrow-right-short db-link-arrow"></i>
                        </a>
                        <a class="db-link-row" href="@Url.Action("Archive", "Home")">
                            <i class="bi bi-archive"></i>
                            <span>Requests Archive</span>
                            <i class="bi bi-arrow-right-short db-link-arrow"></i>
                        </a>
                        <a class="db-link-row" href="@Url.Action("RecognitionMemberMeetings", "Home")">
                            <i class="bi bi-calendar2-week"></i>
                            <span>My Meetings</span>
                            <i class="bi bi-arrow-right-short db-link-arrow"></i>
                        </a>
                        <a class="db-link-row" href="@Url.Action("ManualInstitutionRequests", "Home")">
                            <i class="bi bi-building-add"></i>
                            <span>Manual Institution Requests</span>
                            <i class="bi bi-arrow-right-short db-link-arrow"></i>
                        </a>
                    </div>
                </div>

            </div>
        </main>
    </div>
</body>
</html>
