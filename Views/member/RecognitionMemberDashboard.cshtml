@model MOHRecognition.Models.RecognitionMemberDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Academic Recognition Review Workspace";
    ViewData["ActiveNav"] = "dashboard";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <!-- 🔴 RED TOP LINE -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">

        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Recognition Member Dashboard</h1>
                <p>Review applications, manage recommendations, and track progress</p>
            </div>
        </div>

        <div class="header-right">
            <a asp-controller="Home"
               asp-action="Profile"
               class="user-pill profile-link">
                <i class="bi bi-person-circle"></i>
                Welcome, <b>@Model.CurrentRecognitionMember</b>
            </a>
            <a class="logout-btn" href="@Url.Action("Logout", "Home")">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>

    </div>



  




    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-pagehead">
                <div class="rm-pagehead-left">
                    <h1>Academic Recognition Review Workspace</h1>
                    <p>Review assigned recognition applications, study submitted documents, and record your academic recommendation.</p>
                </div>
                <form class="rm-filters" method="get" asp-action="RecognitionMemberDashboard" asp-controller="Home">
                    <div class="rm-field">
                        <label for="sessionNo">Session No.</label>
                        <select id="sessionNo" name="sessionNo">
                            @foreach (var s in Model.AvailableSessions)
                            {
                                if (Model.SessionNo == s)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="rm-field">
                        <label for="year">Year</label>
                        <select id="year" name="year">
                            @foreach (var y in Model.AvailableYears)
                            {
                                if (Model.Year == y)
                                {
                                    <option value="@y" selected>@y</option>
                                }
                                else
                                {
                                    <option value="@y">@y</option>
                                }
                            }
                        </select>
                    </div>
                    <button class="rm-btn rm-btn-ghost" type="submit">
                        <i class="bi bi-funnel"></i> Apply
                    </button>
                </form>
            </section>

            <section class="rm-kpis">
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-folder2-open"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Assigned Reviews</div>
                        <div class="rm-kpi-val">@Model.AssignedReviewsCount</div>
                        <div class="rm-kpi-sub">Applications assigned in this session and year.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Not Reviewed Yet</div>
                        <div class="rm-kpi-val">@Model.NotReviewedCount</div>
                        <div class="rm-kpi-sub">Applications waiting for first review action.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">In Progress Reviews</div>
                        <div class="rm-kpi-val">@Model.InProgressCount</div>
                        <div class="rm-kpi-sub">Reviews with active notes or draft work.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-check2-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Submitted Recommendations</div>
                        <div class="rm-kpi-val">@Model.SubmittedRecommendationsCount</div>
                        <div class="rm-kpi-sub">Final recommendations submitted by you.</div>
                    </div>
                </article>
            </section>

            <div class="rm-lower">
                <div class="ws-stack">
                    @{
                        int wsTotal     = Model.AssignedReviewsCount;
                        int wsCompleted = Model.SubmittedRecommendationsCount;
                        int wsPending   = Model.NotReviewedCount + Model.InProgressCount;
                        int wsPct       = wsTotal > 0 ? (int)Math.Round((double)wsCompleted / wsTotal * 100) : 0;

                        var firstPending = Model.Applications
                            .FirstOrDefault(a => a.ReviewStatus != "Recommendation Submitted");

                        var latestRec = Model.Applications
                            .Where(a => a.ReviewStatus == "Recommendation Submitted")
                            .OrderByDescending(a => a.LastActivityDate)
                            .FirstOrDefault();
                    }

                    <!-- A) Main Summary Card -->
                    <div class="rm-card ws-main-card">
                        <div class="ws-main-icon-wrap">
                            <i class="bi bi-journal-check"></i>
                        </div>
                        <div class="ws-main-body">
                            <h2 class="ws-main-title">Today's Review Workspace</h2>
                            <p class="ws-main-desc">
                                You have <strong>@wsTotal</strong> assigned application@(wsTotal == 1 ? "" : "s") in this session.
                                <strong>@wsCompleted</strong> recommendation@(wsCompleted == 1 ? "" : "s") submitted.
                            </p>
                            <div class="ws-main-actions">
                                <a class="rm-btn rm-btn-primary" href="@Url.Action("ElectronicRequests", "Home")">
                                    <i class="bi bi-folder2-open"></i> My Assigned Requests
                                </a>
                                <a class="rm-btn" href="@Url.Action("Archive", "Home")">
                                    <i class="bi bi-archive"></i> Requests Archive
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- B/C/D) Three-column row -->
                    <div class="ws-row">

                        <!-- B) Next Action -->
                        <div class="rm-card ws-sub-card">
                            <div class="ws-sub-icon @(wsPending > 0 ? "ws-icon-warn" : "ws-icon-ok")">
                                <i class="bi bi-@(wsPending > 0 ? "exclamation-circle-fill" : "check-circle-fill")"></i>
                            </div>
                            @if (wsPending > 0)
                            {
                                <div class="ws-sub-title">Next Action Required</div>
                                <p class="ws-sub-desc">You have <strong>@wsPending</strong> application@(wsPending == 1 ? "" : "s") waiting for review.</p>
                                <a class="rm-btn rm-btn-primary rm-btn-block ws-cta"
                                   href="@(firstPending != null ? Url.Action("DetailsBasicInfo", "Home", new { id = firstPending.Id }) : Url.Action("ElectronicRequests", "Home"))">
                                    <i class="bi bi-play-circle-fill"></i> Start Review
                                </a>
                            }
                            else if (wsTotal == 0)
                            {
                                <div class="ws-sub-title">No Applications Yet</div>
                                <p class="ws-sub-desc">No applications have been assigned to you for this session.</p>
                                <a class="rm-btn rm-btn-block ws-cta" href="@Url.Action("ElectronicRequests", "Home")">
                                    <i class="bi bi-folder2-open"></i> View Requests
                                </a>
                            }
                            else
                            {
                                <div class="ws-sub-title">All Reviews Complete</div>
                                <p class="ws-sub-desc">All assigned applications for this session are completed.</p>
                                <a class="rm-btn rm-btn-block ws-cta" href="@Url.Action("Archive", "Home")">
                                    <i class="bi bi-archive"></i> View Archive
                                </a>
                            }
                        </div>

                        <!-- C) Review Progress -->
                        <div class="rm-card ws-sub-card">
                            <div class="ws-sub-icon ws-icon-brand">
                                <i class="bi bi-bar-chart-fill"></i>
                            </div>
                            <div class="ws-sub-title">Review Progress</div>
                            <div class="ws-prog-nums">
                                <span class="ws-prog-big">@wsCompleted</span>
                                <span class="ws-prog-label">of @wsTotal completed</span>
                            </div>
                            <div class="ws-prog-track">
                                <div class="ws-prog-fill" style="width:@wsPct%"></div>
                            </div>
                            <div class="ws-prog-pct">@wsPct% complete</div>
                        </div>

                        <!-- D) Latest Recommendation -->
                        <div class="rm-card ws-sub-card">
                            <div class="ws-sub-icon ws-icon-ok">
                                <i class="bi bi-patch-check-fill"></i>
                            </div>
                            <div class="ws-sub-title">Latest Recommendation</div>
                            @if (latestRec != null)
                            {
                                <div class="ws-latest-ref">@latestRec.ReferenceNo</div>
                                <div class="ws-latest-uni">@latestRec.UniversityName</div>
                                <div class="ws-latest-date"><i class="bi bi-calendar3"></i> @latestRec.LastActivityDate.ToString("dd MMM yyyy")</div>
                                <a class="rm-btn rm-btn-block ws-cta"
                                   href="@Url.Action("DetailsRecommendation", "Home", new { id = latestRec.Id })">
                                    <i class="bi bi-eye"></i> View Recommendation
                                </a>
                            }
                            else
                            {
                                <p class="ws-sub-desc ws-empty-note">No recommendations submitted yet for this session.</p>
                            }
                        </div>

                    </div>
                </div>

                <aside class="rm-aside-cards">
                    <section class="rm-card" id="meetings-section">
                        <div class="rm-card-hd">
                            <div class="rm-card-hd-left">
                                <h2><i class="bi bi-calendar2-week rm-hd-icon"></i> Meetings</h2>
                                <p>Meetings linked to your assigned applications.</p>
                            </div>
                        </div>
                        @if (Model.Meetings.Any())
                        {
                            <div class="rm-meeting-list">
                                @foreach (var meeting in Model.Meetings)
                                {
                                    <a class="rm-meeting-row" href="@Url.Action("MeetingDetails", "Home", new { id = meeting.Id, from = "member" })">
                                        <div class="rm-meeting-top">
                                            <span class="rm-meeting-session">Session @meeting.SessionNo</span>
                                            <span class="rm-meeting-date">@meeting.MeetingDate.ToString("dd MMM yyyy")</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(meeting.Notes))
                                        {
                                            <div class="rm-meeting-note">@meeting.Notes</div>
                                        }
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rm-empty-side">No meetings assigned to your applications yet.</div>
                        }
                    </section>

                    <section class="rm-card">
                        <div class="rm-card-hd">
                            <div class="rm-card-hd-left">
                                <h2><i class="bi bi-clock-history rm-hd-icon"></i> Recent Reviewer Activity</h2>
                            </div>
                        </div>
                        @if (Model.RecentActivities.Any())
                        {
                            <div class="rm-activity-list">
                                @foreach (var act in Model.RecentActivities)
                                {
                                    <div class="rm-activity-row">
                                        <div class="rm-activity-text">@act.Description</div>
                                        <div class="rm-activity-date">@act.ActivityDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rm-empty-side">No recent reviewer activity for the selected session.</div>
                        }
                    </section>
                </aside>
            </div>
        </main>
    </div>
</body>
</html>
