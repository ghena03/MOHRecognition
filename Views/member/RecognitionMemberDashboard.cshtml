@model MOHRecognition.Models.RecognitionMemberDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Academic Recognition Review Workspace";
    ViewData["ActiveNav"] = "dashboard";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <!-- 🔴 RED TOP LINE -->
    <div class="top-bar"></div>

    <!-- HEADER -->
    <div class="header">

        <div class="header-left">
            <img src="/images/mohelogo.png" class="logo" />

            <div class="divider"></div>

            <div class="title-box">
                <h1>Recognition Member Dashboard</h1>
                <p>Review applications, manage recommendations, and track progress</p>
            </div>
        </div>

        <div class="header-right">
            <div class="user-pill">
                <i class="bi bi-person-circle"></i>
                Welcome, <b>@Model.CurrentRecognitionMember</b>
            </div>

            <a class="logout-btn" href="@Url.Action("Logout", "Home")">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </div>

    </div>



  




    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-pagehead">
                <div class="rm-pagehead-left">
                    <h1>Academic Recognition Review Workspace</h1>
                    <p>Review assigned recognition applications, study submitted documents, and record your academic recommendation.</p>
                </div>
                <form class="rm-filters" method="get" asp-action="RecognitionMemberDashboard" asp-controller="Home">
                    <div class="rm-field">
                        <label for="sessionNo">Session No.</label>
                        <select id="sessionNo" name="sessionNo">
                            @foreach (var s in Model.AvailableSessions)
                            {
                                if (Model.SessionNo == s)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="rm-field">
                        <label for="year">Year</label>
                        <select id="year" name="year">
                            @foreach (var y in Model.AvailableYears)
                            {
                                if (Model.Year == y)
                                {
                                    <option value="@y" selected>@y</option>
                                }
                                else
                                {
                                    <option value="@y">@y</option>
                                }
                            }
                        </select>
                    </div>
                    <button class="rm-btn rm-btn-ghost" type="submit">
                        <i class="bi bi-funnel"></i> Apply
                    </button>
                </form>
            </section>

            <section class="rm-kpis">
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-folder2-open"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Assigned Reviews</div>
                        <div class="rm-kpi-val">@Model.AssignedReviewsCount</div>
                        <div class="rm-kpi-sub">Applications assigned in this session and year.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-hourglass-split"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Not Reviewed Yet</div>
                        <div class="rm-kpi-val">@Model.NotReviewedCount</div>
                        <div class="rm-kpi-sub">Applications waiting for first review action.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-pencil-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">In Progress Reviews</div>
                        <div class="rm-kpi-val">@Model.InProgressCount</div>
                        <div class="rm-kpi-sub">Reviews with active notes or draft work.</div>
                    </div>
                </article>
                <article class="rm-kpi">
                    <div class="rm-kpi-icon"><i class="bi bi-check2-square"></i></div>
                    <div class="rm-kpi-body">
                        <div class="rm-kpi-label">Submitted Recommendations</div>
                        <div class="rm-kpi-val">@Model.SubmittedRecommendationsCount</div>
                        <div class="rm-kpi-sub">Final recommendations submitted by you.</div>
                    </div>
                </article>
            </section>

            <div class="rm-lower">
                <section class="rm-card">
                    <div class="rm-card-hd">
                        <div class="rm-card-hd-left">
                            <h2>Assigned Recognition Applications</h2>
                            <p>Applications assigned to you for academic review and recommendation.</p>
                        </div>
                    </div>

                    <form class="rm-table-filters" method="get" asp-action="RecognitionMemberDashboard" asp-controller="Home">
                        <input type="hidden" name="sessionNo" value="@Model.SessionNo" />
                        <input type="hidden" name="year" value="@Model.Year" />

                        <div class="rm-field grow">
                            <label for="search">Search</label>
                            <div class="rm-input">
                                <i class="bi bi-search"></i>
                                <input id="search" name="search" type="text" value="@Model.Search" placeholder="Reference or university name" />
                            </div>
                        </div>

                        <div class="rm-field">
                            <label for="status">Status</label>
                            <select id="status" name="status">
                                @foreach (var option in new[] { "All", "Not Reviewed", "In Progress", "Recommendation Submitted", "Returned for Update" })
                                {
                                    if (string.Equals(Model.Status, option, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@option" selected>@option</option>
                                    }
                                    else
                                    {
                                        <option value="@option">@option</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="rm-field">
                            <label for="country">Country</label>
                            <select id="country" name="country">
                                @if (Model.Country == "All")
                                {
                                    <option value="All" selected>All</option>
                                }
                                else
                                {
                                    <option value="All">All</option>
                                }
                                @foreach (var c in Model.AvailableCountries)
                                {
                                    if (string.Equals(Model.Country, c, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <option value="@c" selected>@c</option>
                                    }
                                    else
                                    {
                                        <option value="@c">@c</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="rm-field">
                            <label for="sort">Sort</label>
                            <select id="sort" name="sort">
                                @if (Model.Sort == "NewestActivity")
                                {
                                    <option value="NewestActivity" selected>Newest Activity</option>
                                }
                                else
                                {
                                    <option value="NewestActivity">Newest Activity</option>
                                }
                                @if (Model.Sort == "OldestActivity")
                                {
                                    <option value="OldestActivity" selected>Oldest Activity</option>
                                }
                                else
                                {
                                    <option value="OldestActivity">Oldest Activity</option>
                                }
                                @if (Model.Sort == "UniversityAZ")
                                {
                                    <option value="UniversityAZ" selected>University A-Z</option>
                                }
                                else
                                {
                                    <option value="UniversityAZ">University A-Z</option>
                                }
                            </select>
                        </div>

                        <button class="rm-btn rm-btn-ghost" type="submit">
                            <i class="bi bi-funnel"></i> Apply
                        </button>
                    </form>

                    <div class="rm-tablewrap">
                        <table class="rm-table">
                            <thead>
                                <tr>
                                    <th>Reference</th>
                                    <th>University</th>
                                    <th>Country</th>
                                    <th>Current Review Status</th>
                                    <th>Last Activity</th>
                                    <th class="right">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Applications.Any())
                                {
                                    @foreach (var item in Model.Applications)
                                    {
                                        var actionUrl = item.ReviewStatus == "Recommendation Submitted"
                                            ? Url.Action("DetailsRecommendation", "Home", new { id = item.Id })
                                            : Url.Action("DetailsBasicInfo", "Home", new { id = item.Id });
                                        var actionClass = item.ActionLabel == "Review" ? "rm-action rm-action-primary" : "rm-action";
                                        var statusClass = item.ReviewStatus switch
                                        {
                                            "Not Reviewed" => "badge-neutral",
                                            "In Progress" => "badge-warn",
                                            "Recommendation Submitted" => "badge-ok",
                                            _ => "badge-returned"
                                        };

                                        <tr>
                                            <td class="rm-ref">@item.ReferenceNo</td>
                                            <td class="rm-university">@item.UniversityName</td>
                                            <td>@item.Country</td>
                                            <td><span class="badge @statusClass">@item.ReviewStatus</span></td>
                                            <td class="rm-date">@item.LastActivityDate.ToString("dd MMM yyyy")</td>
                                            <td class="right">
                                                <a class="@actionClass" href="@actionUrl">@item.ActionLabel</a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="rm-empty">
                                            <div class="rm-empty-title">No applications assigned for the selected session and year.</div>
                                            <div class="rm-empty-sub">Assigned applications will appear here once they are distributed to recognition members.</div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>

                <aside class="rm-aside-cards">
                    <section class="rm-card" id="meetings-section">
                        <div class="rm-card-hd">
                            <div class="rm-card-hd-left">
                                <h2><i class="bi bi-calendar2-week rm-hd-icon"></i> Meetings</h2>
                                <p>Meetings linked to your assigned applications.</p>
                            </div>
                        </div>
                        @if (Model.Meetings.Any())
                        {
                            <div class="rm-meeting-list">
                                @foreach (var meeting in Model.Meetings)
                                {
                                    <a class="rm-meeting-row" href="@Url.Action("MeetingDetails", "Home", new { id = meeting.Id, from = "member" })">
                                        <div class="rm-meeting-top">
                                            <span class="rm-meeting-session">Session @meeting.SessionNo</span>
                                            <span class="rm-meeting-date">@meeting.MeetingDate.ToString("dd MMM yyyy")</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(meeting.Notes))
                                        {
                                            <div class="rm-meeting-note">@meeting.Notes</div>
                                        }
                                    </a>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rm-empty-side">No meetings assigned to your applications yet.</div>
                        }
                    </section>

                    <section class="rm-card">
                        <div class="rm-card-hd">
                            <div class="rm-card-hd-left">
                                <h2><i class="bi bi-clock-history rm-hd-icon"></i> Recent Reviewer Activity</h2>
                            </div>
                        </div>
                        @if (Model.RecentActivities.Any())
                        {
                            <div class="rm-activity-list">
                                @foreach (var act in Model.RecentActivities)
                                {
                                    <div class="rm-activity-row">
                                        <div class="rm-activity-text">@act.Description</div>
                                        <div class="rm-activity-date">@act.ActivityDate.ToString("dd MMM yyyy")</div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="rm-empty-side">No recent reviewer activity for the selected session.</div>
                        }
                    </section>
                </aside>
            </div>
        </main>
    </div>
</body>
</html>
