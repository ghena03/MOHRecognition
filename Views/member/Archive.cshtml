@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>
@using System

@{
    Layout = null;
    ViewData["Title"] = "Requests Archive";
    ViewData["ActiveNav"] = "archive";
    var currentMember = ViewBag.CurrentRecognitionMember as string ?? "Recognition Member";
    var currentEmail  = ViewBag.CurrentMemberEmail as string ?? "";
    var successMessage = TempData["ArchiveSuccess"] as string;
    var errorMessage   = TempData["ArchiveError"] as string;
    var nameMap = ViewBag.MemberNameMap as Dictionary<string, string>
                  ?? new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase);

    string MemberName(string? email)
    {
        if (string.IsNullOrWhiteSpace(email) || email.Equals("Unassigned", StringComparison.OrdinalIgnoreCase))
            return "Unassigned";
        var key = email.Trim().ToLowerInvariant();
        return nameMap.TryGetValue(key, out var n) ? n : email;
    }

    string AppTypeStyle(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "background:#ede9fe;color:#5b21b6;border:1px solid #c4b5fd",
        "Online"       => "background:#dcfce7;color:#166534;border:1px solid #86efac",
        _              => "background:#dbeafe;color:#1e40af;border:1px solid #93c5fd"
    };
    string RowClass(string? t) => (t ?? "Bachelor") switch
    {
        "Postgraduate" => "app-row-postgraduate",
        "Online"       => "app-row-online",
        _              => "app-row-bachelor"
    };
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/Archive.css" asp-append-version="true" />
</head>

<body class="rm-page">

    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>

                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>@currentMember</b></span>
                    </div>

                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">

        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">

            <section class="rm-card arc-head">
                <div class="arc-top">
                    <div>
                        <h1>Requests Archive</h1>
                        <p>Browse all submitted requests currently stored in the system.</p>
                    </div>

                    <div class="arc-chips">
                        <div class="arc-chip">
                            <span>Total</span>
                            <b>@Model.Count</b>
                        </div>
                        <div class="arc-chip">
                            <span>Approved</span>
                            <b>@Model.Count(x => x.Status == "Approved")</b>
                        </div>
                        <div class="arc-chip">
                            <span>Pending</span>
                            <b>@Model.Count(x => x.Status == "Pending")</b>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(successMessage))
                {
                    <div style="margin-top:16px; padding:12px 14px; border-radius:12px; background:#ecfdf3; color:#027a48; border:1px solid #abefc6;">
                        @successMessage
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(errorMessage))
                {
                    <div style="margin-top:16px; padding:12px 14px; border-radius:12px; background:#fff1f2; color:#b42318; border:1px solid #fecdca;">
                        @errorMessage
                    </div>
                }

            </section>

            <section class="rm-card">
                <div class="rm-card-hd row">
                    <div>
                        <h2>All Requests</h2>
                        <p>Only the assigned member can send a request to admin review.</p>
                    </div>
                </div>

                <div class="rm-tablewrap">
                    <table class="rm-table arc-table">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>Type</th>
                                <th>University</th>
                                <th>Country</th>
                                <th>Email</th>
                                <th>Assigned Member</th>
                                <th>Status</th>
                                <th>Submitted</th>
                                <th class="right">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    var isMine = string.Equals(item.AssignedMember, currentEmail, StringComparison.OrdinalIgnoreCase);

                                    <tr class="@RowClass(item.ApplicationType)">
                                        <td><b>@item.ReferenceNumber</b></td>
                                        <td><span style="display:inline-block;border-radius:20px;padding:3px 10px;font-size:11px;font-weight:700;@AppTypeStyle(item.ApplicationType)">@(item.ApplicationType ?? "Bachelor")</span></td>
                                        <td>@item.UniversityName</td>
                                        <td>@item.Country</td>
                                        <td>@item.UniversityEmail</td>
                                        <td>@MemberName(item.AssignedMember)</td>
                                        <td><span class="badge badge-pending">@item.Status</span></td>
                                        <td>@item.SubmittedAt.ToString("yyyy-MM-dd")</td>
                                        <td class="right" style="display:flex;gap:6px;align-items:center;flex-wrap:wrap;">
                                            @if (isMine)
                                            {
                                                <a class="rm-mini" href="@Url.Action("DetailsBasicInfo", "Home", new { id = item.Id })">Open</a>
                                            }
                                            else
                                            {
                                                <a class="rm-mini rm-mini--view" href="@Url.Action("DetailsBasicInfo", "Home", new { id = item.Id })">View</a>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="9" style="text-align:center; padding:24px;">
                                        No submitted requests yet.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

        </main>
    </div>
</body>
</html>
