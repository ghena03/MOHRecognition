@model MOHRecognition.Models.RecognitionMemberMeetingsViewModel
@{
    Layout = null;
    ViewData["Title"] = "Assigned Committee Meetings";
    ViewData["ActiveNav"] = "meetings";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/RecognitionMemberMeetings.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>
                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>@Model.CurrentRecognitionMember</b></span>
                    </div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-pagehead">
                <div class="rm-pagehead-left">
                    <h1>Assigned Committee Meetings</h1>
                    <p>View committee meetings submitted by the admin for your assigned recognition applications.</p>
                </div>
            </section>

            <section class="rm-card">
                <div class="rm-tablewrap table-box-theme2">
                    <table class="meeting-theme-table">
                        <thead>
                            <tr>
                                <th>Session #</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Location / Platform</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Meetings.Any())
                            {
                                @foreach (var item in Model.Meetings)
                                {
                                    var isClosed = string.Equals(item.Status, "Closed", StringComparison.OrdinalIgnoreCase);
                                    var statusStyle = item.Status switch {
                                        "Closed"    => "background:#f0f0f0;color:#777;border:1px solid #ccc;",
                                        "Open"      => "background:#e8f5ea;color:#1a7a34;border:1px solid #a7f3d0;",
                                        "Scheduled" => "background:#e8f0fe;color:#1a56db;border:1px solid #c5d8f8;",
                                        _           => "background:#fff3cd;color:#856404;border:1px solid #ffe082;"
                                    };
                                    <tr style="@(isClosed ? "opacity:0.75;" : "")">
                                        <td>@item.SessionNumber</td>
                                        <td>@item.MeetingDate.ToString("yyyy-MM-dd")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.MeetingTime) ? "—" : item.MeetingTime)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.LocationOrPlatform) ? "—" : item.LocationOrPlatform)</td>
                                        <td>
                                            <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:20px;font-size:12px;font-weight:700;@statusStyle">
                                                @if (isClosed)
                                                {
                                                    <i class="bi bi-lock-fill"></i>
                                                }
                                                else
                                                {
                                                    <span style="width:7px;height:7px;border-radius:50%;background:currentColor;display:inline-block;"></span>
                                                }
                                                @item.Status
                                            </span>
                                        </td>
                                        <td>
                                            <a href="/Home/MeetingDetails?id=@item.Id&from=member" class="action-btn">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="meeting-empty">No meetings yet</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
