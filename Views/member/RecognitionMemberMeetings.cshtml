@model MOHRecognition.Models.RecognitionMemberMeetingsViewModel
@{
    Layout = null;
    ViewData["Title"] = "Assigned Committee Meetings";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/RecognitionMemberMeetings.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>
                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>@Model.CurrentRecognitionMember</b></span>
                    </div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        <aside class="rm-sidebar">
            <div class="rm-side-label">Workspace</div>
            <nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")">
                    <i class="bi bi-grid-1x2-fill"></i><span>Review Dashboard</span>
                </a>
                <a class="rm-navitem" href="@Url.Action("ElectronicRequests", "Home")">
                    <i class="bi bi-journal-check"></i><span>My Assigned Requests</span>
                </a>
                <a class="rm-navitem" href="@Url.Action("Archive", "Home")">
                    <i class="bi bi-inboxes"></i><span>Requests Archive</span>
                </a>
                <a class="rm-navitem" href="@Url.Action("ResetPassword", "Home", new { role = "recognition" })">
                    <i class="bi bi-person-gear"></i><span>Profile &amp; Security</span>
                </a>
                <a class="rm-navitem active" href="@Url.Action("RecognitionMemberMeetings", "Home")">
                    <i class="bi bi-calendar2-week"></i><span>Meetings</span>
                </a>
                <div class="rm-nav-divider"></div>
                <a class="rm-navitem rm-navitem-danger" href="@Url.Action("Logout", "Home")">
                    <i class="bi bi-power"></i><span>Sign Out</span>
                </a>
            </nav>
        </aside>

        <main class="rm-main">
            <section class="rm-pagehead">
                <div class="rm-pagehead-left">
                    <h1>Assigned Committee Meetings</h1>
                    <p>View committee meetings submitted by the admin for your assigned recognition applications.</p>
                </div>
            </section>

            <section class="rm-card">
                <div class="rm-tablewrap table-box-theme2">
                    <table class="meeting-theme-table">
                        <thead>
                            <tr>
                                <th>Session #</th>
                                <th>Date</th>
                                <th>Time</th>
                                <th>Location / Platform</th>
                                <th>Actions</th>
                            </tr> 
                        </thead>
                        <tbody>
                            @if (Model.Meetings.Any())
                            {
                                @foreach (var item in Model.Meetings)
                                {
                                    <tr>
                                        <td>@item.SessionNumber</td>
                                        <td>@item.MeetingDate.ToString("yyyy-MM-dd")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.MeetingTime) ? "—" : item.MeetingTime)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.LocationOrPlatform) ? "—" : item.LocationOrPlatform)</td>
                                        <td>
                                            <a href="/Home/MeetingDetails?id=@item.Id&from=member" class="action-btn">
                                                View
                                            </a>
                                        </td>
                                    </tr> 
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="meeting-empty">No meetings yet</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
