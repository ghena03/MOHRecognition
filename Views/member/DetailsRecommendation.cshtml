@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Recommendation";
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var recommendationDecision = Model?.BasicInfoAssessmentDecision ?? string.Empty;
    var recommendationNote = Model?.BasicInfoAssessmentReason ?? string.Empty;
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsRecommendation.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>Recognition Member</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        <aside class="rm-sidebar">
            <div class="rm-side-title">Navigation</div><nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")"><i class="bi bi-grid-1x2"></i><span>Dashboard</span></a>
                <a class="rm-navitem active" href="@Url.Action("ElectronicRequests", "Home")"><i class="bi bi-send-check"></i><span>My Assigned Requests</span></a>
                <a class="rm-navitem" href="@Url.Action("Archive", "Home")"><i class="bi bi-inboxes"></i><span>Requests Archive</span></a>
                <a class="rm-navitem danger" href="@Url.Action("Logout", "Home")"><i class="bi bi-power"></i><span>Sign Out</span></a>
            </nav>
        </aside>

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Final Stage — Analysis & Recommendation.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Stage</span><b>Final</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Final Recognition Decision</h2>
                    <p>Choose a professional recommendation and provide a justification note.</p>
                </div>

                @if (TempData["RecommendationSaved"] != null)
                {
                    <div class="infra-saved">@TempData["RecommendationSaved"]</div>
                }

                @if (TempData["RecommendationError"] != null)
                {
                    <div class="infra-error">@TempData["RecommendationError"]</div>
                }
           

                <form asp-controller="Home" asp-action="SaveRecommendationDecision" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@requestId" />
                    <input type="hidden" name="decision" value="Auto" />
                       <div class="rm-card" style="margin-top:15px;">
                        <h3>Point 1: Accreditation & Recognition</h3>

                        <div class="rd-field" style="margin-top:15px;">
                            <label for="decisionReason"><strong>Write Your Assessment Note</strong></label>
                            <textarea id="decisionReason"
                                      class="doc-notes"
                                      name="reason"
                                      placeholder="Write your professional evaluation regarding accreditation and recognition..."
                                      required>@recommendationNote</textarea>
                        </div>
                    </div>
                 

                    <div style="display:flex; justify-content:flex-end; margin-top:14px;">
                        <button class="rm-btn rm-btn-primary" type="submit"><i class="bi bi-check2-circle"></i> Save Decision</button>
                    </div>
                </form>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsInfrastructure", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("ElectronicRequests", "Home")">Exit</a>
                </div>
            </section>
        </main>
    </div>

    <script>
        (function () {
            const cards = document.querySelectorAll('.decision-card');

            function refreshSelectedState() {
                cards.forEach((card) => {
                    const input = card.querySelector('input[type="radio"]');
                    if (!input) return;

                    card.classList.toggle('is-selected', input.checked);
                });
            }

            cards.forEach((card) => {
                const input = card.querySelector('input[type="radio"]');
                if (!input) return;

                input.addEventListener('change', refreshSelectedState);
                card.addEventListener('click', refreshSelectedState);
            });

            refreshSelectedState();
        })();
    </script>
</body>
</html>