@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Final Assessment";
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var memberViewOnly = (bool)(ViewBag.MemberViewOnly ?? false);
    var readOnlyMode = adminReadOnly || memberViewOnly;
    ViewData["ActiveNav"] = memberViewOnly ? "archive" : "requests";

    // ── Saved values ─────────────────────────────────────────────────────────
    var savedAccreditationStatus = Model?.AccreditationStatus ?? string.Empty;
    var savedAccreditationNote   = Model?.AccreditationNote   ?? string.Empty;
    var savedFinalJustification  = Model?.BasicInfoAssessmentReason ?? string.Empty;
    var savedDecision            = Model?.BasicInfoAssessmentDecision ?? string.Empty;

    // ── Academic Info calculations ────────────────────────────────────────────
    var A = Model?.AcademicInfo ?? new DTOs.AcademicInfoDto();
    var hasFacultyData = Model?.AcademicInfo != null;

    var professorFT          = A.StaffProfessorFullTimeCount         ?? 0;
    var associateProfessorFT = A.StaffAssociateProfessorFullTimeCount ?? 0;
    var assistantProfessorFT = A.StaffAssistantProfessorFullTimeCount ?? 0;
    var teacherFT            = A.StaffTeacherFullTimeCount            ?? 0;
    var researcherFT         = A.StaffResearcherFullTimeCount         ?? 0;
    var assistantTeacherFT   = A.StaffAssistantTeacherFullTimeCount   ?? 0;
    var othersFT             = A.StaffOthersFullTimeCount             ?? 0;

    var totalPhdHolders          = professorFT + associateProfessorFT + assistantProfessorFT + teacherFT;
    var fullTimeFacultyDoctorate = professorFT + associateProfessorFT + assistantProfessorFT +
                                   teacherFT + assistantTeacherFT + othersFT + researcherFT;
    var doctorateHoldersPercentage = fullTimeFacultyDoctorate > 0
        ? Math.Floor(((decimal)totalPhdHolders * 100m) / fullTimeFacultyDoctorate) : 0m;
    var doctorateColorStatus = fullTimeFacultyDoctorate > 0
        ? (doctorateHoldersPercentage >= 50m ? "green" : "red") : "";

    var allowedMscSupport    = Math.Ceiling(0.20m * totalPhdHolders);
    var actualMscSupport     = assistantTeacherFT + othersFT;
    var mscSupportUsed       = Math.Min(allowedMscSupport, actualMscSupport);
    var totalFacultyForRatio = totalPhdHolders + (0.10m * totalPhdHolders) + mscSupportUsed;
    var totalStudents        = A.TotalStudentPopulation ?? 0;
    var ratioValue           = A.StudentsToFacultyRatio ?? 0m;

    var selectedCategories = (A.CollegeCategoriesCsv ?? "")
        .Split(';', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim()).Where(x => !string.IsNullOrWhiteSpace(x)).ToList();
    var categoryRatioMap = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase)
    {
        ["Scientific"] = 20m, ["Humanities"] = 35m, ["Medical"] = 25m, ["Applied"] = 20m
    };
    var selectedRatios = selectedCategories
        .Where(k => categoryRatioMap.ContainsKey(k)).Select(k => categoryRatioMap[k]).ToList();
    var avgRatio    = selectedRatios.Any() ? selectedRatios.Average() : 0m;
    var orangeLimit = avgRatio + (avgRatio * 0.25m);

    var ratioColorStatus = "";
    if (ratioValue >= 1m && avgRatio > 0m)
    {
        if      (ratioValue <= avgRatio)         ratioColorStatus = "green";
        else if (ratioValue <= orangeLimit)      ratioColorStatus = "orange";
        else                                     ratioColorStatus = "red";
    }

    // ── Compliance helpers ───────────────────────────────────────────────────
    static string RatioCompliance(string s) => s switch {
        "green"  => "Compliant",
        "orange" => "Compliant",
        "red"    => "Not Compliant",
        _        => "missing"
    };
    static string DoctorateCompliance(string s) => s switch {
        "green" => "Compliant",
        "red"   => "Not Compliant",
        _       => "missing"
    };
    static string CssClass(string s) => s switch {
        "Compliant"     => "compliant",
        "Needs Review"  => "needs-review",
        "Not Compliant" => "not-compliant",
        "Not Assessed"  => "not-assessed",
        _               => "missing"
    };
    static string CssIcon(string s) => s switch {
        "Compliant"     => "bi-check-circle-fill",
        "Needs Review"  => "bi-exclamation-circle-fill",
        "Not Compliant" => "bi-x-circle-fill",
        "Not Assessed"  => "bi-dash-circle",
        _               => "bi-question-circle"
    };
    static string DisplayLabel(string s) => s == "missing" ? "Missing Data" : s;

    var ratioCompliance = hasFacultyData ? RatioCompliance(ratioColorStatus)        : "missing";
    var docCompliance   = hasFacultyData ? DoctorateCompliance(doctorateColorStatus) : "missing";

    // ── Medicine/Dentistry Clinical Capacity ─────────────────────────────────
    var medDen = Model?.MedicineDentistry ?? new DTOs.MedicineDentistryDto();
    static string ClinicalColor(double? r) => r == null ? "" : r <= 16.5 ? "green" : r <= 20.625 ? "orange" : "red";
    var medClinicalColor = ClinicalColor(medDen.Med_StudentFacultyRatio);
    var denClinicalColor = ClinicalColor(medDen.Den_StudentFacultyRatio);
    string clinicalCapCompliance;
    if (!medDen.Med_StudentFacultyRatio.HasValue && !medDen.Den_StudentFacultyRatio.HasValue)
    {
        clinicalCapCompliance = "Needs Review";
    }
    else
    {
        if (medClinicalColor == "red" || denClinicalColor == "red")
            clinicalCapCompliance = "Not Compliant";
        else if (medClinicalColor == "orange" || denClinicalColor == "orange"
              || string.IsNullOrEmpty(medClinicalColor) || string.IsNullOrEmpty(denClinicalColor))
            clinicalCapCompliance = "Needs Review";
        else
            clinicalCapCompliance = "Compliant";
    }
    static string ClinicalRatioFmt(double? r) => r.HasValue ? "1:" + ((int)Math.Floor(r.Value)).ToString() : "—";
    static string ClinicalBadgeCss(string color) => color switch {
        "green" => "compliant", "orange" => "needs-review", "red" => "not-compliant", _ => "missing"
    };
    static string ClinicalBadgeLabel(string color) => color switch {
        "green" => "Acceptable", "orange" => "Warning", "red" => "Exceeds Limit", _ => "Missing Data"
    };
    static string ClinicalBadgeIcon(string color) => color switch {
        "green" => "bi-check-circle-fill", "orange" => "bi-exclamation-circle-fill",
        "red" => "bi-x-circle-fill", _ => "bi-question-circle"
    };

    // ── Environment assessments ──────────────────────────────────────────────
    static string EnvMap(string? v) => (v ?? "").Trim() switch {
        "Meets Standards"   => "Compliant",
        "Needs Improvement" => "Needs Review",
        _                   => "Not Assessed"
    };

    var envColleges  = EnvMap(Model?.FacultiesAssessment);
    var envHospitals = EnvMap(Model?.HospitalsAssessment);
    var envHospEnv   = EnvMap(Model?.LaboratoriesFacilitiesAssessment);
    var envLibrary   = EnvMap(Model?.LibraryAssessment);

    var envAll = new[] { envColleges, envHospitals, envHospEnv, envLibrary };
    string envOverall;
    if      (envAll.Any(s => s == "Not Compliant")) envOverall = "Not Compliant";
    else if (envAll.Any(s => s == "Needs Review"))  envOverall = "Needs Review";
    else if (envAll.All(s => s == "Compliant"))     envOverall = "Compliant";
    else                                             envOverall = "Not Assessed";

    // ── Auto-suggested recommendation ────────────────────────────────────────
    var p1 = string.IsNullOrWhiteSpace(savedAccreditationStatus) ? "Not Assessed" : savedAccreditationStatus;
    var allPoints = new[] { p1, ratioCompliance, docCompliance, clinicalCapCompliance, envOverall };
    var compliantPoints = allPoints.Count(p => p == "Compliant");
    var reviewPoints = allPoints.Count(p => p == "Needs Review" || p == "Not Assessed" || p == "missing");
    var nonCompliantPoints = allPoints.Count(p => p == "Not Compliant");
    string autoSuggestion;
    if      (allPoints.Any(p => p == "Not Compliant"))
                                                         autoSuggestion = "Reject / Committee Review";
    else if (allPoints.Any(p => p == "Needs Review" || p == "Not Assessed" || p == "missing"))
                                                         autoSuggestion = "Conditional Approval";
    else                                                 autoSuggestion = "Approve";

    var initialDecision = !string.IsNullOrWhiteSpace(savedDecision) ? savedDecision : autoSuggestion;

    string SuggestionClass(string s) => s switch {
        "Approve"              => "approve",
        "Conditional Approval" => "conditional",
        _                      => "reject"
    };
    string SuggestionIcon(string s) => s switch {
        "Approve"              => "bi-check2-circle",
        "Conditional Approval" => "bi-arrow-repeat",
        _                      => "bi-x-octagon-fill"
    };

    var ratioDisplay = ratioValue > 0 ? $"1:{ratioValue:0}" : "—";
    string RatioExplanation(string c) => c switch {
        "Compliant"     => $"The ratio of {ratioDisplay} is within the accepted benchmark range (including the 25% tolerance band) for the selected college category.",
        "Needs Review"  => $"The ratio of {ratioDisplay} exceeds the benchmark but remains within the 25% tolerance band.",
        "Not Compliant" => $"The ratio of {ratioDisplay} exceeds the allowed 25% tolerance — capacity review is required.",
        _               => "Insufficient data to calculate the students-to-faculty ratio."
    };
    string DocExplanation(string c) => c switch {
        "Compliant"     => $"{doctorateHoldersPercentage:0}% of full-time faculty hold a doctorate — meets the 50% minimum requirement.",
        "Not Compliant" => $"Only {doctorateHoldersPercentage:0}% of full-time faculty hold a doctorate — below the 50% minimum requirement.",
        _               => "Insufficient data to calculate the doctorate holders percentage."
    };

    var docProgressWidth = (int)Math.Min(doctorateHoldersPercentage, 100m);
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsRecommendation.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>@(ViewBag.CurrentRecognitionMember ?? "Recognition Member")</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">

            <section class="rm-card rd-head">
                <div>
                    <h1>Final Assessment</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Final Stage — Professional Decision Dashboard.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Stage</span><b>Final</b></div>
                </div>
            </section>

            @if (readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #fedf89; background:#fffaeb; color:#7a2e0e; font-weight:700;">
                    <i class="bi bi-eye"></i> Read-only mode: this university is assigned to another member.
                </section>
            }

            @if (TempData["RecommendationSaved"] != null)
            {
                <div class="infra-saved"><i class="bi bi-check-circle-fill"></i> @TempData["RecommendationSaved"]</div>
            }
            @if (TempData["RecommendationError"] != null)
            {
                <div class="infra-error"><i class="bi bi-exclamation-circle-fill"></i> @TempData["RecommendationError"]</div>
            }

            <form asp-controller="Home" asp-action="SaveRecommendationDecision" method="post" id="finalAssessmentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@requestId" />
                <input type="hidden" name="decision" id="hiddenDecision" value="@initialDecision" />

                <div class="fa-scorecard">
                    <div class="fa-sc-eyebrow"><i class="bi bi-layout-three-columns" style="margin-right:5px;"></i>Assessment Overview</div>
                    <div class="fa-sc-grid">
                        <div class="fa-sc-cell">
                            <div class="fa-sc-step">1</div>
                            <div class="fa-sc-info">
                                <div class="fa-sc-name">Accreditation</div>
                                <span id="p1ScBadge" class="fa-compliance-badge @CssClass(p1)">
                                    <i class="bi @CssIcon(p1)"></i> @DisplayLabel(p1)
                                </span>
                            </div>
                        </div>
                        <div class="fa-sc-cell">
                            <div class="fa-sc-step">2</div>
                            <div class="fa-sc-info">
                                <div class="fa-sc-name">Faculty Ratio</div>
                                <span class="fa-compliance-badge @CssClass(ratioCompliance)">
                                    <i class="bi @CssIcon(ratioCompliance)"></i> @DisplayLabel(ratioCompliance)
                                </span>
                            </div>
                        </div>
                        <div class="fa-sc-cell">
                            <div class="fa-sc-step">3</div>
                            <div class="fa-sc-info">
                                <div class="fa-sc-name">Doctorate %</div>
                                <span class="fa-compliance-badge @CssClass(docCompliance)">
                                    <i class="bi @CssIcon(docCompliance)"></i> @DisplayLabel(docCompliance)
                                </span>
                            </div>
                        </div>
                        <div class="fa-sc-cell">
                            <div class="fa-sc-step">4</div>
                            <div class="fa-sc-info">
                                <div class="fa-sc-name">Clinical Capacity</div>
                                <span class="fa-compliance-badge @CssClass(clinicalCapCompliance)">
                                    <i class="bi @CssIcon(clinicalCapCompliance)"></i> @DisplayLabel(clinicalCapCompliance)
                                </span>
                            </div>
                        </div>
                        <div class="fa-sc-cell">
                            <div class="fa-sc-step">5</div>
                            <div class="fa-sc-info">
                                <div class="fa-sc-name">Environment</div>
                                <span class="fa-compliance-badge @CssClass(envOverall)">
                                    <i class="bi @CssIcon(envOverall)"></i> @DisplayLabel(envOverall)
                                </span>
                            </div>
                        </div>
                    </div>
                </div>

                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div>
                                <h2><i class="bi bi-award"></i> 1. Accreditation &amp; Recognition</h2>
                                <p>Manual evaluation — select the compliance status and provide an assessment note.</p>
                            </div>
                            <span class="fa-mode-badge"><i class="bi bi-pencil-square"></i> Manual</span>
                        </div>
                    </div>

                    <div class="fa-select-row">
                        <div class="fa-select-field">
                            <label for="accreditationStatus">Compliance Status</label>
                            <select id="accreditationStatus" name="accreditationStatus" class="fa-select" @(readOnlyMode ? "disabled" : "required")>
                                <option value="">Select status…</option>
                                @if (savedAccreditationStatus == "Compliant")     { <option value="Compliant" selected>Compliant</option> }
                                else                                               { <option value="Compliant">Compliant</option> }
                                @if (savedAccreditationStatus == "Needs Review")  { <option value="Needs Review" selected>Needs Review</option> }
                                else                                               { <option value="Needs Review">Needs Review</option> }
                                @if (savedAccreditationStatus == "Not Compliant") { <option value="Not Compliant" selected>Not Compliant</option> }
                                else                                               { <option value="Not Compliant">Not Compliant</option> }
                            </select>
                        </div>
                        <div class="fa-live-badge-wrap">
                            <span id="p1Badge" class="fa-compliance-badge @CssClass(p1)">
                                <i class="bi @CssIcon(p1)"></i> @DisplayLabel(p1)
                            </span>
                        </div>
                    </div>

                    <label class="fa-note-label" for="accreditationNote">Assessment Note</label>
                    <textarea id="accreditationNote" name="accreditationNote" class="doc-notes"
                              placeholder="Describe your evaluation of the institution's accreditation and recognition status…"
                              @(readOnlyMode ? "readonly disabled" : "")>@savedAccreditationNote</textarea>
                </section>

                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div>
                                <h2><i class="bi bi-person-lines-fill"></i> 2. Students to Faculty Ratio</h2>
                                <p>Automatically calculated from submitted Academic Info data.</p>
                            </div>
                            <span class="fa-mode-badge"><i class="bi bi-cpu"></i> Automatic</span>
                        </div>
                    </div>

                    <div class="fa-metrics" style="margin-bottom:16px;">
                        <div class="fa-metric-tile primary">
                            <div class="fa-metric-lbl">Calculated Ratio</div>
                            <div class="fa-metric-val @(ratioColorStatus)">@ratioDisplay</div>
                        </div>
                        <div class="fa-metric-tile">
                            <div class="fa-metric-lbl">Compliance Status</div>
                            <span class="fa-compliance-badge @CssClass(ratioCompliance)" style="margin-top:4px;">
                                <i class="bi @CssIcon(ratioCompliance)"></i> @DisplayLabel(ratioCompliance)
                            </span>
                        </div>
                        @if (avgRatio > 0)
                        {
                            <div class="fa-metric-tile">
                                <div class="fa-metric-lbl">Benchmark</div>
                                <div class="fa-metric-val neutral">1:@avgRatio.ToString("0")</div>
                            </div>
                        }
                    </div>

                    <div class="fa-note" style="margin-bottom:12px;">
                        <i class="bi bi-info-circle"></i>
                        <span>@RatioExplanation(ratioCompliance)</span>
                    </div>

                    @if (selectedCategories.Any())
                    {
                        <div class="fa-tags">
                            @foreach (var cat in selectedCategories)
                            {
                                <span class="fa-tag">@cat</span>
                            }
                        </div>
                    }
                </section>

                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div>
                                <h2><i class="bi bi-mortarboard"></i> 3. Doctorate Holders Percentage</h2>
                                <p>Automatically calculated from submitted Academic Info data.</p>
                            </div>
                            <span class="fa-mode-badge"><i class="bi bi-cpu"></i> Automatic</span>
                        </div>
                    </div>

                    <div class="fa-metrics" style="margin-bottom:16px;">
                        <div class="fa-metric-tile primary">
                            <div class="fa-metric-lbl">Doctorate Holders</div>
                            <div class="fa-metric-val @(doctorateColorStatus)">@doctorateHoldersPercentage.ToString("0")%</div>
                            @if (hasFacultyData)
                            {
                                <div class="fa-progress-wrap">
                                    <div class="fa-progress-labels">
                                        <span>0%</span><span>Minimum: 50%</span><span>100%</span>
                                    </div>
                                    <div class="fa-progress-track">
                                        <div class="fa-progress-fill @doctorateColorStatus" style="width:@docProgressWidth%"></div>
                                        <div class="fa-progress-marker"></div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="fa-metric-tile">
                            <div class="fa-metric-lbl">Compliance Status</div>
                            <span class="fa-compliance-badge @CssClass(docCompliance)" style="margin-top:4px;">
                                <i class="bi @CssIcon(docCompliance)"></i> @DisplayLabel(docCompliance)
                            </span>
                        </div>
                        <div class="fa-metric-tile">
                            <div class="fa-metric-lbl">Minimum Required</div>
                            <div class="fa-metric-val neutral">50%</div>
                        </div>
                    </div>

                    <div class="fa-note" style="margin-bottom:12px;">
                        <i class="bi bi-info-circle"></i>
                        <span>@DocExplanation(docCompliance)</span>
                    </div>

                    @if (hasFacultyData)
                    {
                        <div class="fa-breakdown">
                            <i class="bi bi-people-fill" style="color:#7a2d2a;"></i>
                            <span><b>@totalPhdHolders</b> PhD holders</span>
                            <span class="fa-breakdown-sep">out of</span>
                            <span><b>@fullTimeFacultyDoctorate</b> full-time faculty</span>
                        </div>
                    }
                </section>

                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div>
                                <h2><i class="bi bi-hospital"></i> 4. Medicine &amp; Dentistry Clinical Capacity Assessment</h2>
                                <p>Automatically calculated from submitted Medicine/Dentistry staff data.</p>
                            </div>
                            <span class="fa-mode-badge"><i class="bi bi-cpu"></i> Automatic</span>
                        </div>
                    </div>

                    <div class="csr-college-grid">
                        <div class="csr-college-card">
                            <div class="csr-college-head">College of Medicine</div>
                            <div class="csr-college-body">
                                <span class="csr-college-lbl">Student to Faculty Ratio</span>
                                <div class="csr-college-result">
                                    <span class="csr-college-val @medClinicalColor">@ClinicalRatioFmt(medDen.Med_StudentFacultyRatio)</span>
                                    <span class="fa-compliance-badge @ClinicalBadgeCss(medClinicalColor)">
                                        <i class="bi @ClinicalBadgeIcon(medClinicalColor)"></i> @ClinicalBadgeLabel(medClinicalColor)
                                    </span>
                                </div>
                            </div>
                        </div>
                        <div class="csr-college-card">
                            <div class="csr-college-head">College of Dentistry</div>
                            <div class="csr-college-body">
                                <span class="csr-college-lbl">Student to Faculty Ratio</span>
                                <div class="csr-college-result">
                                    <span class="csr-college-val @denClinicalColor">@ClinicalRatioFmt(medDen.Den_StudentFacultyRatio)</span>
                                    <span class="fa-compliance-badge @ClinicalBadgeCss(denClinicalColor)">
                                        <i class="bi @ClinicalBadgeIcon(denClinicalColor)"></i> @ClinicalBadgeLabel(denClinicalColor)
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div>
                                <h2><i class="bi bi-building-check"></i> 5. Environment Assessment</h2>
                                <p>Summarised from the Environment Assessment Summary page.</p>
                            </div>
                            <span class="fa-mode-badge"><i class="bi bi-cpu"></i> Automatic</span>
                        </div>
                    </div>

                    @{
                        var envItems = new[]
                        {
                            (Title: "Colleges Environment", Status: envColleges,  Icon: "bi-building"),
                            (Title: "Hospitals Assessment", Status: envHospitals, Icon: "bi-hospital"),
                            (Title: "Laboratories Facilities", Status: envHospEnv,   Icon: "bi-eyedropper"),
                            (Title: "Library Assessment",   Status: envLibrary,   Icon: "bi-book")
                        };
                    }
                    <div class="fa-env-grid" style="margin-bottom:12px;">
                        @foreach (var item in envItems)
                        {
                            <div class="fa-env-item">
                                <div class="fa-env-item-head">
                                    <i class="bi @item.Icon"></i>
                                    <span>@item.Title</span>
                                </div>
                                <span class="fa-compliance-badge @CssClass(item.Status)">
                                    <i class="bi @CssIcon(item.Status)"></i> @item.Status
                                </span>
                            </div>
                        }
                    </div>

                    <div class="fa-env-overall">
                        <span class="fa-env-overall-lbl">Overall Environment Status</span>
                        <span class="fa-compliance-badge fa-compliance-badge-lg @CssClass(envOverall)">
                            <i class="bi @CssIcon(envOverall)"></i> @envOverall
                        </span>
                    </div>
                </section>

                <section class="rm-card rd-card fa-final-card">
                    <div class="rd-card-hd">
                        <div class="rd-card-hd-row">
                            <div class="fa-final-head">
                                <h2><i class="bi bi-clipboard2-check"></i> Final Recommendation</h2>
                                <p>System-generated suggestion based on all 5 assessment points. Review and provide your justification.</p>
                                <div class="fa-final-kpis">
                                    <span class="fa-final-kpi ok"><i class="bi bi-check-circle-fill"></i> Compliant: @compliantPoints</span>
                                    <span class="fa-final-kpi warn"><i class="bi bi-exclamation-circle-fill"></i> Review Needed: @reviewPoints</span>
                                    <span class="fa-final-kpi bad"><i class="bi bi-x-circle-fill"></i> Non-Compliant: @nonCompliantPoints</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="fa-suggestion-banner @SuggestionClass(autoSuggestion)" id="suggestionBanner">
                        <div class="fa-banner-icon" id="suggestionIconWrap">
                            <i class="bi @SuggestionIcon(autoSuggestion)" id="suggestionIcon"></i>
                        </div>
                        <div class="fa-banner-body">
                            <div class="fa-banner-eyebrow">System Suggestion</div>
                            <div class="fa-suggestion-badge" id="suggestionBadge">
                                <span id="suggestionText">@autoSuggestion</span>
                            </div>
                            <div class="fa-banner-note" id="suggestionNote">
                                @if (autoSuggestion == "Approve")
                                {
                                    <span>All five assessment points meet required standards. The institution qualifies for recognition.</span>
                                }
                                else if (autoSuggestion == "Conditional Approval")
                                {
                                    <span>One or more assessment points require review. Conditional recognition may be granted pending corrective measures.</span>
                                }
                                else
                                {
                                    <span>One or more assessment points are non-compliant. The request should be referred to the committee for further review.</span>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="fa-decision-wrap">
                        <div class="fa-decision-label">
                            <i class="bi bi-person-check-fill"></i>
                            Your Final Decision <span class="fa-required">*</span>
                        </div>
                        <div class="fa-decision-grid">
                            <button type="button" class="fa-dec-btn approve @(initialDecision == "Approve" ? "selected" : "")" data-value="Approve" @(readOnlyMode ? "disabled" : null)>
                                <i class="bi bi-check2-circle"></i>
                                <span>Approve</span>
                                <small>Institution meets all requirements</small>
                            </button>
                            <button type="button" class="fa-dec-btn conditional @(initialDecision == "Conditional Approval" ? "selected" : "")" data-value="Conditional Approval" @(readOnlyMode ? "disabled" : null)>
                                <i class="bi bi-arrow-repeat"></i>
                                <span>Conditional Approval</span>
                                <small>Pending corrective measures</small>
                            </button>
                            <button type="button" class="fa-dec-btn reject @(initialDecision == "Reject / Committee Review" ? "selected" : "")" data-value="Reject / Committee Review" @(readOnlyMode ? "disabled" : null)>
                                <i class="bi bi-x-octagon-fill"></i>
                                <span>Reject / Committee Review</span>
                                <small>Refer to committee for further review</small>
                            </button>
                        </div>
                    </div>

                    <div class="fa-justify-label" for="reason">
                        <i class="bi bi-chat-square-text"></i>
                        Final Justification Note <span class="fa-required">*</span>
                    </div>
                    <textarea id="reason" name="reason" class="doc-notes"
                              placeholder="Provide your professional justification for the final recommendation…"
                              @(readOnlyMode ? "readonly disabled" : "required")>@savedFinalJustification</textarea>

                    @if (!readOnlyMode)
                    {
                        <div class="fa-save-row">
                            <span class="fa-save-hint"><i class="bi bi-lock-fill"></i> Your decision will be recorded once saved.</span>
                            <button class="rm-btn rm-btn-primary" type="submit">
                                <i class="bi bi-send-check"></i> Save &amp; Submit to Admin
                            </button>
                        </div>
                    }
                </section>

            </form>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsInfrastructure", "Home", new { id = requestId })">
                        <i class="bi bi-arrow-left"></i> Previous
                    </a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@(memberViewOnly ? Url.Action("Archive", "Home") : Url.Action("ElectronicRequests", "Home"))">
                        <i class="bi bi-x-lg"></i> Exit
                    </a>
                </div>
            </section>

        </main>
    </div>

    <script>
        (function () {
            const isReadOnlyMode = "@readOnlyMode".toLowerCase() === "true";
            const sel            = document.getElementById("accreditationStatus");
            const p1Badge        = document.getElementById("p1Badge");
            const p1ScBadge      = document.getElementById("p1ScBadge");
            const hiddenDecision = document.getElementById("hiddenDecision");

            const BADGE_MAP = {
                "Compliant":     { cls: "compliant",     icon: "bi-check-circle-fill",      text: "Compliant" },
                "Needs Review":  { cls: "needs-review",  icon: "bi-exclamation-circle-fill", text: "Needs Review" },
                "Not Compliant": { cls: "not-compliant", icon: "bi-x-circle-fill",           text: "Not Compliant" },
                "":              { cls: "not-assessed",  icon: "bi-dash-circle",             text: "Not Assessed" }
            };

            const p2Class = "@CssClass(ratioCompliance)";
            const p3Class = "@CssClass(docCompliance)";
            const p4Class = "@CssClass(clinicalCapCompliance)";
            const p5Class = "@CssClass(envOverall)";

            const SUGGESTION_MAP = {
                "Approve":                   { cls: "approve",     icon: "bi-check2-circle",  text: "Approve",                   note: "All five assessment points meet the required standards. The institution qualifies for recognition." },
                "Conditional Approval":      { cls: "conditional", icon: "bi-arrow-repeat",   text: "Conditional Approval",      note: "One or more assessment points require review. Conditional recognition may be granted pending corrective measures." },
                "Reject / Committee Review": { cls: "reject",      icon: "bi-x-octagon-fill", text: "Reject / Committee Review", note: "One or more assessment points are non-compliant. The request should be referred to the committee for further review." }
            };

            function computeSuggestion(p1Cls) {
                const all = [p1Cls, p2Class, p3Class, p4Class, p5Class];
                if (all.some(c => c === "not-compliant"))                                           return "Reject / Committee Review";
                if (all.some(c => c === "needs-review" || c === "not-assessed" || c === "missing")) return "Conditional Approval";
                return "Approve";
            }

            function setBadge(el, info) {
                el.className = "fa-compliance-badge " + info.cls;
                el.innerHTML = `<i class="bi ${info.icon}"></i> ${info.text}`;
            }

            function updateP1(value) {
                const info = BADGE_MAP[value] || BADGE_MAP[""];
                if (p1Badge)   setBadge(p1Badge,   info);
                if (p1ScBadge) setBadge(p1ScBadge, info);
                return info.cls;
            }

            function updateSuggestion(p1Cls) {
                const key    = computeSuggestion(p1Cls);
                const s      = SUGGESTION_MAP[key];
                const badge  = document.getElementById("suggestionBadge");
                const noteEl = document.getElementById("suggestionNote");
                const banner = document.getElementById("suggestionBanner");
                const iconEl = document.getElementById("suggestionIcon");

                badge.className = "fa-suggestion-badge " + s.cls;
                badge.querySelector("#suggestionText").textContent = s.text;
                if (iconEl) iconEl.className = "bi " + s.icon;
                noteEl.querySelector("span").textContent           = s.note;
                if (banner) banner.className = "fa-suggestion-banner " + s.cls;
                // Does not override the doctor's explicit decision choice
            }

            // Doctor decision buttons
            const decBtns = document.querySelectorAll(".fa-dec-btn");
            decBtns.forEach(function (btn) {
                btn.addEventListener("click", function () {
                    if (isReadOnlyMode) return;
                    decBtns.forEach(function (b) { b.classList.remove("selected"); });
                    this.classList.add("selected");
                    hiddenDecision.value = this.getAttribute("data-value");
                });
            });

            if (sel) {
                sel.addEventListener("change", function () {
                    updateSuggestion(updateP1(this.value));
                });
            }
        })();

        // ── Save Decision toast ───────────────────────────────────────────────
        (function () {
            const isReadOnlyMode = "@readOnlyMode".toLowerCase() === "true";
            if (isReadOnlyMode) return;
            function showToast(message, type) {
                var old = document.getElementById('_rec-toast');
                if (old) old.remove();
                var t = document.createElement('div');
                t.id = '_rec-toast';
                t.textContent = message;
                Object.assign(t.style, {
                    position: 'fixed', bottom: '28px', right: '28px', zIndex: '99999',
                    padding: '13px 20px', borderRadius: '10px', color: '#fff',
                    fontWeight: '600', fontSize: '14px', boxShadow: '0 4px 18px rgba(0,0,0,.18)',
                    background: type === 'success' ? '#16a34a' : '#dc2626',
                    animation: '_recToastIn .22s ease both', transition: 'opacity .3s'
                });
                document.body.appendChild(t);
                setTimeout(function () { t.style.opacity = '0'; setTimeout(function () { t.remove(); }, 320); }, 3500);
            }

            var form = document.getElementById('finalAssessmentForm');
            if (!form) return;
            form.addEventListener('submit', async function (e) {
                e.preventDefault();
                var btn = form.querySelector('[type="submit"]');
                var orig = btn ? btn.innerHTML : '';
                if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving…'; }
                try {
                    var res  = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                    var html = await res.text();
                    if (res.url.includes('ElectronicRequests')) {
                        showToast('Decision saved successfully.', 'success');
                        setTimeout(function () { window.location.href = res.url; }, 900);
                    } else if (html.includes('Please select a valid accreditation status'))
                        showToast('Please select a valid accreditation status for Point 1.', 'error');
                    else if (html.includes('Please provide a final justification'))
                        showToast('Please provide a final justification note.', 'error');
                    else if (html.includes('Unable to save recommendation decision'))
                        showToast('Unable to save decision. Please try again.', 'error');
                    else
                        showToast('Unable to save decision. Please try again.', 'error');
                } catch (_) {
                    showToast('Network error. Please try again.', 'error');
                } finally {
                    if (btn) { btn.disabled = false; btn.innerHTML = orig; }
                }
            });
        })();
    </script>
    <style>
        @@keyframes _recToastIn {
            from { opacity: 0; transform: translateY(16px) scale(.96); }
            to   { opacity: 1; transform: translateY(0)    scale(1); }
        }
    </style>
</body>
</html>
