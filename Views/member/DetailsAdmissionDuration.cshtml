@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Admission Requirements and Study Duration";
    ViewData["ActiveNav"] = "requests";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var adminMeetingId = (int)(ViewBag.AdminMeetingId ?? 0);
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var previousLink = adminReadOnly
        ? Url.Action("AdminDetailsStatistics", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsStatistics", "Home", new { id = requestId });
    var nextLink = adminReadOnly
        ? Url.Action("AdminDetailsAcademicInfo", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAcademicInfo", "Home", new { id = requestId });

    var review = Model?.AdmissionStudyDurationReview ?? new DTOs.AdmissionStudyDurationReviewDto();
    var submittedDuration = Model?.StudyDuration ?? new DTOs.StudyDurationDto();

    string PickDuration(string? reviewed, string? preferred, string? fallback)
    {
        if (!string.IsNullOrWhiteSpace(reviewed)) return reviewed;
        if (!string.IsNullOrWhiteSpace(preferred)) return preferred;
        return fallback ?? string.Empty;
    }

    var diplomaDuration = PickDuration(review.DiplomaDuration, submittedDuration.DiplomaObtain, submittedDuration.DiplomaEnrollment);
    var bScDuration = PickDuration(review.BScDuration, submittedDuration.BachelorObtain, submittedDuration.BachelorEnrollment);
    var higherDiplomaDuration = PickDuration(review.HigherDiplomaDuration, submittedDuration.HigherDiplomaObtain, submittedDuration.HigherDiplomaEnrollment);
    var masterDuration = PickDuration(review.MasterDuration, submittedDuration.MasterObtain, submittedDuration.MasterEnrollment);
    var phdDuration = PickDuration(review.PhdDuration, submittedDuration.PhDObtain, submittedDuration.PhDEnrollment);
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAdmissionDuration.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>@(adminReadOnly ? "Admin Review" : "Recognition Member")</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @if (adminReadOnly)
        {
            @await Html.PartialAsync("_AdminReviewSidebar")
        }
        else
        {
            @await Html.PartialAsync("_MemberSidebar")
        }

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 3 of 7 — Admission Requirements and Study Duration.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>3 / 7</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Admission Requirements and Study Duration</h2>
                    <p>Submitted admission documents and study durations (view / download only).</p>
                </div>

                <div class="adm-grid">
                    <article class="adm-card">
                        <h3>Diploma</h3>
                        <div class="rd-field">
                            <label>Sample requirement PDF</label>
                            @if (!string.IsNullOrWhiteSpace(review.DiplomaSamplePdfFileName))
                            {
                                <div class="adm-file-row">
                                    <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @review.DiplomaSamplePdfFileName</span>
                                    <div class="adm-file-actions">
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "Diploma", inline = true })" target="_blank" rel="noopener">View</a>
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "Diploma" })">Download</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="adm-file-empty">No sample PDF uploaded.</div>
                            }
                        </div>
                        <div class="rd-field">
                            <label>Study duration</label>
                            <input type="text" value="@diplomaDuration" placeholder="—" readonly />
                        </div>
                    </article>

                    <article class="adm-card">
                        <h3>BSc</h3>
                        <div class="rd-field">
                            <label>Sample requirement PDF</label>
                            @if (!string.IsNullOrWhiteSpace(review.BScSamplePdfFileName))
                            {
                                <div class="adm-file-row">
                                    <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @review.BScSamplePdfFileName</span>
                                    <div class="adm-file-actions">
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "BSc", inline = true })" target="_blank" rel="noopener">View</a>
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "BSc" })">Download</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="adm-file-empty">No sample PDF uploaded.</div>
                            }
                        </div>
                        <div class="rd-field">
                            <label>Study duration</label>
                            <input type="text" value="@bScDuration" placeholder="—" readonly />
                        </div>
                    </article>

                    <article class="adm-card">
                        <h3>Higher Diploma</h3>
                        <div class="rd-field">
                            <label>Sample requirement PDF</label>
                            @if (!string.IsNullOrWhiteSpace(review.HigherDiplomaSamplePdfFileName))
                            {
                                <div class="adm-file-row">
                                    <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @review.HigherDiplomaSamplePdfFileName</span>
                                    <div class="adm-file-actions">
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "HigherDiploma", inline = true })" target="_blank" rel="noopener">View</a>
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "HigherDiploma" })">Download</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="adm-file-empty">No sample PDF uploaded.</div>
                            }
                        </div>
                        <div class="rd-field">
                            <label>Study duration</label>
                            <input type="text" value="@higherDiplomaDuration" placeholder="—" readonly />
                        </div>
                    </article>

                    <article class="adm-card">
                        <h3>Master</h3>
                        <div class="rd-field">
                            <label>Sample requirement PDF</label>
                            @if (!string.IsNullOrWhiteSpace(review.MasterSamplePdfFileName))
                            {
                                <div class="adm-file-row">
                                    <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @review.MasterSamplePdfFileName</span>
                                    <div class="adm-file-actions">
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "Master", inline = true })" target="_blank" rel="noopener">View</a>
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "Master" })">Download</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="adm-file-empty">No sample PDF uploaded.</div>
                            }
                        </div>
                        <div class="rd-field">
                            <label>Study duration</label>
                            <input type="text" value="@masterDuration" placeholder="—" readonly />
                        </div>
                    </article>

                    <article class="adm-card">
                        <h3>PhD</h3>
                        <div class="rd-field">
                            <label>Sample requirement PDF</label>
                            @if (!string.IsNullOrWhiteSpace(review.PhdSamplePdfFileName))
                            {
                                <div class="adm-file-row">
                                    <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @review.PhdSamplePdfFileName</span>
                                    <div class="adm-file-actions">
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "PhD", inline = true })" target="_blank" rel="noopener">View</a>
                                        <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = "PhD" })">Download</a>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="adm-file-empty">No sample PDF uploaded.</div>
                            }
                        </div>
                        <div class="rd-field">
                            <label>Study duration</label>
                            <input type="text" value="@phdDuration" placeholder="—" readonly />
                        </div>
                    </article>
                </div>

            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@previousLink">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@nextLink">Next</a>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
