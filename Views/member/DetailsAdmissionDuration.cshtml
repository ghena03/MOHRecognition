@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Admission Requirements and Study Duration";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var memberViewOnly = (bool)(ViewBag.MemberViewOnly ?? false);
    var readOnlyMode = adminReadOnly || memberViewOnly;
    ViewData["ActiveNav"] = memberViewOnly ? "archive" : "requests";
    var adminMeetingId = (int)(ViewBag.AdminMeetingId ?? 0);
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var previousLink = adminReadOnly
        ? Url.Action("AdminDetailsStatistics", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsStatistics", "Home", new { id = requestId });
    var nextLink = adminReadOnly
        ? Url.Action("AdminDetailsAcademicInfo", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAcademicInfo", "Home", new { id = requestId });

    var isManual = (bool)(ViewBag.IsManual ?? false);
    var review = Model?.AdmissionStudyDurationReview ?? new DTOs.AdmissionStudyDurationReviewDto();
    var submittedDuration = Model?.StudyDuration ?? new DTOs.StudyDurationDto();

    string PickDuration(string? reviewed, string? preferred, string? fallback)
    {
        if (!string.IsNullOrWhiteSpace(reviewed)) return reviewed;
        if (!string.IsNullOrWhiteSpace(preferred)) return preferred;
        return fallback ?? string.Empty;
    }

    var diplomaDuration = PickDuration(review.DiplomaDuration, submittedDuration.DiplomaObtain, submittedDuration.DiplomaEnrollment);
    var bScDuration = PickDuration(review.BScDuration, submittedDuration.BachelorObtain, submittedDuration.BachelorEnrollment);
    var higherDiplomaDuration = PickDuration(review.HigherDiplomaDuration, submittedDuration.HigherDiplomaObtain, submittedDuration.HigherDiplomaEnrollment);
    var masterDuration = PickDuration(review.MasterDuration, submittedDuration.MasterObtain, submittedDuration.MasterEnrollment);
    var phdDuration = PickDuration(review.PhdDuration, submittedDuration.PhDObtain, submittedDuration.PhDEnrollment);
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAdmissionDuration.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>@(adminReadOnly ? "Admin Review" : (ViewBag.CurrentRecognitionMember ?? "Recognition Member"))</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @if (adminReadOnly)
        {
            @await Html.PartialAsync("_AdminReviewSidebar")
        }
        else
        {
            @await Html.PartialAsync("_MemberSidebar")
        }

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 3 of 7 — Admission Requirements and Study Duration.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>3 / 7</b></div>
                </div>
            </section>

            @if (readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #fedf89; background:#fffaeb; color:#7a2e0e; font-weight:700;">
                    <i class="bi bi-eye"></i> Read-only mode: this university is assigned to another member.
                </section>
            }

            @if (isManual && !readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #bfdbfe; background:#eff6ff; color:#1e40af; font-weight:600; display:flex; align-items:center; gap:10px;">
                    <i class="bi bi-pencil-square" style="font-size:1.1rem;"></i>
                    Manual Request — Enter study durations for each degree level.
                </section>
            }
            @if (TempData["ManualSaved"] != null)
            {
                <section class="rm-card" style="border:1px solid #bbf7d0; background:#f0fdf4; color:#166534; font-weight:600;">
                    <i class="bi bi-check-circle-fill"></i> @TempData["ManualSaved"]
                </section>
            }

            @if (isManual && !readOnlyMode)
            {
                <form asp-controller="Home" asp-action="SaveManualStudyDuration" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@requestId" />
                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <h2>Study Duration Entry</h2>
                        <p>Enter the study duration (e.g. "4 years") for each degree level offered.</p>
                    </div>
                    <div class="adm-grid">
                        @foreach (var (level, label, fieldName, existingVal) in new[]
                        {
                            ("Diploma",        "Diploma",        "diplomaDuration",        diplomaDuration),
                            ("BSc",            "BSc / Bachelor", "bScDuration",            bScDuration),
                            ("HigherDiploma",  "Higher Diploma", "higherDiplomaDuration",  higherDiplomaDuration),
                            ("Master",         "Master",         "masterDuration",         masterDuration),
                            ("PhD",            "PhD",            "phdDuration",            phdDuration)
                        })
                        {
                            <article class="adm-card">
                                <h3>@label</h3>
                                <div class="rd-field">
                                    <label>Study Duration (years)</label>
                                    <input type="text" name="@fieldName" value="@existingVal" placeholder="e.g. 4 years" />
                                </div>
                            </article>
                        }
                    </div>
                    <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:24px; padding-top:16px; border-top:1px solid #e5e7eb;">
                        <button type="submit" name="nextAction" value="save" class="rm-btn rm-btn-light">
                            <i class="bi bi-floppy"></i> Save
                        </button>
                        <button type="submit" name="nextAction" value="next" class="rm-btn rm-btn-primary">
                            <i class="bi bi-arrow-right-circle"></i> Save &amp; Continue
                        </button>
                    </div>
                </section>
                </form>
            }
            else
            {
                <section class="rm-card rd-card">
                    <div class="rd-card-hd">
                        <h2>Admission Requirements and Study Duration</h2>
                        <p>Submitted admission documents and study durations (view / download only).</p>
                    </div>

                    <div class="adm-grid">
                        @foreach (var (level, label, sampleFile, duration) in new[]
                        {
                            ("Diploma",       "Diploma",        review.DiplomaSamplePdfFileName,       diplomaDuration),
                            ("BSc",           "BSc",            review.BScSamplePdfFileName,           bScDuration),
                            ("HigherDiploma", "Higher Diploma", review.HigherDiplomaSamplePdfFileName, higherDiplomaDuration),
                            ("Master",        "Master",         review.MasterSamplePdfFileName,        masterDuration),
                            ("PhD",           "PhD",            review.PhdSamplePdfFileName,           phdDuration)
                        })
                        {
                            <article class="adm-card">
                                <h3>@label</h3>
                                <div class="rd-field">
                                    <label>Sample requirement PDF</label>
                                    @if (!string.IsNullOrWhiteSpace(sampleFile))
                                    {
                                        <div class="adm-file-row">
                                            <span class="adm-file-name"><i class="bi bi-file-earmark-pdf"></i> @sampleFile</span>
                                            <div class="adm-file-actions">
                                                <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = level, inline = true })" target="_blank" rel="noopener">View</a>
                                                <a class="rm-mini" href="@Url.Action("DownloadAdmissionSamplePdf", "Home", new { id = requestId, level = level })">Download</a>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="adm-file-empty">No sample PDF uploaded.</div>
                                    }
                                </div>
                                <div class="rd-field">
                                    <label>Study duration</label>
                                    <input type="text" value="@duration" placeholder="—" readonly />
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@previousLink">Previous</a>
                </div>
                @if (!isManual || readOnlyMode)
                {
                    <div class="rd-actions-right">
                        <a class="rm-btn rm-btn-light" href="@nextLink">Next</a>
                    </div>
                }
            </section>
        </main>
    </div>
</body>
</html>
