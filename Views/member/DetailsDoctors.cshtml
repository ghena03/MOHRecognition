@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Doctors / Medicine Colleges";
    ViewData["ActiveNav"] = "requests";
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var medDen = Model?.MedicineDentistry ?? new DTOs.MedicineDentistryDto();
    var A = Model?.AcademicInfo ?? new DTOs.AcademicInfoDto();
    var collegeCategories = (A.CollegeCategoriesCsv ?? "")
        .Split(';', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();

    string N(int? value) => (value ?? 0).ToString();
    string ClinicalRatioClass(double? r) => r == null ? "" : r <= 16.5 ? "ok" : r <= 20.625 ? "warn" : "fail";
    string ClinicalRatioText(double? r) => r == null ? "N/A" : r <= 16.5 ? "Acceptable" : r <= 20.625 ? "Warning" : "Exceeds Limit";
    string ClinicalRatioColor(double? r) => r == null ? "" : r <= 16.5 ? "green" : r <= 20.625 ? "orange" : "red";
    string Fmt2(double d) => d.ToString("F2");
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsDoctors.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>Recognition Member</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 4 of 6 — Doctors / Medicine Colleges.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>4 / 6</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>College Categories</h2>
                    <p>Submitted college categories for this institution.</p>
                </div>

                <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:6px;">
                    @if (collegeCategories.Any())
                    {
                        foreach (var cat in collegeCategories)
                        {
                            <span style="display:inline-flex; align-items:center; padding:6px 12px; border-radius:999px; border:1px solid #e5e7eb; font-weight:700;">@cat</span>
                        }
                    }
                    else
                    {
                        <span style="color:#6b7280;">No categories submitted.</span>
                    }
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Doctors / Medicine Colleges</h2>
                    <p>Part-time clinical counts are included in the totals.</p>
                </div>

                <!-- Merged Staff Table -->
                <div class="rd-tablewrap">
                    <table class="rd-table sst-ro-table">
                        <thead>
                            <tr>
                                <th class="sst-ro-cat-col">Category</th>
                                <th>College of Medicine</th>
                                <th>College of Dentistry</th>
                            </tr>
                        </thead>
                        <tbody>

                            <tr class="sst-ro-total">
                                <td class="sst-ro-cat">Total Students</td>
                                <td class="sst-ro-cell">
                                    <div class="value-stack">
                                        <div class="value-row"><span>Students</span><b>@N(medDen.Med_TotalStudents)</b></div>
                                    </div>
                                </td>
                                <td class="sst-ro-cell">
                                    <div class="value-stack">
                                        <div class="value-row"><span>Students</span><b>@N(medDen.Den_TotalStudents)</b></div>
                                    </div>
                                </td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Med_PartTimeClinicalProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Den_PartTimeClinicalProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Associate Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeAssociateProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Med_PartTimeClinicalAssociateProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeAssociateProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Den_PartTimeClinicalAssociateProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Assistant Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeAssistantProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Med_PartTimeClinicalAssistantProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeAssistantProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Den_PartTimeClinicalAssistantProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Lecturer <span class="sst-qual">(PhD)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Med_PartTimeClinicalLecturerPhd)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Den_PartTimeClinicalLecturerPhd)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Lecturer <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeLecturerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeLecturerMsc)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Assistant Lecturer <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeAssistantLecturerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeAssistantLecturerMsc)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Assistant Lecturer <span class="sst-qual">(PhD)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimeAssistantLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Med_PartTimeClinicalAssistantLecturerPhd)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimeAssistantLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@N(medDen.Den_PartTimeClinicalAssistantLecturerPhd)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Practitioner <span class="sst-qual">(BSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimePractitionerPsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimePractitionerPsc)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Practitioner <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Med_FullTimePractitionerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@N(medDen.Den_FullTimePractitionerMsc)</b></div></div></td>
                            </tr>

                        </tbody>
                    </table>
                </div>

                <!-- Computed Read-Only Summary -->
                <h3 class="doctors-group-title" style="margin-top:18px;">Computed Read-Only Summary</h3>
                <p class="doctors-group-note">Totals are automatically calculated for each college.</p>
                <div class="doctors-summary-grid">
                    <div class="doctors-summary-item">
                        <span>Full-Time PhD (Medicine)</span>
                        <b>@medDen.Med_PhdHolders</b>
                    </div>
                    <div class="doctors-summary-item">
                        <span>Full-Time PhD (Dentistry)</span>
                        <b>@medDen.Den_PhdHolders</b>
                    </div>
                    <div class="doctors-summary-item">
                        <span>Full-Time MSc (Medicine)</span>
                        <b>@medDen.Med_MscHolders</b>
                    </div>
                    <div class="doctors-summary-item">
                        <span>Full-Time MSc (Dentistry)</span>
                        <b>@medDen.Den_MscHolders</b>
                    </div>
                    <div class="doctors-summary-item">
                        <span>Full-Time PSc (Medicine)</span>
                        <b>@medDen.Med_PscHolders</b>
                    </div>
                    <div class="doctors-summary-item">
                        <span>Full-Time PSc (Dentistry)</span>
                        <b>@medDen.Den_PscHolders</b>
                    </div>
                    <div class="doctors-summary-item doctors-summary-item--pt">
                        <span>Part-Time Total (Medicine)</span>
                        <b>@medDen.Med_TotalPartTime</b>
                    </div>
                    <div class="doctors-summary-item doctors-summary-item--pt">
                        <span>Part-Time Total (Dentistry)</span>
                        <b>@medDen.Den_TotalPartTime</b>
                    </div>
                </div>

            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Clinical Staff Ratio</h2>
                    <p>Computed clinical ratios for Medicine and Dentistry.</p>
                </div>
                <div class="csr-grid">

                    <div class="csr-col">
                        <div class="csr-col-head">College of Medicine</div>
                        <div class="rd-field">
                            <label>Full-Time Clinical PhD</label>
                            <input type="number" value="@medDen.Med_FullTimeClinicalPhD" readonly />
                        </div>
                        <div class="rd-field">
                            <label>Allowed Part-Time Clinical</label>
                            <input type="text" value="@Fmt2(medDen.Med_AllowedPartTimeClinical)" readonly />
                        </div>
                        <div class="rd-field csr-ratio-field @ClinicalRatioColor(medDen.Med_StudentFacultyRatio)">
                            <label>Student to Faculty Ratio</label>
                            <input type="text" value="@(medDen.Med_StudentFacultyRatio.HasValue ? "1 : " + ((int)Math.Floor(medDen.Med_StudentFacultyRatio.Value)).ToString() : "—")" readonly />
                        </div>
                    </div>

                    <div class="csr-col">
                        <div class="csr-col-head">College of Dentistry</div>
                        <div class="rd-field">
                            <label>Full-Time Clinical PhD</label>
                            <input type="number" value="@medDen.Den_FullTimeClinicalPhD" readonly />
                        </div>
                        <div class="rd-field">
                            <label>Allowed Part-Time Clinical</label>
                            <input type="text" value="@Fmt2(medDen.Den_AllowedPartTimeClinical)" readonly />
                        </div>
                        <div class="rd-field csr-ratio-field @ClinicalRatioColor(medDen.Den_StudentFacultyRatio)">
                            <label>Student to Faculty Ratio</label>
                            <input type="text" value="@(medDen.Den_StudentFacultyRatio.HasValue ? "1 : " + ((int)Math.Floor(medDen.Den_StudentFacultyRatio.Value)).ToString() : "—")" readonly />
                        </div>
                    </div>

                </div>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsAdmissionDuration", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsAcademicInfo", "Home", new { id = requestId })">Next</a>
                </div>
            </section>
        </main>
    </div>
</body>
</html>
