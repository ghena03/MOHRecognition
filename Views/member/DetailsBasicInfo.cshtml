@model MOHRecognition.Services.RecognitionRequestRecord

@{
    Layout = null;
    ViewData["Title"] = "Request Details - Basic Information";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsBasicInfo.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>
                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>Recognition Member</b></span>
                    </div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        <aside class="rm-sidebar">
            <div class="rm-side-title">Navigation</div>
            <nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")">
                    <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
                </a>
                <a class="rm-navitem active" href="@Url.Action("ElectronicRequests", "Home")">
                    <i class="bi bi-send-check"></i><span>My Assigned Requests</span>
                </a>
                <a class="rm-navitem" href="@Url.Action("Archive", "Home")">
                    <i class="bi bi-inboxes"></i><span>Requests Archive</span>
                </a>
                <a class="rm-navitem danger" href="@Url.Action("Logout", "Home")">
                    <i class="bi bi-power"></i><span>Sign Out</span>
                </a>
            </nav>
        </aside>

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@Model.UniversityName</b></p>
                    <p>Step 1 of 5 — Basic Information.</p>
                </div>

                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@Model.Id</b></div>
                    <div class="meta-pill"><span>Reference</span><b>@Model.ReferenceNumber</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Institution Basic Info</h2>
                    <p>General information from the submitted university request.</p>
                </div>

                <div class="rd-grid4">
                    <div class="rd-field">
                        <label>Country</label>
                        <input type="text" value="@Model.Country" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Institution Name</label>
                        <input type="text" value="@Model.UniversityName" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Website</label>
                        <input type="text" value="@Model.PublicInfo.InstitutionalWebAddress" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Institution Type</label>
                        <input type="text" value="@Model.AcademicInfo.TypeOfAcademicInstitution" readonly />
                    </div>
                </div>

                <div class="rd-grid4" style="margin-top:18px;">
                    <div class="rd-field">
                        <label>University Email</label>
                        <input type="text" value="@Model.UniversityEmail" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Applicant Name</label>
                        <input type="text" value="@Model.ApplicantName" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Work Place</label>
                        <input type="text" value="@Model.WorkPlace" readonly />
                    </div>
                    <div class="rd-field">
                        <label>Applicant Email</label>
                        <input type="text" value="@Model.ApplicantEmail" readonly />
                    </div>
                </div>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("ElectronicRequests", "Home")">
                        <i class="bi bi-box-arrow-left"></i> Back to List
                    </a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsStatistics", "Home", new { id = Model.Id })">Next</a>
                    <button class="rm-btn rm-btn-primary" type="button"><i class="bi bi-save"></i> Save</button>
                </div>
            </section>
        </main>
    </div>
</body>
</html>