@model MOHRecognition.Services.RecognitionRequestRecord
@using System
@using System.Linq
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Academic Info";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var memberViewOnly = (bool)(ViewBag.MemberViewOnly ?? false);
    var readOnlyMode = adminReadOnly || memberViewOnly;
    ViewData["ActiveNav"] = memberViewOnly ? "archive" : "requests";
    var adminMeetingId = (int)(ViewBag.AdminMeetingId ?? 0);
    var requestId = ViewBag.RequestId ?? Model?.Id ?? 0;
    var inst = ViewBag.InstitutionName ?? Model?.UniversityName ?? "—";
    var previousLink = adminReadOnly
        ? Url.Action("AdminDetailsAdmissionDuration", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAdmissionDuration", "Home", new { id = requestId });
    var nextLink = adminReadOnly
        ? Url.Action("AdminDetailsAccreditationBodies", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAccreditationBodies", "Home", new { id = requestId });
    var isManual = (bool)(ViewBag.IsManual ?? false);
    var A = Model?.AcademicInfo ?? new DTOs.AcademicInfoDto();

    string YesNo(bool value) => value ? "Yes" : "No";
    var teachingMethods = (A.TeachingMethodsCsv ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).Where(x => x.Length > 0).ToList();
    var assessmentMethods = (A.AssessmentMethodsCsv ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).Where(x => x.Length > 0).ToList();
    var platforms = (A.PlatformsCsv ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).Where(x => x.Length > 0).ToList();
    var eAssessmentMethods = (A.EAssessmentMethodsCsv ?? "").Split(';', StringSplitOptions.RemoveEmptyEntries).Select(x => x.Trim()).Where(x => x.Length > 0).ToList();
    var studyPlanRows = Model?.StudyPlanComplianceRows ?? new List<DTOs.StudyPlanComplianceRowDto>();
    var programs = Model?.Programs ?? new List<DTOs.ProgramRowDto>();
    var attachments = Model?.Attachments?.Rows ?? new List<DTOs.AttachmentRowDto>();
    var medDen = Model?.MedicineDentistry ?? new DTOs.MedicineDentistryDto();
    var hospitals = Model?.Hospitals ?? new DTOs.HospitalsDto();
    var hospitalFacilities = hospitals.Facilities ?? new List<DTOs.HospitalFacilityDto>();
    string NormalizeHospitalDocType(string? rawType)
    {
        var type = (rawType ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(type))
            return string.Empty;

        if (string.Equals(type, "LocalRecognition", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "LocalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "LocalAccreditation";
        if (string.Equals(type, "RegionalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "RegionalAccreditation";
        if (string.Equals(type, "InternationalAccreditation", StringComparison.OrdinalIgnoreCase))
            return "InternationalAccreditation";
        if (string.Equals(type, "OtherAccreditation", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";
        if (string.Equals(type, "HospitalAgreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";

        if (string.Equals(type, "University-Hospital Agreement", StringComparison.OrdinalIgnoreCase))
            return "HospitalAgreement";
        if (string.Equals(type, "Local Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";
        if (string.Equals(type, "Recognition Document", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Recognition Document (", StringComparison.OrdinalIgnoreCase))
            return "LocalRecognition";

        if (type.StartsWith("Accreditation Document (", StringComparison.OrdinalIgnoreCase))
        {
            var open = type.IndexOf('(');
            var close = type.LastIndexOf(')');
            var inner = (open >= 0 && close > open)
                ? type.Substring(open + 1, close - open - 1).Trim()
                : string.Empty;

            if (inner.Equals("Local", StringComparison.OrdinalIgnoreCase))
                return "LocalAccreditation";
            if (inner.Equals("Regional", StringComparison.OrdinalIgnoreCase))
                return "RegionalAccreditation";
            if (inner.Equals("International", StringComparison.OrdinalIgnoreCase))
                return "InternationalAccreditation";

            return "OtherAccreditation";
        }

        if (string.Equals(type, "Accreditation Document", StringComparison.OrdinalIgnoreCase))
            return "OtherAccreditation";

        return type;
    }

    string HospitalDocLabel(string normalizedType) => normalizedType switch
    {
        "LocalRecognition" => "Local Recognition",
        "LocalAccreditation" => "Local Accreditation",
        "RegionalAccreditation" => "Regional Accreditation",
        "InternationalAccreditation" => "International Accreditation",
        "OtherAccreditation" => "Other Accreditation",
        "HospitalAgreement" => "University-Hospital Agreement",
        _ => string.IsNullOrWhiteSpace(normalizedType) ? "—" : normalizedType
    };

    var typedHospitalDocuments = (hospitals.Documents ?? new List<DTOs.HospitalFileDto>())
        .Where(x => !string.IsNullOrWhiteSpace(x.FileUrl))
        .Select(x => new { Doc = x, Type = NormalizeHospitalDocType(x.DocumentType) })
        .Where(x => !string.IsNullOrWhiteSpace(x.Type))
        .OrderBy(x => x.Type)
        .ThenByDescending(x => x.Doc.UploadedAt ?? DateTime.MinValue)
        .ThenBy(x => x.Doc.OriginalFileName)
        .ToList();

    var localRecognitionDocs = typedHospitalDocuments.Where(x => x.Type == "LocalRecognition").Select(x => x.Doc).ToList();
    var localAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "LocalAccreditation").Select(x => x.Doc).ToList();
    var regionalAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "RegionalAccreditation").Select(x => x.Doc).ToList();
    var internationalAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "InternationalAccreditation").Select(x => x.Doc).ToList();
    var otherAccreditationDocs = typedHospitalDocuments.Where(x => x.Type == "OtherAccreditation").Select(x => x.Doc).ToList();
    var hospitalAgreementDocs = typedHospitalDocuments.Where(x => x.Type == "HospitalAgreement").Select(x => x.Doc).ToList();
    var facilityAgreementDocs = hospitalAgreementDocs
        .Where(x => !string.IsNullOrWhiteSpace(x.FacilityId))
        .GroupBy(x => x.FacilityId.Trim(), StringComparer.OrdinalIgnoreCase)
        .ToDictionary(g => g.Key, g => g.ToList(), StringComparer.OrdinalIgnoreCase);

    int NV(int? v) => v ?? 0;

    bool RowCompliant(DTOs.StudyPlanComplianceRowDto r)
    {
        var totalPlanHours = r.UniversityRequirementsHours + r.FacultyRequirementsHours + r.SpecializationRequirementsHours;
        var p = programs.FirstOrDefault(x => x.Id == r.ProgramId);
        var hasProgram = p != null;
        var creditMatch = !hasProgram || totalPlanHours > 0;
        var uniValid = r.UniversityRequirementsHours >= 21 && r.UniversityRequirementsHours <= 27;
        var facValid = totalPlanHours > 0 && r.FacultyRequirementsHours <= Math.Floor(totalPlanHours * 0.15m);
        var specValid = totalPlanHours > 0 && r.SpecializationRequirementsHours >= Math.Ceiling(totalPlanHours * 0.60m);
        var splitValid = (r.SpecializationTheoreticalPercent + r.SpecializationPracticalPercent) == 100
                         && r.SpecializationTheoreticalPercent >= 40 && r.SpecializationTheoreticalPercent <= 50
                         && r.SpecializationPracticalPercent >= 50 && r.SpecializationPracticalPercent <= 60;
        var domainsValid = r.BasicDomainsCount >= 4;
        var trainingValid = r.PracticalTrainingMonths >= 3;
        var projectValid = r.GraduationProjectHours >= 3;

        return uniValid && facValid && specValid && splitValid && domainsValid && trainingValid && projectValid && creditMatch;
    }

    var studyPlanOkCount = studyPlanRows.Count(RowCompliant);
    var studyPlanLevel = studyPlanRows.Count == 0 ? 2 : (studyPlanOkCount == studyPlanRows.Count ? 0 : 1);

    string ResultText(int level) => level == 2 ? "Not Compliant" : level == 1 ? "Warning" : "Complies";
    string ResultClass(int level) => level == 2 ? "fail" : level == 1 ? "warn" : "ok";

    var anyDegree = A.DegreeDiploma || A.DegreeBSC || A.DegreeHigherDiploma || A.DegreeMaster || A.DegreePhD;
    var hasType = !string.IsNullOrWhiteSpace(A.TypeOfAcademicInstitution);
    var recognitionMissing = !string.Equals(A.OfficialRecognitionInHomeCountry, "Yes", StringComparison.OrdinalIgnoreCase);
    var accreditationMissing = !string.Equals(A.OfficialAccreditationQualityInHomeCountry, "Yes", StringComparison.OrdinalIgnoreCase);
    var degreeTypeMismatch = string.Equals(A.TypeOfAcademicInstitution, "International", StringComparison.OrdinalIgnoreCase)
                     && A.DegreeDiploma && !A.DegreeBSC && !A.DegreeMaster && !A.DegreePhD;

    var identityLevel = 0;
    if (!hasType || !anyDegree || recognitionMissing || accreditationMissing) identityLevel = 2;
    else if (degreeTypeMismatch) identityLevel = 1;

    var anySystem = A.SystemYearlyProgram || A.SystemSemesterProgram || A.SystemCreditHours || A.SystemECTS;

    var structureLevel = 0;
    if (!anySystem) structureLevel = 2;

    var hasTeaching = teachingMethods.Any();
    var hasAssessment = assessmentMethods.Any();
    var usesELearningYes = string.Equals(A.UsesELearning, "Yes", StringComparison.OrdinalIgnoreCase);
    var usesELearningNo = string.Equals(A.UsesELearning, "No", StringComparison.OrdinalIgnoreCase);
    var ePct = A.ELearningPercentage ?? -1;
    var ePctValid = ePct >= 0 && ePct <= 100;
    var deliveryValid = !string.IsNullOrWhiteSpace(A.DeliveryType);
    var eLearningRequiredValid = !usesELearningYes || (deliveryValid && ePctValid);
    var programLooksMedical = teachingMethods.Any(x => string.Equals(x, "Clinical Training", StringComparison.OrdinalIgnoreCase));
    var professionalRegValid = !programLooksMedical || !string.IsNullOrWhiteSpace(A.ForeignGraduatesAllowedToPractice);

    var teachingLevel = 0;
    if (!hasTeaching || !hasAssessment || !eLearningRequiredValid) teachingLevel = 2;
    else if (!professionalRegValid) teachingLevel = 1;

    var overallLevel = Math.Max(Math.Max(identityLevel, structureLevel), Math.Max(teachingLevel, studyPlanLevel));

    string ClinicalRatioClass(double? r) => r == null ? "" : r <= 16.5 ? "ok" : r <= 20.625 ? "warn" : "fail";
    string ClinicalRatioText(double? r) => r == null ? "N/A" : r <= 16.5 ? "Acceptable" : r <= 20.625 ? "Warning" : "Exceeds Limit";
    string Fmt2(double d) => d.ToString("F2");
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAcademicInfo.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>@(adminReadOnly ? "Admin Review" : (ViewBag.CurrentRecognitionMember ?? "Recognition Member"))</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @if (adminReadOnly)
        {
            @await Html.PartialAsync("_AdminReviewSidebar")
        }
        else
        {
            @await Html.PartialAsync("_MemberSidebar")
        }

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 4 of 7 — Academic Information Review.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>4 / 7</b></div>
                </div>
            </section>

            @if (readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #fedf89; background:#fffaeb; color:#7a2e0e; font-weight:700;">
                    <i class="bi bi-eye"></i> Read-only mode: this university is assigned to another member.
                </section>
            }

            @if (isManual && !readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #bfdbfe; background:#eff6ff; color:#1e40af; font-weight:600; display:flex; align-items:center; gap:10px;">
                    <i class="bi bi-pencil-square" style="font-size:1.1rem;"></i>
                    Manual Request — Review the computed academic indicators below. Staff and student data was entered in the previous step.
                    <a class="rm-btn rm-btn-primary" href="@nextLink" style="margin-left:auto; white-space:nowrap;">
                        <i class="bi bi-arrow-right-circle"></i> Continue to Next Step
                    </a>
                </section>
            }

            <section id="sec-hospitals" class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2><i class="bi bi-hospital"></i> Hospitals</h2>
                    <p>Submitted hospital data and recognition / accreditation information.</p>
                </div>

                <!-- Section 1: University Submitted Hospital Data -->
                <div class="rd-card-hd" style="margin-top:10px;">
                    <h2 style="font-size:18px;"><i class="bi bi-building"></i> University Submitted Hospital Data</h2>
                </div>
                <div class="clean-table-wrap">
                    <table class="clean-review-table">
                        <thead>
                            <tr>
                                <th style="width:72px;">#</th>
                                <th>Specialization</th>
                                <th>Facility Name</th>
                                <th>Beds</th>
                                <th>Dental Chairs</th>
                                <th>Agreement File</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (hospitalFacilities.Any())
                            {
                                for (var i = 0; i < hospitalFacilities.Count; i++)
                                {
                                    var row = hospitalFacilities[i];
                                    var rowId = (row.Id ?? string.Empty).Trim();
                                    var rowDocs = facilityAgreementDocs.TryGetValue(rowId, out var docs) ? docs : new List<DTOs.HospitalFileDto>();
                                    <tr>
                                        <td class="cell-index">@(i + 1)</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.Specialization) ? "—" : row.Specialization)</td>
                                        <td>@(string.IsNullOrWhiteSpace(row.Name)           ? "—" : row.Name)</td>
                                        <td>@(row.BedCapacity.HasValue        ? row.BedCapacity.Value.ToString()        : "—")</td>
                                        <td>@(row.DentalChairCapacity.HasValue ? row.DentalChairCapacity.Value.ToString() : "—")</td>
                                        <td>
                                            @if (rowDocs.Any())
                                            {
                                                <div class="table-actions">
                                                    <a class="rm-mini" href="@rowDocs[0].FileUrl" target="_blank" rel="noopener">View Files (@rowDocs.Count)</a>
                                                </div>
                                            }
                                            else
                                            {
                                                @:—
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6">No hospital data submitted.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>

            </section>

            <section id="sec-doctors-colleges" class="rm-card rd-card doctors-review-section">
                <div class="rd-card-hd">
                    <h2><i class="bi bi-person-vcard"></i> Doctors / Medicine Colleges</h2>
                    <p>Part-time clinical counts are included in the totals.</p>
                </div>

                <!-- Merged Staff Table -->
                <div class="studyplan-table-wrap">
                    <table class="rd-table doctors-review-table sst-ro-table">
                        <thead>
                            <tr>
                                <th class="sst-ro-cat-col">Category</th>
                                <th>College of Medicine</th>
                                <th>College of Dentistry</th>
                            </tr>
                        </thead>
                        <tbody>

                            <tr class="sst-ro-total">
                                <td class="sst-ro-cat">Total Students</td>
                                <td class="sst-ro-cell">
                                    <div class="value-stack">
                                        <div class="value-row">
                                            <span>Students</span>
                                            <b>@NV(medDen.Med_TotalStudents)</b>
                                        </div>
                                    </div>
                                </td>
                                <td class="sst-ro-cell">
                                    <div class="value-stack">
                                        <div class="value-row">
                                            <span>Students</span>
                                            <b>@NV(medDen.Den_TotalStudents)</b>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Med_PartTimeClinicalProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Den_PartTimeClinicalProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Associate Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeAssociateProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Med_PartTimeClinicalAssociateProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeAssociateProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Den_PartTimeClinicalAssociateProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Assistant Professor</td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeAssistantProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Med_PartTimeClinicalAssistantProfessor)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeAssistantProfessor)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Den_PartTimeClinicalAssistantProfessor)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Lecturer <span class="sst-qual">(PhD)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Med_PartTimeClinicalLecturerPhd)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Den_PartTimeClinicalLecturerPhd)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Lecturer <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeLecturerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeLecturerMsc)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Assistant Lecturer <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeAssistantLecturerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeAssistantLecturerMsc)</b></div></div></td>
                            </tr>

                            <tr class="sst-ro-phd-row">
                                <td class="sst-ro-cat">Assistant Lecturer <span class="sst-qual">(PhD)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimeAssistantLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Med_PartTimeClinicalAssistantLecturerPhd)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimeAssistantLecturerPhd)</b></div><div class="value-row pt"><span>Part-Time</span><b>@NV(medDen.Den_PartTimeClinicalAssistantLecturerPhd)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Practitioner <span class="sst-qual">(BSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimePractitionerPsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimePractitionerPsc)</b></div></div></td>
                            </tr>

                            <tr>
                                <td class="sst-ro-cat">Practitioner <span class="sst-qual">(MSc)</span></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Med_FullTimePractitionerMsc)</b></div></div></td>
                                <td class="sst-ro-cell"><div class="value-stack"><div class="value-row"><span>Full-Time</span><b>@NV(medDen.Den_FullTimePractitionerMsc)</b></div></div></td>
                            </tr>

                        </tbody>
                    </table>
                </div>

                <!-- Clinical Student to Faculty Ratio (assessor only) -->
                <div style="display:flex;align-items:center;gap:8px;margin-top:18px;margin-bottom:10px;">
                    <h3 class="doctors-group-title" style="margin:0;">Clinical Doctor-to-Student Ratio</h3>
                    <button class="eq-info-btn" onclick="openEqModal('modal-clinical')" title="How is this calculated?"><i class="bi bi-info-circle-fill"></i></button>
                </div>
                <div class="doctors-sfr-grid">

                    <div class="doctors-sfr-card">
                        <div class="doctors-sfr-head">College of Medicine</div>
                        <div class="doctors-sfr-body">
                            <span class="doctors-sfr-label">Clinical Doctor-to-Student Ratio</span>
                            <div class="doctors-sfr-result">
                                <span class="doctors-sfr-value">@(medDen.Med_StudentFacultyRatio.HasValue ? "1 : " + ((int)Math.Floor(medDen.Med_StudentFacultyRatio.Value)).ToString() : "—")</span>
                                <span class="status-badge @ClinicalRatioClass(medDen.Med_StudentFacultyRatio)">@ClinicalRatioText(medDen.Med_StudentFacultyRatio)</span>
                            </div>
                        </div>
                    </div>

                    <div class="doctors-sfr-card">
                        <div class="doctors-sfr-head">College of Dentistry</div>
                        <div class="doctors-sfr-body">
                            <span class="doctors-sfr-label">Clinical Doctor-to-Student Ratio</span>
                            <div class="doctors-sfr-result">
                                <span class="doctors-sfr-value">@(medDen.Den_StudentFacultyRatio.HasValue ? "1 : " + ((int)Math.Floor(medDen.Den_StudentFacultyRatio.Value)).ToString() : "—")</span>
                                <span class="status-badge @ClinicalRatioClass(medDen.Den_StudentFacultyRatio)">@ClinicalRatioText(medDen.Den_StudentFacultyRatio)</span>
                            </div>
                        </div>
                    </div>

                </div>

            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@previousLink">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@nextLink">Next</a>
                </div>
            </section>
        </main>
    </div>
<!-- ── Clinical Ratio Modal ──────────────────────────────────────────────── -->
<div id="eq-modal-overlay" class="eq-modal-overlay" onclick="closeEqModalIfOverlay(event)">
    <div id="modal-clinical" class="eq-modal" role="dialog" aria-modal="true">
        <button class="eq-modal-close" onclick="closeEqModal()" aria-label="Close">✕</button>
        <div class="eq-modal-icon">🏥</div>
        <div class="eq-modal-title">Clinical Doctor-to-Student Ratio</div>
        <div class="eq-modal-subtitle">How is the ratio of students to clinical PhD faculty calculated for Medicine and Dentistry?</div>

        <!-- Quick threshold summary at the top -->
        <div class="eq-threshold-row" style="margin-bottom:18px;">
            <span class="eq-thr-tag eq-thr-green"><i class="bi bi-check-circle-fill"></i> Ratio ≤ 1 : 16.5 — Acceptable</span>
            <span class="eq-thr-tag eq-thr-orange"><i class="bi bi-exclamation-circle-fill"></i> 1 : 16.5 &lt; Ratio ≤ 1 : 20.6 — Warning</span>
            <span class="eq-thr-tag eq-thr-red"><i class="bi bi-x-circle-fill"></i> Ratio &gt; 1 : 20.6 — Exceeds Limit</span>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 1 — Identify Full-Time Clinical PhD Staff</div>
            <div class="eq-step-body">
                Count all <b>full-time</b> clinical faculty who hold a <b>PhD</b>. This is calculated <em>separately</em> for Medicine and for Dentistry:
                <ul class="eq-list">
                    <li><b>Professor</b> (Full-Time, clinical)</li>
                    <li><b>Associate Professor</b> (Full-Time, clinical)</li>
                    <li><b>Assistant Professor</b> (Full-Time, clinical)</li>
                    <li><b>Lecturer with PhD</b> (Full-Time, clinical)</li>
                    <li><b>Assistant Lecturer with PhD</b> (Full-Time, clinical)</li>
                </ul>
                <div class="eq-step-note">MSc lecturers and non-clinical staff are not included in this count.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 2 — Calculate the Allowed Part-Time Limit</div>
            <div class="eq-step-body">
                The maximum number of part-time clinical staff that can be counted depends on how many <b>full-time PhD staff (D)</b> the college has. The limit is calculated in tiers:
                <div class="eq-step-formula" style="text-align:left;line-height:2;">
                    If D &lt; 50 &nbsp;&nbsp;&nbsp;→ &nbsp; Allowed PT = D × 0.25<br>
                    If 50 ≤ D ≤ 100 → &nbsp; Allowed PT = (50 × 0.25) + ((D − 50) × 0.35)<br>
                    If D &gt; 100 &nbsp;&nbsp;→ &nbsp; Allowed PT = (50 × 0.25) + (50 × 0.35) + ((D − 100) × 0.50)
                </div>
                <div class="eq-step-note">The more full-time PhD staff a college has, the more part-time staff it is allowed to include — but at a decreasing rate. This prevents over-reliance on part-time staff.</div>
                Then the actual counted part-time is capped:
                <div class="eq-step-formula">Counted PT = min( Actual Part-Time Count, Allowed PT Limit )</div>
                <div class="eq-step-note">If the college employs more part-time staff than the allowed limit, only the allowed number is counted — the rest are ignored.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 3 — Calculate Total Capacity and Ratio</div>
            <div class="eq-step-body">
                The total clinical faculty capacity combines full-time PhD staff with the counted part-time staff:
                <div class="eq-step-formula">Capacity = FT PhD Staff (D) + Counted PT Staff</div>
                Then the ratio is computed separately for <b>Medicine</b> and <b>Dentistry</b>:
                <div class="eq-step-formula">Ratio = Total Students ÷ Capacity</div>
                <div class="eq-step-note">
                    Example: 500 Medicine students, D = 40 FT PhD, Actual PT = 15<br>
                    → Allowed PT = 40 × 0.25 = 10 &nbsp;|&nbsp; Counted PT = min(15, 10) = 10<br>
                    → Capacity = 40 + 10 = 50 &nbsp;|&nbsp; Ratio = 500 ÷ 50 = <b>1 : 10 → Acceptable</b>
                </div>
            </div>
        </div>

        <div class="eq-step eq-step--result">
            <div class="eq-step-hd">Step 4 — Compliance Thresholds</div>
            <div class="eq-step-body">
                The result is compared to fixed international clinical education standards:
                <div class="eq-threshold-row">
                    <span class="eq-thr-tag eq-thr-green"><i class="bi bi-check-circle-fill"></i> Ratio ≤ 1 : 16.5 — Acceptable</span>
                    <span class="eq-thr-tag eq-thr-orange"><i class="bi bi-exclamation-circle-fill"></i> 1 : 16.5 &lt; Ratio ≤ 1 : 20.6 — Warning</span>
                    <span class="eq-thr-tag eq-thr-red"><i class="bi bi-x-circle-fill"></i> Ratio &gt; 1 : 20.6 — Exceeds Limit</span>
                </div>
                <div class="eq-step-note" style="margin-top:10px;">A <b>lower ratio</b> (fewer students per doctor) indicates better supervision quality. The standard of 1 : 16.5 ensures each clinical faculty member can adequately supervise their students in hospital and clinical settings.</div>
            </div>
        </div>
    </div>
</div>

<script>
    function openEqModal(id) {
        var overlay = document.getElementById('eq-modal-overlay');
        overlay.querySelectorAll('.eq-modal').forEach(function(m) { m.style.display = 'none'; });
        var modal = document.getElementById(id);
        if (modal) { modal.style.display = 'block'; }
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeEqModal() {
        document.getElementById('eq-modal-overlay').classList.remove('open');
        document.body.style.overflow = '';
    }
    function closeEqModalIfOverlay(e) {
        if (e.target === document.getElementById('eq-modal-overlay')) closeEqModal();
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeEqModal();
    });
</script>
</body>
</html>
