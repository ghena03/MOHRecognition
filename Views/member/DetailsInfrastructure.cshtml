@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - University Infrastructure";
    var adminReadOnly = (bool)(ViewBag.AdminReadOnly ?? false);
    var memberViewOnly = (bool)(ViewBag.MemberViewOnly ?? false);
    var isManual = (bool)(ViewBag.IsManual ?? false);
    var readOnlyMode = adminReadOnly || memberViewOnly;
    ViewData["ActiveNav"] = memberViewOnly ? "archive" : "requests";
    var adminMeetingId = (int)(ViewBag.AdminMeetingId ?? 0);
    var requestId = Model?.Id ?? 0;
    var inst = Model?.UniversityName ?? "—";
    var previousLink = adminReadOnly
        ? Url.Action("AdminDetailsAccreditationBodies", "Home", new { id = requestId, meetingId = adminMeetingId })
        : Url.Action("DetailsAccreditationBodies", "Home", new { id = requestId });
    var nextLink = adminReadOnly
        ? Url.Action("AdminDetailsRecommendation", "Home", new { id = requestId, meetingId = adminMeetingId })
        : (isManual && !readOnlyMode
            ? Url.Action("MarkManualDataFilled", "Home", new { id = requestId })
            : Url.Action("DetailsRecommendation", "Home", new { id = requestId }));
    var pictures = Model?.Pictures?.Rows ?? new List<DTOs.PictureRowDto>();
    var laboratories = Model?.Laboratories ?? new DTOs.LaboratoriesDto();
    var laboratoryRows = laboratories.Rows ?? new List<DTOs.LaboratoryRowDto>();
    var laboratoryFiles = laboratories.UploadedFiles ?? new List<DTOs.LaboratoryFileDto>();
    var infrastructure = Model?.Infrastructure ?? new DTOs.InfrastructureDto();
    var library = Model?.Library ?? new DTOs.LibraryDto();
    var facultiesAssessment = Model?.FacultiesAssessment ?? string.Empty;
    var hospitalsAssessment = Model?.HospitalsAssessment ?? string.Empty;
    var hospitalEnvironmentAssessment = Model?.HospitalEnvironmentAssessment ?? string.Empty;
    var laboratoriesFacilitiesAssessment = Model?.LaboratoriesFacilitiesAssessment ?? string.Empty;
    var libraryAssessment = Model?.LibraryAssessment ?? string.Empty;
    var facultiesAssessmentNote = Model?.FacultiesAssessmentNote ?? string.Empty;
    var hospitalsAssessmentNote = Model?.HospitalsAssessmentNote ?? string.Empty;
    var hospitalEnvironmentAssessmentNote = Model?.HospitalEnvironmentAssessmentNote ?? string.Empty;
    var laboratoriesFacilitiesAssessmentNote = Model?.LaboratoriesFacilitiesAssessmentNote ?? string.Empty;
    var libraryAssessmentNote = Model?.LibraryAssessmentNote ?? string.Empty;

    string StatusClass(string? value)
    {
        return (value ?? string.Empty).Trim() switch
        {
            "Meets Standards" => "ok",
            "Needs Improvement" => "warn",
            _ => "neutral"
        };
    }

    string StatusText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not Assessed" : value;
    }

    string NumText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "—" : value;
    }
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsInfrastructure.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>@(adminReadOnly ? "Admin Review" : (ViewBag.CurrentRecognitionMember ?? "Recognition Member"))</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @if (adminReadOnly)
        {
            @await Html.PartialAsync("_AdminReviewSidebar")
        }
        else
        {
            @await Html.PartialAsync("_MemberSidebar")
        }

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 7 of 7 — University Infrastructure & Extra Info.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>7 / 7</b></div>
                </div>
            </section>

            @if (readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #fedf89; background:#fffaeb; color:#7a2e0e; font-weight:700;">
                    <i class="bi bi-eye"></i> Read-only mode: this university is assigned to another member.
                </section>
            }

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2><i class="bi bi-123"></i> University Infrastructure</h2>
                    <p>Quick overview of submitted university infrastructure counts.</p>
                </div>

                <div class="infra-summary-grid">
                    <div class="infra-summary-item"><span>Area (Km²)</span><b>@NumText(infrastructure.AreaKm2)</b></div>
                    <div class="infra-summary-item"><span>Number of Colleges</span><b>@NumText(infrastructure.CampusesCount)</b></div>
                    <div class="infra-summary-item"><span>Classrooms and Lecture Halls</span><b>@NumText(infrastructure.ClassroomsAndLectureHallsCount)</b></div>
                    <div class="infra-summary-item"><span>Number of Laboratories</span><b>@NumText(infrastructure.LibrariesCount)</b></div>
                    <div class="infra-summary-item"><span>Number of Stadiums</span><b>@NumText(infrastructure.StadiumsCount)</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Laboratories by College</h2>
                    <p>Submitted rows from the university laboratories section.</p>
                </div>

                <div class="infra-box">
                    <div class="infra-box-hd"><i class="bi bi-building"></i> Laboratories by College</div>

                    @if (laboratoryRows.Any())
                    {
                        <div class="infra-table-wrap">
                            <table class="infra-table">
                                <thead>
                                    <tr>
                                        <th style="width:60px;">#</th>
                                        <th>College</th>
                                        <th>Computers</th>
                                        <th>Laboratories</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        var idx = 1;
                                    }
                                    @foreach (var row in laboratoryRows)
                                    {
                                        <tr>
                                            <td>@idx</td>
                                            <td>@(string.IsNullOrWhiteSpace(row.FacultyName) ? "—" : row.FacultyName)</td>
                                            <td>@(row.Computers?.ToString() ?? "—")</td>
                                            <td>@(row.Laboratories?.ToString() ?? "—")</td>
                                        </tr>
                                        idx++;
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="infra-empty">No laboratories rows were submitted.</div>
                    }
                </div>
            </section>

            <!-- Library of the University -->
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2><i class="bi bi-book"></i> Library of the University</h2>
                    <p>Submitted library resources and capacity information.</p>
                </div>

                <div class="infra-summary-grid">
                    <div class="infra-summary-item"><span>Area (m²)</span><b>@(library.Area.HasValue ? library.Area.Value.ToString("N0") : "—")</b></div>
                    <div class="infra-summary-item"><span>Total Student Capacity</span><b>@(library.TotalStudentCapacity.HasValue ? library.TotalStudentCapacity.Value.ToString("N0") : "—")</b></div>
                    <div class="infra-summary-item"><span>Number of Books</span><b>@(library.NumberOfBooks.HasValue ? library.NumberOfBooks.Value.ToString("N0") : "—")</b></div>
                    <div class="infra-summary-item"><span>Number of Paper Journals</span><b>@(library.NumberOfPaperJournals.HasValue ? library.NumberOfPaperJournals.Value.ToString("N0") : "—")</b></div>
                    <div class="infra-summary-item"><span>Number of Electronic Books</span><b>@(library.NumberOfElectronicBooks.HasValue ? library.NumberOfElectronicBooks.Value.ToString("N0") : "—")</b></div>
                    <div class="infra-summary-item"><span>Number of Electronic Journals</span><b>@(library.NumberOfElectronicJournals.HasValue ? library.NumberOfElectronicJournals.Value.ToString("N0") : "—")</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>University Uploaded Files</h2>
                    <p>Review uploaded contracts and photos/media before writing your notes.</p>
                </div>

                <div class="infra-box">
                    <div class="infra-box-hd"><i class="bi bi-images"></i> Pictures / Media Files</div>
                    @{
                        var hasLaboratoryMedia = laboratoryFiles.Any();
                        var hasAnyMedia = pictures.Any() || hasLaboratoryMedia;

                        var allFiles = pictures
                            .Select(f => new { Subject = f.Subject ?? "Other", FileName = f.FileName, FileUrl = f.FileUrl, UploadedAt = f.UploadedAt })
                            .Concat(laboratoryFiles.Select(f => new {
                                Subject = string.IsNullOrWhiteSpace(f.Subject) ? "Laboratories photos" : f.Subject,
                                FileName = f.OriginalFileName,
                                FileUrl = f.FileUrl,
                                UploadedAt = f.UploadedAt
                            }))
                            .OrderByDescending(f => f.UploadedAt)
                            .ToList();

                        var grouped = allFiles
                            .GroupBy(f => f.Subject)
                            .OrderBy(g => g.Key)
                            .ToList();
                    }
                    @if (hasAnyMedia)
                    {
                        <div class="file-sections">
                            @foreach (var group in grouped)
                            {
                                var groupId = "fgrp-" + System.Text.RegularExpressions.Regex.Replace(group.Key, @"[^a-zA-Z0-9]", "-").ToLower();
                                <div class="file-section">
                                    <button type="button" class="file-section-hd" onclick="toggleFileSection(this)" aria-expanded="true">
                                        <span class="file-section-title">
                                            <i class="bi bi-folder2-open"></i>
                                            @group.Key
                                            <span class="file-section-count">@group.Count() file@(group.Count() != 1 ? "s" : "")</span>
                                        </span>
                                        <i class="bi bi-chevron-up file-section-chevron"></i>
                                    </button>
                                    <ul class="infra-list file-section-body">
                                        @foreach (var f in group)
                                        {
                                            <li>
                                                <div style="display:flex;align-items:center;gap:10px;min-width:0;">
                                                    <i class="bi bi-file-earmark-pdf infra-file-icon"></i>
                                                    <div class="infra-sub" style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@f.FileName</div>
                                                </div>
                                                <div class="infra-actions">
                                                    <a class="rm-mini" href="@f.FileUrl" target="_blank">Open</a>
                                                    <a class="rm-mini" href="@f.FileUrl" download="@f.FileName">Download</a>
                                                </div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="infra-empty">No pictures/files were uploaded.</div>
                    }
                </div>

            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Environment Assessment Summary</h2>
                    <p>Select professional status values for each environment area.</p>
                </div>

                @if (TempData["InfraSaved"] != null)
                {
                    <div class="infra-saved">@TempData["InfraSaved"]</div>
                }

                @if (TempData["InfraSaveError"] != null)
                {
                    <div class="infra-error">@TempData["InfraSaveError"]</div>
                }

                <form asp-controller="Home" asp-action="SaveInfrastructureNotes" method="post" id="infraForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@requestId" />

                    <div class="infra-assessment-grid">
                        <div class="assess-box">
                            <div class="assess-head">
                                <div>
                                    <div class="assess-title">Colleges Environment Assessment</div>
                                    <div class="assess-sub">Evaluate whether college-related resources meet required standards.</div>
                                </div>
                                <span id="facultiesAssessmentBadge" class="assess-status @StatusClass(facultiesAssessment)">@StatusText(facultiesAssessment)</span>
                            </div>

                            <div class="rd-field">
                                <label for="facultiesAssessment">Status</label>
                                <select id="facultiesAssessment" name="facultiesAssessment" data-assessment-select="facultiesAssessmentBadge" data-note-wrap="facultiesAssessmentNoteWrap" data-note-input="facultiesAssessmentNote" @(readOnlyMode ? "disabled" : null)>
                                    <option value="">Select status</option>
                                    <option value="Meets Standards" selected="@(facultiesAssessment == "Meets Standards" ? "selected" : null)">Meets Standards</option>
                                    <option value="Needs Improvement" selected="@(facultiesAssessment == "Needs Improvement" ? "selected" : null)">Needs Improvement</option>
                                </select>
                            </div>

                            <div id="facultiesAssessmentNoteWrap" class="rd-field infra-note-wrap">
                                <label for="facultiesAssessmentNote">Improvement Note</label>
                                <textarea id="facultiesAssessmentNote" name="facultiesAssessmentNote" class="rd-big infra-note" placeholder="Explain why this section needs improvement..." @(readOnlyMode ? "readonly disabled" : null)>@facultiesAssessmentNote</textarea>
                            </div>
                        </div>

                        <div class="assess-box">
                            <div class="assess-head">
                                <div>
                                    <div class="assess-title">Hospitals Environment Assessment</div>
                                    <div class="assess-sub">Assess hospital resources linked to training and academic delivery.</div>
                                </div>
                                <span id="hospitalsAssessmentBadge" class="assess-status @StatusClass(hospitalsAssessment)">@StatusText(hospitalsAssessment)</span>
                            </div>

                            <div class="rd-field">
                                <label for="hospitalsAssessment">Status</label>
                                <select id="hospitalsAssessment" name="hospitalsAssessment" data-assessment-select="hospitalsAssessmentBadge" data-note-wrap="hospitalsAssessmentNoteWrap" data-note-input="hospitalsAssessmentNote" @(readOnlyMode ? "disabled" : null)>
                                    <option value="">Select status</option>
                                    <option value="Meets Standards" selected="@(hospitalsAssessment == "Meets Standards" ? "selected" : null)">Meets Standards</option>
                                    <option value="Needs Improvement" selected="@(hospitalsAssessment == "Needs Improvement" ? "selected" : null)">Needs Improvement</option>
                                </select>
                            </div>

                            <div id="hospitalsAssessmentNoteWrap" class="rd-field infra-note-wrap">
                                <label for="hospitalsAssessmentNote">Improvement Note</label>
                                <textarea id="hospitalsAssessmentNote" name="hospitalsAssessmentNote" class="rd-big infra-note" placeholder="Explain why this section needs improvement..." @(readOnlyMode ? "readonly disabled" : null)>@hospitalsAssessmentNote</textarea>
                            </div>
                        </div>

                        <div class="assess-box">
                            <div class="assess-head">
                                <div>
                                    <div class="assess-title">Laboratories Facilities Assessment</div>
                                    <div class="assess-sub">Evaluate whether laboratories and facilities meet the required academic standards.</div>
                                </div>
                                <span id="laboratoriesFacilitiesAssessmentBadge" class="assess-status @StatusClass(laboratoriesFacilitiesAssessment)">@StatusText(laboratoriesFacilitiesAssessment)</span>
                            </div>

                            <div class="rd-field">
                                <label for="laboratoriesFacilitiesAssessment">Status</label>
                                <select id="laboratoriesFacilitiesAssessment" name="laboratoriesFacilitiesAssessment" data-assessment-select="laboratoriesFacilitiesAssessmentBadge" data-note-wrap="laboratoriesFacilitiesAssessmentNoteWrap" data-note-input="laboratoriesFacilitiesAssessmentNote" @(readOnlyMode ? "disabled" : null)>
                                    <option value="">Select status</option>
                                    <option value="Meets Standards" selected="@(laboratoriesFacilitiesAssessment == "Meets Standards" ? "selected" : null)">Meets Standards</option>
                                    <option value="Needs Improvement" selected="@(laboratoriesFacilitiesAssessment == "Needs Improvement" ? "selected" : null)">Needs Improvement</option>
                                </select>
                            </div>

                            <div id="laboratoriesFacilitiesAssessmentNoteWrap" class="rd-field infra-note-wrap">
                                <label for="laboratoriesFacilitiesAssessmentNote">Improvement Note</label>
                                <textarea id="laboratoriesFacilitiesAssessmentNote" name="laboratoriesFacilitiesAssessmentNote" class="rd-big infra-note" placeholder="Explain why this section needs improvement..." @(readOnlyMode ? "readonly disabled" : null)>@laboratoriesFacilitiesAssessmentNote</textarea>
                            </div>
                        </div>

                        <div class="assess-box">
                            <div class="assess-head">
                                <div>
                                    <div class="assess-title">Library Environment Assessment</div>
                                    <div class="assess-sub">Assess whether the university library environment supports program standards.</div>
                                </div>
                                <span id="libraryAssessmentBadge" class="assess-status @StatusClass(libraryAssessment)">@StatusText(libraryAssessment)</span>
                            </div>

                            <div class="rd-field">
                                <label for="libraryAssessment">Status</label>
                                <select id="libraryAssessment" name="libraryAssessment" data-assessment-select="libraryAssessmentBadge" data-note-wrap="libraryAssessmentNoteWrap" data-note-input="libraryAssessmentNote" @(readOnlyMode ? "disabled" : null)>
                                    <option value="">Select status</option>
                                    <option value="Meets Standards" selected="@(libraryAssessment == "Meets Standards" ? "selected" : null)">Meets Standards</option>
                                    <option value="Needs Improvement" selected="@(libraryAssessment == "Needs Improvement" ? "selected" : null)">Needs Improvement</option>
                                </select>
                            </div>

                            <div id="libraryAssessmentNoteWrap" class="rd-field infra-note-wrap">
                                <label for="libraryAssessmentNote">Improvement Note</label>
                                <textarea id="libraryAssessmentNote" name="libraryAssessmentNote" class="rd-big infra-note" placeholder="Explain why this section needs improvement..." @(readOnlyMode ? "readonly disabled" : null)>@libraryAssessmentNote</textarea>
                            </div>
                        </div>
                    </div>

                    @if (!readOnlyMode)
                    {
                        <div style="display:flex; justify-content:flex-end; margin-top:14px;">
                            <button class="rm-btn rm-btn-primary" type="submit"><i class="bi bi-save"></i> Save Assessments</button>
                        </div>
                    }
                </form>
            </section>

            @if (isManual && !readOnlyMode)
            {
                <section class="rm-card" style="border:1px solid #dcfce7; background:#f0fdf4; display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap;">
                    <div style="display:flex; align-items:center; gap:10px; color:#166534; font-weight:600;">
                        <i class="bi bi-check-circle-fill" style="font-size:1.2rem;"></i>
                        All university data has been entered. You are ready to write the final recommendation.
                    </div>
                    <a class="rm-btn rm-btn-primary" href="@nextLink" style="white-space:nowrap; font-size:1rem; padding:12px 24px;">
                        <i class="bi bi-award-fill"></i> Go to Recommendation
                    </a>
                </section>
            }

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@previousLink">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn @(isManual && !readOnlyMode ? "rm-btn-primary" : "rm-btn-light")" href="@nextLink">
                        @if (isManual && !readOnlyMode)
                        {
                            <i class="bi bi-award-fill"></i>
                            <span>Go to Recommendation</span>
                        }
                        else
                        {
                            <span>Next</span>
                        }
                    </a>
                </div>
            </section>
        </main>
    </div>

    <script>
        function toggleFileSection(btn) {
            const body = btn.nextElementSibling;
            const chevron = btn.querySelector(".file-section-chevron");
            const isOpen = btn.getAttribute("aria-expanded") === "true";
            btn.setAttribute("aria-expanded", String(!isOpen));
            body.style.display = isOpen ? "none" : "grid";
            chevron.style.transform = isOpen ? "rotate(180deg)" : "";
        }
    </script>
    <style>
        @@keyframes _infraToastIn {
            from { opacity: 0; transform: translateY(16px) scale(.96); }
            to   { opacity: 1; transform: translateY(0)     scale(1);   }
        }
        #_infra-toast {
            position: fixed;
            bottom: 28px;
            right: 28px;
            z-index: 99999;
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 20px;
            border-radius: 14px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            font-weight: 600;
            color: #fff;
            box-shadow: 0 8px 32px rgba(0,0,0,.22);
            max-width: 380px;
            animation: _infraToastIn .22s ease both;
            pointer-events: none;
        }
        #_infra-toast.toast-success { background: #2d6a4f; }
        #_infra-toast.toast-error   { background: #dc2626; }
        #_infra-toast i { font-size: 18px; flex-shrink: 0; }
    </style>
    <script>
        (function () {
            const isReadOnlyMode = "@readOnlyMode".toLowerCase() === "true";
            /* ── Toast ─────────────────────────────────────────── */
            function showToast(message, type) {
                const old = document.getElementById('_infra-toast');
                if (old) old.remove();
                const t = document.createElement('div');
                t.id = '_infra-toast';
                t.className = type === 'success' ? 'toast-success' : 'toast-error';
                const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
                t.innerHTML = `<i class="bi ${icon}"></i><span>${message}</span>`;
                document.body.appendChild(t);
                setTimeout(() => {
                    t.style.transition = 'opacity .28s, transform .28s';
                    t.style.opacity = '0';
                    t.style.transform = 'translateY(10px)';
                    setTimeout(() => t.remove(), 300);
                }, 3500);
            }

            /* ── AJAX form submit ──────────────────────────────── */
            const form = document.getElementById('infraForm');
            if (form) {
                form.addEventListener('submit', async function (e) {
                    if (isReadOnlyMode) return;
                    e.preventDefault();
                    const btn = this.querySelector('button[type="submit"]');
                    const origHtml = btn ? btn.innerHTML : '';
                    if (btn) { btn.disabled = true; btn.innerHTML = '<i class="bi bi-hourglass-split"></i> Saving…'; }
                    try {
                        const res  = await fetch(this.action, { method: 'POST', body: new FormData(this) });
                        const html = await res.text();
                        if (html.includes('Infrastructure assessments saved successfully')) {
                            showToast('Infrastructure assessments saved successfully.', 'success');
                        } else if (html.includes('Please add a professional note')) {
                            showToast('Please add a note for each section marked as Needs Improvement.', 'error');
                        } else if (html.includes('Unable to save')) {
                            showToast('Unable to save. Please try again.', 'error');
                        } else {
                            showToast('Saved successfully.', 'success');
                        }
                    } catch {
                        showToast('Connection error. Please try again.', 'error');
                    } finally {
                        if (btn) { btn.disabled = false; btn.innerHTML = origHtml; }
                    }
                });
            }

            /* ── Badge + note-wrap live update ─────────────────── */
            const selects = document.querySelectorAll("[data-assessment-select]");

            function getBadgeStyle(value) {
                if (value === "Meets Standards") return { text: "Meets Standards", cls: "ok" };
                if (value === "Needs Improvement") return { text: "Needs Improvement", cls: "warn" };
                return { text: "Not Assessed", cls: "neutral" };
            }

            function updateAssessment(selectEl) {
                const selectedValue = selectEl.value || "";
                const badgeId    = selectEl.getAttribute("data-assessment-select");
                const noteWrapId = selectEl.getAttribute("data-note-wrap");
                const noteInputId = selectEl.getAttribute("data-note-input");
                const badge     = badgeId    ? document.getElementById(badgeId)    : null;
                const noteWrap  = noteWrapId  ? document.getElementById(noteWrapId)  : null;
                const noteInput = noteInputId ? document.getElementById(noteInputId) : null;
                if (badge) {
                    const status = getBadgeStyle(selectedValue);
                    badge.textContent = status.text;
                    badge.classList.remove("ok", "warn", "neutral", "mod", "bad");
                    badge.classList.add(status.cls);
                }
                const requiresNote = selectedValue === "Needs Improvement";
                if (noteWrap) {
                    if (isReadOnlyMode) {
                        const hasContent = noteInput && noteInput.value && noteInput.value.trim().length > 0;
                        noteWrap.style.display = hasContent ? "grid" : "none";
                    } else {
                        noteWrap.style.display = requiresNote ? "grid" : "none";
                    }
                }
                if (noteInput) {
                    noteInput.required = !isReadOnlyMode && requiresNote;
                    if (!requiresNote && !isReadOnlyMode) noteInput.value = "";
                }
            }

            selects.forEach((s) => {
                s.addEventListener("change", () => updateAssessment(s));
                updateAssessment(s);
            });
        })();
    </script>
</body>
</html>
