@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Research & Global Rankings";
    ViewData["ActiveNav"] = "requests";
    var requestId = ViewBag.RequestId ?? Model?.Id ?? 0;
    var inst = ViewBag.InstitutionName ?? Model?.UniversityName ?? "—";
    var rankings = Model?.GlobalRankings ?? new DTOs.GlobalRankingsDto();
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAcademicInfo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsRankings.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>Recognition Member</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 6 of 7 — Research & Global Rankings.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>6 / 7</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Research & Global Rankings</h2>
                </div>

                @if (TempData["RankingsSaved"] != null)
                {
                    <div class="adm-saved">@TempData["RankingsSaved"]</div>
                }

                @if (TempData["RankingsError"] != null)
                {
                    <div class="adm-error">@TempData["RankingsError"]</div>
                }

                <form asp-controller="Home" asp-action="SaveGlobalRankings" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@requestId" />

                    <div class="rank-stack">
                        <div class="rd-field">
                            <label>Academic Ranking of World Universities (ARWU)</label>
                            <div class="rank-input">
                                <input type="text" name="arwuValue" value="@rankings.ArwuValue" placeholder="Enter ranking" data-rank-input="arwu" />
                                <label class="na-toggle"><input type="checkbox" name="arwuIsNa" value="true" @(rankings.ArwuIsNa ? "checked" : null) data-rank-na="arwu" /> N/A</label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>QS - World University Ranking</label>
                            <div class="rank-input">
                                <input type="text" name="qsValue" value="@rankings.QsValue" placeholder="Enter ranking" data-rank-input="qs" />
                                <label class="na-toggle"><input type="checkbox" name="qsIsNa" value="true" @(rankings.QsIsNa ? "checked" : null) data-rank-na="qs" /> N/A</label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>THE - World University Ranking (Times)</label>
                            <div class="rank-input">
                                <input type="text" name="theValue" value="@rankings.TheValue" placeholder="Enter ranking" data-rank-input="the" />
                                <label class="na-toggle"><input type="checkbox" name="theIsNa" value="true" @(rankings.TheIsNa ? "checked" : null) data-rank-na="the" /> N/A</label>
                            </div>
                        </div>

                        <div class="rd-field">
                            <label>Scopus Ranking</label>
                            <div class="rank-input">
                                <input type="text" name="scopusValue" value="@rankings.ScopusValue" placeholder="Enter ranking" data-rank-input="scopus" />
                                <label class="na-toggle"><input type="checkbox" name="scopusIsNa" value="true" @(rankings.ScopusIsNa ? "checked" : null) data-rank-na="scopus" /> N/A</label>
                            </div>
                        </div>
                    </div>

                    <div style="display:flex; justify-content:flex-end; margin-top:14px;">
                        <button class="rm-btn rm-btn-primary" type="submit"><i class="bi bi-save"></i> Save</button>
                    </div>
                </form>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsAccreditationBodies", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsInfrastructure", "Home", new { id = requestId })">Next</a>
                </div>
            </section>
        </main>
    </div>

    <script>
        (function () {
            const pairs = ["arwu", "qs", "the", "scopus"];

            function syncPair(key) {
                const input = document.querySelector(`[data-rank-input="${key}"]`);
                const check = document.querySelector(`[data-rank-na="${key}"]`);
                if (!input || !check) return;

                input.disabled = check.checked;
                if (check.checked) {
                    input.value = "";
                }
            }

            pairs.forEach((key) => {
                const check = document.querySelector(`[data-rank-na="${key}"]`);
                if (!check) return;

                check.addEventListener("change", function () {
                    syncPair(key);
                });

                syncPair(key);
            });
        })();
    </script>
</body>
</html>