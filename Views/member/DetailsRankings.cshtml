@{
    Layout = null;
    ViewData["Title"] = "Request Details - Rankings & Scopus";
    var requestId = ViewBag.RequestId ?? 0;
    var inst = ViewBag.InstitutionName ?? "—";
}
<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsRankings.css" asp-append-version="true" />
</head>
<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div><div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand"><img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" /></div>
                <div class="rm-user">
                    <div class="rm-userpill"><i class="bi bi-person-circle"></i><span>Welcome, <b>Dr. Khaled Ahmed</b></span></div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")"><i class="bi bi-box-arrow-right"></i> Logout</a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        <aside class="rm-sidebar">
            <div class="rm-side-title">Navigation</div><nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")"><i class="bi bi-grid-1x2"></i><span>Dashboard</span></a>
                <a class="rm-navitem active" href="@Url.Action("ElectronicHome", "Home")"><i class="bi bi-send-check"></i><span>My Assigned Home</span></a>
                <a class="rm-navitem" href="@Url.Action("Archive", "Home")"><i class="bi bi-inboxes"></i><span>Home Archive</span></a>
                <a class="rm-navitem danger" href="@Url.Action("Logout", "Home")"><i class="bi bi-power"></i><span>Sign Out</span></a>
            </nav>
        </aside>

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 3 of 5 — Rankings & Scopus.</p>
                </div>
                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>3 / 5</b></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>World Rankings</h2>
                    <p>ARWU / THE / QS / Others.</p>
                </div>

                <div class="rd-grid4">
                    <div class="rd-field"><label>ARWU Rank</label><input type="text" placeholder="e.g. 501-600" /></div>
                    <div class="rd-field"><label>THE Rank</label><input type="text" placeholder="e.g. 801-1000" /></div>
                    <div class="rd-field"><label>QS Rank</label><input type="text" placeholder="e.g. 1200+" /></div>
                    <div class="rd-field"><label>Other</label><input type="text" placeholder="Optional" /></div>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Scopus Publications</h2>
                    <p>Research output between selected years.</p>
                </div>

                <div class="rd-grid3">
                    <div class="rd-field"><label>From Year</label><input type="number" value="2020" /></div>
                    <div class="rd-field"><label>To Year</label><input type="number" value="2025" /></div>
                    <div class="rd-field"><label>Total Publications</label><input type="number" value="0" /></div>
                </div>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsStatistics", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsInfrastructure", "Home", new { id = requestId })">Next</a>
                    <button class="rm-btn rm-btn-primary" type="button"><i class="bi bi-save"></i> Save</button>
                </div>
            </section>
        </main>
    </div>
</body>
</html>