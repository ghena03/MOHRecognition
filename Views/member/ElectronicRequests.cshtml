@model IReadOnlyList<MOHRecognition.Services.RecognitionRequestRecord>

@{
    Layout = null;
    ViewData["Title"] = "My Assigned Requests";
    var currentMember = ViewBag.CurrentRecognitionMember as string ?? "Recognition Member";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/ElectronicRequests.css" asp-append-version="true" />
</head>

<body class="rm-page">

    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>

                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>@currentMember</b></span>
                    </div>

                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">

        <aside class="rm-sidebar">
            <div class="rm-side-label">Workspace</div>

            <nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")">
                    <i class="bi bi-grid-1x2-fill"></i>
                    <span>Review Dashboard</span>
                </a>

                <a class="rm-navitem active" href="@Url.Action("ElectronicRequests", "Home")">
                    <i class="bi bi-journal-check"></i>
                    <span>My Assigned Requests</span>
                </a>

                <a class="rm-navitem" href="@Url.Action("Archive", "Home")">
                    <i class="bi bi-inboxes"></i>
                    <span>Requests Archive</span>
                </a>

                <a class="rm-navitem" href="@Url.Action("ResetPassword", "Home", new { role = "recognition" })">
                    <i class="bi bi-person-gear"></i>
                    <span>Profile &amp; Security</span>
                </a>

                <a class="rm-navitem" href="@Url.Action("RecognitionMemberMeetings", "Home")">
                    <i class="bi bi-calendar2-week"></i>
                    <span>Meetings</span>
                </a>

                <div class="rm-nav-divider"></div>

                <a class="rm-navitem rm-navitem-danger" href="@Url.Action("Logout", "Home")">
                    <i class="bi bi-power"></i>
                    <span>Sign Out</span>
                </a>
            </nav>
        </aside>

        <main class="rm-main">

            <section class="rm-card er-hero">
                <div class="er-hero-top">
                    <div class="er-hero-left">
                        <h1>My Assigned Requests</h1>
                        <p>Only requests assigned to <b>@currentMember</b> appear here.</p>
                    </div>

                    <div class="er-stats">
                        <div class="er-stat">
                            <span>Assigned</span>
                            <b>@Model.Count</b>
                        </div>
                        <div class="er-stat">
                            <span>Pending</span>
                            <b>@Model.Count(x => x.Status == "Pending" || x.Status == "Assigned")</b>
                        </div>
                        <div class="er-stat">
                            <span>Missing Docs</span>
                            <b>@Model.Count(x => x.Status == "Missing Docs")</b>
                        </div>
                    </div>
                </div>

                <div class="er-filters">
                    <div class="er-field grow">
                        <label for="q">Search</label>
                        <div class="er-input">
                            <i class="bi bi-search"></i>
                            <input id="q" type="text" placeholder="Reference, university..." />
                        </div>
                    </div>

                    <div class="er-field">
                        <label for="status">Status</label>
                        <select id="status">
                            <option value="">All</option>
                            <option>Assigned</option>
                            <option>Pending</option>
                            <option>Under Review</option>
                            <option>Missing Docs</option>
                        </select>
                    </div>

                    <div class="er-actions">
                        <button class="rm-btn rm-btn-light" type="button" onclick="applyFilters()">
                            <i class="bi bi-funnel"></i> Filter
                        </button>
                        <button class="rm-btn rm-btn-light" type="button" onclick="clearFilters()">
                            <i class="bi bi-x-circle"></i> Clear
                        </button>
                    </div>
                </div>
            </section>

            <section class="rm-card">
                <div class="rm-card-hd row">
                    <div>
                        <h2>Assigned Requests</h2>
                        <p>These are the requests already assigned to you by admin.</p>
                    </div>
                </div>

                <div class="rm-tablewrap">
                    <table class="rm-table">
                        <thead>
                            <tr>
                                <th>Reference</th>
                                <th>University</th>
                                <th>Country</th>
                                <th>Status</th>
                                <th>Submitted</th>
                                <th class="right">Action</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td><b>@item.ReferenceNumber</b></td>
                                        <td>@item.UniversityName</td>
                                        <td>@item.Country</td>
                                        <td><span class="badge badge-pending">@item.Status</span></td>
                                        <td>@item.SubmittedAt.ToString("yyyy-MM-dd")</td>
                                        <td class="right">
                                            <a class="rm-mini" href="@Url.Action("DetailsBasicInfo", "Home", new { id = item.Id })">Open</a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" style="text-align:center; padding:24px;">
                                        No assigned requests yet.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="er-footer">
                    <button class="rm-btn rm-btn-light" type="button" disabled>
                        <i class="bi bi-chevron-left"></i> Prev
                    </button>
                    <div class="er-pages">Page <b>1</b> of <b>1</b></div>
                    <button class="rm-btn rm-btn-light" type="button" disabled>
                        Next <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </section>

        </main>
    </div>

    <script src="~/js/member/ElectronicRequests.js" asp-append-version="true"></script>
</body>
</html>
