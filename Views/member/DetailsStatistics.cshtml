@{
    Layout = null;
    ViewData["Title"] = "Request Details - Statistics";
    var requestId = ViewBag.RequestId ?? 0;
    var inst = ViewBag.InstitutionName ?? "—";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsStatistics.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>
                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>Dr. Khaled Ahmed</b></span>
                    </div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        <aside class="rm-sidebar">
            <div class="rm-side-title">Navigation</div>
            <nav class="rm-nav">
                <a class="rm-navitem" href="@Url.Action("RecognitionMemberDashboard", "Home")">
                    <i class="bi bi-grid-1x2"></i><span>Dashboard</span>
                </a>
                <a class="rm-navitem active" href="@Url.Action("ElectronicHome", "Home")">
                    <i class="bi bi-send-check"></i><span>My Assigned Home</span>
                </a>
                <a class="rm-navitem" href="@Url.Action("Archive", "Home")">
                    <i class="bi bi-inboxes"></i><span>Home Archive</span>
                </a>
                <a class="rm-navitem danger" href="@Url.Action("Logout", "Home")">
                    <i class="bi bi-power"></i><span>Sign Out</span>
                </a>
            </nav>
        </aside>

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 2 of 5 — Students & Faculty.</p>
                </div>

                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>2 / 5</b></div>
                </div>
            </section>

            <!-- ✅ Paste your existing sections from Details.cshtml (Students/Faculty/Ranks/Ratios/Colleges/Accreditation) -->
            @* Students *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Students</h2>
                    <p>Student counts by category.</p>
                </div>

                <div class="rd-grid4">
                    <div class="rd-field"><label>Total Students</label><input type="number" value="0" min="0" /></div>
                    <div class="rd-field"><label>Local Students</label><input type="number" value="0" min="0" /></div>
                    <div class="rd-field"><label>Jordanian Students</label><input type="number" value="0" min="0" /></div>
                    <div class="rd-field"><label>International Students</label><input type="number" value="0" min="0" /></div>
                </div>
            </section>

            @* Faculty *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Faculty Members</h2>
                    <p>Total, full-time, and part-time faculty.</p>
                </div>

                <div class="rd-grid3">
                    <div class="rd-field"><label>Total Faculty Members</label><input type="number" value="386" min="0" /></div>
                    <div class="rd-field"><label>Full-time Faculty</label><input type="number" value="386" min="0" /></div>
                    <div class="rd-field"><label>Part-time Faculty</label><input type="number" value="0" min="0" /></div>
                </div>
            </section>

            @* Academic ranks *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Academic Ranks</h2>
                    <p>Faculty count by rank.</p>
                </div>

                <div class="rd-grid5">
                    <div class="rd-field"><label>Professor</label><input type="number" value="20" min="0" /></div>
                    <div class="rd-field"><label>Associate Professor</label><input type="number" value="66" min="0" /></div>
                    <div class="rd-field"><label>Assistant Professor</label><input type="number" value="300" min="0" /></div>
                    <div class="rd-field"><label>Lecturer</label><input type="number" value="70" min="0" /></div>
                    <div class="rd-field"><label>Other</label><input type="number" value="44" min="0" /></div>
                </div>
            </section>

            @* Ratios *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Ratios</h2>
                    <p>Key ratios used for recognition.</p>
                </div>

                <div class="rd-grid4">
                    <div class="rd-field"><label>PhD Holders Ratio (%)</label><input type="number" value="30" min="0" max="100" /></div>
                    <div class="rd-field"><label>Professors Ratio (%)</label><input type="number" value="10" min="0" max="100" /></div>
                    <div class="rd-field"><label>Associate Professors Ratio (%)</label><input type="number" value="10" min="0" max="100" /></div>
                    <div class="rd-field"><label>Students : Faculty</label><input type="text" value="1:25" /></div>
                </div>
            </section>

            @* Colleges + Accreditation (same as your Details) *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Colleges in the Institution</h2>
                    <p>Add and manage colleges.</p>
                </div>

                <div class="rd-inline">
                    <div class="rd-field grow"><label>College Name</label><input type="text" placeholder="Enter college name..." /></div>
                    <button class="rm-btn rm-btn-light" type="button"><i class="bi bi-plus-circle"></i> Add College</button>
                </div>

                <div class="rd-tablewrap">
                    <table class="rd-table">
                        <thead>
                            <tr><th style="width:90px;">#</th><th>College Name</th><th class="right" style="width:140px;">Action</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Faculty of Computer & IT</td><td class="right"><button class="rd-del" type="button">Delete</button></td></tr>
                            <tr><td>2</td><td>Faculty of Administrative Sciences</td><td class="right"><button class="rd-del" type="button">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Accreditation Bodies</h2>
                    <p>Accreditation bodies recognized by the institution.</p>
                </div>

                <div class="rd-inline">
                    <div class="rd-field grow"><label>Body Name</label><input type="text" placeholder="Enter body name..." /></div>
                    <div class="rd-field"><label>Type</label><select><option>Local</option><option>International</option></select></div>
                    <button class="rm-btn rm-btn-light" type="button"><i class="bi bi-plus-circle"></i> Add Body</button>
                </div>

                <div class="rd-tablewrap">
                    <table class="rd-table">
                        <thead>
                            <tr><th style="width:90px;">#</th><th>Body Name</th><th style="width:160px;">Type</th><th class="right" style="width:140px;">Action</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td>Ministry of Higher Education and Scientific Research</td><td>Local</td><td class="right"><button class="rd-del" type="button">Delete</button></td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsBasicInfo", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsRankings", "Home", new { id = requestId })">Next</a>
                    <button class="rm-btn rm-btn-primary" type="button"><i class="bi bi-save"></i> Save</button>
                </div>
            </section>
        </main>
    </div>
</body>
</html>