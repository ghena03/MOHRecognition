@model MOHRecognition.Services.RecognitionRequestRecord
@{
    Layout = null;
    ViewData["Title"] = "Request Details - Students Numbers";
    ViewData["ActiveNav"] = "requests";
    var requestId = ViewBag.RequestId ?? Model?.Id ?? 0;
    var inst = ViewBag.InstitutionName ?? Model?.UniversityName ?? "—";
    var A = Model?.AcademicInfo ?? new DTOs.AcademicInfoDto();
    var professorFullTime = A.StaffProfessorFullTimeCount ?? 0;
    var associateProfessorFullTime = A.StaffAssociateProfessorFullTimeCount ?? 0;
    var assistantProfessorFullTime = A.StaffAssistantProfessorFullTimeCount ?? 0;
    var teacherFullTime = A.StaffTeacherFullTimeCount ?? 0;
    var researcherFullTime = A.StaffResearcherFullTimeCount ?? 0;
    var assistantTeacherFullTime = A.StaffAssistantTeacherFullTimeCount ?? 0;
    var othersFullTime = A.StaffOthersFullTimeCount ?? 0;
    var practitionerPscFullTime = A.StaffPractitionerPscFullTimeCount ?? 0;
    var practitionerMscFullTime = A.StaffPractitionerMscFullTimeCount ?? 0;
    var allFullTimeTeachingStaff =
        professorFullTime + associateProfessorFullTime + assistantProfessorFullTime +
        researcherFullTime + teacherFullTime + assistantTeacherFullTime + othersFullTime + practitionerPscFullTime + practitionerMscFullTime;
    var academicRankTotal =
        (A.StaffProfessorFullTimeCount ?? 0) + (A.StaffProfessorPartTimeCount ?? 0) +
        (A.StaffAssociateProfessorFullTimeCount ?? 0) + (A.StaffAssociateProfessorPartTimeCount ?? 0) +
        (A.StaffAssistantProfessorFullTimeCount ?? 0) + (A.StaffAssistantProfessorPartTimeCount ?? 0) +
        (A.StaffResearcherFullTimeCount ?? 0) + (A.StaffResearcherPartTimeCount ?? 0) +
        (A.StaffTeacherFullTimeCount ?? 0) + (A.StaffTeacherPartTimeCount ?? 0) +
        (A.StaffAssistantTeacherFullTimeCount ?? 0) + (A.StaffAssistantTeacherPartTimeCount ?? 0) +
        (A.StaffOthersFullTimeCount ?? 0) + (A.StaffOthersPartTimeCount ?? 0) +
        (A.StaffPractitionerPscFullTimeCount ?? 0) + (A.StaffPractitionerPscPartTimeCount ?? 0) +
        (A.StaffPractitionerMscFullTimeCount ?? 0) + (A.StaffPractitionerMscPartTimeCount ?? 0);

    var totalPhdHolders = professorFullTime + associateProfessorFullTime + assistantProfessorFullTime + teacherFullTime;
    var fullTimeFacultyForDoctorate =
        professorFullTime + associateProfessorFullTime + assistantProfessorFullTime + teacherFullTime +
        assistantTeacherFullTime + othersFullTime + researcherFullTime;
    var doctorateHoldersPercentage = fullTimeFacultyForDoctorate > 0
        ? Math.Floor(((decimal)totalPhdHolders * 100m) / fullTimeFacultyForDoctorate)
        : 0m;
    var doctorateStatus = fullTimeFacultyForDoctorate > 0
        ? (doctorateHoldersPercentage >= 50m ? "green" : "red")
        : "";
    var allowedMscSupport = 0.20m * totalPhdHolders;
    var actualMscSupport = assistantTeacherFullTime + othersFullTime;
    var mscSupportUsed = Math.Min(allowedMscSupport, actualMscSupport);
    var totalFacultyForRatio = totalPhdHolders + (0.10m * totalPhdHolders) + mscSupportUsed;
    var totalStudents = A.TotalStudentPopulation ?? 0;
    var studentsToFacultyRatio = totalFacultyForRatio > 0
        ? Math.Ceiling((decimal)totalStudents / totalFacultyForRatio)
        : 0m;
    var labAndResearchSum = researcherFullTime;
    var assistantTeacherCount = assistantTeacherFullTime;
    var combinedAcademicStaff = academicRankTotal;

    var totalFaculty = allFullTimeTeachingStaff;
    var seniorFaculty = professorFullTime + associateProfessorFullTime;
    var appliedDoctorateAddition = (0.10m * totalPhdHolders) + mscSupportUsed;

    var difference = totalFacultyForRatio - totalStudents;
    var studentWithinCapacity = totalStudents <= totalFacultyForRatio;

    var facultyDataValid = totalFaculty >= 0 && totalPhdHolders >= 0 && totalFacultyForRatio >= 0;
    var facultySufficiencyAcceptable = facultyDataValid && totalFaculty > 0 && totalFacultyForRatio > 0;

    var rankLevel = 0; // 0=ok,1=warn,2=fail
    if (seniorFaculty <= 0) rankLevel = 2;
    else if (totalFaculty > 0 && seniorFaculty < Math.Max(1, totalFaculty / 10)) rankLevel = 1;

    var doctorateContributionValid = totalPhdHolders > 0 && appliedDoctorateAddition > 0;

    var anyStudySystem = A.SystemYearlyProgram || A.SystemSemesterProgram || A.SystemCreditHours || A.SystemECTS;
    var appliedRuleName = "PhD + MSc Support Capacity Rule";
    var appliedFormulaType = "C = D + 0.10D + min(0.20D, MSc Support)";
    var appliedRuleCorrect = anyStudySystem && totalFacultyForRatio >= 0;

    var doctorateTenPercent = 0.10m * totalPhdHolders;
    var teacherLimitedPart = mscSupportUsed;

    var studentLevel = studentWithinCapacity ? 0 : 2;
    var facultyLevel = (facultyDataValid && facultySufficiencyAcceptable) ? 0 : 2;
    var doctorateLevel = doctorateContributionValid ? 0 : 2;
    var ruleLevel = appliedRuleCorrect ? 0 : 2;
    var overallLevel = new[] { studentLevel, facultyLevel, rankLevel, doctorateLevel, ruleLevel }.Max();

    var ratioValue = A.StudentsToFacultyRatio ?? 0m;

    var selectedCollegeCategories = (A.CollegeCategoriesCsv ?? "")
        .Split(';', StringSplitOptions.RemoveEmptyEntries)
        .Select(x => x.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .ToList();

    var categoryRatioMap = new Dictionary<string, decimal>(StringComparer.OrdinalIgnoreCase)
    {
        ["Scientific"] = 20m,
        ["Humanities"] = 35m,
        ["Medical"] = 25m,
        ["Applied"] = 20m
    };

    var selectedRatios = selectedCollegeCategories
        .Where(k => categoryRatioMap.ContainsKey(k))
        .Select(k => categoryRatioMap[k])
        .ToList();

    var avg = selectedRatios.Any() ? selectedRatios.Average() : 0m;
    var orangeLimit = avg + (avg * 0.25m);
    var numericRatio = ratioValue;

    var ratioStatus = "";
    if (numericRatio >= 1m && avg > 0m)
    {
        if (numericRatio <= avg) ratioStatus = "green";
        else if (numericRatio <= orangeLimit) ratioStatus = "orange";
        else ratioStatus = "red";
    }

    var rankRows = new[]
    {
        new
        {
            Key = "Professor",
            Title = "Professor",
            FullTimeCount = A.StaffProfessorFullTimeCount ?? 0,
            PartTimeCount = A.StaffProfessorPartTimeCount ?? 0,
            FullTimeFile = A.ProfessorFullTimeExcelFileName,
            PartTimeFile = A.ProfessorPartTimeExcelFileName
        },
        new
        {
            Key = "AssociateProfessor",
            Title = "Associate Professor",
            FullTimeCount = A.StaffAssociateProfessorFullTimeCount ?? 0,
            PartTimeCount = A.StaffAssociateProfessorPartTimeCount ?? 0,
            FullTimeFile = A.AssociateProfessorFullTimeExcelFileName,
            PartTimeFile = A.AssociateProfessorPartTimeExcelFileName
        },
        new
        {
            Key = "AssistantProfessor",
            Title = "Assistant Professor",
            FullTimeCount = A.StaffAssistantProfessorFullTimeCount ?? 0,
            PartTimeCount = A.StaffAssistantProfessorPartTimeCount ?? 0,
            FullTimeFile = A.AssistantProfessorFullTimeExcelFileName,
            PartTimeFile = A.AssistantProfessorPartTimeExcelFileName
        },
        new
        {
            Key = "Teacher",
            Title = "Lecturer (PhD Holders)",
            FullTimeCount = A.StaffTeacherFullTimeCount ?? 0,
            PartTimeCount = A.StaffTeacherPartTimeCount ?? 0,
            FullTimeFile = A.TeacherFullTimeExcelFileName,
            PartTimeFile = A.TeacherPartTimeExcelFileName
        },
        new
        {
            Key = "AssistantTeacher",
            Title = "Lecturer (MSc Holders)",
            FullTimeCount = A.StaffAssistantTeacherFullTimeCount ?? 0,
            PartTimeCount = A.StaffAssistantTeacherPartTimeCount ?? 0,
            FullTimeFile = A.AssistantTeacherFullTimeExcelFileName,
            PartTimeFile = A.AssistantTeacherPartTimeExcelFileName
        },
        new
        {
            Key = "Others",
            Title = "Assistant Lecturer (MSc Holders)",
            FullTimeCount = A.StaffOthersFullTimeCount ?? 0,
            PartTimeCount = A.StaffOthersPartTimeCount ?? 0,
            FullTimeFile = A.OthersFullTimeExcelFileName,
            PartTimeFile = A.OthersPartTimeExcelFileName
        },
        new
        {
            Key = "Researcher",
            Title = "Assistant Lecturer (BSc Holders)",
            FullTimeCount = A.StaffResearcherFullTimeCount ?? 0,
            PartTimeCount = A.StaffResearcherPartTimeCount ?? 0,
            FullTimeFile = A.ResearcherFullTimeExcelFileName,
            PartTimeFile = A.ResearcherPartTimeExcelFileName
        },
        new
        {
            Key = "PractitionerMsc",
            Title = "Practitioner (MSc Holders)",
            FullTimeCount = A.StaffPractitionerMscFullTimeCount ?? 0,
            PartTimeCount = A.StaffPractitionerMscPartTimeCount ?? 0,
            FullTimeFile = A.PractitionerMscFullTimeExcelFileName,
            PartTimeFile = A.PractitionerMscPartTimeExcelFileName
        },
        new
        {
            Key = "PractitionerPsc",
            Title = "Practitioner (BSc Holders)",
            FullTimeCount = A.StaffPractitionerPscFullTimeCount ?? 0,
            PartTimeCount = A.StaffPractitionerPscPartTimeCount ?? 0,
            FullTimeFile = A.PractitionerPscFullTimeExcelFileName,
            PartTimeFile = A.PractitionerPscPartTimeExcelFileName
        }
    };

    string LevelText(int level) => level == 2 ? "Not Compliant" : level == 1 ? "Needs Review" : "Complies";
    string LevelClass(int level) => level == 2 ? "fail" : level == 1 ? "warn" : "ok";
}

<!doctype html>
<html lang="en" dir="ltr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link rel="stylesheet" href="~/css/member/RecognitionMemberDashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsStatistics.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/member/DetailsAcademicInfo.css" asp-append-version="true" />
</head>

<body class="rm-page">
    <header class="rm-header">
        <div class="rm-brandbar"></div>
        <div class="rm-top">
            <div class="rm-top-inner">
                <div class="rm-brand">
                    <img class="rm-logo" src="@Url.Content("~/images/mohelogo.png")" alt="MOHE Logo" />
                </div>
                <div class="rm-user">
                    <div class="rm-userpill">
                        <i class="bi bi-person-circle"></i>
                        <span>Welcome, <b>Dr. Khaled Ahmed</b></span>
                    </div>
                    <a class="rm-btn rm-btn-light" href="@Url.Action("Logout", "Home")">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                </div>
            </div>
        </div>
    </header>

    <div class="rm-shell">
        @await Html.PartialAsync("_MemberSidebar")

        <main class="rm-main">
            <section class="rm-card rd-head">
                <div>
                    <h1>Request Details</h1>
                    <p class="rd-inst">Institution: <b>@inst</b></p>
                    <p>Step 2 of 7 — Students Numbers.</p>
                </div>

                <div class="rd-meta">
                    <div class="meta-pill"><span>Request ID</span><b>#@requestId</b></div>
                    <div class="meta-pill"><span>Step</span><b>2 / 7</b></div>
                </div>
            </section>

            @* Students numbers *@
            <section id="sec-doctors-page" class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Students Numbers</h2>
                    <p>Student numbers by category.</p>
                </div>

                <div class="rd-grid4">
                    <div class="rd-field"><label>Total Students</label><input type="number" value="@(A.TotalStudentPopulation?.ToString() ?? "0")" min="0" readonly /></div>
                    <div class="rd-field"><label>Local Students</label><input type="number" value="@(A.LocalStudentPopulation?.ToString() ?? "0")" min="0" readonly /></div>
                    <div class="rd-field"><label>Jordanian Students</label><input type="number" value="@(A.JordanianStudentPopulation?.ToString() ?? "0")" min="0" readonly /></div>
                    <div class="rd-field"><label>International Students</label><input type="number" value="@(A.ForeignStudentPopulation?.ToString() ?? "0")" min="0" readonly /></div>
                </div>
            </section>

            @* Academic ranks *@
            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Academic Ranks</h2>
                    <p>Faculty count by rank with visible Excel evidence files.</p>
                </div>

                <div class="rank-overview-grid">
                    <div class="rank-overview-item">
                        <span>Total Academic Staff</span>
                        <b>@combinedAcademicStaff</b>
                    </div>
                    <div class="rank-overview-item">
                        <span>Full-Time Faculty</span>
                        <b>@(A.FullTimeFacultyCount ?? 0)</b>
                    </div>
                    <div class="rank-overview-item">
                        <span>Part-Time Faculty</span>
                        <b>@(A.PartTimeFacultyCount ?? 0)</b>
                    </div>
                </div>

                <div class="rank-review-grid">
                    @foreach (var rank in rankRows)
                    {
                        <article class="rank-review-card">
                            <header>
                                <h3>@rank.Title</h3>
                                <span class="rank-total-pill">Total: @(rank.FullTimeCount + rank.PartTimeCount)</span>
                            </header>

                            <div class="rank-review-split">
                                <div class="rank-review-block">
                                    <label>Full-Time</label>
                                    <input type="number" value="@rank.FullTimeCount" readonly />
                                    @if (!string.IsNullOrWhiteSpace(rank.FullTimeFile))
                                    {
                                        <div class="rank-file-actions">
                                            <div class="rank-file-pill"><i class="bi bi-file-earmark-excel"></i> @rank.FullTimeFile</div>
                                            <div class="rank-file-links">
                                                <a class="rank-file-download"
                                                   href="@Url.Action("AcademicRankFilePreview", "Home", new { id = requestId, rankKey = rank.Key, employmentType = "fulltime" })"
                                                   target="_blank"
                                                   rel="noopener">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                                <a class="rank-file-download"
                                                   href="@Url.Action("DownloadAcademicRankStaffFile", "Home", new { id = requestId, rankKey = rank.Key, employmentType = "fulltime" })"
                                                   target="_blank"
                                                   rel="noopener">
                                                    <i class="bi bi-download"></i> Download
                                                </a>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rank-file-empty">No file uploaded</div>
                                    }
                                </div>

                                <div class="rank-review-block">
                                    <label>Part-Time</label>
                                    <input type="number" value="@rank.PartTimeCount" readonly />
                                    @if (!string.IsNullOrWhiteSpace(rank.PartTimeFile))
                                    {
                                        <div class="rank-file-actions">
                                            <div class="rank-file-pill"><i class="bi bi-file-earmark-excel"></i> @rank.PartTimeFile</div>
                                            <div class="rank-file-links">
                                                <a class="rank-file-download"
                                                   href="@Url.Action("AcademicRankFilePreview", "Home", new { id = requestId, rankKey = rank.Key, employmentType = "parttime" })"
                                                   target="_blank"
                                                   rel="noopener">
                                                    <i class="bi bi-eye"></i> View
                                                </a>
                                                <a class="rank-file-download"
                                                   href="@Url.Action("DownloadAcademicRankStaffFile", "Home", new { id = requestId, rankKey = rank.Key, employmentType = "parttime" })"
                                                   target="_blank"
                                                   rel="noopener">
                                                    <i class="bi bi-download"></i> Download
                                                </a>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="rank-file-empty">No file uploaded</div>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>
            </section>

            <section class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Ratios &amp; Percentages</h2>
                    <p>Auto-calculated from submitted academic staff and student data.</p>
                </div>

                <!-- ── Two metric cards ──────────────────────────────── -->
                <div class="rp-metrics-grid">

                    <!-- Doctorate Holders (%) -->
                    <div class="rp-metric-card rp-metric-card--@doctorateStatus">
                        <div class="rp-metric-hd">
                            <div class="rp-metric-icon"><i class="bi bi-mortarboard-fill"></i></div>
                            <div>
                                <div class="rp-metric-title">Doctorate Holders <button class="eq-info-btn" onclick="openEqModal('modal-doctorate')" title="How is this calculated?"><i class="bi bi-info-circle-fill"></i></button></div>
                                <div class="rp-metric-sub">Full-time faculty holding a PhD or equivalent</div>
                            </div>
                        </div>

                        <div class="rp-metric-value-row">
                            <span class="rp-metric-value">@doctorateHoldersPercentage.ToString("0")%</span>
                            @{
                                string docBadgeClass = doctorateStatus == "green" ? "rp-badge--green"
                                                     : doctorateStatus == "red"   ? "rp-badge--red" : "rp-badge--na";
                                string docBadgeText  = doctorateStatus == "green" ? "Acceptable"
                                                     : doctorateStatus == "red"   ? "Below Threshold" : "No Data";
                            }
                            <span class="rp-status-badge @docBadgeClass">@docBadgeText</span>
                        </div>

                        @if (fullTimeFacultyForDoctorate > 0)
                        {
                            var progWidth = Math.Min((double)doctorateHoldersPercentage, 100);
                            <div class="rp-progress-wrap">
                                <div class="rp-progress-track">
                                    <div class="rp-progress-fill rp-fill--@doctorateStatus" style="width:@progWidth.ToString("0", System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                    <div class="rp-progress-marker" title="Min. 50%"></div>
                                </div>
                                <div class="rp-progress-labels">
                                    <span>0%</span><span>Min: 50%</span><span>100%</span>
                                </div>
                            </div>
                        }

                    </div>

                    <!-- Students to Faculty Ratio -->
                    <div class="rp-metric-card rp-metric-card--@ratioStatus">
                        <div class="rp-metric-hd">
                            <div class="rp-metric-icon"><i class="bi bi-people-fill"></i></div>
                            <div>
                                <div class="rp-metric-title">Doctor-to-Student Capacity Ratio <button class="eq-info-btn" onclick="openEqModal('modal-sfr')" title="This ratio shows how many students are supported by one weighted doctor capacity. It is calculated using full-time PhD holders, a 10% PhD capacity bonus, and capped MSc support."><i class="bi bi-info-circle-fill"></i></button></div>
                                <div class="rp-metric-sub">Student count relative to weighted doctor capacity</div>
                            </div>
                        </div>

                        <div class="rp-metric-value-row">
                            <span class="rp-metric-value">@(ratioValue > 0 ? $"1 : {ratioValue:0}" : "—")</span>
                            @{
                                string ratioBadgeClass = ratioStatus == "green"  ? "rp-badge--green"
                                                       : ratioStatus == "orange" ? "rp-badge--orange"
                                                       : ratioStatus == "red"    ? "rp-badge--red" : "rp-badge--na";
                                string ratioBadgeText  = ratioStatus == "green"  ? "Within Average"
                                                       : ratioStatus == "orange" ? "Within 25% Tolerance"
                                                       : ratioStatus == "red"    ? "Exceeds Tolerance" : "No Data";
                            }
                            <span class="rp-status-badge @ratioBadgeClass">@ratioBadgeText</span>
                        </div>

                        @if (avg > 0)
                        {
                            <div class="rp-benchmark">
                                <span class="rp-benchmark-lbl">Benchmark</span>
                                <span class="rp-benchmark-val">1 : @avg.ToString("0")</span>
                                <span class="rp-benchmark-sub">selected college average</span>
                            </div>
                        }

                    </div>

                    @{
                        var allProgCount  = (Model?.Programs ?? new System.Collections.Generic.List<DTOs.ProgramRowDto>())
                            .Count(p => string.Equals((p.DegreeAwarded ?? "").Trim(), "Bachelor", StringComparison.OrdinalIgnoreCase));
                        var avgPhDPerProg = allProgCount > 0
                            ? Math.Floor((double)totalPhdHolders / allProgCount)
                            : 0.0;
                        string dppStatus  = avgPhDPerProg >= 1.0 ? "green" : (avgPhDPerProg > 0 ? "orange" : "");
                    }
                    <!-- Avg PhD per Bachelor Program -->
                    <div class="rp-metric-card rp-metric-card--@dppStatus">
                        <div class="rp-metric-hd">
                            <div class="rp-metric-icon"><i class="bi bi-mortarboard-fill"></i></div>
                            <div>
                                <div class="rp-metric-title">PhD Doctors per Bachelor Program <button class="eq-info-btn" onclick="openEqModal('modal-dpp')" title="How is this calculated?"><i class="bi bi-info-circle-fill"></i></button></div>
                                <div class="rp-metric-sub">Average full-time PhD faculty per submitted Bachelor program</div>
                            </div>
                        </div>

                        <div class="rp-metric-value-row">
                            <span class="rp-metric-value">@avgPhDPerProg.ToString("0")</span>
                        </div>

                        <div class="rp-benchmark">
                            <span class="rp-benchmark-lbl">Total PhD Faculty</span>
                            <span class="rp-benchmark-val">@totalPhdHolders</span>
                            <span class="rp-benchmark-sub">÷ @allProgCount bachelor programs</span>
                        </div>
                    </div>

                </div>

                <!-- ── Legend ────────────────────────────────────────── -->
                <div class="rp-legend">
                    <div class="rp-legend-hd">Legend</div>
                    <div class="rp-legend-grid">
                        <div class="rp-legend-section">
                            <div class="rp-legend-title">Students to Faculty Ratio</div>
                            <div class="rp-legend-item"><span class="rd-dot green"></span>Within the selected college average</div>
                            <div class="rp-legend-item"><span class="rd-dot orange"></span>Above average but within 25% tolerance</div>
                            <div class="rp-legend-item"><span class="rd-dot red"></span>Exceeds the 25% tolerance</div>
                        </div>
                        <div class="rp-legend-section">
                            <div class="rp-legend-title">Doctorate Holders (%)</div>
                            <div class="rp-legend-item"><span class="rd-dot green"></span>50% or more of full-time faculty are doctorate holders</div>
                            <div class="rp-legend-item"><span class="rd-dot red"></span>Less than 50% of full-time faculty are doctorate holders</div>
                        </div>
                    </div>
                </div>

                <!-- ── Intake Capacity Notes ──────────────────────────── -->
                @if (!string.IsNullOrWhiteSpace(A.IntakeCapacityNotes))
                {
                    <div class="rp-notes-wrap">
                        <div class="rp-notes-label">Intake Capacity Notes</div>
                        <textarea rows="3" class="rd-note" readonly>@A.IntakeCapacityNotes</textarea>
                    </div>
                }

            </section>

            <section id="sec-colleges" class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Colleges</h2>
                    <p>Submitted colleges from the university.</p>
                </div>

                <div class="rd-tablewrap">
                    <table class="rd-table">
                        <thead>
                            <tr><th style="width:90px;">#</th><th>College Name</th><th>College Type</th><th>Number of Students</th></tr>
                        </thead>
                        <tbody>
                            @if (Model?.Faculties != null && Model.Faculties.Any())
                            {
                                for (var i = 0; i < Model.Faculties.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@Model.Faculties[i].FacultyName</td>
                                        <td>@(string.IsNullOrWhiteSpace(Model.Faculties[i].CollegeType) ? "—" : Model.Faculties[i].CollegeType)</td>
                                        <td>@(Model.Faculties[i].StudentsCount?.ToString() ?? "—")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" style="text-align:center;">No colleges were submitted.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            <section id="sec-programs" class="rm-card rd-card">
                <div class="rd-card-hd">
                    <h2>Programs</h2>
                    <p>Submitted programs from the university.</p>
                </div>

                <div class="rd-tablewrap">
                    <table class="rd-table">
                        <thead>
                            <tr>
                                <th style="width:90px;">#</th>
                                <th>College</th>
                                <th>Program</th>
                                <th>Degree Awarded</th>
                                <th>Number of Years</th>
                                <th>Educational System</th>
                                <th>Accreditation Date</th>
                                <th>Graduation date of last regiment</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model?.Programs != null && Model.Programs.Any())
                            {
                                for (var i = 0; i < Model.Programs.Count; i++)
                                {
                                    <tr>
                                        <td>@(i + 1)</td>
                                        <td>@Model.Programs[i].FacultyName</td>
                                        <td>@Model.Programs[i].Program</td>
                                        <td>@Model.Programs[i].DegreeAwarded</td>
                                        <td>@Model.Programs[i].NumberOfYears</td>
                                        <td>@Model.Programs[i].EducationalSystem</td>
                                        <td>@(Model.Programs[i].AccreditationDate?.ToString("dd/MM/yyyy") ?? "")</td>
                                        <td>@(Model.Programs[i].GraduationDateOfLastRegiment?.ToString("dd/MM/yyyy") ?? "")</td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="8" style="text-align:center;">No programs were submitted.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>


            <section class="rm-card rd-actions">
                <div class="rd-actions-left">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsBasicInfo", "Home", new { id = requestId })">Previous</a>
                </div>
                <div class="rd-actions-right">
                    <a class="rm-btn rm-btn-light" href="@Url.Action("DetailsAdmissionDuration", "Home", new { id = requestId })">Next</a>
                </div>
            </section>
        </main>
    </div>
<!-- ── Equation Modals ─────────────────────────────────────────────────── -->
<div id="eq-modal-overlay" class="eq-modal-overlay" onclick="closeEqModalIfOverlay(event)">

    <!-- Modal: Doctorate Holders % -->
    <div id="modal-doctorate" class="eq-modal" role="dialog" aria-modal="true">
        <button class="eq-modal-close" onclick="closeEqModal()" aria-label="Close">✕</button>
        <div class="eq-modal-icon">🎓</div>
        <div class="eq-modal-title">Doctorate Holders Percentage</div>
        <div class="eq-modal-subtitle">How is the percentage of PhD-holding faculty calculated, and what does it mean?</div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 1 — Identify PhD Holders</div>
            <div class="eq-step-body">
                Count all <b>full-time</b> faculty members who hold a doctorate-level degree. The following ranks qualify:
                <ul class="eq-list">
                    <li><b>Professor</b> (Full-Time)</li>
                    <li><b>Associate Professor</b> (Full-Time)</li>
                    <li><b>Assistant Professor</b> (Full-Time)</li>
                    <li><b>Lecturer with PhD</b> (Full-Time)</li>
                </ul>
                <div class="eq-step-note">⚠ MSc Lecturers, Researchers, Assistant Teachers, Practitioners, and Others do <em>not</em> count as PhD holders for this metric.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 2 — Count All Full-Time Teaching Staff</div>
            <div class="eq-step-body">
                The denominator includes <em>everyone</em> who works full-time in a teaching or academic role:
                <ul class="eq-list">
                    <li>Professors (all ranks)</li>
                    <li>Lecturers (PhD and MSc)</li>
                    <li>Researchers</li>
                    <li>Teachers &amp; Assistant Teachers</li>
                    <li>Others in academic roles</li>
                </ul>
                <div class="eq-step-note">⚠ Part-time staff are <em>not</em> included in the denominator.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 3 — Apply the Formula</div>
            <div class="eq-step-body">
                <div class="eq-step-formula">Percentage = ( PhD Holders ÷ All Full-Time Staff ) × 100</div>
                <div class="eq-step-note">Example: 40 PhD holders out of 70 full-time staff = (40 ÷ 70) × 100 = 57.1%</div>
            </div>
        </div>

        <div class="eq-step eq-step--result">
            <div class="eq-step-hd">Step 4 — Compliance Threshold</div>
            <div class="eq-step-body">
                The percentage must meet the minimum required standard:
                <div class="eq-threshold-row">
                    <span class="eq-thr-tag eq-thr-green"><i class="bi bi-check-circle-fill"></i> ≥ 50% — Acceptable</span>
                    <span class="eq-thr-tag eq-thr-red"><i class="bi bi-x-circle-fill"></i> &lt; 50% — Does Not Meet Requirement</span>
                </div>
                <div class="eq-step-note">Why 50%? The standard requires that at least half of the full-time faculty hold a doctorate to ensure academic quality and research capacity.</div>
            </div>
        </div>
    </div>

    <!-- Modal: Students to Faculty Ratio -->
    <div id="modal-sfr" class="eq-modal" role="dialog" aria-modal="true">
        <button class="eq-modal-close" onclick="closeEqModal()" aria-label="Close">✕</button>
        <div class="eq-modal-icon">👥</div>
        <div class="eq-modal-title">Students to Faculty Ratio</div>
        <div class="eq-modal-subtitle">How many students does each qualified faculty member effectively support?</div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 1 — Calculate D (PhD-Level Core Staff)</div>
            <div class="eq-step-body">
                <b>D</b> is the number of full-time faculty members who hold a PhD and are the "core" of teaching capacity:
                <div class="eq-step-formula">D = FT Professor + FT Associate Professor + FT Assistant Professor + FT Lecturer (PhD)</div>
                <div class="eq-step-note">D is the foundation — everything else is calculated as a percentage of D.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 2 — Bonus Capacity (+10% of D)</div>
            <div class="eq-step-body">
                Universities with more PhD staff are rewarded with extra capacity:
                <div class="eq-step-formula">Bonus = D × 10%</div>
                For every 10 PhD-level staff, 1 extra student slot is added to the capacity. This bonus recognises that highly qualified faculty can handle slightly more students.
                <div class="eq-step-note">Example: D = 60 → Bonus = 6 extra capacity units.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 3 — MSc Lecturer Support (capped at 20% of D)</div>
            <div class="eq-step-body">
                Lecturers holding an MSc degree can supplement capacity, but only up to a limit:
                <div class="eq-step-formula">MSc Cap = D × 20%
MSc Support Used = min( Actual MSc Count,  MSc Cap )</div>
                If the university has more MSc lecturers than the cap, <b>only the cap amount counts</b> — the excess is ignored.
                <div class="eq-step-note">Example: D = 60 → Cap = 12. If there are 20 MSc lecturers → only 12 count.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 4 — Total Capacity (C)</div>
            <div class="eq-step-body">
                Combine all three components to get the university's effective teaching capacity:
                <div class="eq-step-formula">C = D  +  (D × 10%)  +  MSc Support Used</div>
                C is the maximum number of students the faculty can adequately supervise according to the standard.
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 5 — Calculate the Ratio</div>
            <div class="eq-step-body">
                <div class="eq-step-formula">Ratio = Total Students ÷ C</div>
                The result shows how many students each "capacity unit" is responsible for.
                <div class="eq-step-note">Example: 3,500 students ÷ C of 120 = ratio of 1:29 (each capacity unit handles ~29 students).</div>
            </div>
        </div>

        <div class="eq-step eq-step--result">
            <div class="eq-step-hd">Step 6 — Benchmark &amp; Compliance</div>
            <div class="eq-step-body">
                The benchmark is <b>not a fixed number</b> — it depends on which college categories the university has selected:
                <div class="eq-threshold-row" style="margin-bottom:10px;">
                    <span class="eq-thr-tag" style="background:#f0f4f8;color:#374151;">Scientific — 1 : 20</span>
                    <span class="eq-thr-tag" style="background:#f0f4f8;color:#374151;">Medical — 1 : 25</span>
                    <span class="eq-thr-tag" style="background:#f0f4f8;color:#374151;">Humanities — 1 : 35</span>
                    <span class="eq-thr-tag" style="background:#f0f4f8;color:#374151;">Applied — 1 : 20</span>
                </div>
                <div class="eq-step-formula">University Benchmark = Average of selected category standards</div>
                Then a 25% tolerance band is applied above the benchmark:
                <div class="eq-threshold-row" style="margin-top:10px;">
                    <span class="eq-thr-tag eq-thr-green"><i class="bi bi-check-circle-fill"></i> Ratio ≤ Benchmark — Compliant</span>
                    <span class="eq-thr-tag eq-thr-orange"><i class="bi bi-exclamation-circle-fill"></i> Ratio ≤ Benchmark + 25% — Warning</span>
                    <span class="eq-thr-tag eq-thr-red"><i class="bi bi-x-circle-fill"></i> Ratio &gt; Benchmark + 25% — Exceeds Tolerance</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal: PhD Doctors per Program -->
    <div id="modal-dpp" class="eq-modal" role="dialog" aria-modal="true">
        <button class="eq-modal-close" onclick="closeEqModal()" aria-label="Close">✕</button>
        <div class="eq-modal-icon">📊</div>
        <div class="eq-modal-title">PhD Doctors per Program</div>
        <div class="eq-modal-subtitle">How many full-time PhD faculty does the university have for each academic program it offers?</div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 1 — Count All Full-Time PhD Faculty (Entire University)</div>
            <div class="eq-step-body">
                This metric uses <b>all</b> full-time PhD-holding faculty across the entire university — not limited to any specific college or specialty:
                <ul class="eq-list">
                    <li><b>Professor</b> (Full-Time)</li>
                    <li><b>Associate Professor</b> (Full-Time)</li>
                    <li><b>Assistant Professor</b> (Full-Time)</li>
                    <li><b>Lecturer with PhD</b> (Full-Time)</li>
                </ul>
                <div class="eq-step-note">MSc lecturers, researchers, assistant teachers, and practitioners are not counted here — only staff with a doctorate degree.</div>
            </div>
        </div>

        <div class="eq-step">
            <div class="eq-step-hd">Step 2 — Count All Submitted Programs</div>
            <div class="eq-step-body">
                Count every academic program the university has submitted in this application — across all colleges, all degree levels (Bachelor, Master, Higher Diploma, etc.).
                <div class="eq-step-note">Each program is counted once, regardless of how many students are enrolled in it.</div>
            </div>
        </div>

        <div class="eq-step eq-step--result">
            <div class="eq-step-hd">Step 3 — Apply the Formula</div>
            <div class="eq-step-body">
                <div class="eq-step-formula">Avg. PhD per Program = Total PhD Faculty ÷ Total Programs</div>
                This tells the assessor, on average, how many doctorate-holding staff support each program the university offers. A higher number indicates stronger academic staffing relative to the program portfolio.
                <div class="eq-step-note">Example: 65 PhD faculty across 8 programs = 8.1 PhD doctors per program on average.</div>
            </div>
        </div>
    </div>

</div>

<script>
    function openEqModal(id) {
        var overlay = document.getElementById('eq-modal-overlay');
        overlay.querySelectorAll('.eq-modal').forEach(function(m) { m.style.display = 'none'; });
        var modal = document.getElementById(id);
        if (modal) { modal.style.display = 'block'; }
        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';
    }
    function closeEqModal() {
        document.getElementById('eq-modal-overlay').classList.remove('open');
        document.body.style.overflow = '';
    }
    function closeEqModalIfOverlay(e) {
        if (e.target === document.getElementById('eq-modal-overlay')) closeEqModal();
    }
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') closeEqModal();
    });
</script>
</body>
</html>
